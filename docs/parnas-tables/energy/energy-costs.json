{
  "_meta": {
    "description": "Energy cost calculations. Pre-HP cost is targeted electricity times electricity price. Post-HP cost is total energy use (accounting for heating system type) times electricity price. Heatpump ROI divides the cost premium by annual savings. Other fuel cost sums actual consumption of gas, propane, wood, and oil at their respective prices.",
    "instances": [
      {
        "id": "energy.cost.preHP",
        "legacyId": "d_141",
        "label": "Annual Electricity Cost (Pre-Heatpump)"
      },
      {
        "id": "energy.cost.heatpumpPremium",
        "legacyId": "d_142",
        "label": "Heatpump Cost Premium",
        "note": "Now a registered graph INPUT (migrated from static cell value). Edits trigger live ROI recalculation. See energy-inputs.json."
      },
      {
        "id": "energy.cost.postHP",
        "legacyId": "h_141",
        "label": "Annual Electricity Cost (Post-Heatpump)"
      },
      {
        "id": "energy.roi.heatpump",
        "legacyId": "h_142",
        "label": "Heatpump ROI (Simple Payback Years)"
      },
      {
        "id": "energy.cost.otherFuel",
        "legacyId": "l_141",
        "label": "Other Fuel Annual Cost"
      }
    ]
  },
  "section": "S15",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "energy.total.targeted",
        "type": "number",
        "unit": "kWh/yr",
        "description": "TEU targeted electricity (d_135)"
      },
      {
        "name": "energy.total.all",
        "type": "number",
        "unit": "kWh/yr",
        "description": "TEU by heating system type (d_136)"
      },
      {
        "name": "energy.cost.heatpumpPremium",
        "type": "number",
        "unit": "$",
        "description": "User-input heatpump cost premium (d_142), default 30000. Now a registered graph input \u2014 edits trigger live ROI update."
      },
      {
        "name": "climate.electricity.price",
        "type": "number",
        "unit": "$/kWh",
        "description": "Electricity unit price (l_12)"
      },
      {
        "name": "mechanical.heating.systemType",
        "type": "string",
        "description": "Primary heating type (d_113)"
      },
      {
        "name": "energy.actual.gas",
        "type": "number",
        "unit": "m\u00b3/yr",
        "description": "Actual gas consumption (d_28)"
      },
      {
        "name": "energy.actual.propane",
        "type": "number",
        "unit": "L/yr",
        "description": "Actual propane consumption (d_29)"
      },
      {
        "name": "energy.actual.oil",
        "type": "number",
        "unit": "L/yr",
        "description": "Actual oil consumption (d_30)"
      },
      {
        "name": "energy.actual.wood",
        "type": "number",
        "unit": "m\u00b3/yr",
        "description": "Actual wood consumption (d_31)"
      },
      {
        "name": "climate.gas.price",
        "type": "number",
        "unit": "$/m\u00b3",
        "description": "Gas unit price (l_13)"
      },
      {
        "name": "climate.propane.price",
        "type": "number",
        "unit": "$/kg",
        "description": "Propane unit price (l_14)"
      },
      {
        "name": "climate.wood.price",
        "type": "number",
        "unit": "$/m\u00b3",
        "description": "Wood unit price (l_15)"
      },
      {
        "name": "climate.oil.price",
        "type": "number",
        "unit": "$/L",
        "description": "Oil unit price (l_16)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "$ or years",
      "precision": 2
    }
  },
  "domain": {
    "preconditions": [],
    "invariants": [
      {
        "condition": "h_142 >= 0 when applicable",
        "description": "Payback years cannot be negative (only calculated when savings > 0)"
      }
    ]
  },
  "behavior": [
    {
      "condition": "d_141 (pre-HP cost)",
      "output": "d_135 \u00d7 l_12",
      "note": "Targeted electricity total times electricity price"
    },
    {
      "condition": "d_142 (HP premium)",
      "output": "user input, default 30000",
      "note": "Editable field for heatpump cost premium"
    },
    {
      "condition": "h_141 (post-HP cost)",
      "output": "d_136 \u00d7 l_12",
      "note": "Actual electricity use (by system type) times electricity price"
    },
    {
      "condition": "h_142 when primaryHeating = 'Heatpump' AND savings > 0",
      "output": "d_142 / (d_141 - h_141)",
      "note": "Simple payback: premium divided by annual electricity savings"
    },
    {
      "condition": "h_142 when primaryHeating != 'Heatpump' OR savings <= 0",
      "output": "0",
      "note": "ROI only meaningful for heatpump systems with positive savings"
    },
    {
      "condition": "l_141 (other fuel cost)",
      "output": "(l_13 \u00d7 d_28) + (d_29 \u00d7 l_14) + (l_15 \u00d7 d_31) + (l_16 \u00d7 d_30)",
      "note": "Sum of gas, propane, wood, and oil costs from actual consumption"
    }
  ],
  "edgeCases": [
    {
      "condition": "No savings (d_141 <= h_141)",
      "handling": "h_142 = 0",
      "rationale": "Cannot compute payback when heatpump costs more to operate"
    },
    {
      "condition": "Non-heatpump system",
      "handling": "h_142 = 0",
      "rationale": "ROI calculation only applies to heatpump systems"
    }
  ],
  "formula": {
    "symbolic": "d_141 = d_135 \u00d7 l_12; h_141 = d_136 \u00d7 l_12; h_142 = IF(d_113='Heatpump' AND d_141>h_141, d_142/(d_141-h_141), 0); l_141 = (l_13\u00d7d_28) + (d_29\u00d7l_14) + (l_15\u00d7d_31) + (l_16\u00d7d_30)",
    "implementation": "EnergyNodes.js:607-727"
  },
  "tests": [
    {
      "name": "Pre-HP electricity cost",
      "inputs": {
        "energy.total.targeted": 20000,
        "climate.electricity.price": 0.12
      },
      "expected": 2400.0,
      "note": "d_141 = 20000 \u00d7 0.12 = $2400"
    },
    {
      "name": "Post-HP electricity cost",
      "inputs": {
        "energy.total.all": 12500,
        "climate.electricity.price": 0.12
      },
      "expected": 1500.0,
      "note": "h_141 = 12500 \u00d7 0.12 = $1500"
    },
    {
      "name": "Heatpump ROI",
      "inputs": {
        "mechanical.heating.systemType": "Heatpump",
        "energy.cost.heatpumpPremium": 30000,
        "energy.cost.preHP": 2400,
        "energy.cost.postHP": 1500
      },
      "expected": 33.33,
      "tolerance": 0.01,
      "note": "h_142 = 30000 / (2400 - 1500) = 33.33 years"
    },
    {
      "name": "Non-heatpump ROI is 0",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "energy.cost.heatpumpPremium": 30000,
        "energy.cost.preHP": 2400,
        "energy.cost.postHP": 1500
      },
      "expected": 0,
      "note": "ROI not applicable for non-heatpump systems"
    },
    {
      "name": "Other fuel cost",
      "inputs": {
        "energy.actual.gas": 1000,
        "climate.gas.price": 0.35,
        "energy.actual.propane": 500,
        "climate.propane.price": 0.8,
        "energy.actual.wood": 10,
        "climate.wood.price": 120,
        "energy.actual.oil": 800,
        "climate.oil.price": 1.2
      },
      "expected": 2910.0,
      "note": "l_141 = (0.35\u00d71000) + (500\u00d70.80) + (120\u00d710) + (1.20\u00d7800) = 350 + 400 + 1200 + 960 = 2910"
    }
  ],
  "references": [
    {
      "source": "Section15.js lines 1886-1911"
    }
  ]
}
