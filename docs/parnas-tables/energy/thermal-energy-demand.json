{
  "_meta": {
    "description": "Thermal Energy Demand (TED) and Thermal Energy Demand Intensity (TEDI) for heating. TED sums transmission losses, air leakage losses, and ventilation losses minus usable internal/solar gains. Envelope variants exclude ventilation losses. TEDI normalizes by conditioned floor area.",
    "instances": [
      {
        "id": "energy.ted.heating",
        "legacyId": "d_127",
        "label": "Total Energy Demand for Heating (TED)"
      },
      {
        "id": "energy.tedi",
        "legacyId": "h_127",
        "label": "Thermal Energy Demand Intensity (TEDI)"
      },
      {
        "id": "energy.ted.envelope",
        "legacyId": "d_128",
        "label": "TED Envelope Only (no ventilation)"
      },
      {
        "id": "energy.tedi.envelope",
        "legacyId": "h_128",
        "label": "TEDI Envelope Only"
      }
    ]
  },
  "section": "S14",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.thermalBridgePenalty.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Thermal bridge penalty heat loss (i_97)"
      },
      {
        "name": "transmissionLoss.components.subtotalHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Envelope subtotal heat loss (i_98)"
      },
      {
        "name": "airTightness.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Natural air leakage heat loss (i_103)"
      },
      {
        "name": "ventilation.netHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Net heating season ventilation loss (m_121)"
      },
      {
        "name": "radiantGains.usableGains",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Usable internal and solar gains (i_80)"
      },
      {
        "name": "building.conditionedFloorArea",
        "type": "number",
        "unit": "m²",
        "description": "Conditioned floor area (h_15)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr or kWh/m²/yr",
      "precision": 4
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "building.conditionedFloorArea > 0",
        "description": "Floor area must be positive for intensity calculations"
      }
    ],
    "invariants": []
  },
  "behavior": [
    {
      "condition": "d_127 (TED heating)",
      "output": "i_97 + i_98 + i_103 + m_121 - i_80",
      "note": "Full TED including ventilation losses"
    },
    {
      "condition": "h_127 (TEDI)",
      "output": "d_127 / h_15",
      "note": "TED normalized by conditioned floor area"
    },
    {
      "condition": "d_128 (TED envelope)",
      "output": "i_97 + i_98 + i_103 - i_80",
      "note": "Envelope-only TED, excludes ventilation losses (m_121)"
    },
    {
      "condition": "h_128 (TEDI envelope)",
      "output": "d_128 / h_15",
      "note": "Envelope-only TEDI normalized by conditioned floor area"
    },
    {
      "condition": "area = 0",
      "output": "0 for intensity nodes (h_127, h_128)",
      "note": "Division guard prevents divide-by-zero"
    }
  ],
  "edgeCases": [
    {
      "condition": "Usable gains (i_80) exceed total losses",
      "handling": "TED can go negative (net heating surplus)",
      "rationale": "Well-insulated passive buildings may have net gains"
    }
  ],
  "formula": {
    "symbolic": "d_127 = i_97 + i_98 + i_103 + m_121 - i_80; h_127 = d_127 / h_15; d_128 = i_97 + i_98 + i_103 - i_80; h_128 = d_128 / h_15",
    "implementation": "EnergyNodes.js:109-188"
  },
  "tests": [
    {
      "name": "Standard TED calculation",
      "inputs": {
        "transmissionLoss.thermalBridgePenalty.heatLoss": 500,
        "transmissionLoss.components.subtotalHeatLoss": 8000,
        "airTightness.heatLoss": 2000,
        "ventilation.netHeatLoss": 3000,
        "radiantGains.usableGains": 1500
      },
      "expected": 12000,
      "note": "500 + 8000 + 2000 + 3000 - 1500 = 12000 kWh/yr"
    },
    {
      "name": "TEDI intensity",
      "inputs": {
        "energy.ted.heating": 12000,
        "building.conditionedFloorArea": 200
      },
      "expected": 60.0,
      "note": "12000 / 200 = 60.0 kWh/m²/yr"
    },
    {
      "name": "Envelope-only TED (no ventilation)",
      "inputs": {
        "transmissionLoss.thermalBridgePenalty.heatLoss": 500,
        "transmissionLoss.components.subtotalHeatLoss": 8000,
        "airTightness.heatLoss": 2000,
        "radiantGains.usableGains": 1500
      },
      "expected": 9000,
      "note": "500 + 8000 + 2000 - 1500 = 9000 kWh/yr (no m_121)"
    },
    {
      "name": "Zero area returns 0 intensity",
      "inputs": {
        "energy.ted.heating": 12000,
        "building.conditionedFloorArea": 0
      },
      "expected": 0,
      "note": "Division guard for h_127"
    }
  ],
  "references": [
    {
      "source": "EnergyNodes.js:109-188"
    },
    {
      "source": "Section14.js lines 1162-1175"
    }
  ]
}
