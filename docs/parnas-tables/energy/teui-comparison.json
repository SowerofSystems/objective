{
  "_meta": {
    "description": "TEUI comparison metrics for reference, target, and actual energy use intensities. d_143 is the reference TEUI pass-through from Section 01. h_143 is the target TEUI. l_143 is the actual TEUI from utility bills (N/A if in Targeted Use mode). Reduction percentage, target/actual ratio, and actual/target ratio provide comparison metrics.",
    "instances": [
      {
        "id": "energy.reference.teui",
        "legacyId": "d_143",
        "label": "Reference TEUI"
      },
      {
        "id": "energy.teui.reductionPercent",
        "legacyId": "d_144",
        "label": "TEUI Reduction from Reference (%)"
      },
      {
        "id": "teuiSummary.target.teui",
        "legacyId": "h_143",
        "label": "Target TEUI"
      },
      {
        "id": "teuiSummary.actual.teui",
        "legacyId": "l_143",
        "label": "Actual TEUI (from Utility Bills)"
      },
      {
        "id": "energy.targetActual.ratio",
        "legacyId": "h_144",
        "label": "Target vs Actual TEUI Ratio"
      },
      {
        "id": "energy.actualTarget.ratio",
        "legacyId": "l_144",
        "label": "Actual vs Target TEUI Ratio"
      }
    ]
  },
  "section": "S15",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "reference.teui",
        "type": "number",
        "unit": "kWh/m²/yr",
        "description": "Reference TEUI from Section 01 (e_10)"
      },
      {
        "name": "target.teui",
        "type": "number",
        "unit": "kWh/m²/yr",
        "description": "Target TEUI from Section 01 (h_10)"
      },
      {
        "name": "actual.teui",
        "type": "number",
        "unit": "kWh/m²/yr",
        "description": "Actual TEUI from Section 01, utility bills mode only (k_10)"
      },
      {
        "name": "reporting.mode",
        "type": "string",
        "description": "Reporting mode (d_14) - 'Utility Bills' or 'Targeted Use'"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/m²/yr, %, or ratio",
      "precision": 2
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "reference.teui > 0",
        "description": "Reference TEUI must be positive for reduction percentage"
      }
    ],
    "invariants": []
  },
  "behavior": [
    {
      "condition": "d_143 (reference TEUI)",
      "output": "e_10",
      "note": "Pass-through from Section 01 reference TEUI"
    },
    {
      "condition": "d_144 (reduction %)",
      "output": "1 - (h_143 / d_143)",
      "note": "Percentage improvement of target over reference. Positive = improvement."
    },
    {
      "condition": "h_143 (target TEUI)",
      "output": "h_10",
      "note": "Pass-through from Section 01 target TEUI"
    },
    {
      "condition": "l_143 when mode = 'Utility Bills'",
      "output": "k_10",
      "note": "Actual TEUI from utility bills data"
    },
    {
      "condition": "l_143 when mode = 'Targeted Use'",
      "output": "N/A",
      "note": "No actual data available in targeted use mode"
    },
    {
      "condition": "h_144 when l_143 is available and > 0",
      "output": "h_143 / l_143",
      "note": "Target-to-actual ratio. < 1 means target is lower than actual."
    },
    {
      "condition": "h_144 when l_143 is N/A",
      "output": "N/A",
      "note": "Cannot compute ratio without actual data"
    },
    {
      "condition": "l_144 when mode = 'Utility Bills' and h_143 > 0",
      "output": "l_143 / h_143",
      "note": "Actual-to-target ratio. < 1 means actual is lower than target."
    },
    {
      "condition": "l_144 when mode = 'Targeted Use'",
      "output": "N/A",
      "note": "Cannot compute ratio without actual data"
    },
    {
      "condition": "d_143 = 0",
      "output": "0 for d_144",
      "note": "Division guard for reduction percentage"
    }
  ],
  "edgeCases": [
    {
      "condition": "Targeted Use reporting mode",
      "handling": "l_143, h_144, l_144 all return N/A (NaN internally)",
      "rationale": "No actual utility bill data to compare against"
    },
    {
      "condition": "Reference TEUI is 0",
      "handling": "d_144 returns 0",
      "rationale": "Cannot compute reduction percentage from zero baseline"
    },
    {
      "condition": "Actual TEUI is 0",
      "handling": "h_144 returns 0",
      "rationale": "Division guard for target/actual ratio"
    }
  ],
  "formula": {
    "symbolic": "d_143 = e_10; d_144 = 1 - (h_143/d_143); h_143 = h_10; l_143 = IF(mode='Utility Bills', k_10, N/A); h_144 = IF(l_143!=N/A AND l_143>0, h_143/l_143, N/A); l_144 = IF(mode='Utility Bills' AND h_143>0, l_143/h_143, N/A)",
    "implementation": "Section15.js:1913-1942"
  },
  "tests": [
    {
      "name": "TEUI reduction percentage",
      "inputs": {
        "reference.teui": 150,
        "target.teui": 100
      },
      "expected": 0.333,
      "tolerance": 0.001,
      "note": "d_144 = 1 - (100/150) = 0.333 (33.3% reduction)"
    },
    {
      "name": "Utility Bills mode - actual available",
      "inputs": {
        "reporting.mode": "Utility Bills",
        "actual.teui": 120
      },
      "expected": 120,
      "note": "l_143 = k_10 = 120"
    },
    {
      "name": "Targeted Use mode - actual N/A",
      "inputs": {
        "reporting.mode": "Targeted Use"
      },
      "expected": "N/A",
      "note": "l_143 = N/A when not in Utility Bills mode"
    },
    {
      "name": "Target vs actual ratio",
      "inputs": {
        "target.teui": 100,
        "actual.teui": 120,
        "reporting.mode": "Utility Bills"
      },
      "expected": 0.833,
      "tolerance": 0.001,
      "note": "h_144 = 100/120 = 0.833"
    },
    {
      "name": "Actual vs target ratio",
      "inputs": {
        "actual.teui": 120,
        "target.teui": 100,
        "reporting.mode": "Utility Bills"
      },
      "expected": 1.2,
      "note": "l_144 = 120/100 = 1.2"
    }
  ],
  "references": [
    {
      "source": "Section15.js lines 1913-1942"
    },
    {
      "source": "Section01 e_10, h_10, k_10 pass-through values"
    }
  ]
}
