{
  "_meta": {
    "description": "Total Energy Use (TEU) and Total Energy Use Intensity (TEUI) calculations. d_135 is the targeted electricity sum. d_136 adjusts by primary heating system type: Electricity buildings use d_135 directly; Heatpump buildings sum electrical loads plus HP demand; Gas/Oil buildings sum only electrical loads (excluding space heating). TEUI normalizes by conditioned floor area.",
    "instances": [
      {
        "id": "energy.total.targeted",
        "legacyId": "d_135",
        "label": "TEU Targeted Electricity"
      },
      {
        "id": "energy.total.all",
        "legacyId": "d_136",
        "label": "TEU Targeted Electricity if HP/Gas/Oil Bldg"
      },
      {
        "id": "energy.teui",
        "legacyId": "h_136",
        "label": "Total Energy Use Intensity (TEUI)"
      },
      {
        "id": "energy.teui.targeted",
        "legacyId": "h_135",
        "label": "TEUI Targeted Electricity"
      }
    ]
  },
  "section": "S15",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "renewable.exteriorLoads",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Onsite energy subtotals (m_43)"
      },
      {
        "name": "waterHeating.netElectricalDemand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "DHW net electrical demand (k_51)"
      },
      {
        "name": "energy.plugLoads.subtotal",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Plug/Light/Equipment subtotal annual kWh (h_70)"
      },
      {
        "name": "mechanical.cooling.electricalDemand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Cooling electrical demand (d_117), set to 0 if No Cooling"
      },
      {
        "name": "mechanical.cooling.systemType",
        "type": "string",
        "description": "Cooling system type (d_116) - 'No Cooling' zeroes d_117"
      },
      {
        "name": "envelope.total.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Envelope total heat loss (i_104)"
      },
      {
        "name": "ventilation.netHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Net heating season ventilation loss (m_121)"
      },
      {
        "name": "radiantGains.usableGains",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Usable internal and solar gains (i_80)"
      },
      {
        "name": "mechanical.heating.systemType",
        "type": "string",
        "description": "Primary heating type (d_113) - 'Electricity', 'Heatpump', 'Gas', 'Oil'"
      },
      {
        "name": "mechanical.heating.demand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Heating system demand after COP/AFUE (d_114)"
      },
      {
        "name": "building.conditionedFloorArea",
        "type": "number",
        "unit": "m²",
        "description": "Conditioned floor area (h_15)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr or kWh/m²/yr",
      "precision": 4
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "building.conditionedFloorArea > 0",
        "description": "Floor area must be positive for TEUI calculations"
      }
    ],
    "invariants": []
  },
  "behavior": [
    {
      "condition": "d_135 (targeted electricity)",
      "output": "m_43 + k_51 + h_70 + d_117 + i_104 + m_121 - i_80",
      "note": "d_117 = 0 if cooling type is 'No Cooling'"
    },
    {
      "condition": "d_136 when primaryHeating = 'Electricity'",
      "output": "d_135",
      "note": "All-electric building uses targeted total directly"
    },
    {
      "condition": "d_136 when primaryHeating = 'Heatpump'",
      "output": "k_51 + d_117 + d_114 + m_43 + h_70",
      "note": "Heatpump building sums electrical loads plus HP demand"
    },
    {
      "condition": "d_136 when primaryHeating = 'Gas' or 'Oil'",
      "output": "k_51 + d_117 + m_43 + h_70",
      "note": "Fossil fuel building sums only electrical loads, excludes space heating"
    },
    {
      "condition": "h_136 (TEUI)",
      "output": "d_136 / h_15",
      "note": "Total energy use intensity"
    },
    {
      "condition": "h_135 (TEUI targeted)",
      "output": "d_135 / h_15",
      "note": "Targeted electricity TEUI"
    },
    {
      "condition": "area = 0",
      "output": "0 for h_135 and h_136",
      "note": "Division guard"
    }
  ],
  "edgeCases": [
    {
      "condition": "No Cooling selected (d_116)",
      "handling": "d_117 is forced to 0 in d_135 and d_136 calculations",
      "rationale": "No electrical cooling demand when cooling is disabled"
    }
  ],
  "formula": {
    "symbolic": "d_135 = m_43 + k_51 + h_70 + d_117_eff + i_104 + m_121 - i_80; d_136 = f(primaryHeating, d_135, k_51, d_117, d_114, m_43, h_70); h_136 = d_136 / h_15; h_135 = d_135 / h_15",
    "implementation": "EnergyNodes.js:278-363"
  },
  "tests": [
    {
      "name": "Electricity building d_135 and d_136",
      "inputs": {
        "renewable.exteriorLoads": -500,
        "waterHeating.netElectricalDemand": 3000,
        "energy.plugLoads.subtotal": 5000,
        "mechanical.cooling.electricalDemand": 1000,
        "mechanical.cooling.systemType": "Active",
        "envelope.total.heatLoss": 10000,
        "ventilation.netHeatLoss": 3000,
        "radiantGains.usableGains": 1500,
        "mechanical.heating.systemType": "Electricity"
      },
      "expected": 20000,
      "note": "d_135 = -500 + 3000 + 5000 + 1000 + 10000 + 3000 - 1500 = 20000; d_136 = d_135 for Electricity"
    },
    {
      "name": "Heatpump building d_136",
      "inputs": {
        "mechanical.heating.systemType": "Heatpump",
        "waterHeating.netElectricalDemand": 3000,
        "mechanical.cooling.electricalDemand": 1000,
        "mechanical.cooling.systemType": "Active",
        "mechanical.heating.demand": 4000,
        "renewable.exteriorLoads": -500,
        "energy.plugLoads.subtotal": 5000
      },
      "expected": 12500,
      "note": "d_136 = k_51(3000) + d_117(1000) + d_114(4000) + m_43(-500) + h_70(5000) = 12500"
    },
    {
      "name": "Gas building d_136 (no heating demand in sum)",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "waterHeating.netElectricalDemand": 3000,
        "mechanical.cooling.electricalDemand": 1000,
        "mechanical.cooling.systemType": "Active",
        "renewable.exteriorLoads": -500,
        "energy.plugLoads.subtotal": 5000
      },
      "expected": 8500,
      "note": "d_136 = k_51(3000) + d_117(1000) + m_43(-500) + h_70(5000) = 8500"
    },
    {
      "name": "No Cooling zeroes d_117",
      "inputs": {
        "renewable.exteriorLoads": 0,
        "waterHeating.netElectricalDemand": 3000,
        "energy.plugLoads.subtotal": 5000,
        "mechanical.cooling.electricalDemand": 2000,
        "mechanical.cooling.systemType": "No Cooling",
        "envelope.total.heatLoss": 10000,
        "ventilation.netHeatLoss": 3000,
        "radiantGains.usableGains": 1500,
        "mechanical.heating.systemType": "Electricity"
      },
      "expected": 19500,
      "note": "d_135 = 0 + 3000 + 5000 + 0(No Cooling) + 10000 + 3000 - 1500 = 19500"
    },
    {
      "name": "TEUI calculation",
      "inputs": {
        "energy.total.all": 20000,
        "building.conditionedFloorArea": 200
      },
      "expected": 100.0,
      "note": "h_136 = 20000 / 200 = 100.0 kWh/m²/yr"
    }
  ],
  "references": [
    {
      "source": "EnergyNodes.js:278-363"
    },
    {
      "source": "Section15.js lines 1777-1806"
    }
  ]
}
