{
  "_meta": {
    "description": "Cooling Energy Demand (CED) calculations. Unmitigated CED sums all cooling loads: occupant internal gains, solar cooling gains, thermal bridge heat gain, envelope heat gain, air leakage heat gain, and ventilation heat gain. CEDI normalizes by floor area. Mitigated CED subtracts free cooling and recovered ventilation cooling.",
    "instances": [
      {
        "id": "energy.ced.unmitigated",
        "legacyId": "d_129",
        "label": "Cooling Energy Demand Unmitigated"
      },
      {
        "id": "energy.cedi.unmitigated",
        "legacyId": "h_129",
        "label": "Cooling Energy Demand Intensity (Unmitigated)"
      },
      {
        "id": "energy.ced.mitigated",
        "legacyId": "m_129",
        "label": "Cooling Energy Demand Mitigated"
      }
    ]
  },
  "section": "S14",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "internal.coolingLoad.occupants",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Occupant cooling load (k_71)"
      },
      {
        "name": "radiantGains.subtotal.coolingGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total solar cooling gain (k_79)"
      },
      {
        "name": "transmissionLoss.thermalBridgePenalty.heatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Thermal bridge penalty heat gain (k_97)"
      },
      {
        "name": "envelope.total.heatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Envelope total heat gain - capacitance conditional (k_104)"
      },
      {
        "name": "airTightness.heatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Air leakage heat gain (k_103)"
      },
      {
        "name": "ventilation.heatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Ventilation heat gain (d_122)"
      },
      {
        "name": "building.conditionedFloorArea",
        "type": "number",
        "unit": "m²",
        "description": "Conditioned floor area (h_15)"
      },
      {
        "name": "cooling.freeCoolingLimit",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Free cooling capacity from night ventilation (h_124)"
      },
      {
        "name": "ventilation.energyRecoveredCooling",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Energy recovered during cooling via ventilation (d_123)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr or kWh/m²/yr",
      "precision": 4
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "building.conditionedFloorArea > 0",
        "description": "Floor area must be positive for intensity calculation"
      }
    ],
    "invariants": [
      {
        "condition": "m_129 >= 0",
        "description": "Mitigated CED is floored at zero (MAX function)"
      }
    ]
  },
  "behavior": [
    {
      "condition": "d_129 (CED unmitigated)",
      "output": "k_71 + k_79 + k_97 + k_104 + k_103 + d_122",
      "note": "Sum of all cooling loads before mitigation"
    },
    {
      "condition": "h_129 (CEDI unmitigated)",
      "output": "d_129 / h_15",
      "note": "Unmitigated CED normalized by floor area"
    },
    {
      "condition": "m_129 (CED mitigated)",
      "output": "MAX(0, d_129 - h_124 - d_123)",
      "note": "CED after subtracting free cooling and recovered ventilation cooling, floored at 0"
    },
    {
      "condition": "area = 0",
      "output": "0 for h_129",
      "note": "Division guard"
    }
  ],
  "edgeCases": [
    {
      "condition": "Free cooling + recovered cooling exceed CED",
      "handling": "m_129 clamped to 0 via MAX(0, ...)",
      "rationale": "Cannot have negative cooling demand"
    }
  ],
  "formula": {
    "symbolic": "d_129 = k_71 + k_79 + k_97 + k_104 + k_103 + d_122; h_129 = d_129 / h_15; m_129 = MAX(0, d_129 - h_124 - d_123)",
    "implementation": "EnergyNodes.js:197-266"
  },
  "tests": [
    {
      "name": "Standard CED unmitigated",
      "inputs": {
        "internal.coolingLoad.occupants": 1000,
        "radiantGains.subtotal.coolingGain": 3000,
        "transmissionLoss.thermalBridgePenalty.heatGain": 200,
        "envelope.total.heatGain": 1500,
        "airTightness.heatGain": 800,
        "ventilation.heatGain": 500
      },
      "expected": 7000,
      "note": "1000 + 3000 + 200 + 1500 + 800 + 500 = 7000 kWh/yr"
    },
    {
      "name": "CEDI unmitigated",
      "inputs": {
        "energy.ced.unmitigated": 7000,
        "building.conditionedFloorArea": 200
      },
      "expected": 35.0,
      "note": "7000 / 200 = 35.0 kWh/m²/yr"
    },
    {
      "name": "CED mitigated with partial offset",
      "inputs": {
        "energy.ced.unmitigated": 7000,
        "cooling.freeCoolingLimit": 2000,
        "ventilation.energyRecoveredCooling": 1000
      },
      "expected": 4000,
      "note": "MAX(0, 7000 - 2000 - 1000) = 4000 kWh/yr"
    },
    {
      "name": "CED mitigated clamped to zero",
      "inputs": {
        "energy.ced.unmitigated": 3000,
        "cooling.freeCoolingLimit": 2000,
        "ventilation.energyRecoveredCooling": 2000
      },
      "expected": 0,
      "note": "MAX(0, 3000 - 2000 - 2000) = MAX(0, -1000) = 0"
    }
  ],
  "references": [
    {
      "source": "EnergyNodes.js:197-266"
    },
    {
      "source": "Section13.js lines 3055-3078 (authoritative CED calculation)"
    },
    {
      "source": "Section14.js lines 1177-1189"
    }
  ]
}
