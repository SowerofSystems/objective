  },
  "section": "S14",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "energy.ced.unmitigated",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Unmitigated cooling energy demand (d_129)"
      },
      {
        "name": "energy.ced.mitigated",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Mitigated cooling energy demand (m_129)"
      },
      {
        "name": "transmissionLoss.thermalBridgePenalty.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Thermal bridge penalty heat loss (i_97)"
      },
      {
        "name": "transmissionLoss.components.subtotalHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Envelope subtotal heat loss (i_98)"
      },
      {
        "name": "airTightness.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Air leakage heat loss (i_103)"
      },
      {
        "name": "transmissionLoss.thermalBridgePenalty.heatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Thermal bridge penalty heat gain (k_97)"
      },
      {
        "name": "transmissionLoss.components.subtotalHeatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Envelope subtotal heat gain (k_98)"
      },
      {
        "name": "airTightness.heatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Air leakage heat gain (k_103)"
      },
      {
        "name": "building.conditionedFloorArea",
        "type": "number",
        "unit": "m²",
        "description": "Conditioned floor area (h_15)"
      },
      {
        "name": "energy.teli.intensity",
        "type": "number",
        "unit": "kWh/m²/yr",
        "description": "TELI for ratio calculation (h_131)"
      },
      {
        "name": "energy.tedi",
        "type": "number",
        "unit": "kWh/m²/yr",
        "description": "TEDI for ratio calculation (h_127)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "varies (W/m², kWh/yr, kWh/m²/yr, ratio)",
      "precision": 2
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "building.conditionedFloorArea > 0",
        "description": "Floor area must be positive for intensity and W/m² calculations"
      }
    ],
    "invariants": []
  },
  "behavior": [
    {
      "condition": "d_130 (CEDI load W/m²)",
      "output": "(d_129 / 8760 × 1000) / h_15",
      "note": "Converts annual kWh to average continuous watts per m². 8760 = hours/year, ×1000 converts kW to W."
    },
    {
      "condition": "d_131 (TEL heat loss)",
      "output": "i_97 + i_98 + i_103",
      "note": "Total envelope heat loss: thermal bridge + subtotal + air leakage"
    },
    {
      "condition": "d_132 (CEG heat gain)",
      "output": "k_97 + k_98 + k_103",
      "note": "Total envelope heat gain: thermal bridge + subtotal + air leakage"
    },
    {
      "condition": "h_131 (TELI)",
      "output": "d_131 / h_15",
      "note": "Envelope heat loss intensity"
    },
    {
      "condition": "h_132 (CEGI)",
      "output": "d_132 / h_15",
      "note": "Envelope heat gain intensity"
    },
    {
      "condition": "h_130 (CEDI mitigated W/m²)",
      "output": "(m_129 / 8760 × 1000) / h_15",
      "note": "Mitigated cooling demand as average continuous watts per m²"
    },
    {
      "condition": "m_131 (TELI/TEDI ratio)",
      "output": "h_131 / h_127",
      "note": "Ratio of envelope loss intensity to total energy demand intensity, used for cost pro-rating"
    },
    {
      "condition": "area = 0 or TEDI = 0",
      "output": "0 for intensity/ratio nodes",
      "note": "Division guard"
    }
  ],
  "edgeCases": [
    {
      "condition": "TEDI (h_127) = 0",
      "handling": "m_131 returns 0",
      "rationale": "Avoid division by zero in ratio"
    }
  ],
  "formula": {
    "symbolic": "d_130 = (d_129 / 8760 × 1000) / h_15; d_131 = i_97 + i_98 + i_103; d_132 = k_97 + k_98 + k_103; h_131 = d_131 / h_15; h_132 = d_132 / h_15; h_130 = (m_129 / 8760 × 1000) / h_15; m_131 = h_131 / h_127",
    "implementation": "Section14.js:1192-1221"
  },
  "tests": [
    {
      "name": "CEDI load in W/m²",
      "inputs": {
        "energy.ced.unmitigated": 17520,
        "building.conditionedFloorArea": 200
      },
      "expected": 10.0,
      "note": "(17520 / 8760 × 1000) / 200 = (2 × 1000) / 200 = 10.0 W/m²"
    },
    {
      "name": "TEL heat loss sum",
      "inputs": {
        "transmissionLoss.thermalBridgePenalty.heatLoss": 500,
        "transmissionLoss.components.subtotalHeatLoss": 8000,
        "airTightness.heatLoss": 2000
      },
      "expected": 10500,
      "note": "500 + 8000 + 2000 = 10500 kWh/yr"
    },
    {
      "name": "CEG heat gain sum",
      "inputs": {
        "transmissionLoss.thermalBridgePenalty.heatGain": 200,
        "transmissionLoss.components.subtotalHeatGain": 3000,
        "airTightness.heatGain": 800
      },
      "expected": 4000,
      "note": "200 + 3000 + 800 = 4000 kWh/yr"
    },
    {
      "name": "TELI/TEDI ratio",
      "inputs": {
        "energy.teli.intensity": 52.5,
        "energy.tedi": 60.0
      },
      "expected": 0.875,
      "note": "52.5 / 60.0 = 0.875"
    },
    {
      "name": "Mitigated CEDI in W/m²",
      "inputs": {
        "energy.ced.mitigated": 8760,
        "building.conditionedFloorArea": 200
      },
      "expected": 5.0,
      "note": "(8760 / 8760 × 1000) / 200 = 1000 / 200 = 5.0 W/m²"
    }
  ],
  "references": [
    {
      "source": "Section14.js lines 1192-1221"
    },
    {
      "source": "EnergyNodes.js (upstream d_129, m_129 dependencies)"
    }
  ]
}
