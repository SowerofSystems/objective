{
  "_meta": {
    "description": "Celsius to Fahrenheit conversion nodes. Most are rounded to integer; winterAverageF is NOT rounded. Setpoint conversions (i_23, i_24) are computed in legacy Section03.js but not yet migrated to ClimateNodes.js as separate graph nodes.",
    "instances": [
      {
        "id": "climate.temperature.coldestF",
        "legacyId": "e_23",
        "label": "Coldest Day Temperature (Fahrenheit)",
        "unit": "deg-F",
        "rounded": true
      },
      {
        "id": "climate.temperature.hottestF",
        "legacyId": "e_24",
        "label": "Hottest Day Temperature (Fahrenheit)",
        "unit": "deg-F",
        "rounded": true
      },
      {
        "id": "climate.temperature.winterAverageF",
        "legacyId": "e_25",
        "label": "Winter Average Temperature (Fahrenheit)",
        "unit": "deg-F",
        "rounded": false
      },
      {
        "id": "climate.heating.setpointF",
        "legacyId": "i_23",
        "label": "Heating Setpoint (Fahrenheit)",
        "unit": "deg-F",
        "rounded": true,
        "migrationNote": "Computed in Section03.js:1859, not yet in ClimateNodes.js"
      },
      {
        "id": "climate.cooling.setpointF",
        "legacyId": "i_24",
        "label": "Cooling Setpoint (Fahrenheit)",
        "unit": "deg-F",
        "rounded": true,
        "migrationNote": "Computed in Section03.js:2317, not yet in ClimateNodes.js"
      }
    ]
  },
  "section": "S03",
  "classification": "G",
  "signature": {
    "inputs": [
      { "name": "climate.temperature.coldest", "type": "number", "unit": "deg-C", "description": "Coldest day temp (d_23) -- for e_23" },
      { "name": "climate.temperature.hottest", "type": "number", "unit": "deg-C", "description": "Hottest day temp (d_24) -- for e_24" },
      { "name": "climate.temperature.winterAverage", "type": "number", "unit": "deg-C", "description": "Winter average temp (d_25) -- for e_25" },
      { "name": "climate.heating.setpoint", "type": "number", "unit": "deg-C", "description": "Heating setpoint (h_23) -- for i_23" },
      { "name": "climate.cooling.setpoint", "type": "number", "unit": "deg-C", "description": "Cooling setpoint (h_24) -- for i_24" }
    ],
    "output": { "type": "number", "unit": "deg-F" }
  },
  "domain": {
    "preconditions": [],
    "invariants": [
      { "condition": "F = C * 9/5 + 32", "description": "Standard Celsius to Fahrenheit conversion" }
    ]
  },
  "behavior": [
    {
      "condition": "e_23, e_24, i_23, i_24: always",
      "output": "ROUND(C * 9/5 + 32)",
      "note": "Rounded to nearest integer"
    },
    {
      "condition": "e_25: always",
      "output": "C * 9/5 + 32",
      "note": "NOT rounded -- preserves decimal precision for winter average"
    }
  ],
  "edgeCases": [
    {
      "condition": "Input is non-numeric or 'Unavailable'",
      "handling": "parseNum returns default: coldest=-24, hottest=34, winterAvg=-7",
      "rationale": "Defensive parsing with sensible defaults"
    }
  ],
  "formula": {
    "symbolic": {
      "e_23": "ROUND(d_23 * 9/5 + 32)",
      "e_24": "ROUND(d_24 * 9/5 + 32)",
      "e_25": "d_25 * 9/5 + 32",
      "i_23": "ROUND(h_23 * 9/5 + 32)",
      "i_24": "ROUND(h_24 * 9/5 + 32)"
    },
    "implementation": {
      "e_23": "ClimateNodes.js:504-516",
      "e_24": "ClimateNodes.js:517-529",
      "e_25": "ClimateNodes.js:530-543",
      "i_23": "Section03.js:1859 (legacy, not yet migrated)",
      "i_24": "Section03.js:2317 (legacy, not yet migrated)"
    }
  },
  "tests": [
    {
      "name": "e_23: -24 C to F",
      "inputs": { "climate.temperature.coldest": -24 },
      "expected": -11,
      "note": "ROUND(-24 * 9/5 + 32) = ROUND(-11.2) = -11"
    },
    {
      "name": "e_24: 34 C to F",
      "inputs": { "climate.temperature.hottest": 34 },
      "expected": 93,
      "note": "ROUND(34 * 9/5 + 32) = ROUND(93.2) = 93"
    },
    {
      "name": "e_25: -7 C to F (not rounded)",
      "inputs": { "climate.temperature.winterAverage": -7 },
      "expected": 19.4,
      "note": "-7 * 9/5 + 32 = 19.4 (decimal preserved)"
    },
    {
      "name": "e_25: 0 C to F (not rounded)",
      "inputs": { "climate.temperature.winterAverage": 0 },
      "expected": 32,
      "note": "0 * 9/5 + 32 = 32.0"
    },
    {
      "name": "i_23: 22 C to F",
      "inputs": { "climate.heating.setpoint": 22 },
      "expected": 72,
      "note": "ROUND(22 * 9/5 + 32) = ROUND(71.6) = 72"
    },
    {
      "name": "i_23: 18 C to F",
      "inputs": { "climate.heating.setpoint": 18 },
      "expected": 64,
      "note": "ROUND(18 * 9/5 + 32) = ROUND(64.4) = 64"
    },
    {
      "name": "i_24: 24 C to F",
      "inputs": { "climate.cooling.setpoint": 24 },
      "expected": 75,
      "note": "ROUND(24 * 9/5 + 32) = ROUND(75.2) = 75"
    }
  ],
  "references": [
    { "source": "ClimateNodes.js:504-543" },
    { "source": "Section03.js:1859, 2317 (legacy i_23, i_24)" }
  ]
}
