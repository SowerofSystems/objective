{
  "id": "climate.zone",
  "legacyId": "j_19",
  "label": "Climate Zone",
  "section": "S03",
  "classification": "G",
  "_meta": {
    "description": "Determines NECB climate zone from Heating Degree Days using stepped thresholds. Returns string representation (e.g. '6.0'). Zone 7 is split into 7.1 and 7.2."
  },
  "signature": {
    "inputs": [
      { "name": "climate.heating.degreedays", "type": "number | string", "unit": "deg-C-days", "description": "Heating Degree Days (d_20)" }
    ],
    "output": { "type": "string", "unit": "zone" }
  },
  "domain": {
    "preconditions": [
      { "condition": "HDD is not 'Unavailable'", "description": "Climate zone cannot be determined without HDD" }
    ],
    "invariants": [
      { "condition": "output in {'4.0','5.0','6.0','7.1','7.2','8.0','Unavailable'}", "description": "Only valid NECB climate zones" }
    ]
  },
  "behavior": [
    { "condition": "HDD is 'Unavailable' or 'N/A'", "output": "Unavailable" },
    { "condition": "HDD < 3000", "output": "4.0" },
    { "condition": "3000 <= HDD < 4000", "output": "5.0" },
    { "condition": "4000 <= HDD < 5000", "output": "6.0" },
    { "condition": "5000 <= HDD < 6000", "output": "7.1" },
    { "condition": "6000 <= HDD < 7000", "output": "7.2" },
    { "condition": "HDD >= 7000", "output": "8.0" }
  ],
  "edgeCases": [
    {
      "condition": "HDD is 'Unavailable'",
      "handling": "Returns 'Unavailable'",
      "rationale": "Cannot determine zone without valid HDD"
    }
  ],
  "formula": {
    "symbolic": "j_19 = IF(d_20<3000,'4.0', IF(d_20<4000,'5.0', IF(d_20<5000,'6.0', IF(d_20<6000,'7.1', IF(d_20<7000,'7.2','8.0')))))",
    "implementation": "ClimateNodes.js:307-326"
  },
  "tests": [
    { "name": "Zone 4 (mild)", "inputs": { "climate.heating.degreedays": 2500 }, "expected": "4.0" },
    { "name": "Zone 5", "inputs": { "climate.heating.degreedays": 3500 }, "expected": "5.0" },
    { "name": "Zone 6", "inputs": { "climate.heating.degreedays": 4500 }, "expected": "6.0" },
    { "name": "Zone 7.1", "inputs": { "climate.heating.degreedays": 5500 }, "expected": "7.1" },
    { "name": "Zone 7.2", "inputs": { "climate.heating.degreedays": 6500 }, "expected": "7.2" },
    { "name": "Zone 8 (extreme cold)", "inputs": { "climate.heating.degreedays": 8000 }, "expected": "8.0" },
    { "name": "Boundary at 3000", "inputs": { "climate.heating.degreedays": 3000 }, "expected": "5.0" },
    { "name": "Unavailable HDD", "inputs": { "climate.heating.degreedays": "Unavailable" }, "expected": "Unavailable" }
  ],
  "references": [
    { "source": "ClimateNodes.js:307-326" },
    { "source": "NECB Climate Zone classification" }
  ]
}
