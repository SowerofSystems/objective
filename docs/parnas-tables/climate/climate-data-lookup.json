{
  "_meta": {
    "description": "Climate data lookup nodes. Each node reads weather data from ClimateValues.js based on province and city selection. Data keys vary by timeframe (Present vs Future) and occupancy type (for coldest day). Values of 666 in the source data indicate unavailability.",
    "instances": [
      {
        "id": "climate.heating.degreedays",
        "legacyId": "d_20",
        "label": "Heating Degree Days (HDD)",
        "unit": "deg-C-days",
        "lookupKey": "Present=HDD18, Future=HDD18_2021_2050",
        "default": "Unavailable"
      },
      {
        "id": "climate.cooling.degreedays",
        "legacyId": "d_21",
        "label": "Cooling Degree Days (CDD)",
        "unit": "deg-C-days",
        "lookupKey": "Present=CDD24, Future=CDD24_2021_2050",
        "default": "Unavailable"
      },
      {
        "id": "climate.temperature.coldest",
        "legacyId": "d_23",
        "label": "Coldest Day Temperature",
        "unit": "deg-C",
        "lookupKey": "Care=January_1, Others=January_2_5",
        "default": -24
      },
      {
        "id": "climate.temperature.hottest",
        "legacyId": "d_24",
        "label": "Hottest Day Temperature",
        "unit": "deg-C",
        "lookupKey": "July_2_5_Tdb",
        "default": 34
      },
      {
        "id": "climate.elevation",
        "legacyId": "l_22",
        "label": "Elevation ASL",
        "unit": "m",
        "lookupKey": "Elev ASL (m)",
        "default": 80
      },
      {
        "id": "climate.temperature.winterAverage",
        "legacyId": "d_25",
        "label": "Winter Average Temperature",
        "unit": "deg-C",
        "lookupKey": "Winter_Tdb_Avg",
        "default": -7
      }
    ]
  },
  "section": "S03",
  "classification": "G",
  "signature": {
    "inputs": [
      { "name": "climate.location.province", "type": "string", "description": "Province code (d_19)" },
      { "name": "climate.location.city", "type": "string", "description": "City name (h_19)" },
      { "name": "climate.timeframe", "type": "string", "description": "Present or Future (h_20) -- used by HDD/CDD only" },
      { "name": "metadata.occupancyType", "type": "string", "description": "Occupancy type (d_12) -- used by coldest day only" }
    ],
    "output": { "type": "number | string", "unit": "varies by instance" }
  },
  "domain": {
    "preconditions": [
      { "condition": "province and city are non-empty", "description": "Climate data requires valid location" }
    ],
    "invariants": []
  },
  "behavior": [
    {
      "condition": "No climate data found for province/city",
      "output": "default value for that node",
      "note": "Each instance has its own default: HDD/CDD='Unavailable', coldest=-24, hottest=34, elevation=80, winterAvg=-7"
    },
    {
      "condition": "HDD: timeframe=Present",
      "output": "data.HDD18",
      "note": "Returns 'Unavailable' if HDD18 is null or 666"
    },
    {
      "condition": "HDD: timeframe=Future",
      "output": "data.HDD18_2021_2050",
      "note": "Returns 'Unavailable' if value is null or 666"
    },
    {
      "condition": "CDD: timeframe=Present",
      "output": "data.CDD24",
      "note": "Returns 'Unavailable' if CDD24 is null or 666"
    },
    {
      "condition": "CDD: timeframe=Future, future value available",
      "output": "data.CDD24_2021_2050",
      "note": "Returns 'Unavailable' if value is null or 666"
    },
    {
      "condition": "CDD: timeframe=Future, future value unavailable but present available",
      "output": "data.CDD24",
      "note": "Falls back to present CDD when future CDD is null/666"
    },
    {
      "condition": "Coldest: occupancy=Care",
      "output": "data.January_1 || data.January_2_5 || -26",
      "note": "Care facilities use 1% design temp (more conservative), falls back to 2.5% then -26"
    },
    {
      "condition": "Coldest: occupancy!=Care",
      "output": "data.January_2_5 || -24",
      "note": "Non-care uses 2.5% design temp, default -24"
    },
    {
      "condition": "Hottest: always",
      "output": "data.July_2_5_Tdb || 34",
      "note": "2.5% July dry bulb temperature"
    },
    {
      "condition": "Elevation: always",
      "output": "data['Elev ASL (m)'] || 80",
      "note": "Elevation above sea level in metres"
    },
    {
      "condition": "WinterAverage: always",
      "output": "data.Winter_Tdb_Avg ?? -7",
      "note": "Uses nullish coalescing -- 0 is a valid temperature"
    }
  ],
  "edgeCases": [
    {
      "condition": "Province or city is empty/null",
      "handling": "Returns null from getClimateData, node returns its default",
      "rationale": "No location selected yet"
    },
    {
      "condition": "Value is 666 in ClimateValues.js",
      "handling": "Treated as unavailable",
      "rationale": "666 is a sentinel value meaning data not available for this location"
    },
    {
      "condition": "City name case mismatch",
      "handling": "Case-insensitive fallback lookup",
      "rationale": "getClimateData tries exact match, then trimmed, then case-insensitive"
    }
  ],
  "formula": {
    "symbolic": "value = ClimateData[province][city][lookupKey] || default",
    "implementation": "ClimateNodes.js:163-301"
  },
  "tests": [
    {
      "name": "HDD Present for valid city",
      "inputs": { "climate.location.province": "ON", "climate.location.city": "Toronto", "climate.timeframe": "Present" },
      "expected": "data.HDD18 value from ClimateValues"
    },
    {
      "name": "HDD with 666 sentinel",
      "inputs": { "climate.location.province": "ON", "climate.location.city": "CityWith666", "climate.timeframe": "Present" },
      "expected": "Unavailable"
    },
    {
      "name": "CDD Future falls back to Present",
      "inputs": { "climate.location.province": "ON", "climate.location.city": "CityWithNullFutureCDD", "climate.timeframe": "Future" },
      "expected": "data.CDD24 (present value)"
    },
    {
      "name": "Coldest day for Care occupancy",
      "inputs": { "climate.location.province": "ON", "climate.location.city": "Ottawa", "metadata.occupancyType": "Care" },
      "expected": "data.January_1 (1% design temp)"
    },
    {
      "name": "Winter average allows zero",
      "inputs": { "climate.location.province": "BC", "climate.location.city": "Vancouver" },
      "expected": "data.Winter_Tdb_Avg even if 0"
    }
  ],
  "references": [
    { "source": "ClimateNodes.js:163-301" },
    { "source": "ClimateValues.js (lookup data)" }
  ]
}
