{
  "_meta": {
    "description": "Heating and cooling setpoint nodes. Heating setpoint varies by reference standard (PH override) and occupancy type. Cooling setpoint enforces a minimum of 24 deg-C. OBC setpoint is the building-code baseline without PH override. NBC limit is a constant 26 deg-C.",
    "instances": [
      {
        "id": "climate.heating.setpoint",
        "legacyId": "h_23",
        "label": "Heating Setpoint",
        "unit": "deg-C"
      },
      {
        "id": "climate.heating.obcSetpoint",
        "legacyId": "m_23",
        "label": "OBC Heating Setpoint (Building Code Baseline)",
        "unit": "deg-C"
      },
      {
        "id": "climate.cooling.setpoint",
        "legacyId": "h_24",
        "label": "Cooling Setpoint",
        "unit": "deg-C"
      },
      {
        "id": "climate.cooling.nbcLimit",
        "legacyId": "m_24",
        "label": "NBC Cooling Upper Limit",
        "unit": "deg-C"
      }
    ]
  },
  "section": "S03",
  "classification": "C",
  "signature": {
    "inputs": [
      { "name": "metadata.occupancyType", "type": "string", "description": "Occupancy type (d_12) -- used by heating setpoints" },
      { "name": "metadata.referenceStandard", "type": "string", "description": "Reference standard (d_13) -- used by h_23 only" },
      { "name": "climate.cooling.override", "type": "number", "unit": "deg-C", "description": "User cooling setpoint override (l_24) -- used by h_24 only" }
    ],
    "output": { "type": "number", "unit": "deg-C" }
  },
  "domain": {
    "preconditions": [],
    "invariants": [
      { "condition": "heating setpoint in {18, 22}", "description": "Only two possible heating setpoints" },
      { "condition": "cooling setpoint >= 24", "description": "Cooling setpoint has a floor of 24 deg-C" },
      { "condition": "NBC limit = 26", "description": "Constant value" }
    ]
  },
  "behavior": [
    {
      "condition": "h_23: reference standard contains 'PH' (case-insensitive)",
      "output": "18",
      "note": "Passive House standards always use 18 deg-C regardless of occupancy"
    },
    {
      "condition": "h_23: occupancy includes 'Residential' or 'Care' (non-PH)",
      "output": "22",
      "note": "OBC requires 22 deg-C for residential and care occupancies"
    },
    {
      "condition": "h_23: other occupancy (non-PH)",
      "output": "18",
      "note": "Default heating setpoint for commercial/assembly/etc."
    },
    {
      "condition": "m_23: occupancy includes 'Residential' or 'Care'",
      "output": "22",
      "note": "Building code baseline -- no PH override applied"
    },
    {
      "condition": "m_23: other occupancy",
      "output": "18",
      "note": "Building code baseline for non-residential"
    },
    {
      "condition": "h_24: override > 24",
      "output": "override value",
      "note": "User can raise setpoint above 24 but not below"
    },
    {
      "condition": "h_24: override <= 24",
      "output": "24",
      "note": "Floor of 24 deg-C enforced"
    },
    {
      "condition": "m_24: always",
      "output": "26",
      "note": "NBC standard upper limit, constant"
    }
  ],
  "edgeCases": [
    {
      "condition": "Occupancy string contains 'Residential' as substring (e.g. 'C-Residential', 'D-Residential MURB')",
      "handling": "Uses includes() check, matches any variant",
      "rationale": "Multiple occupancy values contain the word 'Residential'"
    },
    {
      "condition": "Reference standard is null/undefined",
      "handling": "Defaults to 'OBC SB-10', isPH=false",
      "rationale": "Fallback to non-PH behavior"
    }
  ],
  "formula": {
    "symbolic": {
      "h_23": "IF(standard.includes('PH'), 18, IF(occupancy.includes('Residential'|'Care'), 22, 18))",
      "m_23": "IF(occupancy.includes('Residential'|'Care'), 22, 18)",
      "h_24": "MAX(l_24, 24)",
      "m_24": "26"
    },
    "implementation": "ClimateNodes.js:331-409"
  },
  "tests": [
    {
      "name": "h_23: PH standard overrides to 18",
      "inputs": { "metadata.referenceStandard": "PHIUS", "metadata.occupancyType": "C-Residential" },
      "expected": 18
    },
    {
      "name": "h_23: Residential non-PH gets 22",
      "inputs": { "metadata.referenceStandard": "OBC SB-10", "metadata.occupancyType": "C-Residential" },
      "expected": 22
    },
    {
      "name": "h_23: Care non-PH gets 22",
      "inputs": { "metadata.referenceStandard": "OBC SB-10", "metadata.occupancyType": "Care" },
      "expected": 22
    },
    {
      "name": "h_23: Assembly non-PH gets 18",
      "inputs": { "metadata.referenceStandard": "OBC SB-10", "metadata.occupancyType": "A-Assembly" },
      "expected": 18
    },
    {
      "name": "m_23: Residential always 22 (no PH override)",
      "inputs": { "metadata.occupancyType": "D-Residential MURB" },
      "expected": 22
    },
    {
      "name": "m_23: Other always 18",
      "inputs": { "metadata.occupancyType": "A-Assembly" },
      "expected": 18
    },
    {
      "name": "h_24: Override above 24 is used",
      "inputs": { "climate.cooling.override": 26 },
      "expected": 26
    },
    {
      "name": "h_24: Override at 24 returns 24",
      "inputs": { "climate.cooling.override": 24 },
      "expected": 24
    },
    {
      "name": "h_24: Override below 24 floors to 24",
      "inputs": { "climate.cooling.override": 20 },
      "expected": 24
    },
    {
      "name": "m_24: Always 26",
      "inputs": {},
      "expected": 26
    }
  ],
  "references": [
    { "source": "ClimateNodes.js:331-409" }
  ]
}
