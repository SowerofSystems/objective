{
  "nodes": [
    {
      "id": "compliance.plugLoad.ratio",
      "legacyId": "m_65",
      "label": "Plug Load Compliance Ratio",
      "section": "S09",
      "classification": "C",
      "_meta": {
        "description": "Ratio of target plug load density to reference plug load density, expressed as percentage string. Lower plug load density is better (less energy waste from appliances). Values <= 100% indicate improvement."
      },
      "signature": {
        "inputs": [
          {
            "name": "internal.plugLoadDensity",
            "type": "number",
            "unit": "W/m²",
            "description": "Target model plug load density (d_65)"
          },
          {
            "name": "reference.internal.plugLoadDensity",
            "type": "number",
            "unit": "W/m²",
            "description": "Reference model plug load density (ref_d_65)"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%'"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "ref > 0",
            "description": "Reference plug load must be positive"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "ref > 0",
          "output": "round(target / ref * 100) + '%'",
          "note": "Lower target density = lower percentage = better"
        },
        {
          "condition": "ref == 0",
          "output": "'100%'",
          "note": "Default to 100% when no reference"
        }
      ],
      "edgeCases": [],
      "compliance": {
        "passCondition": "target / ref <= 1.0",
        "passSymbol": "✓",
        "failSymbol": "✗",
        "relatedField": "n_65"
      },
      "formula": {
        "symbolic": "m_65 = IF(ref_d_65 > 0, round(d_65 / ref_d_65 * 100) + '%', '100%')",
        "implementation": "SectionComplianceNodes.js:152-166"
      },
      "tests": [
        {
          "name": "Target lower than reference (better)",
          "inputs": {
            "internal.plugLoadDensity": 5,
            "reference.internal.plugLoadDensity": 7
          },
          "expected": "71%"
        },
        {
          "name": "Target equals reference",
          "inputs": {
            "internal.plugLoadDensity": 7,
            "reference.internal.plugLoadDensity": 7
          },
          "expected": "100%"
        },
        {
          "name": "Target exceeds reference (worse)",
          "inputs": {
            "internal.plugLoadDensity": 10,
            "reference.internal.plugLoadDensity": 7
          },
          "expected": "143%"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:152-166"
        }
      ]
    },
    {
      "id": "compliance.plugLoad.pass",
      "legacyId": "n_65",
      "label": "Plug Load Compliance Status",
      "section": "S09",
      "classification": "C",
      "_meta": {
        "description": "Pass/fail indicator for plug load density compliance. Passes when target density is less than or equal to reference density (lower is better)."
      },
      "signature": {
        "inputs": [
          {
            "name": "internal.plugLoadDensity",
            "type": "number",
            "unit": "W/m²",
            "description": "Target model plug load density (d_65)"
          },
          {
            "name": "reference.internal.plugLoadDensity",
            "type": "number",
            "unit": "W/m²",
            "description": "Reference model plug load density (ref_d_65)"
          }
        ],
        "output": {
          "type": "string",
          "values": ["✓", "✗"]
        }
      },
      "domain": {
        "invariants": [
          {
            "condition": "output in ['✓', '✗']",
            "description": "Only two possible output values"
          }
        ]
      },
      "behavior": [
        {
          "condition": "ref > 0 AND target / ref <= 1.0",
          "output": "✓",
          "note": "Target density is at or below reference"
        },
        {
          "condition": "ref > 0 AND target / ref > 1.0",
          "output": "✗",
          "note": "Target density exceeds reference"
        },
        {
          "condition": "ref == 0",
          "output": "✗",
          "note": "Cannot pass when no reference"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "n_65 = IF(ref_d_65 > 0 AND d_65/ref_d_65 <= 1.0, '✓', '✗')",
        "implementation": "SectionComplianceNodes.js:167-179"
      },
      "tests": [
        {
          "name": "Passing - lower density",
          "inputs": {
            "internal.plugLoadDensity": 5,
            "reference.internal.plugLoadDensity": 7
          },
          "expected": "✓"
        },
        {
          "name": "Passing - equal density",
          "inputs": {
            "internal.plugLoadDensity": 7,
            "reference.internal.plugLoadDensity": 7
          },
          "expected": "✓"
        },
        {
          "name": "Failing - higher density",
          "inputs": {
            "internal.plugLoadDensity": 10,
            "reference.internal.plugLoadDensity": 7
          },
          "expected": "✗"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:167-179"
        }
      ]
    },
