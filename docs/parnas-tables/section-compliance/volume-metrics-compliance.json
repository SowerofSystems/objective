{
  "nodes": [
    {
      "id": "compliance.passiveHouse.text",
      "legacyId": "m_104",
      "label": "Passive House Compliance Level",
      "section": "S12",
      "classification": "C",
      "_meta": {
        "description": "Qualitative assessment of envelope performance based on combined U-value (g_104). Thresholds: < 0.15 W/m²K = PH level, < 0.2 = Very Good, < 0.3 = Good, >= 0.3 = Meh."
      },
      "signature": {
        "inputs": [
          {
            "name": "envelope.combined.uValue",
            "type": "number",
            "unit": "W/m²K",
            "description": "Combined envelope U-value (g_104)"
          }
        ],
        "output": {
          "type": "string",
          "values": ["PH level", "Very Good", "Good", "Meh"]
        }
      },
      "domain": {
        "preconditions": [],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "g_104 < 0.15",
          "output": "'PH level'",
          "note": "Meets Passive House standard"
        },
        {
          "condition": "g_104 >= 0.15 AND g_104 < 0.2",
          "output": "'Very Good'",
          "note": "Near Passive House level"
        },
        {
          "condition": "g_104 >= 0.2 AND g_104 < 0.3",
          "output": "'Good'",
          "note": "Acceptable envelope performance"
        },
        {
          "condition": "g_104 >= 0.3",
          "output": "'Meh'",
          "note": "Below target envelope performance"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "m_104 = IF(g_104<0.15,'PH level',IF(g_104<0.2,'Very Good',IF(g_104<0.3,'Good','Meh')))",
        "implementation": "SectionComplianceNodes.js:355-368"
      },
      "tests": [
        {
          "name": "Passive House level",
          "inputs": { "envelope.combined.uValue": 0.12 },
          "expected": "PH level"
        },
        {
          "name": "Very Good envelope",
          "inputs": { "envelope.combined.uValue": 0.18 },
          "expected": "Very Good"
        },
        {
          "name": "Good envelope",
          "inputs": { "envelope.combined.uValue": 0.25 },
          "expected": "Good"
        },
        {
          "name": "Meh envelope",
          "inputs": { "envelope.combined.uValue": 0.4 },
          "expected": "Meh"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:355-368"
        }
      ]
    },
    {
      "id": "compliance.passiveHouse.pass",
      "legacyId": "n_104",
      "label": "Passive House Compliance Status",
      "section": "S12",
      "classification": "C",
      "_meta": {
        "description": "Pass/fail indicator for envelope performance. Passes when combined U-value < 0.3 W/m²K (at least 'Good' level)."
      },
      "signature": {
        "inputs": [
          {
            "name": "envelope.combined.uValue",
            "type": "number",
            "unit": "W/m²K",
            "description": "Combined envelope U-value (g_104)"
          }
        ],
        "output": {
          "type": "string",
          "values": ["✓", "✗"]
        }
      },
      "domain": {
        "invariants": [
          {
            "condition": "output in ['✓', '✗']",
            "description": "Only two possible output values"
          }
        ]
      },
      "behavior": [
        {
          "condition": "g_104 < 0.3",
          "output": "✓",
          "note": "Envelope U-value is acceptable (Good or better)"
        },
        {
          "condition": "g_104 >= 0.3",
          "output": "✗",
          "note": "Envelope U-value too high"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "n_104 = IF(g_104 < 0.3, '✓', '✗')",
        "implementation": "SectionComplianceNodes.js:369-380"
      },
      "tests": [
        {
          "name": "Passing (Good level)",
          "inputs": { "envelope.combined.uValue": 0.25 },
          "expected": "✓"
        },
        {
          "name": "Failing (Meh level)",
          "inputs": { "envelope.combined.uValue": 0.35 },
          "expected": "✗"
        },
        {
          "name": "Boundary - exactly 0.3 fails",
          "inputs": { "envelope.combined.uValue": 0.3 },
          "expected": "✗"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:369-380"
        }
      ]
    },
    {
      "id": "compliance.ach50.ratio",
      "legacyId": "m_109",
      "label": "ACH50 Compliance Ratio",
      "section": "S12",
      "classification": "C",
      "_meta": {
        "description": "Ratio of reference ACH50 to target ACH50, expressed as percentage string. Lower ACH50 is better (tighter building), so the formula is inverted (ref/target). Values >= 100% indicate the target has equal or better (lower) airtightness than reference."
      },
      "signature": {
        "inputs": [
          {
            "name": "airTightness.ach50Target",
            "type": "number",
            "unit": "ACH",
            "description": "Target model ACH50 (d_109)"
          },
          {
            "name": "reference.airTightness.ach50Target",
            "type": "number",
            "unit": "ACH",
            "description": "Reference model ACH50 (ref_d_109)"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%'"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "target > 0",
            "description": "Target ACH50 must be positive for division"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "target > 0",
          "output": "round(ref / target * 100) + '%'",
          "note": "INVERTED: lower target ACH50 = higher percentage = better"
        },
        {
          "condition": "target == 0",
          "output": "'0%'",
          "note": "Zero target air changes"
        }
      ],
      "edgeCases": [],
      "compliance": {
        "passCondition": "ref / target >= 0.995",
        "passSymbol": "✓",
        "failSymbol": "✗",
        "tolerance": "0.5%",
        "relatedField": "n_109"
      },
      "formula": {
        "symbolic": "m_109 = IF(d_109 > 0, round(ref_d_109 / d_109 * 100) + '%', '0%')",
        "implementation": "SectionComplianceNodes.js:383-398"
      },
      "tests": [
        {
          "name": "Target tighter than reference (better)",
          "inputs": {
            "airTightness.ach50Target": 1.0,
            "reference.airTightness.ach50Target": 1.5
          },
          "expected": "150%"
        },
        {
          "name": "Target equals reference",
          "inputs": {
            "airTightness.ach50Target": 1.5,
            "reference.airTightness.ach50Target": 1.5
          },
          "expected": "100%"
        },
        {
          "name": "Target leakier than reference (worse)",
          "inputs": {
            "airTightness.ach50Target": 3.0,
            "reference.airTightness.ach50Target": 1.5
          },
          "expected": "50%"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:383-398"
        }
      ]
    },
    {
      "id": "compliance.ach50.pass",
      "legacyId": "n_109",
      "label": "ACH50 Compliance Status",
      "section": "S12",
      "classification": "C",
      "_meta": {
        "description": "Pass/fail indicator for ACH50 airtightness compliance. Passes when ref/target >= 0.995 (0.5% tolerance). This allows minor rounding differences to still pass."
      },
      "signature": {
        "inputs": [
          {
            "name": "airTightness.ach50Target",
            "type": "number",
            "description": "Target model ACH50 (d_109)"
          },
          {
            "name": "reference.airTightness.ach50Target",
            "type": "number",
            "description": "Reference model ACH50 (ref_d_109)"
          }
        ],
        "output": {
          "type": "string",
          "values": ["✓", "✗"]
        }
      },
      "domain": {
        "invariants": [
          {
            "condition": "output in ['✓', '✗']",
            "description": "Only two possible output values"
          }
        ]
      },
      "behavior": [
        {
          "condition": "target > 0 AND ref / target >= 0.995",
          "output": "✓",
          "note": "Target ACH50 at or below reference (with 0.5% tolerance)"
        },
        {
          "condition": "target > 0 AND ref / target < 0.995",
          "output": "✗",
          "note": "Target ACH50 exceeds reference beyond tolerance"
        },
        {
          "condition": "target == 0",
          "output": "✗",
          "note": "Zero target is invalid"
        }
      ],
      "edgeCases": [
        {
          "condition": "ref/target is 0.996 (within tolerance)",
          "handling": "Return ✓",
          "rationale": "0.5% tolerance prevents false failures from floating point rounding"
        }
      ],
      "formula": {
        "symbolic": "n_109 = IF(d_109 > 0 AND ref_d_109/d_109 >= 0.995, '✓', '✗')",
        "implementation": "SectionComplianceNodes.js:399-412"
      },
      "tests": [
        {
          "name": "Target tighter than reference (pass)",
          "inputs": {
            "airTightness.ach50Target": 1.0,
            "reference.airTightness.ach50Target": 1.5
          },
          "expected": "✓"
        },
        {
          "name": "Target equals reference (pass)",
          "inputs": {
            "airTightness.ach50Target": 1.5,
            "reference.airTightness.ach50Target": 1.5
          },
          "expected": "✓"
        },
        {
          "name": "Target leakier than reference (fail)",
          "inputs": {
            "airTightness.ach50Target": 3.0,
            "reference.airTightness.ach50Target": 1.5
          },
          "expected": "✗"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:399-412"
        }
      ]
    },
    {
      "id": "compliance.wwr.ratio",
      "legacyId": "m_107",
      "label": "WWR Compliance Value",
      "section": "S12",
      "classification": "C",
      "_meta": {
        "description": "Window-to-wall ratio displayed as a percentage string. Not a compliance ratio per se, but a direct display of the envelope.wwr value as a percentage."
      },
      "signature": {
        "inputs": [
          {
            "name": "envelope.wwr",
            "type": "number",
            "unit": "decimal",
            "description": "Window-to-wall ratio (d_107), e.g. 0.18 for 18%"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%'"
        }
      },
      "domain": {
        "preconditions": [],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "always",
          "output": "round(wwr * 100) + '%'",
          "note": "Convert decimal ratio to percentage string"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "m_107 = round(d_107 * 100) + '%'",
        "implementation": "SectionComplianceNodes.js:415-425"
      },
      "tests": [
        {
          "name": "Typical residential WWR",
          "inputs": { "envelope.wwr": 0.18 },
          "expected": "18%"
        },
        {
          "name": "Commercial building WWR",
          "inputs": { "envelope.wwr": 0.35 },
          "expected": "35%"
        },
        {
          "name": "Zero WWR",
          "inputs": { "envelope.wwr": 0 },
          "expected": "0%"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:415-425"
        }
      ]
    },
    {
      "id": "compliance.wwr.pass",
      "legacyId": "n_107",
      "label": "WWR Compliance Status",
      "section": "S12",
      "classification": "C",
      "_meta": {
        "description": "Pass/fail indicator for window-to-wall ratio. Threshold depends on occupancy type: Residential (C-Residential) uses 22%, all other occupancies use 40%."
      },
      "signature": {
        "inputs": [
          {
            "name": "envelope.wwr",
            "type": "number",
            "unit": "decimal",
            "description": "Window-to-wall ratio (d_107)"
          },
          {
            "name": "building.majorOccupancy",
            "type": "string",
            "description": "Major occupancy classification"
          }
        ],
        "output": {
          "type": "string",
          "values": ["✓", "✗"]
        }
      },
      "domain": {
        "invariants": [
          {
            "condition": "output in ['✓', '✗']",
            "description": "Only two possible output values"
          }
        ]
      },
      "behavior": [
        {
          "condition": "occupancy == 'C-Residential' AND wwr <= 0.22",
          "output": "✓",
          "note": "Residential buildings limited to 22% WWR"
        },
        {
          "condition": "occupancy == 'C-Residential' AND wwr > 0.22",
          "output": "✗"
        },
        {
          "condition": "occupancy != 'C-Residential' AND wwr <= 0.40",
          "output": "✓",
          "note": "Non-residential buildings limited to 40% WWR"
        },
        {
          "condition": "occupancy != 'C-Residential' AND wwr > 0.40",
          "output": "✗"
        }
      ],
      "edgeCases": [
        {
          "condition": "occupancy is empty",
          "handling": "Treated as non-residential (40% threshold)",
          "rationale": "Default to more permissive threshold"
        }
      ],
      "formula": {
        "symbolic": "n_107 = IF(occupancy='C-Residential', IF(d_107<=0.22,'✓','✗'), IF(d_107<=0.40,'✓','✗'))",
        "implementation": "SectionComplianceNodes.js:426-441"
      },
      "tests": [
        {
          "name": "Residential within limit",
          "inputs": {
            "envelope.wwr": 0.18,
            "building.majorOccupancy": "C-Residential"
          },
          "expected": "✓"
        },
        {
          "name": "Residential over limit",
          "inputs": {
            "envelope.wwr": 0.30,
            "building.majorOccupancy": "C-Residential"
          },
          "expected": "✗"
        },
        {
          "name": "Commercial within limit",
          "inputs": {
            "envelope.wwr": 0.35,
            "building.majorOccupancy": "D-Business"
          },
          "expected": "✓"
        },
        {
          "name": "Commercial over limit",
          "inputs": {
            "envelope.wwr": 0.45,
            "building.majorOccupancy": "D-Business"
          },
          "expected": "✗"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:426-441"
        }
      ]
    },
    {
      "id": "compliance.ela10.ratio",
      "legacyId": "m_110",
      "label": "ELA10 Compliance Ratio",
      "section": "S12",
      "classification": "C",
      "_meta": {
        "description": "Ratio of target ELA10 to reference ELA10, expressed as percentage string. Lower ELA10 is better (tighter building), so values <= 100% indicate improvement."
      },
      "signature": {
        "inputs": [
          {
            "name": "airTightness.ela10",
            "type": "number",
            "unit": "m²",
            "description": "Target model ELA at 10 Pa (d_110)"
          },
          {
            "name": "reference.airTightness.ela10",
            "type": "number",
            "unit": "m²",
            "description": "Reference model ELA at 10 Pa (ref_d_110)"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%'"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "ref > 0",
            "description": "Reference ELA10 must be positive for ratio"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "ref > 0",
          "output": "round(target / ref * 100) + '%'",
          "note": "Lower target ELA = lower percentage = better"
        },
        {
          "condition": "ref == 0",
          "output": "'100%'",
          "note": "Default when no reference"
        }
      ],
      "edgeCases": [],
      "compliance": {
        "passCondition": "target / ref <= 1.005",
        "passSymbol": "✓",
        "failSymbol": "✗",
        "tolerance": "0.5%",
        "relatedField": "n_110"
      },
      "formula": {
        "symbolic": "m_110 = IF(ref_d_110 > 0, round(d_110 / ref_d_110 * 100) + '%', '100%')",
        "implementation": "SectionComplianceNodes.js:444-458"
      },
      "tests": [
        {
          "name": "Target tighter than reference",
          "inputs": {
            "airTightness.ela10": 0.03,
            "reference.airTightness.ela10": 0.05
          },
          "expected": "60%"
        },
        {
          "name": "Target equals reference",
          "inputs": {
            "airTightness.ela10": 0.05,
            "reference.airTightness.ela10": 0.05
          },
          "expected": "100%"
        },
        {
          "name": "No reference ELA",
          "inputs": {
            "airTightness.ela10": 0.03,
            "reference.airTightness.ela10": 0
          },
          "expected": "100%"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:444-458"
        }
      ]
    },
    {
      "id": "compliance.ela10.pass",
      "legacyId": "n_110",
      "label": "ELA10 Compliance Status",
      "section": "S12",
      "classification": "C",
      "_meta": {
        "description": "Pass/fail indicator for ELA10 compliance. Passes when target/ref <= 1.005 (0.5% tolerance). Lower ELA is better (tighter building)."
      },
      "signature": {
        "inputs": [
          {
            "name": "airTightness.ela10",
            "type": "number",
            "description": "Target model ELA10 (d_110)"
          },
          {
            "name": "reference.airTightness.ela10",
            "type": "number",
            "description": "Reference model ELA10 (ref_d_110)"
          }
        ],
        "output": {
          "type": "string",
          "values": ["✓", "✗"]
        }
      },
      "domain": {
        "invariants": [
          {
            "condition": "output in ['✓', '✗']",
            "description": "Only two possible output values"
          }
        ]
      },
      "behavior": [
        {
          "condition": "ref > 0 AND target / ref <= 1.005",
          "output": "✓",
          "note": "Target ELA at or below reference (with 0.5% tolerance)"
        },
        {
          "condition": "ref > 0 AND target / ref > 1.005",
          "output": "✗",
          "note": "Target ELA exceeds reference beyond tolerance"
        },
        {
          "condition": "ref == 0",
          "output": "✗",
          "note": "No reference for comparison"
        }
      ],
      "edgeCases": [
        {
          "condition": "target/ref is 1.004 (within tolerance)",
          "handling": "Return ✓",
          "rationale": "0.5% tolerance prevents false failures from floating point rounding"
        }
      ],
      "formula": {
        "symbolic": "n_110 = IF(ref_d_110 > 0 AND d_110/ref_d_110 <= 1.005, '✓', '✗')",
        "implementation": "SectionComplianceNodes.js:459-472"
      },
      "tests": [
        {
          "name": "Target tighter than reference (pass)",
          "inputs": {
            "airTightness.ela10": 0.03,
            "reference.airTightness.ela10": 0.05
          },
          "expected": "✓"
        },
        {
          "name": "Target equals reference (pass)",
          "inputs": {
            "airTightness.ela10": 0.05,
            "reference.airTightness.ela10": 0.05
          },
          "expected": "✓"
        },
        {
          "name": "Target leakier than reference (fail)",
          "inputs": {
            "airTightness.ela10": 0.08,
            "reference.airTightness.ela10": 0.05
          },
          "expected": "✗"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:459-472"
        }
      ]
    }
  ]
}
