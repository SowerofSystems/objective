    {
      "id": "compliance.envelope.thermalBridge.ratio",
      "legacyId": "m_97",
      "label": "Thermal Bridge Compliance Ratio",
      "section": "S11",
      "classification": "C",
      "_meta": {
        "description": "INVERTED ratio of reference thermal bridge penalty to target thermal bridge penalty. Lower penalty is better. Both values converted from percentage (e.g. 20 means 20%) to decimal before ratio. Values >= 100% indicate compliance."
      },
      "signature": {
        "inputs": [
          { "name": "transmissionLoss.thermalBridgePenalty", "type": "number", "unit": "%", "description": "Target thermal bridge penalty (d_97), e.g. 15 for 15%" },
          { "name": "reference.transmissionLoss.thermalBridgePenalty", "type": "number", "unit": "%", "description": "Reference thermal bridge penalty (ref_d_97), e.g. 20 for 20%" }
        ],
        "output": { "type": "string", "format": "'{integer}%'" }
      },
      "behavior": [
        { "condition": "targetPct > 0", "output": "round((refPct / targetPct) * 100) + '%'", "note": "INVERTED: lower penalty = higher %. Both divided by 100 first." },
        { "condition": "targetPct == 0", "output": "'100%'" }
      ],
      "compliance": { "passCondition": "targetPct <= refPct", "passSymbol": "✓", "failSymbol": "✗", "relatedField": "n_97" },
      "formula": { "symbolic": "m_97 = IF(d_97/100 > 0, round((ref_d_97/100) / (d_97/100) * 100) + '%', '100%')", "implementation": "SectionComplianceNodes.js:321-334" },
      "tests": [
        {
          "name": "Target has lower penalty (better)",
          "inputs": {
            "transmissionLoss.thermalBridgePenalty": 10,
            "reference.transmissionLoss.thermalBridgePenalty": 20
          },
          "expected": "200%"
        },
        {
          "name": "Equal penalties",
          "inputs": {
            "transmissionLoss.thermalBridgePenalty": 20,
            "reference.transmissionLoss.thermalBridgePenalty": 20
          },
          "expected": "100%"
        },
        {
