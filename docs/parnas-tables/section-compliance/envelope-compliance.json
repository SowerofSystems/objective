{
  "_meta": {
    "description": "Envelope compliance ratios for S11. RSI components (higher is better) use target/ref, U-value components (lower is better) use ref/target. Thermal bridge penalty (lower is better) uses ref/target with percentage conversion. All ratios displayed as '{integer}%' strings."
  },
  "nodes": [
    {
      "id": "compliance.envelope.roof.ratio",
      "legacyId": "m_85",
      "label": "Roof RSI Compliance Ratio",
      "section": "S11",
      "classification": "C",
      "_meta": {
        "description": "Ratio of target roof RSI to reference roof RSI. Higher RSI is better (more insulation). Values >= 100% indicate compliance."
      },
      "signature": {
        "inputs": [
          { "name": "transmissionLoss.roof.rsi", "type": "number", "description": "Target roof RSI (f_85)" },
          { "name": "reference.transmissionLoss.roof.rsi", "type": "number", "description": "Reference roof RSI (ref_f_85)" }
        ],
        "output": { "type": "string", "format": "'{integer}%'" }
      },
      "behavior": [
        { "condition": "ref > 0", "output": "round(target / ref * 100) + '%'" },
        { "condition": "ref == 0", "output": "'100%'" }
      ],
      "compliance": { "passCondition": "target >= ref", "passSymbol": "✓", "failSymbol": "✗", "relatedField": "n_85" },
      "formula": { "symbolic": "m_85 = round(f_85 / ref_f_85 * 100) + '%'", "implementation": "SectionComplianceNodes.js:246-280" }
    },
    {
