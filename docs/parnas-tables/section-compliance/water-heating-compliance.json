{
  "nodes": [
    {
      "id": "compliance.waterUse.ratio",
      "legacyId": "m_49",
      "label": "Water Use Compliance Ratio",
      "section": "S07",
      "classification": "C",
      "_meta": {
        "description": "Ratio of target water use (L/person/day) to reference water use, expressed as percentage string. Lower water use is better, so values <= 100% indicate improvement. Displayed as '{integer}%'."
      },
      "signature": {
        "inputs": [
          {
            "name": "waterHeating.lpppd",
            "type": "number",
            "unit": "L/person/day",
            "description": "Target model litres per person per day (h_49)"
          },
          {
            "name": "reference.waterHeating.lpppd",
            "type": "number",
            "unit": "L/person/day",
            "description": "Reference model litres per person per day (ref_h_49)"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%'"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "ref > 0",
            "description": "Reference water use must be positive for ratio calculation"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "ref > 0",
          "output": "round(target / ref * 100) + '%'",
          "note": "Lower target = lower percentage = better water efficiency"
        },
        {
          "condition": "ref == 0",
          "output": "'0%'",
          "note": "Default when no reference value available"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "m_49 = IF(ref_h_49 > 0, round(h_49 / ref_h_49 * 100) + '%', '0%')",
        "implementation": "SectionComplianceNodes.js:77-92"
      },
      "tests": [
        {
          "name": "Target uses less water than reference",
          "inputs": {
            "waterHeating.lpppd": 30,
            "reference.waterHeating.lpppd": 40
          },
          "expected": "75%"
        },
        {
          "name": "Target equals reference",
          "inputs": {
            "waterHeating.lpppd": 40,
            "reference.waterHeating.lpppd": 40
          },
          "expected": "100%"
        },
        {
          "name": "Zero reference",
          "inputs": {
            "waterHeating.lpppd": 30,
            "reference.waterHeating.lpppd": 0
          },
          "expected": "0%"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:77-92"
        }
      ]
    },
    {
      "id": "compliance.waterEnergy.ratio",
      "legacyId": "m_50",
      "label": "Water Energy Compliance Ratio",
      "section": "S07",
      "classification": "C",
      "_meta": {
        "description": "Ratio of target warm water fraction to reference warm water fraction, expressed as percentage string. Lower is better (less energy for water heating). Warm water fraction is computed as lpppd * 0.4."
      },
      "signature": {
        "inputs": [
          {
            "name": "waterHeating.warmWaterFraction",
            "type": "number",
            "description": "Target model warm water fraction (h_50)"
          },
          {
            "name": "reference.waterHeating.warmWaterFraction",
            "type": "number",
            "description": "Reference model warm water fraction (ref_h_50)"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%'"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "ref > 0",
            "description": "Reference warm water fraction must be positive"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "ref > 0",
          "output": "round(target / ref * 100) + '%'",
          "note": "Lower target = lower percentage = better"
        },
        {
          "condition": "ref == 0",
          "output": "'0%'",
          "note": "Default when no reference value available"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "m_50 = IF(ref_h_50 > 0, round(h_50 / ref_h_50 * 100) + '%', '0%')",
        "implementation": "SectionComplianceNodes.js:95-110"
      },
      "tests": [
        {
          "name": "Target has lower warm water fraction",
          "inputs": {
            "waterHeating.warmWaterFraction": 12,
            "reference.waterHeating.warmWaterFraction": 16
          },
          "expected": "75%"
        },
        {
          "name": "Target equals reference",
          "inputs": {
            "waterHeating.warmWaterFraction": 16,
            "reference.waterHeating.warmWaterFraction": 16
          },
          "expected": "100%"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:95-110"
        }
      ]
    },
    {
      "id": "compliance.waterEfficiency.ratio",
      "legacyId": "m_52",
      "label": "Water Heating Efficiency Compliance Ratio",
      "section": "S07",
      "classification": "C",
      "_meta": {
        "description": "Ratio of target water heating efficiency to reference water heating efficiency, expressed as percentage string. Higher efficiency is better. Values >= 100% indicate improvement."
      },
      "signature": {
        "inputs": [
          {
            "name": "waterHeating.efficiency",
            "type": "number",
            "unit": "%",
            "description": "Target model water heating efficiency (d_52)"
          },
          {
            "name": "reference.waterHeating.efficiency",
            "type": "number",
            "unit": "%",
            "description": "Reference model water heating efficiency (ref_d_52)"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%'"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "ref > 0",
            "description": "Reference efficiency must be positive"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "ref > 0",
          "output": "round(target / ref * 100) + '%'",
          "note": "Higher target efficiency = higher percentage = better"
        },
        {
          "condition": "ref == 0",
          "output": "'100%'",
          "note": "Default to compliant when no reference"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "m_52 = IF(ref_d_52 > 0, round(d_52 / ref_d_52 * 100) + '%', '100%')",
        "implementation": "SectionComplianceNodes.js:113-128"
      },
      "tests": [
        {
          "name": "Target has higher efficiency",
          "inputs": {
            "waterHeating.efficiency": 400,
            "reference.waterHeating.efficiency": 300
          },
          "expected": "133%"
        },
        {
          "name": "Target equals reference",
          "inputs": {
            "waterHeating.efficiency": 300,
            "reference.waterHeating.efficiency": 300
          },
          "expected": "100%"
        },
        {
          "name": "No reference",
          "inputs": {
            "waterHeating.efficiency": 400,
            "reference.waterHeating.efficiency": 0
          },
          "expected": "100%"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:113-128"
        }
      ]
    },
    {
      "id": "compliance.waterDWHR.ratio",
      "legacyId": "m_53",
      "label": "DWHR Compliance Ratio",
      "section": "S07",
      "classification": "C",
      "_meta": {
        "description": "Ratio of target DWHR (Drain Water Heat Recovery) efficiency to reference DWHR efficiency, expressed as percentage string. Higher is better. Returns 'N/A' if reference DWHR efficiency is 0 (no DWHR in reference building)."
      },
      "signature": {
        "inputs": [
          {
            "name": "waterHeating.dwhrEfficiency",
            "type": "number",
            "unit": "%",
            "description": "Target model DWHR efficiency (d_53)"
          },
          {
            "name": "reference.waterHeating.dwhrEfficiency",
            "type": "number",
            "unit": "%",
            "description": "Reference model DWHR efficiency (ref_d_53)"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%' or 'N/A'"
        }
      },
      "domain": {
        "preconditions": [],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "ref == 0",
          "output": "'N/A'",
          "note": "Reference has no DWHR, comparison not meaningful"
        },
        {
          "condition": "ref > 0",
          "output": "round(target / ref * 100) + '%'",
          "note": "Higher target DWHR = higher percentage = better"
        }
      ],
      "edgeCases": [
        {
          "condition": "Reference has no DWHR (ref = 0)",
          "handling": "Return 'N/A'",
          "rationale": "Cannot compare DWHR efficiency when reference has none"
        }
      ],
      "formula": {
        "symbolic": "m_53 = IF(ref_d_53 == 0, 'N/A', round(d_53 / ref_d_53 * 100) + '%')",
        "implementation": "SectionComplianceNodes.js:131-144"
      },
      "tests": [
        {
          "name": "Both have DWHR",
          "inputs": {
            "waterHeating.dwhrEfficiency": 55,
            "reference.waterHeating.dwhrEfficiency": 40
          },
          "expected": "138%"
        },
        {
          "name": "Reference has no DWHR",
          "inputs": {
            "waterHeating.dwhrEfficiency": 55,
            "reference.waterHeating.dwhrEfficiency": 0
          },
          "expected": "N/A"
        },
        {
          "name": "Equal DWHR efficiency",
          "inputs": {
            "waterHeating.dwhrEfficiency": 40,
            "reference.waterHeating.dwhrEfficiency": 40
          },
          "expected": "100%"
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:131-144"
        }
      ]
    }
  ]
}
