{
  "nodes": [
    {
      "id": "compliance.ghgReduction",
      "legacyId": "d_145",
      "label": "GHG Reduction from Reference",
      "section": "S15",
      "classification": "C",
      "_meta": {
        "description": "Fractional GHG reduction from reference baseline to target. Computed as 1 - (targetEmissions / refEmissions). A value of 0.5 means 50% reduction. Used for GHG compliance reporting in Section 15."
      },
      "signature": {
        "inputs": [
          {
            "name": "emissions.target.subtotal",
            "type": "number",
            "unit": "kgCO2e/yr",
            "description": "Target model total emissions (k_32)"
          },
          {
            "name": "reference.emissions.subtotal",
            "type": "number",
            "unit": "kgCO2e/yr",
            "description": "Reference model total emissions (ref_k_32), injected via cross-model sync"
          }
        ],
        "output": {
          "type": "number",
          "unit": "fraction",
          "description": "Reduction as fraction (0.5 = 50% reduction)"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "refEmissions > 0",
            "description": "Reference emissions must be positive for meaningful reduction"
          }
        ],
        "invariants": [
          {
            "condition": "output <= 1",
            "description": "Reduction cannot exceed 100% unless sequestration"
          }
        ]
      },
      "behavior": [
        {
          "condition": "refEmissions > 0",
          "output": "1 - (targetEmissions / refEmissions)",
          "note": "Standard reduction formula"
        },
        {
          "condition": "refEmissions == 0 AND targetEmissions < 0",
          "output": "1",
          "note": "Full reduction (sequestration edge case)"
        },
        {
          "condition": "refEmissions == 0 AND targetEmissions >= 0",
          "output": "0",
          "note": "No reference emissions to reduce from"
        }
      ],
      "edgeCases": [
        {
          "condition": "refEmissions == 0 and targetEmissions < 0",
          "handling": "Return 1 (100% reduction)",
          "rationale": "Carbon sequestration with no baseline still counts as maximum reduction"
        },
        {
          "condition": "targetEmissions > refEmissions",
          "handling": "Returns negative value",
          "rationale": "Negative reduction means target is worse than reference"
        }
      ],
      "formula": {
        "symbolic": "d_145 = IF(ref_k_32 > 0, 1 - k_32/ref_k_32, IF(k_32 < 0, 1, 0))",
        "implementation": "SectionComplianceNodes.js:479-497"
      },
      "tests": [
        {
          "name": "50% emissions reduction",
          "inputs": {
            "emissions.target.subtotal": 3000,
            "reference.emissions.subtotal": 6000
          },
          "expected": 0.5
        },
        {
          "name": "Zero emissions (100% reduction)",
          "inputs": {
            "emissions.target.subtotal": 0,
            "reference.emissions.subtotal": 6000
          },
          "expected": 1.0
        },
        {
          "name": "No change",
          "inputs": {
            "emissions.target.subtotal": 6000,
            "reference.emissions.subtotal": 6000
          },
          "expected": 0
        },
        {
          "name": "Negative reduction (target worse)",
          "inputs": {
            "emissions.target.subtotal": 8000,
            "reference.emissions.subtotal": 6000
          },
          "expected": -0.333,
          "note": "Approximately -1/3, target is 33% worse than reference"
        },
        {
          "name": "Sequestration edge case",
          "inputs": {
            "emissions.target.subtotal": -100,
            "reference.emissions.subtotal": 0
          },
          "expected": 1
        },
        {
          "name": "Zero reference, zero target",
          "inputs": {
            "emissions.target.subtotal": 0,
            "reference.emissions.subtotal": 0
          },
          "expected": 0
        }
      ],
      "references": [
        {
          "source": "SectionComplianceNodes.js:479-497"
        }
      ]
    }
  ]
}
