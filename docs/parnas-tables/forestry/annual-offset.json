{
  "id": "forestry.annualOffset",
  "legacyId": "d_60",
  "label": "Annual Wood Offset (MT CO2/yr)",
  "section": "S08",
  "classification": "C",
  "_meta": {
    "description": "Annual carbon offset from wood usage. Converts kg CO2 to metric tonnes. Only applies when wood volume > 0."
  },
  "signature": {
    "inputs": [
      { "name": "forestry.woodVolume", "type": "number", "unit": "m³/yr", "description": "Wood volume (d_31)" },
      { "name": "forestry.woodEmissions", "type": "number", "unit": "kg CO2/yr", "description": "Wood emissions (k_31)" }
    ],
    "output": { "type": "number", "unit": "MT CO2/yr" }
  },
  "domain": {
    "preconditions": [],
    "invariants": [{ "condition": "output >= 0", "description": "Offset cannot be negative" }]
  },
  "behavior": [
    { "condition": "volume > 0", "output": "emissions / 1000", "note": "Convert kg to MT" },
    { "condition": "volume <= 0", "output": "0", "note": "No wood usage means no offset" }
  ],
  "edgeCases": [],
  "formula": {
    "symbolic": "d_60 = IF(d_31 > 0, k_31 / 1000, 0)",
    "implementation": "ForestryNodes.js:60-73"
  },
  "tests": [
    { "name": "With wood", "inputs": { "forestry.woodVolume": 10, "forestry.woodEmissions": 1500 }, "expected": 1.5 },
    { "name": "No wood", "inputs": { "forestry.woodVolume": 0, "forestry.woodEmissions": 0 }, "expected": 0 }
  ]
}
