{
  "id": "forestry.woodEmissions",
  "legacyId": "k_31",
  "label": "Wood Emissions (kg CO2/yr)",
  "section": "S04",
  "classification": "C",
  "_meta": {
    "description": "Intermediate calculation: wood volume multiplied by emissions factor of 150 kg CO2 per m³."
  },
  "signature": {
    "inputs": [
      { "name": "forestry.woodVolume", "type": "number", "unit": "m³/yr", "description": "Wood volume (d_31)" }
    ],
    "output": { "type": "number", "unit": "kg CO2/yr" }
  },
  "domain": {
    "preconditions": [],
    "invariants": [{ "condition": "output >= 0", "description": "Emissions cannot be negative" }]
  },
  "behavior": [
    { "condition": "always", "output": "volume * 150", "note": "Fixed emissions factor of 150 kg CO2 per m³ wood" }
  ],
  "edgeCases": [
    { "condition": "volume = 0", "handling": "Returns 0", "rationale": "No wood, no emissions" }
  ],
  "formula": {
    "symbolic": "k_31 = d_31 × 150",
    "implementation": "ForestryNodes.js:44-56"
  },
  "tests": [
    { "name": "Typical wood volume", "inputs": { "forestry.woodVolume": 10 }, "expected": 1500 },
    { "name": "Zero wood", "inputs": { "forestry.woodVolume": 0 }, "expected": 0 }
  ]
}
