    {
      "id": "compliance.coolingIntensity.ratio",
      "legacyId": "m_117",
      "label": "Cooling Intensity Compliance Ratio",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "INVERTED ratio of reference cooling intensity to target cooling intensity. Unlike other compliance ratios, LOWER cooling intensity is better, so the formula is inverted (ref/target). Values >= 100% indicate the target has equal or better (lower) cooling intensity than reference."
      },
      "signature": {
        "inputs": [
          {
            "name": "mechanical.cooling.intensity",
            "type": "number",
            "unit": "kWh/m2",
            "description": "Target model cooling intensity (f_117)"
          },
          {
            "name": "reference.mechanical.cooling.intensity",
            "type": "number",
            "unit": "kWh/m2",
            "description": "Reference model cooling intensity (ref_f_117), injected via cross-model sync"
          }
        ],
        "output": {
          "type": "number",
          "unit": "percent",
          "format": "integer"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "targetIntensity > 0",
            "description": "Target intensity must be positive for ratio calculation"
          }
        ],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "Percentage cannot be negative"
          }
        ]
      },
      "behavior": [
        {
          "condition": "targetIntensity > 0",
          "output": "round(referenceIntensity / targetIntensity * 100)",
          "note": "INVERTED: Lower target intensity = higher (better) percentage"
        },
        {
          "condition": "targetIntensity == 0",
          "output": "100",
          "note": "Default to 100% (compliant) when no target intensity"
        }
      ],
      "edgeCases": [],
      "architectureNote": "Compliance nodes always compute in the Target model context. Reference values arrive via cross-model sync (reference.* bridge inputs).",
      "rationale": {
        "whyInverted": "For cooling intensity, lower values are better (less cooling needed). Standard ratio (target/ref) would show low % for good buildings. Inverting (ref/target) makes higher % = better, matching other compliance metrics."
      },
      "compliance": {
        "passCondition": "output >= 100",
        "passSymbol": "✓",
        "failSymbol": "✗",
        "relatedField": "n_117"
      },
      "formula": {
        "symbolic": "m_117 = IF(f_117 > 0, round(ref_f_117 / f_117 * 100), 100)",
        "implementation": "ComplianceNodes.js:236-257"
      },
      "tests": [
        {
          "name": "Target better than reference (lower intensity)",
          "inputs": {
            "mechanical.cooling.intensity": 10,
            "reference.mechanical.cooling.intensity": 15
          },
          "expected": 150,
          "note": "Target uses 33% less cooling energy, so compliance is 150%"
        },
        {
          "name": "Target same as reference",
          "inputs": {
            "mechanical.cooling.intensity": 15,
            "reference.mechanical.cooling.intensity": 15
          },
          "expected": 100
        },
        {
          "name": "Target worse than reference",
          "inputs": {
            "mechanical.cooling.intensity": 20,
            "reference.mechanical.cooling.intensity": 15
          },
          "expected": 75,
          "note": "Target uses 33% more cooling energy, so compliance is only 75%"
        },
        {
          "name": "No target intensity",
          "inputs": {
            "mechanical.cooling.intensity": 0,
            "reference.mechanical.cooling.intensity": 15
          },
          "expected": 100
        }
      ],
      "references": [
        {
          "source": "ComplianceNodes.js:236-257"
        }
      ]
    },
