{
  "nodes": [
    {
      "id": "compliance.hspf.ratio",
      "legacyId": "m_113",
      "label": "HSPF Compliance Ratio",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Ratio of target HSPF to reference HSPF, expressed as percentage. Values >= 100% indicate compliance. HSPF (Heating Seasonal Performance Factor) measures heat pump heating efficiency. Higher HSPF is better."
      },
      "signature": {
        "inputs": [
          {
            "name": "mechanical.heating.hspf",
            "type": "number",
            "unit": "BTU/Wh",
            "description": "Target model HSPF (f_113)"
          },
          {
            "name": "reference.mechanical.heating.hspf",
            "type": "number",
            "unit": "BTU/Wh",
            "description": "Reference model HSPF (ref_f_113), injected via cross-model sync"
          }
        ],
        "output": {
          "type": "number",
          "unit": "percent",
          "format": "integer"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "referenceHSPF > 0",
            "description": "Reference HSPF must be positive for ratio calculation"
          }
        ],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "Percentage cannot be negative"
          }
        ]
      },
      "behavior": [
        {
          "condition": "referenceHSPF > 0",
          "output": "round(targetHSPF / referenceHSPF * 100)",
          "note": "Higher target HSPF = higher compliance percentage"
        },
        {
          "condition": "referenceHSPF == 0",
          "output": "100",
          "note": "Default to 100% (compliant) when no reference value available"
        }
      ],
      "edgeCases": [],
      "architectureNote": "Compliance nodes always compute in the Target model context. Reference values arrive via cross-model sync (reference.* bridge inputs).",
      "compliance": {
        "passCondition": "output >= 100",
        "passSymbol": "✓",
        "failSymbol": "✗",
        "relatedField": "n_113"
      },
      "formula": {
        "symbolic": "m_113 = IF(ref_f_113 > 0, round(f_113 / ref_f_113 * 100), 100)",
        "implementation": "ComplianceNodes.js:122-143"
      },
      "tests": [
        {
          "name": "Target exceeds reference (compliant)",
          "inputs": {
            "mechanical.heating.hspf": 14.0,
            "reference.mechanical.heating.hspf": 12.5
          },
          "expected": 112
        },
        {
          "name": "Target equals reference",
          "inputs": {
            "mechanical.heating.hspf": 12.5,
            "reference.mechanical.heating.hspf": 12.5
          },
          "expected": 100
        },
        {
          "name": "No reference value available",
          "inputs": {
            "mechanical.heating.hspf": 14.0,
            "reference.mechanical.heating.hspf": 0
          },
          "expected": 100
        }
      ],
      "references": [
        {
          "source": "ComplianceNodes.js:122-143"
        }
      ]
    },
    {
