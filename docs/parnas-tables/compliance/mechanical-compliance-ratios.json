      "label": "HSPF Compliance Status",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Pass/fail indicator for HSPF compliance. Shows checkmark if ratio >= 100%, cross otherwise."
      },
      "signature": {
        "inputs": [
          {
