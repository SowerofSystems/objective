      },
      "tests": [
        {
          "name": "Passing (ratio = 112)",
          "inputs": { "compliance.hspf.ratio": 112 },
          "expected": "✓"
        },
        {
          "name": "Exactly 100 passes",
          "inputs": { "compliance.hspf.ratio": 100 },
          "expected": "✓"
        },
        {
          "name": "Failing (ratio = 90)",
          "inputs": { "compliance.hspf.ratio": 90 },
          "expected": "✗"
        }
      ],
      "references": [
        {
          "source": "ComplianceNodes.js:144-155"
        }
      ]
    },
