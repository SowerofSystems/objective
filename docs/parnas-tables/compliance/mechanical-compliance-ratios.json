            "description": "HSPF compliance ratio (m_113)"
          }
        ],
        "output": {
          "type": "string",
          "values": ["✓", "✗"]
        }
      },
      "domain": {
        "invariants": [
          {
            "condition": "output in ['✓', '✗']",
            "description": "Only two possible output values"
          }
        ]
      },
      "behavior": [
        {
          "condition": "ratio >= 100",
          "output": "✓"
        },
        {
          "condition": "ratio < 100",
          "output": "✗"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "n_113 = IF(m_113 >= 100, '✓', '✗')",
