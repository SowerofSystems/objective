{
  "nodes": [
    {
      "id": "compliance.sre.ratio",
      "legacyId": "m_118",
      "label": "SRE Compliance Ratio",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Ratio of target SRE (Sensible Recovery Efficiency) to reference SRE, expressed as percentage. Higher SRE means better heat recovery from ventilation exhaust. Values >= 100% indicate compliance."
      },
      "signature": {
        "inputs": [
          {
            "name": "mechanical.ventilation.efficiency",
            "type": "number",
            "unit": "%",
            "description": "Target model SRE (d_118)"
          },
          {
            "name": "reference.mechanical.ventilation.efficiency",
            "type": "number",
            "unit": "%",
            "description": "Reference model SRE (ref_d_118), injected via cross-model sync"
          }
        ],
        "output": {
          "type": "number",
          "unit": "percent",
          "format": "integer"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "referenceSRE > 0",
            "description": "Reference SRE must be positive for ratio calculation"
          }
        ],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "Percentage cannot be negative"
          }
        ]
      },
      "behavior": [
        {
          "condition": "referenceSRE > 0",
          "output": "round(targetSRE / referenceSRE * 100)",
          "note": "Higher target SRE = higher compliance percentage"
        },
        {
          "condition": "referenceSRE == 0",
          "output": "100",
          "note": "Default to 100% when no reference value available"
        }
      ],
      "edgeCases": [],
      "architectureNote": "Compliance nodes always compute in the Target model context. Reference values arrive via cross-model sync (reference.* bridge inputs).",
      "compliance": {
        "passCondition": "output >= 100",
        "passSymbol": "✓",
        "failSymbol": "✗",
        "relatedField": "n_118"
      },
      "formula": {
        "symbolic": "m_118 = IF(ref_d_118 > 0, round(d_118 / ref_d_118 * 100), 100)",
        "implementation": "ComplianceNodes.js:274-294"
      },
      "tests": [
        {
          "name": "Target exceeds reference",
          "inputs": {
            "mechanical.ventilation.efficiency": 75,
            "reference.mechanical.ventilation.efficiency": 55
          },
          "expected": 136
        },
        {
          "name": "Target equals reference",
          "inputs": {
            "mechanical.ventilation.efficiency": 55,
            "reference.mechanical.ventilation.efficiency": 55
          },
          "expected": 100
        },
        {
          "name": "No reference value available",
          "inputs": {
            "mechanical.ventilation.efficiency": 75,
            "reference.mechanical.ventilation.efficiency": 0
          },
          "expected": 100
        }
      ],
      "references": [
        {
          "source": "ComplianceNodes.js:274-294"
        }
      ]
    },
    {
      "id": "compliance.sre.pass",
      "legacyId": "n_118",
      "label": "SRE Compliance Status",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Pass/fail indicator for SRE compliance. Shows checkmark if ratio >= 100%, cross otherwise."
      },
      "signature": {
        "inputs": [
          {
            "name": "compliance.sre.ratio",
            "type": "number",
            "unit": "percent",
            "description": "SRE compliance ratio (m_118)"
          }
        ],
        "output": {
          "type": "string",
          "values": ["✓", "✗"]
        }
      },
      "domain": {
        "invariants": [
          {
            "condition": "output in ['✓', '✗']",
            "description": "Only two possible output values"
          }
        ]
      },
      "behavior": [
        {
          "condition": "ratio >= 100",
          "output": "✓"
        },
        {
          "condition": "ratio < 100",
          "output": "✗"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "n_118 = IF(m_118 >= 100, '✓', '✗')",
        "implementation": "ComplianceNodes.js:295-306"
      },
      "tests": [
        {
          "name": "Passing (ratio = 136)",
          "inputs": { "compliance.sre.ratio": 136 },
          "expected": "✓"
        },
        {
          "name": "Failing (ratio = 80)",
          "inputs": { "compliance.sre.ratio": 80 },
          "expected": "✗"
        }
      ],
      "references": [
        {
          "source": "ComplianceNodes.js:295-306"
        }
      ]
    },
    {
