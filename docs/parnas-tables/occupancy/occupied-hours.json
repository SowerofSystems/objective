{
  "id": "occupancy.occupiedHours",
  "legacyId": "i_63",
  "label": "Occupied Hours per Year",
  "section": "S09",
  "classification": "C",
  "_meta": {
    "description": "Annual occupied hours calculated from daily hours. Used for per-capita energy calculations."
  },
  "signature": {
    "inputs": [
      { "name": "occupancy.occupiedHoursPerDay", "type": "number", "unit": "hours/day", "description": "Daily occupied hours (g_63), default 12" }
    ],
    "output": { "type": "number", "unit": "hours/yr" }
  },
  "domain": {
    "preconditions": [],
    "invariants": [{ "condition": "output > 0", "description": "Always positive" }]
  },
  "behavior": [
    { "condition": "always", "output": "dailyHours × 365", "note": "Simple annualization" }
  ],
  "edgeCases": [
    { "condition": "dailyHours is NaN", "handling": "Defaults to 12", "rationale": "parseFloat fallback" }
  ],
  "formula": {
    "symbolic": "i_63 = g_63 × 365",
    "implementation": "OccupancyNodes.js:24-35"
  },
  "tests": [
    { "name": "Default 12 hours", "inputs": { "occupancy.occupiedHoursPerDay": 12 }, "expected": 4380 },
    { "name": "24 hours", "inputs": { "occupancy.occupiedHoursPerDay": 24 }, "expected": 8760 }
  ]
}
