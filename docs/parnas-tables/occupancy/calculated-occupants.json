{
  "id": "occupancy.calculatedOccupants",
  "label": "Calculated Occupants",
  "section": "S09",
  "classification": "C",
  "_meta": {
    "description": "Number of occupants derived from floor area and occupant density. Uses CEIL to round up."
  },
  "signature": {
    "inputs": [
      { "name": "building.conditionedFloorArea", "type": "number", "unit": "m²", "description": "CFA (h_15)" },
      { "name": "occupancy.occupantDensity", "type": "number", "unit": "m²/person", "description": "Occupant density (h_63), default 35" }
    ],
    "output": { "type": "integer", "unit": "persons" }
  },
  "domain": {
    "preconditions": [],
    "invariants": [{ "condition": "output >= 1", "description": "At least 1 occupant" }]
  },
  "behavior": [
    { "condition": "density > 0", "output": "CEIL(area / density)", "note": "Round up to whole person" },
    { "condition": "density <= 0", "output": "1", "note": "Fallback to 1 occupant" }
  ],
  "edgeCases": [
    { "condition": "area = 0", "handling": "Returns CEIL(0/35) = 0 → actually 1 from density guard", "rationale": "Prevents zero occupants" }
  ],
  "formula": {
    "symbolic": "occupants = CEIL(h_15 / h_63)",
    "implementation": "OccupancyNodes.js:38-49"
  },
  "tests": [
    { "name": "Typical house", "inputs": { "building.conditionedFloorArea": 200, "occupancy.occupantDensity": 35 }, "expected": 6 },
    { "name": "Large building", "inputs": { "building.conditionedFloorArea": 1427.2, "occupancy.occupantDensity": 35 }, "expected": 41 }
  ]
}
