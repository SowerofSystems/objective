  "section": "S10",
  "signature": {
    "inputs": "These ARE the inputs (registered via graph.registerInput in RadiantGainsNodes.js)",
    "output": "Values stored in MultiModelState, consumed by directional gain, total solar gain, utilized gain, and WWR calculations"
  },
  "domain": {
    "preconditions": [
      {
        "condition": "SHGC in [0, 1]",
        "description": "Solar heat gain coefficient is a ratio from 0 (opaque) to 1 (fully transparent)"
      },
      {
        "condition": "Window areas >= 0",
        "description": "Window areas cannot be negative"
      },
      {
        "condition": "Shading factors in [0, 1]",
        "description": "1 = no shading, 0 = fully shaded"
      },
      {
        "condition": "Utilization factors in [0, 1]",
        "description": "Fraction of solar gains usefully captured"
      },
      {
        "condition": "heatingSeasonFraction + coolingSeasonFraction = 1",
        "description": "Season fractions should sum to 1"
      }
    ],
    "invariants": []
  },
  "behavior": [
    {
      "condition": "SHGC or window area or radiation or shading changes",
      "output": "Triggers recomputation of directional gain (k_71-k_74), total solar gain (k_75), season gains (l_75_calc, n_75_calc)",
      "note": "Directional gain = SHGC × area × radiation × shading"
    },
    {
      "condition": "Utilization factors change",
      "output": "Triggers recomputation of heating/cooling utilized gains (l_76, n_76)",
      "note": "Utilized = sum(directional × utilization) × seasonFraction"
    },
    {
      "condition": "Season fractions change",
      "output": "Triggers recomputation of heating/cooling season gains and utilized gains",
      "note": "G-classified, affects all models"
    },
    {
      "condition": "Window-to-wall ratio override (g_79) changes",
      "output": "Triggers recomputation of effective WWR (g_79_eff)",
      "note": "If 0, falls back to computed WWR from window areas / wall area"
    }
  ],
  "edgeCases": [
    {
      "condition": "All window areas are 0",
      "handling": "All solar gains = 0, computed WWR = 0",
      "rationale": "Building has no glazing"
    },
    {
      "condition": "WWR override = 0",
      "handling": "Uses computed WWR from directional window areas / gross wall area",
      "rationale": "0 is sentinel for 'not overridden'"
    }
  ],
