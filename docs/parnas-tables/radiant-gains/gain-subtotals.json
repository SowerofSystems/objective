{
  "_meta": {
    "description": "Sum of all orientation-row solar gains for heating and cooling seasons. Simple accumulator nodes that sum rows 73-78.",
    "instances": [
      {
        "id": "radiantGains.subtotal.heatingGain",
        "legacyId": "i_79",
        "label": "Total Solar Heating Gain"
      },
      {
        "id": "radiantGains.subtotal.coolingGain",
        "legacyId": "k_79",
        "label": "Total Solar Cooling Gain"
      }
    ]
  },
  "section": "S10",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.row{73..78}.heatingGain (or .coolingGain)",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Individual orientation heating/cooling gains (i_{73..78} or k_{73..78})"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Sum of non-negative values is non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "heatingGain subtotal",
      "output": "SUM(i_73, i_74, i_75, i_76, i_77, i_78)",
      "note": "Sum of all 6 orientation heating gains"
    },
    {
      "condition": "coolingGain subtotal",
      "output": "SUM(k_73, k_74, k_75, k_76, k_77, k_78)",
      "note": "Sum of all 6 orientation cooling gains"
    }
  ],
  "edgeCases": [
    {
      "condition": "all individual gains are 0",
      "handling": "Return 0",
      "rationale": "No glazing or fully shaded in all orientations"
    }
  ],
  "formula": {
    "symbolic": "i_79 = SUM(i_73:i_78); k_79 = SUM(k_73:k_78)",
    "implementation": "RadiantGainsNodes.js:165-191",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "Sum of mixed gains",
      "inputs": {
        "radiantGains.row73.heatingGain": 100,
        "radiantGains.row74.heatingGain": 50,
        "radiantGains.row75.heatingGain": 200,
        "radiantGains.row76.heatingGain": 500,
        "radiantGains.row77.heatingGain": 150,
        "radiantGains.row78.heatingGain": 0
      },
      "expected": 1000
    },
    {
      "name": "All zero",
      "inputs": {
        "radiantGains.row73.heatingGain": 0,
        "radiantGains.row74.heatingGain": 0,
        "radiantGains.row75.heatingGain": 0,
        "radiantGains.row76.heatingGain": 0,
        "radiantGains.row77.heatingGain": 0,
        "radiantGains.row78.heatingGain": 0
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:165-191"
    }
  ]
}
