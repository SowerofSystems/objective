{
  "id": "radiantGains.unusableGains",
  "legacyId": "i_82",
  "label": "Unusable Gains",
  "section": "S10",
  "classification": "C",
  "_meta": {
    "description": "Portion of total gains that cannot be utilized to offset heating demand. This is the complement of usable gains - it represents heat that is generated but dissipated without benefit (e.g., overheating during mild periods). Displayed on row 82."
  },
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.totalGains",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total gains - solar + internal (e_80)"
      },
      {
        "name": "radiantGains.usableGains",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Usable gains (i_80)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Unusable gains are non-negative (usable <= total)"
      },
      {
        "condition": "output = totalGains - usableGains",
        "description": "Complementary to usable gains"
      }
    ]
  },
  "behavior": [
    {
      "condition": "always",
      "output": "totalGains - usableGains",
      "note": "Simple difference"
    }
  ],
  "formula": {
    "symbolic": "i_82 = e_80 - i_80",
    "implementation": "RadiantGainsNodes.js:456-468",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "40% utilization leaves 60% unusable",
      "inputs": {
        "radiantGains.totalGains": 5000,
        "radiantGains.usableGains": 2000
      },
      "expected": 3000
    },
    {
      "name": "100% utilization leaves 0 unusable",
      "inputs": {
        "radiantGains.totalGains": 5000,
        "radiantGains.usableGains": 5000
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:456-468"
    }
  ]
}
