{
  "_meta": {
    "description": "PHPP reference display values on row 81. e_81 echoes total gains from e_80; g_81 always computes the PHPP utilization factor using the gamma formula regardless of the user-selected method. These serve as a reference comparison line in the UI.",
    "instances": [
      {
        "id": "radiantGains.phppTotalGains",
        "legacyId": "e_81",
        "label": "PHPP Total Gains (echo)"
      },
      {
        "id": "radiantGains.phppUtilizationFactor",
        "legacyId": "g_81",
        "label": "PHPP Utilization Factor"
      }
    ]
  },
  "section": "S10",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.totalGains",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total gains (e_80) - for e_81 passthrough and g_81 gamma numerator"
      },
      {
        "name": "transmissionLoss.thermalBridgePenalty.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Thermal bridge penalty heat loss (i_97) - for g_81 only"
      },
      {
        "name": "airTightness.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Air tightness heat loss (i_103) - for g_81 only"
      },
      {
        "name": "ventilation.netHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Ventilation net heat loss (m_121) - for g_81 only"
      },
      {
        "name": "transmissionLoss.components.subtotalHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Transmission loss components subtotal (i_98) - for g_81 only"
      }
    ],
    "output": {
      "type": "number",
      "description": "e_81: kWh/yr (echo of e_80), g_81: ratio 0-1 (PHPP utilization factor)"
    }
  },
  "behavior": [
    {
      "condition": "e_81 (phppTotalGains)",
      "output": "totalGains",
      "note": "Direct passthrough of e_80"
    },
    {
      "condition": "g_81 with denominator > 0 and gamma != 1",
      "output": "(1 - gamma^5) / (1 - gamma^6), clamped to [0, 1]",
      "note": "Standard PHPP gamma formula"
    },
    {
      "condition": "g_81 with gamma == 1",
      "output": "5/6",
      "note": "L'Hopital limit"
    },
    {
      "condition": "g_81 with denominator == 0",
      "output": "1 if gains > 0, else 0",
      "note": "Degenerate case with no losses"
    }
  ],
  "formula": {
    "symbolic": "e_81 = e_80; g_81 = PHPP_FACTOR(e_80 / (i_97 + i_103 + m_121 + i_98))",
    "implementation": "RadiantGainsNodes.js:411-453",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "e_81 echoes total gains",
      "inputs": {
        "radiantGains.totalGains": 5000
      },
      "expected": 5000
    },
    {
      "name": "g_81 with gamma = 0.5",
      "inputs": {
        "radiantGains.totalGains": 5000,
        "transmissionLoss.thermalBridgePenalty.heatLoss": 3000,
        "airTightness.heatLoss": 3000,
        "ventilation.netHeatLoss": 2000,
        "transmissionLoss.components.subtotalHeatLoss": 2000
      },
      "expected": 0.9999,
      "note": "gamma=0.5, factor very close to 1.0"
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:411-453"
    }
  ]
}
