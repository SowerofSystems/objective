  "section": "S10",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.row{N}.heatingGain (or .coolingGain)",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Individual orientation gain"
      },
      {
        "name": "radiantGains.subtotal.heatingGain (or .coolingGain)",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total of all orientation gains"
      }
    ],
    "output": {
      "type": "number",
      "unit": "ratio (0-1)",
      "precision": 4
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "0 <= output <= 1",
        "description": "Percentage is between 0 and 1 inclusive"
      },
      {
        "condition": "SUM(all percentages for a season) = 1 when total > 0",
        "description": "Percentages sum to 100% when there are gains"
      }
    ]
  },
  "behavior": [
    {
      "condition": "total > 0",
      "output": "gain / total",
      "note": "Simple ratio of individual to total"
    },
    {
      "condition": "total == 0",
      "output": "0",
      "note": "Avoid division by zero"
    }
  ],
  "edgeCases": [
    {
      "condition": "total is 0 (no glazing or fully shaded)",
      "handling": "Return 0",
      "rationale": "No meaningful percentage when there are no gains"
    }
  ],
  "formula": {
    "symbolic": "j_{N} = i_{N} / i_79; l_{N} = k_{N} / k_79",
    "implementation": "RadiantGainsNodes.js:196-224",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "South dominates heating",
      "inputs": {
        "radiantGains.row76.heatingGain": 800,
        "radiantGains.subtotal.heatingGain": 1000
      },
      "expected": 0.8
    },
    {
      "name": "Zero total returns 0",
      "inputs": {
        "radiantGains.row74.heatingGain": 0,
        "radiantGains.subtotal.heatingGain": 0
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:196-224"
    }
  ]
}
