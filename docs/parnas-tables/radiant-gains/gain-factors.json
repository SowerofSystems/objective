{
  "_meta": {
    "description": "Solar gain factor by orientation and climate zone. Uses lookup table with northern (zone > 6) and southern (zone <= 6) factor sets. Normalizes orientation string to table key; falls back to 'Average' if unrecognized.",
    "instances": [
      {
        "id": "radiantGains.row73.gainFactor",
        "legacyId": "m_73",
        "label": "Average/Doors Gain Factor"
      },
      {
        "id": "radiantGains.row74.gainFactor",
        "legacyId": "m_74",
        "label": "North Gain Factor"
      },
      {
        "id": "radiantGains.row75.gainFactor",
        "legacyId": "m_75",
        "label": "East Gain Factor"
      },
      {
        "id": "radiantGains.row76.gainFactor",
        "legacyId": "m_76",
        "label": "South Gain Factor"
      },
      {
        "id": "radiantGains.row77.gainFactor",
        "legacyId": "m_77",
        "label": "West Gain Factor"
      },
      {
        "id": "radiantGains.row78.gainFactor",
        "legacyId": "m_78",
        "label": "Skylight Gain Factor"
      }
    ]
  },
  "section": "S10",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.row{N}.orientation",
        "type": "string",
        "description": "Glazing orientation (e_{N}) - one of: North, NorthEast, East, SouthEast, South, SouthWest, West, NorthWest, Average, Skylight"
      },
      {
        "name": "climate.zone",
        "type": "number",
        "description": "Climate zone number - determines northern (>6) vs southern (<=6) factor table"
      }
    ],
    "output": {
      "type": "number",
      "unit": "dimensionless",
      "precision": 2
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "climate.zone is not 'Unavailable' or 'N/A'",
        "description": "Climate zone must be resolved before gain factors can be computed"
      }
    ],
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Gain factors are non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "climateZone > 6 (northern)",
      "output": "GAIN_FACTORS.northern[orientation]",
      "note": "Northern table: North=0.19, NE=0.89, E=2.09, SE=6.01, S=24.76, SW=82.25, W=64.37, NW=18.14, Average=24.84, Skylight=25.0"
    },
    {
      "condition": "climateZone <= 6 (southern)",
      "output": "GAIN_FACTORS.southern[orientation]",
      "note": "Southern table: North=1.31, NE=34.69, E=76.94, SE=86.59, S=70.74, SW=60.4, W=25.86, NW=2.88, Average=50.0, Skylight=75.0"
    }
  ],
  "edgeCases": [
    {
      "condition": "climate.zone is 'Unavailable' or 'N/A'",
      "handling": "Return 'Unavailable'",
      "rationale": "Cannot determine factor table without climate zone"
    },
    {
      "condition": "orientation not in lookup table",
      "handling": "Falls back to 'Average' factor",
      "rationale": "getGainFactor returns factors['Average'] when key not found"
    }
  ],
  "formula": {
    "symbolic": "m_{N} = GAIN_FACTORS[zone > 6 ? 'northern' : 'southern'][orientation]",
    "implementation": "RadiantGainsNodes.js:84-100",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "South-facing in northern climate (zone 7)",
      "inputs": {
        "radiantGains.row76.orientation": "South",
        "climate.zone": 7
      },
      "expected": 24.76
    },
    {
      "name": "South-facing in southern climate (zone 5)",
      "inputs": {
        "radiantGains.row76.orientation": "South",
        "climate.zone": 5
      },
      "expected": 70.74
    },
    {
      "name": "Skylight in northern climate",
      "inputs": {
        "radiantGains.row78.orientation": "Skylight",
        "climate.zone": 7
      },
      "expected": 25.0
    },
    {
      "name": "Unknown orientation falls back to Average",
      "inputs": {
        "radiantGains.row73.orientation": "UnknownDirection",
        "climate.zone": 6
      },
      "expected": 50.0
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:17-28 (GAIN_FACTORS tables)"
    },
    {
      "source": "RadiantGainsNodes.js:84-100"
    }
  ]
}
