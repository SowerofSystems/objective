{
  "id": "radiantGains.phppUsableGains",
  "legacyId": "i_81",
  "label": "PHPP Usable Gains",
  "section": "S10",
  "classification": "C",
  "_meta": {
    "description": "Always-calculated PHPP reference value for usable gains, regardless of the selected utilization method. Applies the PHPP gamma formula (a=5) to total gains and total losses. Displayed on row 81 as a reference comparison to the user-selected method on row 80."
  },
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.totalGains",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total gains - solar + internal (e_80)"
      },
      {
        "name": "transmissionLoss.thermalBridgePenalty.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Thermal bridge penalty heat loss (i_97)"
      },
      {
        "name": "airTightness.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Air tightness heat loss (i_103)"
      },
      {
        "name": "ventilation.netHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Ventilation net heat loss (m_121)"
      },
      {
        "name": "transmissionLoss.components.subtotalHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Transmission loss components subtotal (i_98)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Usable gains are non-negative"
      },
      {
        "condition": "output <= totalGains",
        "description": "PHPP utilization factor is at most 1.0"
      }
    ]
  },
  "behavior": [
    {
      "condition": "totalLosses > 0 and gamma != 1",
      "output": "totalGains * (1 - gamma^5) / (1 - gamma^6)",
      "note": "Standard PHPP formula where gamma = totalGains / totalLosses"
    },
    {
      "condition": "gamma == 1 (within 1e-9)",
      "output": "totalGains * (5/6)",
      "note": "L'Hopital limit case"
    },
    {
      "condition": "totalLosses == 0 and totalGains > 0",
      "output": "totalGains * 1.0",
      "note": "All gains usable when no losses exist"
    },
    {
      "condition": "totalLosses == 0 and totalGains == 0",
      "output": "0",
      "note": "No gains and no losses"
    }
  ],
  "edgeCases": [
    {
      "condition": "default phUtilizationFactor initialized to 0.9",
      "handling": "Overwritten by computed value when denominator > 0",
      "rationale": "The 0.9 default is only used if the code path somehow bypasses all conditions (defensive fallback)"
    }
  ],
  "formula": {
    "symbolic": "i_81 = e_80 * PHPP_FACTOR(e_80, i_97 + i_103 + m_121 + i_98)",
    "implementation": "RadiantGainsNodes.js:350-390",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "Gamma < 1 (gains < losses)",
      "inputs": {
        "radiantGains.totalGains": 5000,
        "transmissionLoss.thermalBridgePenalty.heatLoss": 3000,
        "airTightness.heatLoss": 3000,
        "ventilation.netHeatLoss": 2000,
        "transmissionLoss.components.subtotalHeatLoss": 2000
      },
      "expected": 4999.5,
      "note": "gamma=0.5, factor~0.9999"
    },
    {
      "name": "Zero losses, positive gains",
      "inputs": {
        "radiantGains.totalGains": 5000,
        "transmissionLoss.thermalBridgePenalty.heatLoss": 0,
        "airTightness.heatLoss": 0,
        "ventilation.netHeatLoss": 0,
        "transmissionLoss.components.subtotalHeatLoss": 0
      },
      "expected": 5000
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:350-390"
    },
    {
      "source": "PHPP (Passive House Planning Package)"
    }
  ]
}
