{
  "id": "radiantGains.usableGains",
  "legacyId": "i_80",
  "label": "Usable Gains",
  "section": "S10",
  "classification": "C",
  "_meta": {
    "description": "Total heat gains multiplied by the selected utilization factor. This is the portion of solar + internal gains that offsets heating demand. Directly subtracted from gross heating demand to calculate net heating energy."
  },
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.totalGains",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total gains - solar + internal (e_80)"
      },
      {
        "name": "radiantGains.utilizationFactor",
        "type": "number",
        "unit": "ratio (0-1)",
        "description": "Gains utilization factor (g_80) - default 0.4"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Usable gains are non-negative"
      },
      {
        "condition": "output <= totalGains",
        "description": "Cannot use more gains than exist (factor <= 1)"
      }
    ]
  },
  "behavior": [
    {
      "condition": "always",
      "output": "totalGains * utilizationFactor",
      "note": "Simple product of total gains and utilization factor"
    }
  ],
  "formula": {
    "symbolic": "i_80 = e_80 * g_80",
    "implementation": "RadiantGainsNodes.js:334-346",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "NRC 40% of 5000 kWh",
      "inputs": {
        "radiantGains.totalGains": 5000,
        "radiantGains.utilizationFactor": 0.4
      },
      "expected": 2000
    },
    {
      "name": "100% utilization",
      "inputs": {
        "radiantGains.totalGains": 5000,
        "radiantGains.utilizationFactor": 1.0
      },
      "expected": 5000
    },
    {
      "name": "Zero gains",
      "inputs": {
        "radiantGains.totalGains": 0,
        "radiantGains.utilizationFactor": 0.4
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:334-346"
    }
  ]
}
