{
  "id": "radiantGains.usableGainsPerArea",
  "label": "Usable Gains Intensity",
  "section": "S10",
  "classification": "C",
  "_meta": {
    "description": "Usable gains normalized by conditioned floor area. Internal calculation with no legacy spreadsheet equivalent. Used for intensity-based comparisons and benchmarking."
  },
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.usableGains",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Usable gains (i_80)"
      },
      {
        "name": "building.conditionedFloorArea",
        "type": "number",
        "unit": "m2",
        "description": "Conditioned floor area - default 1 to avoid division by zero"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/m2/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Intensity is non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "area > 0",
      "output": "usableGains / area",
      "note": "Simple division"
    },
    {
      "condition": "area <= 0",
      "output": "0",
      "note": "Guard against zero or negative area"
    }
  ],
  "edgeCases": [
    {
      "condition": "area is 0",
      "handling": "Return 0",
      "rationale": "Avoid division by zero; no meaningful intensity without floor area"
    }
  ],
  "formula": {
    "symbolic": "usableGainsPerArea = i_80 / conditionedFloorArea",
    "implementation": "RadiantGainsNodes.js:393-404"
  },
  "tests": [
    {
      "name": "Standard intensity",
      "inputs": {
        "radiantGains.usableGains": 2000,
        "building.conditionedFloorArea": 200
      },
      "expected": 10
    },
    {
      "name": "Zero area returns 0",
      "inputs": {
        "radiantGains.usableGains": 2000,
        "building.conditionedFloorArea": 0
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:393-404"
    }
  ]
}
