{
  "_meta": {
    "description": "Solar heating gain per glazing row. Computed from glazing area, gain factor, SHGC (normalized to 0.5 baseline), and winter shading fraction. One node per orientation row (73-78).",
    "instances": [
      {
        "id": "radiantGains.row73.heatingGain",
        "legacyId": "i_73",
        "label": "Average/Doors Heating Gain"
      },
      {
        "id": "radiantGains.row74.heatingGain",
        "legacyId": "i_74",
        "label": "North Heating Gain"
      },
      {
        "id": "radiantGains.row75.heatingGain",
        "legacyId": "i_75",
        "label": "East Heating Gain"
      },
      {
        "id": "radiantGains.row76.heatingGain",
        "legacyId": "i_76",
        "label": "South Heating Gain"
      },
      {
        "id": "radiantGains.row77.heatingGain",
        "legacyId": "i_77",
        "label": "West Heating Gain"
      },
      {
        "id": "radiantGains.row78.heatingGain",
        "legacyId": "i_78",
        "label": "Skylight Heating Gain"
      }
    ]
  },
  "section": "S10",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.row{N}.area",
        "type": "number",
        "unit": "m2",
        "description": "Glazing area for this orientation (d_{N})"
      },
      {
        "name": "radiantGains.row{N}.gainFactor",
        "type": "number",
        "description": "Gain factor from climate/orientation lookup (m_{N})"
      },
      {
        "name": "radiantGains.row{N}.shgc",
        "type": "number",
        "description": "Solar Heat Gain Coefficient (f_{N}) - default 0.35"
      },
      {
        "name": "radiantGains.row{N}.winterShading",
        "type": "number",
        "unit": "%",
        "description": "Winter shading percentage (g_{N}) - default 0"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Heating gains are non-negative (all factors are non-negative, shading <= 100%)"
      }
    ]
  },
  "behavior": [
    {
      "condition": "always",
      "output": "area * gainFactor * (shgc / 0.5) * (1 - winterShading / 100)",
      "note": "SHGC is normalized to 0.5 baseline. Winter shading reduces gain proportionally."
    }
  ],
  "edgeCases": [
    {
      "condition": "area is 0 or not provided",
      "handling": "Return 0",
      "rationale": "parseNum defaults to 0, so 0 * anything = 0"
    },
    {
      "condition": "winterShading is 100%",
      "handling": "Return 0",
      "rationale": "(1 - 1.0) = 0, fully shaded window contributes no heating gain"
    }
  ],
  "formula": {
    "symbolic": "i_{N} = d_{N} * m_{N} * (f_{N} / 0.5) * (1 - g_{N} / 100)",
    "implementation": "RadiantGainsNodes.js:105-128",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "Standard south-facing window",
      "inputs": {
        "radiantGains.row76.area": 10,
        "radiantGains.row76.gainFactor": 24.76,
        "radiantGains.row76.shgc": 0.35,
        "radiantGains.row76.winterShading": 0
      },
      "expected": 173.32
    },
    {
      "name": "50% winter shading halves gain",
      "inputs": {
        "radiantGains.row76.area": 10,
        "radiantGains.row76.gainFactor": 24.76,
        "radiantGains.row76.shgc": 0.35,
        "radiantGains.row76.winterShading": 50
      },
      "expected": 86.66
    },
    {
      "name": "Zero area yields zero",
      "inputs": {
        "radiantGains.row74.area": 0,
        "radiantGains.row74.gainFactor": 0.19,
        "radiantGains.row74.shgc": 0.35,
        "radiantGains.row74.winterShading": 0
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:105-128"
    }
  ]
}
