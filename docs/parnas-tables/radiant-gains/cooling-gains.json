{
  "_meta": {
    "description": "Solar cooling gain per glazing row. Same structure as heating gains but uses summer shading and a cooling modifier (0.5 for windows, 1.25 for skylights) to account for sun angle differences between seasons.",
    "instances": [
      {
        "id": "radiantGains.row73.coolingGain",
        "legacyId": "k_73",
        "label": "Average/Doors Cooling Gain"
      },
      {
        "id": "radiantGains.row74.coolingGain",
        "legacyId": "k_74",
        "label": "North Cooling Gain"
      },
      {
        "id": "radiantGains.row75.coolingGain",
        "legacyId": "k_75",
        "label": "East Cooling Gain"
      },
      {
        "id": "radiantGains.row76.coolingGain",
        "legacyId": "k_76",
        "label": "South Cooling Gain"
      },
      {
        "id": "radiantGains.row77.coolingGain",
        "legacyId": "k_77",
        "label": "West Cooling Gain"
      },
      {
        "id": "radiantGains.row78.coolingGain",
        "legacyId": "k_78",
        "label": "Skylight Cooling Gain"
      }
    ]
  },
  "section": "S10",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.row{N}.area",
        "type": "number",
        "unit": "m2",
        "description": "Glazing area for this orientation (d_{N})"
      },
      {
        "name": "radiantGains.row{N}.gainFactor",
        "type": "number",
        "description": "Gain factor from climate/orientation lookup (m_{N}) - same factor as heating"
      },
      {
        "name": "radiantGains.row{N}.shgc",
        "type": "number",
        "description": "Solar Heat Gain Coefficient (f_{N}) - default 0.35"
      },
      {
        "name": "radiantGains.row{N}.summerShading",
        "type": "number",
        "unit": "%",
        "description": "Summer shading percentage (h_{N}) - default 0"
      },
      {
        "name": "radiantGains.row{N}.orientation",
        "type": "string",
        "description": "Orientation (e_{N}) - used only to determine cooling modifier (Skylight vs other)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Cooling gains are non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "orientation == 'Skylight'",
      "output": "area * gainFactor * (shgc / 0.5) * (1 - summerShading / 100) * 1.25",
      "note": "Skylights get 1.25x modifier (higher sun angle in cooling season increases overhead solar exposure)"
    },
    {
      "condition": "orientation != 'Skylight'",
      "output": "area * gainFactor * (shgc / 0.5) * (1 - summerShading / 100) * 0.5",
      "note": "Vertical windows get 0.5x modifier (higher sun angle in cooling season reduces vertical wall exposure)"
    }
  ],
  "edgeCases": [
    {
      "condition": "area is 0",
      "handling": "Return 0",
      "rationale": "No glazing area means no gain"
    },
    {
      "condition": "summerShading is 100%",
      "handling": "Return 0",
      "rationale": "Fully shaded window contributes no cooling load"
    }
  ],
  "formula": {
    "symbolic": "k_{N} = d_{N} * m_{N} * (f_{N} / 0.5) * (1 - h_{N} / 100) * coolingModifier",
    "implementation": "RadiantGainsNodes.js:133-160",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "South-facing window (0.5x modifier)",
      "inputs": {
        "radiantGains.row76.area": 10,
        "radiantGains.row76.gainFactor": 24.76,
        "radiantGains.row76.shgc": 0.35,
        "radiantGains.row76.summerShading": 0,
        "radiantGains.row76.orientation": "South"
      },
      "expected": 86.66
    },
    {
      "name": "Skylight (1.25x modifier)",
      "inputs": {
        "radiantGains.row78.area": 10,
        "radiantGains.row78.gainFactor": 25.0,
        "radiantGains.row78.shgc": 0.35,
        "radiantGains.row78.summerShading": 0,
        "radiantGains.row78.orientation": "Skylight"
      },
      "expected": 218.75
    },
    {
      "name": "Full summer shading",
      "inputs": {
        "radiantGains.row75.area": 10,
        "radiantGains.row75.gainFactor": 2.09,
        "radiantGains.row75.shgc": 0.35,
        "radiantGains.row75.summerShading": 100,
        "radiantGains.row75.orientation": "East"
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:133-160"
    }
  ]
}
