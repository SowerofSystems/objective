{
  "_meta": {
    "description": "Boolean indicators (0 or 1) for whether any solar gains exist in the heating or cooling subtotals. Used downstream to gate further calculations.",
    "instances": [
      {
        "id": "radiantGains.subtotal.heatingIndicator",
        "legacyId": "j_79",
        "label": "Heating Gains Indicator"
      },
      {
        "id": "radiantGains.subtotal.coolingIndicator",
        "legacyId": "l_79",
        "label": "Cooling Gains Indicator"
      }
    ]
  },
  "section": "S10",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.subtotal.heatingGain (or .coolingGain)",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total solar gain subtotal for the season"
      }
    ],
    "output": {
      "type": "number",
      "unit": "boolean (0 or 1)",
      "precision": 0
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output in [0, 1]",
        "description": "Output is strictly 0 or 1"
      }
    ]
  },
  "behavior": [
    {
      "condition": "total > 0",
      "output": "1",
      "note": "There are solar gains for this season"
    },
    {
      "condition": "total <= 0",
      "output": "0",
      "note": "No solar gains for this season"
    }
  ],
  "formula": {
    "symbolic": "j_79 = i_79 > 0 ? 1 : 0; l_79 = k_79 > 0 ? 1 : 0",
    "implementation": "RadiantGainsNodes.js:227-252",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "Positive gains",
      "inputs": {
        "radiantGains.subtotal.heatingGain": 500
      },
      "expected": 1
    },
    {
      "name": "Zero gains",
      "inputs": {
        "radiantGains.subtotal.heatingGain": 0
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:227-252"
    }
  ]
}
