{
  "id": "radiantGains.totalGains",
  "legacyId": "e_80",
  "label": "Total Gains (Solar + Internal)",
  "section": "S10",
  "classification": "C",
  "_meta": {
    "description": "Combined total of solar heating gains and internal heating gains. This is the numerator input for the PHPP utilization factor gamma calculation. Solar gains come from glazing; internal gains come from occupants, plug loads, lighting, equipment, and DHW losses."
  },
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.subtotal.heatingGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total solar heating gain (i_79) - sum of all orientation rows"
      },
      {
        "name": "internal.heatingGains",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Internal heating gains (i_71) - from InternalGainsNodes"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Total gains are non-negative (both components are non-negative)"
      }
    ]
  },
  "behavior": [
    {
      "condition": "always",
      "output": "solarGains + internalGains",
      "note": "Simple sum of the two gain sources"
    }
  ],
  "formula": {
    "symbolic": "e_80 = i_79 + i_71",
    "implementation": "RadiantGainsNodes.js:259-271",
    "legacy": "Section10.js"
  },
  "tests": [
    {
      "name": "Both gain sources present",
      "inputs": {
        "radiantGains.subtotal.heatingGain": 3000,
        "internal.heatingGains": 2000
      },
      "expected": 5000
    },
    {
      "name": "No internal gains",
      "inputs": {
        "radiantGains.subtotal.heatingGain": 3000,
        "internal.heatingGains": 0
      },
      "expected": 3000
    }
  ],
  "references": [
    {
      "source": "RadiantGainsNodes.js:259-271"
    }
  ]
}
