{
  "_meta": {
    "description": "Heat loss percentage contribution of each envelope group (air-facing, ground-facing, air leakage) to total envelope heat loss. Includes a checksum node that should sum to 1.0, and the air tightness climate zone classification.",
    "instances": [
      {
        "id": "envelope.airFacing.lossPercent",
        "legacyId": "l_101",
        "label": "Air-Facing Heat Loss %"
      },
      {
        "id": "envelope.groundFacing.lossPercent",
        "legacyId": "l_102",
        "label": "Ground-Facing Heat Loss %"
      },
      {
        "id": "airLeakage.lossPercent",
        "legacyId": "l_103",
        "label": "Air Leakage Heat Loss %"
      },
      {
        "id": "envelope.total.lossPercent",
        "legacyId": "l_104",
        "label": "Total Heat Loss % (checksum)"
      },
      {
        "id": "airTightness.climateZoneNum",
        "legacyId": "i_110",
        "label": "Air Leakage Climate Zone Number"
      }
    ]
  },
  "section": "S12",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "envelope.airFacing.totalHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_101 - Air-facing heat loss"
      },
      {
        "name": "envelope.groundFacing.totalHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_102 - Ground-facing heat loss"
      },
      {
        "name": "airTightness.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_103 - Air leakage heat loss"
      },
      {
        "name": "envelope.total.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_104 - Total envelope heat loss (denominator)"
      },
      {
        "name": "climate.zone",
        "type": "number",
        "description": "Climate zone number (1-8)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "ratio (0-1) or integer (1-3)",
      "precision": 4
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "l_101 + l_102 + l_103 = l_104 approximately 1.0",
        "description": "Percentages should sum to 100% (checksum)"
      },
      {
        "condition": "climateZoneNum in {1, 2, 3}",
        "description": "Climate zone number is always 1, 2, or 3"
      }
    ]
  },
  "behavior": [
    {
      "condition": "l_101 (airFacing.lossPercent)",
      "output": "i_101 / i_104",
      "note": "Air-facing heat loss as fraction of total"
    },
    {
      "condition": "l_102 (groundFacing.lossPercent)",
      "output": "i_102 / i_104",
      "note": "Ground-facing heat loss as fraction of total"
    },
    {
      "condition": "l_103 (airLeakage.lossPercent)",
      "output": "i_103 / i_104",
      "note": "Air leakage heat loss as fraction of total"
    },
    {
      "condition": "l_104 (total.lossPercent)",
      "output": "l_101 + l_102 + l_103",
      "note": "Sum of all three percentages (should equal 1.0)"
    },
    {
      "condition": "i_110 (climateZoneNum) when cz <= 4",
      "output": "1",
      "note": "Climate zones 1-4 map to zone number 1"
    },
    {
      "condition": "i_110 (climateZoneNum) when 4 < cz < 7",
      "output": "2",
      "note": "Climate zones 5-6 map to zone number 2"
    },
    {
      "condition": "i_110 (climateZoneNum) when cz >= 7",
      "output": "3",
      "note": "Climate zones 7-8 map to zone number 3"
    }
  ],
  "edgeCases": [
    {
      "condition": "total heat loss is 0",
      "handling": "All percentages return 0",
      "rationale": "Avoid division by zero"
    }
  ],
  "formula": {
    "symbolic": "l_{row} = i_{row} / i_104; i_110 = cz<=4 ? 1 : cz<7 ? 2 : 3",
    "implementation": "VolumeMetricsNodes.js:769-823",
    "legacy": "Section12.js"
  },
  "tests": [
    {
      "name": "Standard loss percentages",
      "inputs": {
        "envelope.airFacing.totalHeatLoss": 5530,
        "envelope.groundFacing.totalHeatLoss": 2420,
        "airTightness.heatLoss": 800,
        "envelope.total.heatLoss": 8750
      },
      "expected": {
        "l_101": 0.632,
        "l_102": 0.2766,
        "l_103": 0.0914,
        "l_104": 1.0
      }
    },
    {
      "name": "Climate zone 5 maps to zone number 2",
      "inputs": {
        "climate.zone": 5
      },
      "expected": {
        "i_110": 2
      }
    },
    {
      "name": "Climate zone 7 maps to zone number 3",
      "inputs": {
        "climate.zone": 7
      },
      "expected": {
        "i_110": 3
      }
    },
    {
      "name": "Zero total returns 0",
      "inputs": {
        "envelope.airFacing.totalHeatLoss": 0,
        "envelope.total.heatLoss": 0
      },
      "expected": {
        "l_101": 0
      }
    }
  ],
  "references": [
    {
      "source": "VolumeMetricsNodes.js:769-823 (loss percentages)"
    },
    {
      "source": "VolumeMetricsNodes.js:753-766 (climate zone number)"
    }
  ]
}
