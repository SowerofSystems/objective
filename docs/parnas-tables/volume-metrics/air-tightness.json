{
  "_meta": {
    "description": "Air tightness calculations including NRL50 (normalized leakage rate at 50Pa), ACH50 target, N-factor, ELA10, and air leakage heat loss/gain. NRL50 calculation varies by method: measured, Passive House presets, or standard air leakage class presets.",
    "instances": [
      {
        "id": "airTightness.nrl50",
        "legacyId": "g_108",
        "label": "NRL50 Target (L/s per m2)"
      },
      {
        "id": "airTightness.ach50Target",
        "legacyId": "d_109",
        "label": "ACH50 Target"
      },
      {
        "id": "airTightness.nFactor",
        "legacyId": "g_110",
        "label": "N-Factor"
      },
      {
        "id": "airTightness.ela10",
        "legacyId": "d_110",
        "label": "Equivalent Leakage Area at 10 Pa"
      },
      {
        "id": "airTightness.heatLoss",
        "legacyId": "i_103",
        "label": "Air Leakage Heat Loss"
      },
      {
        "id": "airTightness.heatGain",
        "legacyId": "k_103",
        "label": "Air Leakage Heat Gain"
      }
    ]
  },
  "section": "S12",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "airTightness.method",
        "type": "string",
        "description": "d_108 - Air tightness method: MEASURED, PH_CLASSIC, PH_LOW, PH_PLUS, AL-1A..AL-4B"
      },
      {
        "name": "airTightness.measuredAch50",
        "type": "number",
        "description": "g_109 - Measured ACH50 value (only used when method=MEASURED)"
      },
      {
        "name": "volume.conditioned",
        "type": "number",
        "unit": "m3",
        "description": "d_105 - Conditioned volume"
      },
      {
        "name": "envelope.airFacing.area",
        "type": "number",
        "unit": "m2",
        "description": "d_101 - Air-facing envelope area"
      },
      {
        "name": "climate.zone",
        "type": "number",
        "description": "Climate zone number (1-8)"
      },
      {
        "name": "airTightness.shielding",
        "type": "string",
        "description": "g_103 - Shielding condition: Shielded, Normal, Exposed"
      },
      {
        "name": "volume.numStoreys",
        "type": "number",
        "description": "d_103 - Number of storeys"
      },
      {
        "name": "climate.heating.degreedays",
        "type": "number",
        "unit": "degree-days",
        "description": "HDD for heat loss calculation"
      },
      {
        "name": "climate.cooling.degreedays",
        "type": "number",
        "unit": "degree-days",
        "description": "CDD for heat gain calculation"
      }
    ],
    "output": {
      "type": "number",
      "unit": "varies (L/s/m2, ACH, dimensionless, m2, kWh/yr)",
      "precision": 2
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "volume > 0 and area > 0 for ACH/NRL conversions",
        "description": "Need both volume and area for unit conversions"
      }
    ],
    "invariants": [
      {
        "condition": "NRL50 >= 0",
        "description": "Leakage rate is non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "NRL50 when method=MEASURED",
      "output": "measuredAch50 * volume / (area * 3.6)",
      "note": "Convert ACH50 to NRL50"
    },
    {
      "condition": "NRL50 when method=PH_CLASSIC",
      "output": "0.6 * volume / (area * 3.6)",
      "note": "Passive House Classic target: 0.6 ACH50 converted to NRL50"
    },
    {
      "condition": "NRL50 when method=PH_LOW",
      "output": "1.0 * volume / (area * 3.6)",
      "note": "Passive House Low Energy target: 1.0 ACH50 converted to NRL50"
    },
    {
      "condition": "NRL50 when method=PH_PLUS",
      "output": "0.1",
      "note": "Passive House Plus: fixed NRL50 value"
    },
    {
      "condition": "NRL50 when method=AL-{n}{A|B}",
      "output": "NRL50_PRESETS[method]",
      "note": "Lookup: AL-1A=0.89, AL-2A=0.71, AL-3A=0.53, AL-4A=0.35, AL-1B=1.17, AL-2B=0.94, AL-3B=0.70, AL-4B=0.47"
    },
    {
      "condition": "ACH50 target (d_109)",
      "output": "NRL50 * (area / volume) * 3.6",
      "note": "Reverse conversion from NRL50 to ACH50"
    },
    {
      "condition": "N-Factor (g_110)",
      "output": "N_FACTOR_TABLE[zoneNum][shielding][storyKey]",
      "note": "Zone: cz<=4 -> 1, cz<=6 -> 2, cz>=7 -> 3. Story key snapped to 1/1.5/2/3/4/5/6"
    },
    {
      "condition": "ELA10 (d_110)",
      "output": "ACH50 * volume / 3600",
      "note": "Equivalent leakage area at 10 Pa"
    },
    {
      "condition": "Heat loss (i_103)",
      "output": "(1.21 * NRL50 * area / N_factor * HDD * 24) / 1000",
      "note": "1.21 = volumetric heat capacity of air (W*s/m3*K) / 1000"
    },
    {
      "condition": "Heat gain (k_103)",
      "output": "(1.21 * NRL50 * area / N_factor * CDD * 24) / 1000",
      "note": "Same formula as heat loss but with CDD"
    }
  ],
  "edgeCases": [
    {
      "condition": "unknown method string",
      "handling": "NRL50 defaults to AL-1B preset (1.17)",
      "rationale": "Fallback to most common default"
    },
    {
      "condition": "volume or area is 0",
      "handling": "NRL50 and ACH50 return 0",
      "rationale": "Cannot compute leakage without geometry"
    },
    {
      "condition": "HDD is 'Unavailable'",
      "handling": "Heat loss returns 'Unavailable'",
      "rationale": "Cannot compute heat loss without degree days"
    },
    {
      "condition": "CDD is 'Unavailable'",
      "handling": "Heat gain returns 0",
      "rationale": "Legacy returns 0 for unavailable CDD"
    },
    {
      "condition": "N-factor not in table",
      "handling": "Falls back to zone 2, Normal, 1.5 stories",
      "rationale": "Default N-factor from table"
    }
  ],
  "formula": {
    "symbolic": "NRL50 = f(method); ACH50 = NRL50*(area/vol)*3.6; i_103 = (1.21*NRL50*area/N*HDD*24)/1000",
    "implementation": "VolumeMetricsNodes.js:344-507",
    "legacy": "Section12.js"
  },
  "constants": {
    "NRL50_PRESETS": {
      "AL-1A": 0.89,
      "AL-2A": 0.71,
      "AL-3A": 0.53,
      "AL-4A": 0.35,
      "AL-1B": 1.17,
      "AL-2B": 0.94,
      "AL-3B": 0.70,
      "AL-4B": 0.47
    },
    "N_FACTOR_TABLE": {
      "zone1": {
        "Shielded": { "1": 18.6, "1.5": 16.7, "2": 14.8, "3": 13.0, "4": 11.2, "5": 9.4, "6": 7.6 },
        "Normal": { "1": 15.5, "1.5": 14.0, "2": 12.4, "3": 10.9, "4": 9.4, "5": 7.9, "6": 6.4 },
        "Exposed": { "1": 14.0, "1.5": 12.6, "2": 11.2, "3": 9.8, "4": 13.0, "5": 13.0, "6": 13.0 }
      },
      "zone2": {
        "Shielded": { "1": 22.2, "1.5": 20.0, "2": 17.8, "3": 15.5, "4": 13.2, "5": 10.9, "6": 8.6 },
        "Normal": { "1": 18.5, "1.5": 16.7, "2": 14.8, "3": 13.0, "4": 11.2, "5": 9.4, "6": 7.6 },
        "Exposed": { "1": 16.7, "1.5": 15.0, "2": 13.3, "3": 11.7, "4": 10.1, "5": 8.5, "6": 6.9 }
      },
      "zone3": {
        "Shielded": { "1": 25.8, "1.5": 23.1, "2": 20.6, "3": 18.1, "4": 15.6, "5": 13.1, "6": 10.6 },
        "Normal": { "1": 21.5, "1.5": 19.4, "2": 17.2, "3": 15.1, "4": 13.0, "5": 10.9, "6": 8.8 },
        "Exposed": { "1": 19.4, "1.5": 17.4, "2": 15.5, "3": 13.5, "4": 11.5, "5": 9.5, "6": 7.5 }
      }
    },
    "leakageFactor": 1.21,
    "storyKeyMapping": "<=1->1, <=1.75->1.5, <2.5->2, <3.5->3, <4.5->4, <5.5->5, else->6"
  },
  "tests": [
    {
      "name": "NRL50 from measured ACH50",
      "inputs": {
        "airTightness.method": "MEASURED",
        "airTightness.measuredAch50": 3.0,
        "volume.conditioned": 400,
        "envelope.airFacing.area": 300
      },
      "expected": {
        "nrl50": 1.111,
        "note": "3.0 * 400 / (300 * 3.6) = 1.111"
      }
    },
    {
      "name": "NRL50 from AL-2B preset",
      "inputs": {
        "airTightness.method": "AL-2B"
      },
      "expected": {
        "nrl50": 0.94
      }
    },
    {
      "name": "N-factor for zone 6, Normal, 1.5 stories",
      "inputs": {
        "climate.zone": 6,
        "airTightness.shielding": "Normal",
        "volume.numStoreys": 1.5
      },
      "expected": {
        "nFactor": 16.7,
        "note": "Zone 6 -> zoneNum=2, Normal, storyKey=1.5"
      }
    },
    {
      "name": "Air leakage heat loss",
      "inputs": {
        "airTightness.nrl50": 1.0,
        "envelope.airFacing.area": 300,
        "airTightness.nFactor": 15,
        "climate.heating.degreedays": 4000
      },
      "expected": {
        "i_103": 2323.2,
        "note": "(1.21 * 1.0 * 300 / 15 * 4000 * 24) / 1000 = 2323.2"
      }
    },
    {
      "name": "ELA10 calculation",
      "inputs": {
        "airTightness.ach50Target": 3.0,
        "volume.conditioned": 400
      },
      "expected": {
        "ela10": 0.3333,
        "note": "3.0 * 400 / 3600 = 0.3333"
      }
    }
  ],
  "references": [
    {
      "source": "VolumeMetricsNodes.js:31-59 (N_FACTOR_TABLE, getStoryKey)"
    },
    {
      "source": "VolumeMetricsNodes.js:330-381 (NRL50 calculation)"
    },
    {
      "source": "VolumeMetricsNodes.js:383-403 (ACH50 target)"
    },
    {
      "source": "VolumeMetricsNodes.js:407-442 (N-factor)"
    },
    {
      "source": "VolumeMetricsNodes.js:448-507 (air leakage heat loss/gain)"
    },
    {
      "source": "VolumeMetricsNodes.js:631-647 (ELA10)"
    }
  ]
}
