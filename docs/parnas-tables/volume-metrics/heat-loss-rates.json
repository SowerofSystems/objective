{
  "_meta": {
    "description": "Heat loss rate per unit area for air-facing and ground-facing envelope groups. Converts weighted U-values to annual heat loss rates using degree days.",
    "instances": [
      {
        "id": "envelope.airFacing.heatLossRate",
        "legacyId": "h_101",
        "label": "Heat Loss Rate (Ae) per m2"
      },
      {
        "id": "envelope.groundFacing.heatLossRate",
        "legacyId": "h_102",
        "label": "Heat Loss Rate (Ag) per m2"
      }
    ]
  },
  "section": "S12",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "envelope.airFacing.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "g_101 - weighted U-value for air-facing envelope"
      },
      {
        "name": "envelope.groundFacing.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "g_102 - weighted U-value for ground-facing envelope"
      },
      {
        "name": "climate.heating.degreedays",
        "type": "number",
        "unit": "degree-days",
        "description": "Heating degree days (HDD)"
      },
      {
        "name": "climate.groundFacing.hdd",
        "type": "number",
        "unit": "degree-days",
        "description": "Ground-facing heating degree days"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/m2/yr",
      "precision": 2
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "HDD is not 'Unavailable' or 'N/A'",
        "description": "Degree days must be available"
      }
    ],
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Heat loss rates are non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "h_101 (airFacing.heatLossRate)",
      "output": "(g_101 * HDD * 24) / 1000",
      "note": "U-value * degree-days * hours/day / W-to-kW conversion"
    },
    {
      "condition": "h_102 (groundFacing.heatLossRate)",
      "output": "(g_102 * groundHDD * 24) / 1000",
      "note": "Same formula using ground-facing degree days"
    }
  ],
  "edgeCases": [
    {
      "condition": "HDD is 'Unavailable' or 'N/A'",
      "handling": "Return 'Unavailable'",
      "rationale": "Cannot compute rate without degree days"
    }
  ],
  "formula": {
    "symbolic": "h_101 = (g_101 * HDD * 24) / 1000; h_102 = (g_102 * groundHDD * 24) / 1000",
    "implementation": "VolumeMetricsNodes.js:185-216",
    "legacy": "Section12.js"
  },
  "tests": [
    {
      "name": "Air-facing heat loss rate",
      "inputs": {
        "envelope.airFacing.uValue": 0.24,
        "climate.heating.degreedays": 4000
      },
      "expected": 23.04,
      "note": "(0.24 * 4000 * 24) / 1000 = 23.04"
    },
    {
      "name": "Ground-facing heat loss rate",
      "inputs": {
        "envelope.groundFacing.uValue": 0.28,
        "climate.groundFacing.hdd": 3000
      },
      "expected": 20.16,
      "note": "(0.28 * 3000 * 24) / 1000 = 20.16"
    },
    {
      "name": "Unavailable HDD",
      "inputs": {
        "envelope.airFacing.uValue": 0.24,
        "climate.heating.degreedays": "Unavailable"
      },
      "expected": "Unavailable"
    }
  ],
  "references": [
    {
      "source": "VolumeMetricsNodes.js:185-216"
    }
  ]
}
