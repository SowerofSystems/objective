{
  "_meta": {
    "description": "Aggregate interior surface temperature estimates for envelope groups using weighted U-values. Air-facing uses winterAverage, ground-facing uses constant 10 C ground temp. Total uses area-weighted delta-T approach.",
    "instances": [
      {
        "id": "envelope.airFacing.surfaceTemp",
        "legacyId": "o_101",
        "label": "Air-Facing Aggregate Surface Temperature"
      },
      {
        "id": "envelope.groundFacing.surfaceTemp",
        "legacyId": "o_102",
        "label": "Ground-Facing Aggregate Surface Temperature"
      },
      {
        "id": "envelope.total.surfaceTemp",
        "legacyId": "o_104",
        "label": "Total Aggregate Surface Temperature"
      },
      {
        "id": "envelope.airFacing.condensationRisk",
        "legacyId": "cr_101",
        "label": "Air-Facing Condensation Risk"
      },
      {
        "id": "envelope.groundFacing.condensationRisk",
        "legacyId": "cr_102",
        "label": "Ground-Facing Condensation Risk"
      }
    ]
  },
  "section": "S12",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "envelope.airFacing.area",
        "type": "number",
        "unit": "m2",
        "description": "d_101 - Air-facing envelope area"
      },
      {
        "name": "envelope.airFacing.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "g_101 - Weighted U-value for air-facing"
      },
      {
        "name": "envelope.groundFacing.area",
        "type": "number",
        "unit": "m2",
        "description": "d_102 - Ground-facing envelope area"
      },
      {
        "name": "envelope.groundFacing.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "g_102 - Weighted U-value for ground-facing"
      },
      {
        "name": "envelope.combined.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "g_104 - Combined weighted U-value (for total surface temp)"
      },
      {
        "name": "climate.heating.setpoint",
        "type": "number",
        "unit": "C",
        "description": "Interior heating setpoint temperature (default 21)"
      },
      {
        "name": "climate.temperature.winterAverage",
        "type": "number",
        "unit": "C",
        "description": "Winter average outdoor temperature (default -5)"
      }
    ],
    "output": {
      "type": "number | string",
      "unit": "C",
      "precision": 2
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "area > 0 for the respective group",
        "description": "Surface temp is only meaningful when there is envelope area"
      }
    ],
    "invariants": [
      {
        "condition": "T_si <= T_interior",
        "description": "Surface temperature is at or below interior setpoint during heating"
      }
    ]
  },
  "behavior": [
    {
      "condition": "o_101 (airFacing.surfaceTemp) with area > 0",
      "output": "T_int - (g_101 * (T_int - winterAverage) * 0.13)",
      "note": "R_si = 0.13 (horizontal heat flow, representative average)"
    },
    {
      "condition": "o_102 (groundFacing.surfaceTemp) with area > 0",
      "output": "T_int - (g_102 * (T_int - 10) * 0.17)",
      "note": "R_si = 0.17 (downward heat flow); ground temp = 10 C constant"
    },
    {
      "condition": "o_104 (total.surfaceTemp) with totalArea > 0",
      "output": "T_int - (g_104 * deltaT_weighted * 0.13)",
      "note": "deltaT_weighted = (deltaT_air * d_101 + deltaT_ground * d_102) / (d_101 + d_102)"
    },
    {
      "condition": "area <= 0",
      "output": "\"\"",
      "note": "Empty string when no area exists"
    },
    {
      "condition": "cr_101 (airFacing.condensationRisk) with surfaceTemp available",
      "output": "surfaceTemp < (T_int - 4.2) ? 'risk' : 'safe'",
      "note": "Passivhaus threshold: 4.2°C below setpoint indicates condensation risk. DOMBridge renders 💧 (risk) or 🌵 (safe)"
    },
    {
      "condition": "cr_102 (groundFacing.condensationRisk) with surfaceTemp available",
      "output": "surfaceTemp < (T_int - 4.2) ? 'risk' : 'safe'",
      "note": "Same Passivhaus threshold applied to ground-facing surfaces"
    },
    {
      "condition": "cr_101/cr_102: surfaceTemp is empty/null/undefined",
      "output": "\"\"",
      "note": "No risk assessment when surface temp cannot be computed"
    }
  ],
  "edgeCases": [
    {
      "condition": "area is 0",
      "handling": "Return empty string ''",
      "rationale": "No physical surface to compute temperature for"
    },
    {
      "condition": "total area is 0",
      "handling": "Return empty string ''",
      "rationale": "Cannot compute area-weighted delta-T"
    }
  ],
  "formula": {
    "symbolic": "o_101 = T_int - (g_101 * (T_int - T_ext) * 0.13); o_102 = T_int - (g_102 * (T_int - 10) * 0.17); o_104 = T_int - (g_104 * deltaT_weighted * 0.13); cr_101 = o_101 < (T_int - 4.2) ? risk : safe; cr_102 = o_102 < (T_int - 4.2) ? risk : safe",
    "implementation": "VolumeMetricsNodes.js:831-917",
    "legacy": "Section12.js"
  },
  "tests": [
    {
      "name": "Air-facing aggregate surface temp",
      "inputs": {
        "envelope.airFacing.area": 240,
        "envelope.airFacing.uValue": 0.24,
        "climate.heating.setpoint": 21,
        "climate.temperature.winterAverage": -5
      },
      "expected": 20.19,
      "note": "21 - (0.24 * 26 * 0.13) = 21 - 0.8112 = 20.1888 -> 20.19"
    },
    {
      "name": "Ground-facing aggregate surface temp",
      "inputs": {
        "envelope.groundFacing.area": 120,
        "envelope.groundFacing.uValue": 0.28,
        "climate.heating.setpoint": 21
      },
      "expected": 20.48,
      "note": "21 - (0.28 * 11 * 0.17) = 21 - 0.5236 = 20.4764 -> 20.48"
    },
    {
      "name": "Total aggregate surface temp (area-weighted deltaT)",
      "inputs": {
        "envelope.airFacing.area": 240,
        "envelope.groundFacing.area": 120,
        "envelope.combined.uValue": 0.2533,
        "climate.heating.setpoint": 21,
        "climate.temperature.winterAverage": -5
      },
      "expected": 20.31,
      "note": "deltaT_weighted = (26*240 + 11*120)/360 = (6240+1320)/360 = 21; T_si = 21 - (0.2533*21*0.13) = 21 - 0.6916 = 20.31"
    },
    {
      "name": "Zero area returns empty string",
      "inputs": {
        "envelope.airFacing.area": 0,
        "envelope.airFacing.uValue": 0.24,
        "climate.heating.setpoint": 21,
        "climate.temperature.winterAverage": -5
      },
      "expected": ""
    },
    {
      "name": "Air-facing condensation risk - safe (well insulated)",
      "inputs": {
        "envelope.airFacing.surfaceTemp": 20.19,
        "climate.heating.setpoint": 21
      },
      "expected": "safe",
      "note": "20.19 >= (21 - 4.2 = 16.8) → safe"
    },
    {
      "name": "Air-facing condensation risk - at risk (poor insulation)",
      "inputs": {
        "envelope.airFacing.surfaceTemp": 15.5,
        "climate.heating.setpoint": 21
      },
      "expected": "risk",
      "note": "15.5 < (21 - 4.2 = 16.8) → risk"
    },
    {
      "name": "Ground-facing condensation risk - safe",
      "inputs": {
        "envelope.groundFacing.surfaceTemp": 20.48,
        "climate.heating.setpoint": 21
      },
      "expected": "safe",
      "note": "20.48 >= (21 - 4.2 = 16.8) → safe"
    },
    {
      "name": "Condensation risk - empty surface temp returns empty",
      "inputs": {
        "envelope.airFacing.surfaceTemp": "",
        "climate.heating.setpoint": 21
      },
      "expected": ""
    }
  ],
  "references": [
    {
      "source": "VolumeMetricsNodes.js:831-852 (o_101 air-facing)"
    },
    {
      "source": "VolumeMetricsNodes.js:854-875 (o_102 ground-facing)"
    },
    {
      "source": "VolumeMetricsNodes.js:877-905 (o_104 total)"
    },
    {
      "source": "VolumeMetricsNodes.js:884-899 (cr_101 air-facing condensation risk)"
    },
    {
      "source": "VolumeMetricsNodes.js:902-917 (cr_102 ground-facing condensation risk)"
    }
  ]
}
