{
  "_meta": {
    "description": "Weighted U-values for envelope groups. Air-facing is a pass-through from S11. Ground-facing is computed as the area-weighted average of below-grade components including thermal bridge penalty. Combined is the overall area-weighted average.",
    "instances": [
      {
        "id": "envelope.airFacing.uValue",
        "legacyId": "g_101",
        "label": "Weighted U-Value for Air-Facing (Ae)"
      },
      {
        "id": "envelope.groundFacing.uValue",
        "legacyId": "g_102",
        "label": "Weighted U-Value for Ground-Facing (Ag)"
      },
      {
        "id": "envelope.combined.uValue",
        "legacyId": "g_104",
        "label": "Combined Envelope U-Value"
      }
    ]
  },
  "section": "S12",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.airFacing.weightedUValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "Weighted U-value from S11 (already includes penalty)"
      },
      {
        "name": "transmissionLoss.wallsBelowGrade.area",
        "type": "number",
        "unit": "m2",
        "description": "Below-grade wall area"
      },
      {
        "name": "transmissionLoss.wallsBelowGrade.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "Below-grade wall U-value"
      },
      {
        "name": "transmissionLoss.slabOnGrade.area",
        "type": "number",
        "unit": "m2",
        "description": "Slab on grade area"
      },
      {
        "name": "transmissionLoss.slabOnGrade.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "Slab on grade U-value"
      },
      {
        "name": "transmissionLoss.groundFacing.totalArea",
        "type": "number",
        "unit": "m2",
        "description": "Total ground-facing area"
      },
      {
        "name": "transmissionLoss.thermalBridgePenalty",
        "type": "number",
        "unit": "%",
        "description": "Thermal bridge penalty percentage (d_97)"
      },
      {
        "name": "envelope.airFacing.area",
        "type": "number",
        "unit": "m2",
        "description": "d_101 - air-facing area (for combined weighting)"
      },
      {
        "name": "envelope.groundFacing.area",
        "type": "number",
        "unit": "m2",
        "description": "d_102 - ground-facing area (for combined weighting)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "W/m2K",
      "precision": 4
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "total area > 0",
        "description": "Area must be nonzero for weighted average"
      }
    ],
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "U-values are non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "g_101 (airFacing.uValue)",
      "output": "transmissionLoss.airFacing.weightedUValue",
      "note": "Direct pass-through from S11 weighted U-value (already includes penalty)"
    },
    {
      "condition": "g_102 (groundFacing.uValue)",
      "output": "(wallsBelowGrade.area * wallsBelowGrade.uValue + slabOnGrade.area * slabOnGrade.uValue) / groundFacing.totalArea * (1 + d_97/100)",
      "note": "Area-weighted average of ground-facing component U-values with thermal bridge penalty"
    },
    {
      "condition": "g_104 (combined.uValue)",
      "output": "(g_101 * d_101 + g_102 * d_102) / (d_101 + d_102)",
      "note": "Area-weighted combination of air-facing and ground-facing U-values; tiny epsilon added to avoid div/0"
    }
  ],
  "edgeCases": [
    {
      "condition": "ground-facing total area is 0",
      "handling": "g_102 returns 0",
      "rationale": "No ground-facing components"
    },
    {
      "condition": "total area is 0",
      "handling": "g_104 uses epsilon (0.000001) to avoid division by zero",
      "rationale": "Returns near-zero value rather than error"
    }
  ],
  "formula": {
    "symbolic": "g_101 = S11.weightedU; g_102 = SUMPRODUCT(area,U)/SUM(area) * (1+d_97/100); g_104 = (g_101*d_101 + g_102*d_102) / (d_101+d_102)",
    "implementation": "VolumeMetricsNodes.js:131-595",
    "legacy": "Section12.js"
  },
  "tests": [
    {
      "name": "Air-facing pass-through",
      "inputs": {
        "transmissionLoss.airFacing.weightedUValue": 0.24
      },
      "expected": {
        "g_101": 0.24
      }
    },
    {
      "name": "Ground-facing weighted U with penalty",
      "inputs": {
        "transmissionLoss.wallsBelowGrade.area": 40,
        "transmissionLoss.wallsBelowGrade.uValue": 0.3,
        "transmissionLoss.slabOnGrade.area": 80,
        "transmissionLoss.slabOnGrade.uValue": 0.2,
        "transmissionLoss.groundFacing.totalArea": 120,
        "transmissionLoss.thermalBridgePenalty": 20
      },
      "expected": {
        "g_102": 0.28,
        "note": "((40*0.3 + 80*0.2)/120) * 1.2 = (12+16)/120 * 1.2 = 0.2333 * 1.2 = 0.28"
      }
    },
    {
      "name": "Combined U-value",
      "inputs": {
        "envelope.airFacing.uValue": 0.24,
        "envelope.airFacing.area": 240,
        "envelope.groundFacing.uValue": 0.28,
        "envelope.groundFacing.area": 120
      },
      "expected": {
        "g_104": 0.2533,
        "note": "(0.24*240 + 0.28*120) / 360 = (57.6+33.6)/360 = 0.2533"
      }
    }
  ],
  "references": [
    {
      "source": "VolumeMetricsNodes.js:131-141 (g_101 air-facing pass-through)"
    },
    {
      "source": "VolumeMetricsNodes.js:146-177 (g_102 ground-facing weighted)"
    },
    {
      "source": "VolumeMetricsNodes.js:574-595 (g_104 combined)"
    }
  ]
}
