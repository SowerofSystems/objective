{
  "_meta": {
    "description": "Building geometry and derived metrics: total floor area, volume-to-area ratio, area-to-volume ratio, total wall area, window/door heat loss total, and window-to-wall ratio (WWR).",
    "instances": [
      {
        "id": "geometry.totalFloorArea",
        "legacyId": "d_106",
        "label": "Total Floor Area"
      },
      {
        "id": "geometry.volumeToAreaRatio",
        "legacyId": "g_105",
        "label": "Volume/Area Ratio"
      },
      {
        "id": "geometry.areaToVolumeRatio",
        "legacyId": "i_105",
        "label": "Area/Volume Ratio"
      },
      {
        "id": "geometry.totalWallArea",
        "legacyId": "g_107",
        "label": "Total Wall Area"
      },
      {
        "id": "geometry.windowDoorHeatLoss",
        "legacyId": "i_107",
        "label": "Window/Door Heat Loss Total"
      },
      {
        "id": "envelope.wwr",
        "legacyId": "d_107",
        "label": "Window-to-Wall Ratio"
      }
    ]
  },
  "section": "S12",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.exposedFloor.area",
        "type": "number",
        "unit": "m2",
        "description": "d_87 - Exposed floor area"
      },
      {
        "name": "transmissionLoss.slabOnGrade.area",
        "type": "number",
        "unit": "m2",
        "description": "d_95 - Slab on grade area"
      },
      {
        "name": "transmissionLoss.interiorFloorArea",
        "type": "number",
        "unit": "m2",
        "description": "d_96 - Interior floor area"
      },
      {
        "name": "volume.conditioned",
        "type": "number",
        "unit": "m3",
        "description": "d_105 - Conditioned volume"
      },
      {
        "name": "envelope.airFacing.area",
        "type": "number",
        "unit": "m2",
        "description": "d_101 - Total air-facing envelope area"
      },
      {
        "name": "transmissionLoss.walls.area",
        "type": "number",
        "unit": "m2",
        "description": "d_86 - Opaque walls area"
      },
      {
        "name": "transmissionLoss.doors.area",
        "type": "number",
        "unit": "m2",
        "description": "d_88 - Doors area"
      },
      {
        "name": "transmissionLoss.windowNorth.area",
        "type": "number",
        "unit": "m2",
        "description": "d_89 - Window North area"
      },
      {
        "name": "transmissionLoss.windowEast.area",
        "type": "number",
        "unit": "m2",
        "description": "d_90 - Window East area"
      },
      {
        "name": "transmissionLoss.windowSouth.area",
        "type": "number",
        "unit": "m2",
        "description": "d_91 - Window South area"
      },
      {
        "name": "transmissionLoss.windowWest.area",
        "type": "number",
        "unit": "m2",
        "description": "d_92 - Window West area"
      },
      {
        "name": "transmissionLoss.doors.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_88 - Doors heat loss"
      },
      {
        "name": "transmissionLoss.windowNorth.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_89 - Window North heat loss"
      },
      {
        "name": "transmissionLoss.windowEast.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_90 - Window East heat loss"
      },
      {
        "name": "transmissionLoss.windowSouth.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_91 - Window South heat loss"
      },
      {
        "name": "transmissionLoss.windowWest.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_92 - Window West heat loss"
      }
    ],
    "output": {
      "type": "number",
      "unit": "varies (m2, m3/m2, m2/m3, kWh/yr, ratio)",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "volumeToAreaRatio * areaToVolumeRatio = 1 (when both > 0)",
        "description": "Ratios are reciprocals"
      },
      {
        "condition": "0 <= WWR <= 1",
        "description": "Window-to-wall ratio is between 0 and 1"
      }
    ]
  },
  "behavior": [
    {
      "condition": "d_106 (totalFloorArea)",
      "output": "d_87 + d_95 + d_96",
      "note": "Exposed floor + slab on grade + interior floor"
    },
    {
      "condition": "g_105 (volumeToAreaRatio)",
      "output": "volume / airFacingArea",
      "note": "m3/m2 ratio; returns 0 if area is 0"
    },
    {
      "condition": "i_105 (areaToVolumeRatio)",
      "output": "airFacingArea / volume",
      "note": "m2/m3 ratio; returns 0 if volume is 0"
    },
    {
      "condition": "g_107 (totalWallArea)",
      "output": "d_86 + d_88 + d_89 + d_90 + d_91 + d_92",
      "note": "Opaque walls + doors + all 4 window orientations (excludes skylights d_93)"
    },
    {
      "condition": "i_107 (windowDoorHeatLoss)",
      "output": "SUM(i_88, i_89, i_90, i_91, i_92)",
      "note": "Sum of door and window heat losses (excludes skylights)"
    },
    {
      "condition": "d_107 (WWR)",
      "output": "SUM(d_88:d_92) / (d_86 + SUM(d_88:d_92))",
      "note": "Window+door area / (opaque wall + window+door area); excludes skylights"
    }
  ],
  "edgeCases": [
    {
      "condition": "air-facing area is 0",
      "handling": "volumeToAreaRatio returns 0",
      "rationale": "Avoid division by zero"
    },
    {
      "condition": "volume is 0",
      "handling": "areaToVolumeRatio returns 0",
      "rationale": "Avoid division by zero"
    },
    {
      "condition": "total wall area is 0",
      "handling": "WWR returns 0",
      "rationale": "Avoid division by zero; no walls means no ratio"
    }
  ],
  "formula": {
    "symbolic": "d_106 = d_87+d_95+d_96; g_105 = vol/area; d_107 = SUM(d_88:d_92)/(d_86+SUM(d_88:d_92))",
    "implementation": "VolumeMetricsNodes.js:655-750",
    "legacy": "Section12.js"
  },
  "tests": [
    {
      "name": "Total floor area",
      "inputs": {
        "transmissionLoss.exposedFloor.area": 0,
        "transmissionLoss.slabOnGrade.area": 80,
        "transmissionLoss.interiorFloorArea": 80
      },
      "expected": {
        "d_106": 160
      }
    },
    {
      "name": "Volume to area ratio",
      "inputs": {
        "volume.conditioned": 400,
        "envelope.airFacing.area": 300
      },
      "expected": {
        "g_105": 1.333
      }
    },
    {
      "name": "Window-to-wall ratio",
      "inputs": {
        "transmissionLoss.walls.area": 120,
        "transmissionLoss.doors.area": 5,
        "transmissionLoss.windowNorth.area": 8,
        "transmissionLoss.windowEast.area": 6,
        "transmissionLoss.windowSouth.area": 12,
        "transmissionLoss.windowWest.area": 6
      },
      "expected": {
        "d_107": 0.2357,
        "note": "37/(120+37) = 37/157 = 0.2357"
      }
    },
    {
      "name": "Total wall area (excludes skylights)",
      "inputs": {
        "transmissionLoss.walls.area": 120,
        "transmissionLoss.doors.area": 5,
        "transmissionLoss.windowNorth.area": 8,
        "transmissionLoss.windowEast.area": 6,
        "transmissionLoss.windowSouth.area": 12,
        "transmissionLoss.windowWest.area": 6
      },
      "expected": {
        "g_107": 157
      }
    }
  ],
  "references": [
    {
      "source": "VolumeMetricsNodes.js:655-672 (d_106 total floor area)"
    },
    {
      "source": "VolumeMetricsNodes.js:675-702 (g_105, i_105 ratios)"
    },
    {
      "source": "VolumeMetricsNodes.js:704-750 (g_107, i_107, d_107)"
    },
    {
      "source": "VolumeMetricsNodes.js:601-626 (d_107 WWR)"
    }
  ]
}
