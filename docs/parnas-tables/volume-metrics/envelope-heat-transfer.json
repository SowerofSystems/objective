{
  "_meta": {
    "description": "Total envelope heat loss and heat gain calculations for air-facing and ground-facing groups, plus grand totals. Heat loss = rate * area. Heat gain uses CDD. Total heat gain has special capacitance branching logic.",
    "instances": [
      {
        "id": "envelope.airFacing.totalHeatLoss",
        "legacyId": "i_101",
        "label": "Total Heat Loss (Ae)"
      },
      {
        "id": "envelope.groundFacing.totalHeatLoss",
        "legacyId": "i_102",
        "label": "Total Heat Loss (Ag)"
      },
      {
        "id": "envelope.airFacing.heatGainRate",
        "legacyId": "j_101",
        "label": "Heat Gain Rate (Ae) per m2"
      },
      {
        "id": "envelope.airFacing.totalHeatGain",
        "legacyId": "k_101",
        "label": "Total Heat Gain (Ae)"
      },
      {
        "id": "envelope.groundFacing.heatGainRate",
        "legacyId": "j_102",
        "label": "Heat Gain Rate (Ag) per m2"
      },
      {
        "id": "envelope.groundFacing.totalHeatGain",
        "legacyId": "k_102",
        "label": "Total Heat Gain (Ag)"
      },
      {
        "id": "envelope.total.heatLoss",
        "legacyId": "i_104",
        "label": "Total Envelope Heat Loss"
      },
      {
        "id": "envelope.total.heatGain",
        "legacyId": "k_104",
        "label": "Total Envelope Heat Gain"
      }
    ]
  },
  "section": "S12",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "envelope.airFacing.heatLossRate",
        "type": "number",
        "unit": "kWh/m2/yr",
        "description": "h_101 - heat loss rate per m2 for air-facing"
      },
      {
        "name": "envelope.groundFacing.heatLossRate",
        "type": "number",
        "unit": "kWh/m2/yr",
        "description": "h_102 - heat loss rate per m2 for ground-facing"
      },
      {
        "name": "envelope.airFacing.area",
        "type": "number",
        "unit": "m2",
        "description": "d_101 - air-facing envelope area"
      },
      {
        "name": "envelope.groundFacing.area",
        "type": "number",
        "unit": "m2",
        "description": "d_102 - ground-facing envelope area"
      },
      {
        "name": "envelope.airFacing.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "g_101 - weighted U-value for air-facing"
      },
      {
        "name": "envelope.groundFacing.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "g_102 - weighted U-value for ground-facing"
      },
      {
        "name": "climate.cooling.degreedays",
        "type": "number",
        "unit": "degree-days",
        "description": "Cooling degree days (CDD)"
      },
      {
        "name": "climate.groundFacing.cdd",
        "type": "number",
        "unit": "degree-days",
        "description": "Ground-facing cooling degree days"
      },
      {
        "name": "airTightness.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_103 - air leakage heat loss"
      },
      {
        "name": "building.capacitance.setting",
        "type": "string",
        "description": "Capacitance setting - 'Capacitance' or 'No Capacitance'"
      },
      {
        "name": "transmissionLoss.components.subtotalHeatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "k_98 from S11 - used when capacitance is enabled"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr or kWh/m2",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "i_104 = i_101 + i_102 + i_103",
        "description": "Total heat loss = air-facing + ground-facing + air leakage"
      }
    ]
  },
  "behavior": [
    {
      "condition": "i_101 (airFacing.totalHeatLoss)",
      "output": "h_101 * d_101",
      "note": "Heat loss rate * area"
    },
    {
      "condition": "i_102 (groundFacing.totalHeatLoss)",
      "output": "h_102 * d_102",
      "note": "Heat loss rate * area"
    },
    {
      "condition": "j_101 (airFacing.heatGainRate)",
      "output": "(g_101 * CDD * 24) / 1000",
      "note": "Same structure as heat loss rate but with CDD; returns 0 when CDD unavailable"
    },
    {
      "condition": "k_101 (airFacing.totalHeatGain)",
      "output": "j_101 * d_101",
      "note": "Heat gain rate * area"
    },
    {
      "condition": "j_102 (groundFacing.heatGainRate)",
      "output": "(g_102 * GF_CDD * 24) / 1000",
      "note": "Uses ground-facing CDD"
    },
    {
      "condition": "k_102 (groundFacing.totalHeatGain)",
      "output": "j_102 * d_102",
      "note": "Heat gain rate * area"
    },
    {
      "condition": "i_104 (total.heatLoss)",
      "output": "i_101 + i_102 + i_103",
      "note": "Includes air leakage heat loss; defaults 0 for unavailable values"
    },
    {
      "condition": "k_104 when capacitance = 'Capacitance'",
      "output": "k_98 (transmissionLoss.components.subtotalHeatGain from S11)",
      "note": "Uses S11 component sums instead of S12 weighted calculations"
    },
    {
      "condition": "k_104 when capacitance != 'Capacitance'",
      "output": "k_101 + k_102",
      "note": "Sum of air-facing and ground-facing heat gains (k_103 NOT included)"
    }
  ],
  "edgeCases": [
    {
      "condition": "CDD is 'Unavailable' or 'N/A'",
      "handling": "Heat gain rate returns 0",
      "rationale": "Legacy behavior returns 0 for unavailable CDD"
    },
    {
      "condition": "heat loss components are 'Unavailable'",
      "handling": "parseNum defaults to 0 in i_104 sum",
      "rationale": "Graceful degradation when some values unavailable"
    },
    {
      "condition": "capacitance setting is 'Capacitance'",
      "handling": "k_104 uses k_98 from S11 instead of k_101+k_102",
      "rationale": "Excel formula: =IF(H21='Capacitance', K98, SUM(K101:K102))"
    }
  ],
  "formula": {
    "symbolic": "i_101 = h_101*d_101; j_101 = (g_101*CDD*24)/1000; k_101 = j_101*d_101; i_104 = i_101+i_102+i_103; k_104 = IF(Capacitance, k_98, k_101+k_102)",
    "implementation": "VolumeMetricsNodes.js:224-567",
    "legacy": "Section12.js"
  },
  "tests": [
    {
      "name": "Air-facing total heat loss",
      "inputs": {
        "envelope.airFacing.heatLossRate": 23.04,
        "envelope.airFacing.area": 240
      },
      "expected": {
        "i_101": 5529.6
      }
    },
    {
      "name": "Total envelope heat loss",
      "inputs": {
        "envelope.airFacing.totalHeatLoss": 5530,
        "envelope.groundFacing.totalHeatLoss": 2420,
        "airTightness.heatLoss": 800
      },
      "expected": {
        "i_104": 8750
      }
    },
    {
      "name": "Total heat gain with capacitance",
      "inputs": {
        "building.capacitance.setting": "Capacitance",
        "transmissionLoss.components.subtotalHeatGain": 1500,
        "envelope.airFacing.totalHeatGain": 1200,
        "envelope.groundFacing.totalHeatGain": 400
      },
      "expected": {
        "k_104": 1500,
        "note": "Uses k_98 when Capacitance setting"
      }
    },
    {
      "name": "Total heat gain without capacitance",
      "inputs": {
        "building.capacitance.setting": "No Capacitance",
        "transmissionLoss.components.subtotalHeatGain": 1500,
        "envelope.airFacing.totalHeatGain": 1200,
        "envelope.groundFacing.totalHeatGain": 400
      },
      "expected": {
        "k_104": 1600,
        "note": "Uses k_101+k_102 when not Capacitance"
      }
    }
  ],
  "references": [
    {
      "source": "VolumeMetricsNodes.js:224-253 (i_101, i_102 heat losses)"
    },
    {
      "source": "VolumeMetricsNodes.js:261-323 (j_101, k_101, j_102, k_102 heat gains)"
    },
    {
      "source": "VolumeMetricsNodes.js:516-567 (i_104, k_104 totals)"
    }
  ]
}
