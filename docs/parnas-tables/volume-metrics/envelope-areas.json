{
  "_meta": {
    "description": "Envelope area pass-through nodes from Section 11 transmission loss totals. Air-facing and ground-facing areas are bridged from S11 subtotals, and the total is their sum.",
    "instances": [
      {
        "id": "envelope.airFacing.area",
        "legacyId": "d_101",
        "label": "Total Air-Facing Envelope Area (Ae)"
      },
      {
        "id": "envelope.groundFacing.area",
        "legacyId": "d_102",
        "label": "Total Ground-Facing Envelope Area (Ag)"
      },
      {
        "id": "envelope.total.area",
        "legacyId": "d_104",
        "label": "Total Envelope Area"
      }
    ]
  },
  "section": "S12",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.airFacing.totalArea",
        "type": "number",
        "unit": "m2",
        "description": "Sum of air-facing component areas from S11"
      },
      {
        "name": "transmissionLoss.groundFacing.totalArea",
        "type": "number",
        "unit": "m2",
        "description": "Sum of ground-facing component areas from S11"
      }
    ],
    "output": {
      "type": "number",
      "unit": "m2",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Areas are non-negative"
      },
      {
        "condition": "d_104 = d_101 + d_102",
        "description": "Total is sum of air-facing and ground-facing"
      }
    ]
  },
  "behavior": [
    {
      "condition": "d_101 (airFacing.area)",
      "output": "transmissionLoss.airFacing.totalArea",
      "note": "Direct pass-through from S11"
    },
    {
      "condition": "d_102 (groundFacing.area)",
      "output": "transmissionLoss.groundFacing.totalArea",
      "note": "Direct pass-through from S11"
    },
    {
      "condition": "d_104 (total.area)",
      "output": "d_101 + d_102",
      "note": "Sum of air-facing and ground-facing areas"
    }
  ],
  "edgeCases": [
    {
      "condition": "source area is null/undefined",
      "handling": "Return 0",
      "rationale": "parseNum defaults to 0"
    }
  ],
  "formula": {
    "symbolic": "d_101 = transmissionLoss.airFacing.totalArea; d_102 = transmissionLoss.groundFacing.totalArea; d_104 = d_101 + d_102",
    "implementation": "VolumeMetricsNodes.js:84-123",
    "legacy": "Section12.js"
  },
  "tests": [
    {
      "name": "Standard envelope areas",
      "inputs": {
        "transmissionLoss.airFacing.totalArea": 240,
        "transmissionLoss.groundFacing.totalArea": 120
      },
      "expected": {
        "d_101": 240,
        "d_102": 120,
        "d_104": 360
      }
    },
    {
      "name": "No ground-facing area",
      "inputs": {
        "transmissionLoss.airFacing.totalArea": 300,
        "transmissionLoss.groundFacing.totalArea": 0
      },
      "expected": {
        "d_101": 300,
        "d_102": 0,
        "d_104": 300
      }
    }
  ],
  "references": [
    {
      "source": "VolumeMetricsNodes.js:84-123"
    }
  ]
}
