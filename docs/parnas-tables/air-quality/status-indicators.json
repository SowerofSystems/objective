{
  "_meta": {
    "description": "Pass/fail status indicators for each air quality metric. Pollutants check if compliance ratio <= 1.0. Humidity checks if both heating and cooling season RH are within 30-60% range.",
    "instances": [
      {
        "id": "airQuality.radon.status",
        "legacyId": "n_56",
        "label": "Radon Status"
      },
      {
        "id": "airQuality.co2.status",
        "legacyId": "n_57",
        "label": "CO2 Status"
      },
      {
        "id": "airQuality.tvoc.status",
        "legacyId": "n_58",
        "label": "TVOC Status"
      },
      {
        "id": "airQuality.humidity.status",
        "legacyId": "n_59",
        "label": "Humidity Status"
      }
    ]
  },
  "section": "S08",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "airQuality.{pollutant}.compliance",
        "type": "number",
        "description": "Compliance ratio (m_56/m_57/m_58) - for pollutant status nodes"
      },
      {
        "name": "airQuality.humidity.heatingTarget",
        "type": "number",
        "unit": "%",
        "description": "Heating season RH target (d_59) - for humidity status only"
      },
      {
        "name": "building.indoorRH",
        "type": "number",
        "unit": "%",
        "description": "Cooling season RH (i_59) - for humidity status only"
      }
    ],
    "output": {
      "type": "string",
      "description": "Check mark or X mark unicode character"
    }
  },
  "behavior": [
    {
      "condition": "pollutant compliance ratio <= 1.0",
      "output": "checkmark",
      "note": "Target is within guideline limit"
    },
    {
      "condition": "pollutant compliance ratio > 1.0",
      "output": "X mark",
      "note": "Target exceeds guideline limit"
    },
    {
      "condition": "humidity: both heating and cooling RH in [30, 60]",
      "output": "checkmark",
      "note": "Both seasons within acceptable range"
    },
    {
      "condition": "humidity: either RH outside [30, 60]",
      "output": "X mark",
      "note": "At least one season outside acceptable range"
    }
  ],
  "edgeCases": [
    {
      "condition": "compliance ratio exactly 1.0",
      "handling": "Pass (checkmark)",
      "rationale": "At the limit is considered acceptable"
    },
    {
      "condition": "RH exactly 30 or 60",
      "handling": "Pass (checkmark)",
      "rationale": "Boundary values are inclusive (>= 30 && <= 60)"
    }
  ],
  "formula": {
    "symbolic": "n_56/57/58 = m_{N} <= 1.0 ? pass : fail; n_59 = d_59 in [30,60] AND i_59 in [30,60]",
    "implementation": "AirQualityNodes.js:127-179"
  },
  "tests": [
    {
      "name": "Radon passes",
      "inputs": {
        "airQuality.radon.compliance": 0.33
      },
      "expected": "checkmark"
    },
    {
      "name": "CO2 fails",
      "inputs": {
        "airQuality.co2.compliance": 1.5
      },
      "expected": "X mark"
    },
    {
      "name": "Humidity both in range",
      "inputs": {
        "airQuality.humidity.heatingTarget": 45,
        "building.indoorRH": 50
      },
      "expected": "checkmark"
    },
    {
      "name": "Humidity heating too low",
      "inputs": {
        "airQuality.humidity.heatingTarget": 25,
        "building.indoorRH": 50
      },
      "expected": "X mark"
    }
  ],
  "references": [
    {
      "source": "AirQualityNodes.js:127-179"
    }
  ]
}
