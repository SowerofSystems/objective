{
  "_meta": {
    "description": "Ratio of user target to guidance limit for each pollutant. Values <= 1.0 indicate the target is within (better than or equal to) the guideline. Values > 1.0 indicate the target exceeds the guideline.",
    "instances": [
      {
        "id": "airQuality.radon.compliance",
        "legacyId": "m_56",
        "label": "Radon Compliance Ratio"
      },
      {
        "id": "airQuality.co2.compliance",
        "legacyId": "m_57",
        "label": "CO2 Compliance Ratio"
      },
      {
        "id": "airQuality.tvoc.compliance",
        "legacyId": "m_58",
        "label": "TVOC Compliance Ratio"
      }
    ]
  },
  "section": "S08",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "airQuality.{pollutant}.target",
        "type": "number",
        "description": "User-set target value (d_56/d_57/d_58)"
      },
      {
        "name": "airQuality.{pollutant}.limit",
        "type": "number",
        "description": "Guidance limit constant (k_56/k_57/k_58)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "ratio",
      "precision": 4
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "limit > 0",
        "description": "Guidance limits are positive constants"
      }
    ],
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Ratio is non-negative (targets are non-negative)"
      }
    ]
  },
  "behavior": [
    {
      "condition": "limit > 0",
      "output": "target / limit",
      "note": "Simple ratio"
    },
    {
      "condition": "limit == 0",
      "output": "0",
      "note": "Guard against division by zero (should never occur with constant limits)"
    }
  ],
  "formula": {
    "symbolic": "m_{N} = d_{N} / k_{N}",
    "implementation": "AirQualityNodes.js:72-112"
  },
  "tests": [
    {
      "name": "Radon target within limit",
      "inputs": {
        "airQuality.radon.target": 50,
        "airQuality.radon.limit": 150
      },
      "expected": 0.3333
    },
    {
      "name": "CO2 target at limit",
      "inputs": {
        "airQuality.co2.target": 1000,
        "airQuality.co2.limit": 1000
      },
      "expected": 1.0
    },
    {
      "name": "TVOC target exceeds limit",
      "inputs": {
        "airQuality.tvoc.target": 500,
        "airQuality.tvoc.limit": 400
      },
      "expected": 1.25
    }
  ],
  "references": [
    {
      "source": "AirQualityNodes.js:72-112"
    }
  ]
}
