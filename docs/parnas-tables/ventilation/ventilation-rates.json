{
  "_meta": {
    "description": "Ventilation rate calculations. Volumetric rate (L/s) depends on method: volume-based uses ACH and conditioned volume; occupant-based uses per-person rate and occupant count. Schedule variants apply an occupancy schedule factor. Volume rate (m3/h) is a unit conversion.",
    "instances": [
      {
        "id": "ventilation.volumetricRate",
        "legacyId": "d_120",
        "label": "Volumetric Ventilation Rate (L/s)"
      },
      {
        "id": "ventilation.volumeRate",
        "legacyId": "h_120",
        "label": "Volumetric Ventilation Rate (m3/h)"
      }
    ]
  },
  "section": "S13",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "mechanical.ventilation.method",
        "type": "string",
        "description": "Ventilation method: 'Volume Constant', 'Volume by Schedule', 'Occupant Constant', 'Occupant by Schedule'"
      },
      {
        "name": "mechanical.ventilation.ach",
        "type": "number",
        "unit": "ACH",
        "description": "Air changes per hour - default 3"
      },
      {
        "name": "mechanical.ventilation.ratePerPerson",
        "type": "number",
        "unit": "L/s/person",
        "description": "Ventilation rate per person - default 14"
      },
      {
        "name": "volume.conditioned",
        "type": "number",
        "unit": "m3",
        "description": "Conditioned volume - default 6000"
      },
      {
        "name": "occupancy.occupants",
        "type": "number",
        "description": "Number of occupants - default 20"
      },
      {
        "name": "occupancy.occupiedHours",
        "type": "number",
        "unit": "hours/yr",
        "description": "Occupied hours per year - default 4380"
      },
      {
        "name": "occupancy.totalHours",
        "type": "number",
        "unit": "hours/yr",
        "description": "Total hours per year - default 8760"
      }
    ],
    "output": {
      "type": "number",
      "unit": "L/s (d_120) or m3/h (h_120)"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "method in ['Volume Constant', 'Volume by Schedule', 'Occupant Constant', 'Occupant by Schedule']",
        "description": "Method must be one of the four supported ventilation methods"
      }
    ],
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Ventilation rate cannot be negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "method == 'Volume Constant'",
      "output": "(ach * volume) / 3.6",
      "note": "Continuous volume-based ventilation, no schedule reduction"
    },
    {
      "condition": "method == 'Volume by Schedule'",
      "output": "((ach * volume) / 3.6) * scheduleFactor",
      "note": "Volume-based ventilation scaled by occupancy schedule. scheduleFactor = occupiedHours / totalHours"
    },
    {
      "condition": "method == 'Occupant Constant'",
      "output": "ratePerPerson * occupants",
      "note": "Per-person rate times number of occupants, continuous"
    },
    {
      "condition": "method == 'Occupant by Schedule'",
      "output": "ratePerPerson * occupants * scheduleFactor",
      "note": "Per-person rate scaled by occupancy schedule"
    },
    {
      "condition": "method unknown",
      "output": "((ach * volume) / 3.6) * scheduleFactor",
      "note": "Default to Volume by Schedule (matches legacy default)"
    },
    {
      "condition": "h_120: always",
      "output": "d_120 * 3.6",
      "note": "Unit conversion from L/s to m3/h"
    }
  ],
  "edgeCases": [
    {
      "condition": "totalHours == 0",
      "handling": "scheduleFactor = 0.5",
      "rationale": "Prevent division by zero, use half-time default"
    }
  ],
  "formula": {
    "symbolic": "d_120 = CASE(method, (ach×V)/3.6, (ach×V)/3.6×sf, rate×occ, rate×occ×sf); h_120 = d_120 × 3.6; sf = occupiedHours/totalHours",
    "implementation": "VentilationNodes.js:37-89"
  },
  "tests": [
    {
      "name": "Volume Constant - typical",
      "inputs": {
        "mechanical.ventilation.method": "Volume Constant",
        "mechanical.ventilation.ach": 3,
        "volume.conditioned": 6000
      },
      "expected": 5000,
      "note": "d_120 = (3 * 6000) / 3.6 = 5000 L/s"
    },
    {
      "name": "Volume by Schedule - half occupancy",
      "inputs": {
        "mechanical.ventilation.method": "Volume by Schedule",
        "mechanical.ventilation.ach": 3,
        "volume.conditioned": 6000,
        "occupancy.occupiedHours": 4380,
        "occupancy.totalHours": 8760
      },
      "expected": 2500,
      "note": "d_120 = (3 * 6000) / 3.6 * 0.5 = 2500 L/s"
    },
    {
      "name": "Occupant Constant",
      "inputs": {
        "mechanical.ventilation.method": "Occupant Constant",
        "mechanical.ventilation.ratePerPerson": 14,
        "occupancy.occupants": 20
      },
      "expected": 280,
      "note": "d_120 = 14 * 20 = 280 L/s"
    },
    {
      "name": "Occupant by Schedule",
      "inputs": {
        "mechanical.ventilation.method": "Occupant by Schedule",
        "mechanical.ventilation.ratePerPerson": 14,
        "occupancy.occupants": 20,
        "occupancy.occupiedHours": 4380,
        "occupancy.totalHours": 8760
      },
      "expected": 140,
      "note": "d_120 = 14 * 20 * 0.5 = 140 L/s"
    },
    {
      "name": "Volume rate unit conversion",
      "inputs": {
        "ventilation.volumetricRate": 280
      },
      "expected": 1008,
      "note": "h_120 = 280 * 3.6 = 1008 m3/h"
    }
  ]
}
