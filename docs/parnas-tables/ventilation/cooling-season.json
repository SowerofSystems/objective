{
  "_meta": {
    "description": "Cooling season ventilation energy calculations. Heat gain uses degree-day method with adjustments for occupancy, summer ventilation boost, and latent load factor (from psychrometric calculations). Energy recovered applies HRV/ERV efficiency to the cooling load.",
    "instances": [
      {
        "id": "ventilation.heatGain",
        "legacyId": "d_122",
        "label": "Net Ventilation Heat Gain (kWh/yr)"
      },
      {
        "id": "ventilation.energyRecoveredCooling",
        "legacyId": "d_123",
        "label": "Ventilation Energy Recovered Cooling (kWh/yr)"
      }
    ]
  },
  "section": "S13",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "ventilation.volumetricRate",
        "type": "number",
        "unit": "L/s",
        "description": "Volumetric ventilation rate (d_120)"
      },
      {
        "name": "climate.cooling.degreedays",
        "type": "number|string",
        "unit": "degree-days",
        "description": "Cooling degree days. May be undefined, null, or 'Unavailable'"
      },
      {
        "name": "mechanical.cooling.systemType",
        "type": "string",
        "description": "Cooling system type: 'Cooling' or 'No Cooling'"
      },
      {
        "name": "occupancy.occupiedHours",
        "type": "number",
        "unit": "hours/yr",
        "description": "Occupied hours per year - default 4380"
      },
      {
        "name": "occupancy.totalHours",
        "type": "number",
        "unit": "hours/yr",
        "description": "Total hours per year - default 8760"
      },
      {
        "name": "mechanical.ventilation.summerBoost",
        "type": "number",
        "description": "Summer ventilation boost factor (l_119) - default 0 (treated as 1.0)"
      },
      {
        "name": "cooling.latentLoadFactor",
        "type": "number",
        "description": "Latent load multiplier from psychrometrics (>=1.0). Formula: 1 + humidityRatio/sensibleRatio. Default 1.0"
      },
      {
        "name": "mechanical.ventilation.efficiency",
        "type": "number",
        "unit": "%",
        "description": "HRV/ERV heat recovery efficiency - default 89%"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "CDD is numeric and > 0",
        "description": "CDD must be available and positive for cooling load to exist"
      }
    ],
    "invariants": [
      {
        "condition": "heatGain >= 0",
        "description": "Ventilation heat gain cannot be negative"
      },
      {
        "condition": "energyRecoveredCooling >= 0",
        "description": "Energy recovered cannot be negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "d_122: CDD undefined, null, unavailable, or 0",
      "output": "0",
      "note": "No cooling load when CDD not available or zero"
    },
    {
      "condition": "d_122: CDD > 0, systemType == 'Cooling'",
      "output": "(1.21 * ventRate * CDD * 24) / 1000 * occupancyFactor * summerBoostFactor * latentLoadFactor",
      "note": "Full formula with occupancy factor for active cooling systems"
    },
    {
      "condition": "d_122: CDD > 0, systemType != 'Cooling'",
      "output": "(1.21 * ventRate * CDD * 24) / 1000 * summerBoostFactor * latentLoadFactor",
      "note": "No occupancy factor applied for passive/no cooling - ventilation always runs"
    },
    {
      "condition": "d_123: always",
      "output": "d_122 * (efficiency / 100)",
      "note": "Energy recovered during cooling season by HRV/ERV"
    }
  ],
  "edgeCases": [
    {
      "condition": "CDD is undefined or null",
      "handling": "Return 0",
      "rationale": "No cooling degree days means no cooling ventilation load"
    },
    {
      "condition": "latentLoadFactor <= 0",
      "handling": "Use 1.0",
      "rationale": "Invalid latent load factor (from NaN fallback in CoolingNodes) defaults to sensible-only"
    },
    {
      "condition": "summerBoost == 0",
      "handling": "Use 1.0 (no boost)",
      "rationale": "Zero boost factor means no summer ventilation boost configured"
    },
    {
      "condition": "totalHours == 0",
      "handling": "occupancyFactor = 0.5",
      "rationale": "Prevent division by zero"
    }
  ],
  "formula": {
    "symbolic": "d_122 = (1.21 × ventRate × CDD × 24) / 1000 × [occFactor] × boostFactor × latentFactor; d_123 = d_122 × (eff/100); occFactor = occupiedHours/totalHours (Cooling only)",
    "implementation": "VentilationNodes.js:149-220"
  },
  "tests": [
    {
      "name": "CDD unavailable - returns 0",
      "inputs": {
        "climate.cooling.degreedays": "Unavailable"
      },
      "expected": 0
    },
    {
      "name": "CDD zero - returns 0",
      "inputs": {
        "ventilation.volumetricRate": 280,
        "climate.cooling.degreedays": 0
      },
      "expected": 0
    },
    {
      "name": "Active cooling with all factors",
      "inputs": {
        "ventilation.volumetricRate": 280,
        "climate.cooling.degreedays": 200,
        "mechanical.cooling.systemType": "Cooling",
        "occupancy.occupiedHours": 4380,
        "occupancy.totalHours": 8760,
        "mechanical.ventilation.summerBoost": 1.5,
        "cooling.latentLoadFactor": 1.2
      },
      "expected": 1464.24,
      "note": "base = (1.21 * 280 * 200 * 24) / 1000 = 1626.24; * 0.5 * 1.5 * 1.2 = 1464.216"
    },
    {
      "name": "No cooling - no occupancy factor",
      "inputs": {
        "ventilation.volumetricRate": 280,
        "climate.cooling.degreedays": 200,
        "mechanical.cooling.systemType": "No Cooling",
        "mechanical.ventilation.summerBoost": 0,
        "cooling.latentLoadFactor": 1.0
      },
      "expected": 1626.24,
      "note": "base = (1.21 * 280 * 200 * 24) / 1000 = 1626.24; boost=1.0, latent=1.0"
    },
    {
      "name": "Energy recovered cooling at 89%",
      "inputs": {
        "ventilation.heatGain": 1626.24,
        "mechanical.ventilation.efficiency": 89
      },
      "expected": 1447.35,
      "note": "d_123 = 1626.24 * 0.89 = 1447.3536"
    }
  ]
}
