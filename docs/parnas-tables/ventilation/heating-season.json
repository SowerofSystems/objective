{
  "_meta": {
    "description": "Heating season ventilation energy calculations. Gross heat loss uses degree-day method with volumetric heat capacity of air (1.21 kJ/m3K). Energy recovered applies HRV/ERV efficiency. Net loss is the difference.",
    "instances": [
      {
        "id": "ventilation.grossHeatLoss",
        "legacyId": "d_121",
        "label": "Ventilation Heating Load (kWh/yr)"
      },
      {
        "id": "ventilation.energyRecovered",
        "legacyId": "h_121",
        "label": "Ventilation Energy Recovered (kWh/yr)"
      },
      {
        "id": "ventilation.netHeatLoss",
        "legacyId": "m_121",
        "label": "Net Ventilation Heat Loss (kWh/yr)"
      }
    ]
  },
  "section": "S13",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "ventilation.volumetricRate",
        "type": "number",
        "unit": "L/s",
        "description": "Volumetric ventilation rate (d_120)"
      },
      {
        "name": "climate.heating.degreedays",
        "type": "number|string",
        "unit": "degree-days",
        "description": "Heating degree days. May be 'Unavailable' if climate data missing"
      },
      {
        "name": "mechanical.ventilation.efficiency",
        "type": "number",
        "unit": "%",
        "description": "HRV/ERV heat recovery efficiency - default 89%"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "climate.heating.degreedays is numeric",
        "description": "HDD must be available for gross heat loss calculation"
      }
    ],
    "invariants": [
      {
        "condition": "grossHeatLoss >= 0",
        "description": "Gross heat loss cannot be negative"
      },
      {
        "condition": "energyRecovered <= grossHeatLoss",
        "description": "Cannot recover more than total loss"
      },
      {
        "condition": "netHeatLoss >= 0",
        "description": "Net heat loss cannot be negative when efficiency <= 100%"
      }
    ]
  },
  "behavior": [
    {
      "condition": "d_121: HDD available",
      "output": "(1.21 * ventRate * HDD * 24) / 1000",
      "note": "1.21 is volumetric heat capacity of air (kJ/m3K). 24 converts degree-days to degree-hours. /1000 converts kJ to kWh"
    },
    {
      "condition": "d_121: HDD unavailable",
      "output": "'Unavailable'",
      "note": "Returns string 'Unavailable' when climate data missing"
    },
    {
      "condition": "h_121: always",
      "output": "grossHeatLoss * (efficiency / 100)",
      "note": "Energy recovered by HRV/ERV system"
    },
    {
      "condition": "m_121: always",
      "output": "grossHeatLoss - energyRecovered",
      "note": "Net heat loss after recovery"
    }
  ],
  "edgeCases": [
    {
      "condition": "HDD is 'Unavailable' or 'N/A'",
      "handling": "d_121 returns 'Unavailable'",
      "rationale": "Cannot compute ventilation heat loss without climate data"
    },
    {
      "condition": "efficiency not provided",
      "handling": "Default to 89%",
      "rationale": "Typical ERV efficiency"
    }
  ],
  "formula": {
    "symbolic": "d_121 = (1.21 × d_120 × HDD × 24) / 1000; h_121 = d_121 × (eff/100); m_121 = d_121 - h_121",
    "implementation": "VentilationNodes.js:96-142"
  },
  "tests": [
    {
      "name": "Typical heating season - gross loss",
      "inputs": {
        "ventilation.volumetricRate": 280,
        "climate.heating.degreedays": 4000
      },
      "expected": 32524.8,
      "note": "d_121 = (1.21 * 280 * 4000 * 24) / 1000 = 32524.8"
    },
    {
      "name": "Energy recovered at 89%",
      "inputs": {
        "ventilation.grossHeatLoss": 32524.8,
        "mechanical.ventilation.efficiency": 89
      },
      "expected": 28947.07,
      "note": "h_121 = 32524.8 * 0.89 = 28947.072"
    },
    {
      "name": "Net heat loss",
      "inputs": {
        "ventilation.grossHeatLoss": 32524.8,
        "ventilation.energyRecovered": 28947.07
      },
      "expected": 3577.73,
      "note": "m_121 = 32524.8 - 28947.07 = 3577.73"
    },
    {
      "name": "HDD unavailable",
      "inputs": {
        "ventilation.volumetricRate": 280,
        "climate.heating.degreedays": "Unavailable"
      },
      "expected": "Unavailable"
    }
  ]
}
