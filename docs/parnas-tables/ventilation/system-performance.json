{
  "_meta": {
    "description": "Heating and cooling system performance calculations. COP derivation converts HSPF to COP for heat pumps, uses 1.0 for electric resistance, or AFUE for combustion systems. Energy consumption divides total energy demand by COP.",
    "instances": [
      {
        "id": "heating.copDerived",
        "label": "Heating COP"
      },
      {
        "id": "heating.energyConsumption",
        "label": "Heating Energy Consumption (kWh/yr)"
      },
      {
        "id": "cooling.energyConsumption",
        "label": "Cooling Energy Consumption (kWh/yr)"
      }
    ]
  },
  "section": "S13",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "mechanical.heating.systemType",
        "type": "string",
        "description": "Heating system type: 'Heatpump', 'Electricity', 'Gas', 'Oil', etc."
      },
      {
        "name": "mechanical.heating.hspf",
        "type": "number",
        "unit": "BTU/Wh",
        "description": "Heating Seasonal Performance Factor - default 10"
      },
      {
        "name": "mechanical.heating.afue",
        "type": "number",
        "unit": "decimal",
        "description": "Annual Fuel Utilization Efficiency - default 0.95"
      },
      {
        "name": "energy.ted.heating",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total energy demand for heating"
      },
      {
        "name": "energy.ced.unmitigated",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Cooling energy demand (unmitigated)"
      },
      {
        "name": "mechanical.cooling.effectiveCop",
        "type": "number",
        "description": "Effective cooling COP - default 2.66"
      }
    ],
    "output": {
      "type": "number",
      "unit": "COP (dimensionless) or kWh/yr"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "systemType is valid",
        "description": "Heating system type must be recognized"
      }
    ],
    "invariants": [
      {
        "condition": "COP > 0",
        "description": "COP must be positive for division"
      },
      {
        "condition": "energyConsumption >= 0",
        "description": "Energy consumption cannot be negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "heating.copDerived: systemType == 'Heatpump'",
      "output": "HSPF / 3.412",
      "note": "Convert HSPF (BTU/Wh) to COP (dimensionless). 3.412 BTU = 1 Wh"
    },
    {
      "condition": "heating.copDerived: systemType == 'Electricity'",
      "output": "1.0",
      "note": "Electric resistance heating has COP of exactly 1.0"
    },
    {
      "condition": "heating.copDerived: other systemTypes",
      "output": "AFUE",
      "note": "Combustion systems use AFUE directly as efficiency (already decimal, e.g. 0.95)"
    },
    {
      "condition": "heating.energyConsumption: COP > 0",
      "output": "TED / COP",
      "note": "Total energy demand divided by coefficient of performance"
    },
    {
      "condition": "heating.energyConsumption: COP == 0",
      "output": "TED",
      "note": "Fallback: if COP is zero, return raw demand"
    },
    {
      "condition": "cooling.energyConsumption: effectiveCOP > 0",
      "output": "CED / effectiveCOP",
      "note": "Cooling energy demand divided by effective COP"
    },
    {
      "condition": "cooling.energyConsumption: effectiveCOP == 0",
      "output": "CED",
      "note": "Fallback: if COP is zero, return raw demand"
    }
  ],
  "edgeCases": [
    {
      "condition": "COP parses to 0",
      "handling": "Return raw demand (TED or CED)",
      "rationale": "Prevent division by zero"
    },
    {
      "condition": "HSPF default",
      "handling": "Default to 10 (COP ~2.93)",
      "rationale": "Typical mid-range heat pump"
    },
    {
      "condition": "effectiveCOP default",
      "handling": "Default to 2.66",
      "rationale": "Baseline cooling efficiency"
    }
  ],
  "formula": {
    "symbolic": "COP = CASE(type, HSPF/3.412, 1.0, AFUE); heatingConsumption = TED/COP; coolingConsumption = CED/effectiveCOP",
    "implementation": "VentilationNodes.js:227-282"
  },
  "tests": [
    {
      "name": "Heatpump COP from HSPF",
      "inputs": {
        "mechanical.heating.systemType": "Heatpump",
        "mechanical.heating.hspf": 10
      },
      "expected": 2.931,
      "note": "COP = 10 / 3.412 = 2.931"
    },
    {
      "name": "Electric resistance COP",
      "inputs": {
        "mechanical.heating.systemType": "Electricity"
      },
      "expected": 1.0
    },
    {
      "name": "Gas furnace COP from AFUE",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "mechanical.heating.afue": 0.96
      },
      "expected": 0.96
    },
    {
      "name": "Heating energy consumption",
      "inputs": {
        "energy.ted.heating": 50000,
        "heating.copDerived": 2.931
      },
      "expected": 17058.34,
      "note": "50000 / 2.931 = 17058.34"
    },
    {
      "name": "Cooling energy consumption",
      "inputs": {
        "energy.ced.unmitigated": 10000,
        "mechanical.cooling.effectiveCop": 2.66
      },
      "expected": 3759.4,
      "note": "10000 / 2.66 = 3759.4"
    }
  ]
}
