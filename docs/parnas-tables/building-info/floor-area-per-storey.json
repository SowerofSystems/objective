{
  "id": "building.floorAreaPerStorey",
  "label": "Floor Area per Storey (m\u00b2)",
  "section": "S02",
  "classification": "G",
  "_meta": {
    "description": "Calculates the average floor area per storey by dividing total conditioned floor area by number of storeys. Used for envelope and footprint calculations."
  },
  "signature": {
    "inputs": [
      { "name": "building.conditionedFloorArea", "type": "number", "unit": "m\u00b2", "description": "Conditioned floor area (h_15)" },
      { "name": "building.numStoreys", "type": "number", "description": "Number of storeys (d_16_storeys)" }
    ],
    "output": { "type": "number", "unit": "m\u00b2" }
  },
  "domain": {
    "preconditions": [
      { "condition": "area >= 0", "description": "Floor area must be non-negative" },
      { "condition": "storeys >= 1", "description": "At least one storey" }
    ],
    "invariants": [
      { "condition": "output >= 0", "description": "Area per storey is non-negative" },
      { "condition": "output <= area", "description": "Per-storey area cannot exceed total area" }
    ]
  },
  "behavior": [
    {
      "condition": "storeys > 0",
      "output": "area / storeys",
      "note": "Standard division"
    },
    {
      "condition": "storeys <= 0",
      "output": "area",
      "note": "Guard against division by zero -- returns total area as fallback"
    }
  ],
  "edgeCases": [
    {
      "condition": "storeys is 0 or negative",
      "handling": "Returns total area (no division)",
      "rationale": "Prevents division by zero; assumes single-storey building"
    },
    {
      "condition": "storeys is non-numeric",
      "handling": "parseFloat falls back to 1",
      "rationale": "Default to single storey"
    },
    {
      "condition": "Area is non-numeric",
      "handling": "parseFloat returns 0",
      "rationale": "Defensive parsing"
    }
  ],
  "formula": {
    "symbolic": "floorAreaPerStorey = h_15 / d_16_storeys",
    "implementation": "BuildingInfoNodes.js:261-275"
  },
  "tests": [
    {
      "name": "Default values: 2 storeys",
      "inputs": { "building.conditionedFloorArea": 1427.2, "building.numStoreys": 2 },
      "expected": 713.6,
      "note": "1427.2 / 2 = 713.6"
    },
    {
      "name": "Single storey",
      "inputs": { "building.conditionedFloorArea": 500, "building.numStoreys": 1 },
      "expected": 500
    },
    {
      "name": "Three storeys",
      "inputs": { "building.conditionedFloorArea": 3000, "building.numStoreys": 3 },
      "expected": 1000
    },
    {
      "name": "Zero storeys fallback",
      "inputs": { "building.conditionedFloorArea": 1000, "building.numStoreys": 0 },
      "expected": 1000,
      "note": "Division guard: returns full area when storeys=0"
    }
  ],
  "references": [
    { "source": "BuildingInfoNodes.js:261-275" }
  ]
}
