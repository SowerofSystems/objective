{
  "id": "building.isTargetMode",
  "label": "Is Target Mode",
  "section": "S02",
  "classification": "A",
  "_meta": {
    "description": "Boolean flag indicating whether the analysis is in Target mode (as opposed to Utility Bills mode). Many downstream nodes use this to switch between actual energy data and target/modelled values."
  },
  "signature": {
    "inputs": [
      { "name": "building.analysisMode", "type": "string", "description": "Analysis mode selection (d_14): 'Utility Bills' or any target mode string" }
    ],
    "output": { "type": "boolean" }
  },
  "domain": {
    "preconditions": [],
    "invariants": [
      { "condition": "output is strictly boolean", "description": "true or false only" }
    ]
  },
  "behavior": [
    {
      "condition": "mode = 'Utility Bills'",
      "output": "false",
      "note": "Utility Bills mode uses actual consumption data"
    },
    {
      "condition": "mode != 'Utility Bills'",
      "output": "true",
      "note": "Any other mode (e.g. 'Target', 'Design') is considered target mode"
    }
  ],
  "edgeCases": [
    {
      "condition": "mode is null/undefined",
      "handling": "Defaults to 'Utility Bills', returns false",
      "rationale": "Fallback to utility bills mode when no selection made"
    }
  ],
  "formula": {
    "symbolic": "isTargetMode = (d_14 !== 'Utility Bills')",
    "implementation": "BuildingInfoNodes.js:278-288"
  },
  "tests": [
    {
      "name": "Utility Bills mode",
      "inputs": { "building.analysisMode": "Utility Bills" },
      "expected": false
    },
    {
      "name": "Target mode",
      "inputs": { "building.analysisMode": "Target" },
      "expected": true
    },
    {
      "name": "Design mode",
      "inputs": { "building.analysisMode": "Design" },
      "expected": true
    },
    {
      "name": "Null defaults to Utility Bills",
      "inputs": { "building.analysisMode": null },
      "expected": false
    }
  ],
  "references": [
    { "source": "BuildingInfoNodes.js:278-288" }
  ]
}
