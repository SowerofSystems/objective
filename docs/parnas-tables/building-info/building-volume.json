{
  "id": "building.volume",
  "label": "Building Volume (m\u00b3)",
  "section": "S02",
  "classification": "G",
  "_meta": {
    "description": "Calculates total conditioned building volume from floor area and ceiling height. Used downstream for air change rate and ventilation calculations."
  },
  "signature": {
    "inputs": [
      { "name": "building.conditionedFloorArea", "type": "number", "unit": "m\u00b2", "description": "Conditioned floor area (h_15)" },
      { "name": "building.ceilingHeight", "type": "number", "unit": "m", "description": "Ceiling height (h_17)" }
    ],
    "output": { "type": "number", "unit": "m\u00b3" }
  },
  "domain": {
    "preconditions": [
      { "condition": "area > 0", "description": "Floor area must be positive" },
      { "condition": "height > 0", "description": "Ceiling height must be positive" }
    ],
    "invariants": [
      { "condition": "output >= 0", "description": "Volume is non-negative" }
    ]
  },
  "behavior": [
    {
      "condition": "always",
      "output": "area * ceilingHeight",
      "note": "Simple volume calculation"
    }
  ],
  "edgeCases": [
    {
      "condition": "Floor area is 0 or non-numeric",
      "handling": "parseFloat returns 0, volume = 0",
      "rationale": "Defensive parsing"
    },
    {
      "condition": "Ceiling height is non-numeric",
      "handling": "parseFloat falls back to 2.7 m default",
      "rationale": "Typical residential ceiling height as fallback"
    }
  ],
  "formula": {
    "symbolic": "volume = h_15 * h_17",
    "implementation": "BuildingInfoNodes.js:244-258"
  },
  "tests": [
    {
      "name": "Default values",
      "inputs": { "building.conditionedFloorArea": 1427.2, "building.ceilingHeight": 2.7 },
      "expected": 3853.44,
      "note": "1427.2 * 2.7 = 3853.44"
    },
    {
      "name": "Round numbers",
      "inputs": { "building.conditionedFloorArea": 1000, "building.ceilingHeight": 3 },
      "expected": 3000
    },
    {
      "name": "Zero area",
      "inputs": { "building.conditionedFloorArea": 0, "building.ceilingHeight": 2.7 },
      "expected": 0
    }
  ],
  "references": [
    { "source": "BuildingInfoNodes.js:244-258" }
  ]
}
