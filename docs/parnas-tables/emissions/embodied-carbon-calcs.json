{
  "id": "emissions.embodiedCalcs",
  "label": "Embodied Carbon Calculations (S05)",
  "section": "S05",
  "classification": "C",
  "_meta": {
    "description": "Embodied carbon target passthrough, total embodied carbon (per-area to absolute MT), and lifetime avoided operational emissions comparing project to reference.",
    "instances": [
      { "id": "emissions.embodiedTarget", "legacyId": "i_40", "label": "Embodied Carbon Target (kgCO2e/m²)" },
      { "id": "emissions.embodied.total", "legacyId": "d_40", "label": "Total Embodied Carbon (MT CO2e)" },
      { "id": "emissions.avoidedLifetime", "legacyId": "d_41", "label": "Lifetime Avoided Operational (MT CO2e)" }
    ]
  },
  "signature": {
    "inputs": [
      { "name": "building.embodiedCarbonTarget", "type": "number|string", "description": "d_16, can be 'N/A'" },
      { "name": "building.userModelledEmbodiedCarbon", "type": "number", "description": "i_41" },
      { "name": "geometry.totalFloorArea", "type": "number", "unit": "m²", "description": "d_106" },
      { "name": "emissions.operational.mt", "type": "number", "unit": "MT CO2e/yr", "description": "d_38" },
      { "name": "reference.emissions.operational.mt", "type": "number", "description": "ref_d_38" },
      { "name": "building.serviceLife", "type": "number", "description": "h_13, default 50" }
    ],
    "output": { "type": "number|string" }
  },
  "domain": { "preconditions": [], "invariants": [] },
  "behavior": [
    { "condition": "i_40: numeric target", "output": "passthrough of building.embodiedCarbonTarget" },
    { "condition": "i_40: target is 'N/A'", "output": "'N/A'" },
    { "condition": "d_40", "output": "i_41 × d_106 / 1000", "note": "kgCO2e/m² × m² / 1000 = MT" },
    { "condition": "d_41", "output": "(ref_d_38 - d_38) × h_13", "note": "Negative if project worse than reference" }
  ],
  "edgeCases": [
    { "condition": "Target is 'N/A'", "handling": "i_40 returns 'N/A' string" },
    { "condition": "d_38 > ref_d_38", "handling": "d_41 is negative" }
  ],
  "formula": {
    "symbolic": "i_40 = passthrough; d_40 = i_41 * d_106 / 1000; d_41 = (ref_d_38 - d_38) * h_13",
    "implementation": "EmissionsNodes.js:1042-1085"
  },
  "tests": [
    { "name": "d_40 total embodied", "inputs": { "building.userModelledEmbodiedCarbon": 345.82, "geometry.totalFloorArea": 200 }, "expected": 69.164 },
    { "name": "d_41 avoided (better)", "inputs": { "reference.emissions.operational.mt": 10, "emissions.operational.mt": 5, "building.serviceLife": 50 }, "expected": 250 }
  ]
}
