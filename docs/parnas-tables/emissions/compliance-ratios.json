{
  "id": "compliance.s05",
  "label": "S05 Compliance Ratios (m_38-m_41, n_38-n_41)",
  "section": "S05",
  "classification": "C",
  "_meta": {
    "description": "Compliance ratio and pass/fail nodes for S05 emissions metrics. Each metric has a ratio (formatted as 'NN%') and a status (checkmark/X). Ratio = round((project/reference) × 100). Pass = ratio ≤ 100%.",
    "instances": [
      { "id": "compliance.operational.ratio", "legacyId": "m_38", "label": "Operational Compliance Ratio" },
      { "id": "compliance.operational.pass", "legacyId": "n_38", "label": "Operational Compliance Status" },
      { "id": "compliance.typology.ratio", "legacyId": "m_39", "label": "Typology Compliance Ratio" },
      { "id": "compliance.typology.pass", "legacyId": "n_39", "label": "Typology Compliance Status" },
      { "id": "compliance.embodied.ratio", "legacyId": "m_40", "label": "Embodied Compliance Ratio" },
      { "id": "compliance.embodied.pass", "legacyId": "n_40", "label": "Embodied Compliance Status" },
      { "id": "compliance.userModelled.ratio", "legacyId": "m_41", "label": "User Modelled Compliance Ratio" },
      { "id": "compliance.userModelled.pass", "legacyId": "n_41", "label": "User Modelled Compliance Status" }
    ]
  },
  "signature": {
    "inputs": [
      { "name": "emissions.ghgi.annual", "type": "number", "description": "g_38" },
      { "name": "reference.emissions.ghgi.annual", "type": "number", "description": "ref_g_38" },
      { "name": "building.typologyEmbodiedCarbon", "type": "number", "description": "i_39" },
      { "name": "reference.emissions.typologyCarbon", "type": "number", "description": "ref_i_39, default 350" },
      { "name": "emissions.embodied.total", "type": "number", "description": "d_40" },
      { "name": "reference.emissions.embodied.total", "type": "number", "description": "ref_d_40" },
      { "name": "building.userModelledEmbodiedCarbon", "type": "number", "description": "i_41" },
      { "name": "reference.emissions.userModelled", "type": "number", "description": "ref_i_41, default 345.82" }
    ],
    "output": { "type": "string", "description": "'NN%' for ratios, '✓' or '✗' for status" }
  },
  "domain": { "preconditions": [], "invariants": [] },
  "behavior": [
    { "condition": "m_XX: ref > 0", "output": "Math.round((project / ref) × 100) + '%'" },
    { "condition": "m_XX: ref = 0", "output": "'100%'" },
    { "condition": "n_XX: ref > 0 and ratio ≤ 1.0", "output": "'✓'" },
    { "condition": "n_XX: ref = 0 or ratio > 1.0", "output": "'✗'" }
  ],
  "edgeCases": [
    { "condition": "Reference is 0", "handling": "Ratio = '100%', status = '✗'" },
    { "condition": "Exactly equal", "handling": "Ratio = '100%', status = '✓'" }
  ],
  "formula": {
    "symbolic": "m = round((project/ref)*100) + '%'; n = (ref>0 && project/ref<=1.0) ? '✓' : '✗'",
    "implementation": "EmissionsNodes.js:1131-1232"
  },
  "tests": [
    { "name": "m_38 below reference", "inputs": { "emissions.ghgi.annual": 15, "reference.emissions.ghgi.annual": 25 }, "expected": "60%" },
    { "name": "n_38 pass", "inputs": { "emissions.ghgi.annual": 15, "reference.emissions.ghgi.annual": 25 }, "expected": "✓" },
    { "name": "n_38 fail", "inputs": { "emissions.ghgi.annual": 30, "reference.emissions.ghgi.annual": 25 }, "expected": "✗" },
    { "name": "m_41 at boundary", "inputs": { "building.userModelledEmbodiedCarbon": 345.82, "reference.emissions.userModelled": 345.82 }, "expected": "100%" }
  ]
}
