{
  "id": "energy.actual",
  "label": "Actual Energy and Emissions (f_27-f_31, g_27-g_31)",
  "section": "S04",
  "classification": "C",
  "_meta": {
    "description": "Actual energy consumption (kWh conversion from raw bills) and actual emissions (energy × emission factor). f_27 is net of renewables; f_28-f_31 are unit conversions; g_27-g_31 are emissions calculations.",
    "instances": [
      { "id": "energy.actual.electricity", "legacyId": "f_27", "label": "Actual Electricity (kWh/yr)" },
      { "id": "energy.actual.gas", "legacyId": "f_28", "label": "Actual Gas (kWh/yr)" },
      { "id": "energy.actual.propane", "legacyId": "f_29", "label": "Actual Propane (kWh/yr)" },
      { "id": "energy.actual.oil", "legacyId": "f_30", "label": "Actual Oil (kWh/yr)" },
      { "id": "energy.actual.wood", "legacyId": "f_31", "label": "Actual Wood (kWh/yr)" },
      { "id": "emissions.actual.electricity", "legacyId": "g_27", "label": "Actual Electricity Emissions (kg CO2e/yr)" },
      { "id": "emissions.actual.gas", "legacyId": "g_28", "label": "Actual Gas Emissions (kg CO2e/yr)" },
      { "id": "emissions.actual.propane", "legacyId": "g_29", "label": "Actual Propane Emissions (kg CO2e/yr)" },
      { "id": "emissions.actual.oil", "legacyId": "g_30", "label": "Actual Oil Emissions (kg CO2e/yr)" },
      { "id": "emissions.actual.wood", "legacyId": "g_31", "label": "Actual Wood Emissions (kg CO2e/yr)" }
    ]
  },
  "signature": {
    "inputs": [
      { "name": "energy.raw.electricity", "type": "number", "unit": "kWh/yr", "description": "Raw electricity bills (d_27)" },
      { "name": "renewable.onsiteTotal", "type": "number", "unit": "kWh/yr", "description": "Onsite renewables (d_43)" },
      { "name": "renewable.offsiteTotal", "type": "number", "unit": "kWh/yr", "description": "Offsite renewables (i_43)" },
      { "name": "energy.raw.gas", "type": "number", "unit": "m³/yr", "description": "Raw gas bills (d_28)" },
      { "name": "energy.actual.propane.kg", "type": "number", "unit": "kg/yr", "description": "Propane (d_29)" },
      { "name": "energy.raw.oil", "type": "number", "unit": "L/yr", "description": "Raw oil bills (d_30)" },
      { "name": "forestry.woodVolume", "type": "number", "unit": "m³/yr", "description": "Wood volume (d_31)" },
      { "name": "emissions.factor.electricity", "type": "number", "description": "l_27" },
      { "name": "emissions.factor.gas", "type": "number", "description": "l_28, default 1921" },
      { "name": "emissions.factor.propane", "type": "number", "description": "l_29, default 2970" },
      { "name": "emissions.factor.oil", "type": "number", "description": "l_30, default 2753" },
      { "name": "emissions.factor.wood", "type": "number", "description": "l_31, default 150" }
    ],
    "output": { "type": "number" }
  },
  "domain": { "preconditions": [], "invariants": [] },
  "behavior": [
    { "condition": "f_27", "output": "d_27 - d_43 - i_43", "note": "Net of renewables" },
    { "condition": "f_28", "output": "d_28 × 0.0373 × 277.7778", "note": "m³ to kWh" },
    { "condition": "f_29", "output": "d_29 × 14.019", "note": "kg to kWh" },
    { "condition": "f_30", "output": "d_30 × 36.72 × 0.2777778", "note": "L to kWh" },
    { "condition": "f_31", "output": "d_31 × 1000", "note": "m³ to kWh" },
    { "condition": "g_27", "output": "f_27 × l_27 / 1000" },
    { "condition": "g_28", "output": "d_28 × l_28 / 1000", "note": "Uses raw volume, not kWh" },
    { "condition": "g_29", "output": "d_29 × l_29 / 1000" },
    { "condition": "g_30", "output": "d_30 × l_30 / 1000" },
    { "condition": "g_31", "output": "d_31 × l_31", "note": "No /1000, factor already in kgCO2e" }
  ],
  "edgeCases": [],
  "formula": {
    "symbolic": "f = raw × conversion_factor; g = raw × emission_factor / 1000 (except wood)",
    "implementation": "EmissionsNodes.js:207-357"
  },
  "tests": [
    { "name": "f_27 net electricity", "inputs": { "energy.raw.electricity": 20000, "renewable.onsiteTotal": 3000, "renewable.offsiteTotal": 1000 }, "expected": 16000 },
    { "name": "g_27 electricity emissions", "inputs": { "energy.actual.electricity": 16000, "emissions.factor.electricity": 51 }, "expected": 816 }
  ]
}
