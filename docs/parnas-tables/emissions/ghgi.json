{
  "id": "emissions.ghgi",
  "label": "GHGI Calculations (S05)",
  "section": "S05",
  "classification": "C",
  "_meta": {
    "description": "Greenhouse Gas Intensity calculations. Annual GHGI normalizes target emissions by floor area. Lifetime operational multiplies by service life. Total lifetime adds embodied. Operational MT converts kg to metric tonnes.",
    "instances": [
      { "id": "emissions.ghgi.annual", "legacyId": "g_38", "label": "Annual GHG Intensity (kg CO2e/m²/yr)" },
      { "id": "emissions.ghgi.lifetime", "legacyId": "i_38", "label": "Lifetime Operational Emissions (kg CO2e/m²)" },
      { "id": "emissions.lifetime.total", "legacyId": null, "label": "Total Lifetime Carbon (kg CO2e/m²)" },
      { "id": "emissions.operational.mt", "legacyId": "d_38", "label": "Operational Emissions (MT CO2e/yr)" }
    ]
  },
  "signature": {
    "inputs": [
      { "name": "emissions.target.subtotal", "type": "number", "unit": "kg CO2e/yr", "description": "k_32" },
      { "name": "building.conditionedFloorArea", "type": "number", "unit": "m²", "description": "h_15" },
      { "name": "building.serviceLife", "type": "number", "unit": "years", "description": "h_13, default 50" },
      { "name": "building.userModelledEmbodiedCarbon", "type": "number", "unit": "kgCO2e/m²", "description": "i_41" }
    ],
    "output": { "type": "number" }
  },
  "domain": { "preconditions": [{ "condition": "h_15 > 0", "description": "Floor area must be positive" }], "invariants": [] },
  "behavior": [
    { "condition": "g_38", "output": "k_32 / h_15", "note": "Returns 0 if h_15 = 0" },
    { "condition": "i_38", "output": "g_38 × h_13" },
    { "condition": "lifetime.total", "output": "i_38 + i_41" },
    { "condition": "d_38", "output": "k_32 / 1000" }
  ],
  "edgeCases": [
    { "condition": "h_15 = 0", "handling": "g_38 returns 0", "rationale": "Division guard" }
  ],
  "formula": {
    "symbolic": "g_38 = k_32/h_15; i_38 = g_38*h_13; total = i_38+i_41; d_38 = k_32/1000",
    "implementation": "EmissionsNodes.js:748-791, 1031-1039"
  },
  "tests": [
    { "name": "g_38 annual GHGI", "inputs": { "emissions.target.subtotal": 5000, "building.conditionedFloorArea": 200 }, "expected": 25 },
    { "name": "i_38 lifetime", "inputs": { "emissions.ghgi.annual": 25, "building.serviceLife": 50 }, "expected": 1250 },
    { "name": "d_38 MT", "inputs": { "emissions.target.subtotal": 5000 }, "expected": 5 }
  ]
}
