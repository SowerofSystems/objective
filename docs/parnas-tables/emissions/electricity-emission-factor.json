{
  "id": "emissions.factor.electricity",
  "legacyId": "l_27",
  "label": "Electricity Emission Factor (gCO2e/kWh)",
  "section": "S04",
  "classification": "C",
  "_meta": {
    "description": "Provincial grid electricity emission factor based on province and reporting year. Ontario has year-specific factors from 2015-2050 reflecting grid decarbonization projections; all other provinces use a single default value."
  },
  "signature": {
    "inputs": [
      { "name": "climate.location.province", "type": "string", "description": "Two-letter province/territory code" },
      { "name": "building.reportingYear", "type": "number", "description": "Reporting year (h_12), default 2022" }
    ],
    "output": { "type": "number", "unit": "gCO2e/kWh" }
  },
  "domain": { "preconditions": [], "invariants": [] },
  "behavior": [
    { "condition": "province has year-specific factor (ON only)", "output": "GRID_INTENSITY_FACTORS[province][year]" },
    { "condition": "province has no year-specific factor", "output": "GRID_INTENSITY_FACTORS[province].default" },
    { "condition": "province unrecognized", "output": "Falls back to ON factors" }
  ],
  "edgeCases": [
    { "condition": "Province not in lookup", "handling": "Use ON factors", "rationale": "Ontario is most common" }
  ],
  "formula": {
    "symbolic": "GRID_INTENSITY_FACTORS[province][year] || GRID_INTENSITY_FACTORS[province].default",
    "implementation": "EmissionsNodes.js:94-107",
    "lookup_tables": {
      "ON_defaults": 51, "QC": 1, "BC": 12, "AB": 650, "SK": 720, "MB": 3,
      "NS": 600, "NB": 340, "NL": 30, "PE": 12, "NT": 180, "YT": 2, "NU": 200
    }
  },
  "tests": [
    { "name": "Ontario 2022", "inputs": { "climate.location.province": "ON", "building.reportingYear": 2022 }, "expected": 51 },
    { "name": "Alberta default", "inputs": { "climate.location.province": "AB", "building.reportingYear": 2022 }, "expected": 650 },
    { "name": "Quebec hydro", "inputs": { "climate.location.province": "QC", "building.reportingYear": 2022 }, "expected": 1 }
  ]
}
