{
  "_meta": {
    "description": "Fuel volume calculations for combustion water heating systems. Gas volume converts net energy demand to cubic metres of natural gas. Oil volume converts net energy demand to litres of heating oil. Both are zero for non-matching fuel types.",
    "instances": [
      {
        "id": "waterHeating.gasVolume",
        "legacyId": "e_51",
        "label": "Water Heating Gas Volume (m3/yr)"
      },
      {
        "id": "waterHeating.oilVolume",
        "legacyId": "k_54",
        "label": "Water Heating Oil Volume (L/yr)"
      }
    ]
  },
  "section": "S07",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "waterHeating.systemType",
        "type": "string",
        "description": "System type: 'Gas', 'Oil', 'Electric', 'Heatpump'"
      },
      {
        "name": "waterHeating.netDemandAfterRecovery",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Net demand after DWHR recovery (j_52)"
      },
      {
        "name": "waterHeating.efficiencyDecimal",
        "type": "number",
        "description": "System efficiency as decimal (e_52)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "m3/yr (gas) or L/yr (oil)"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "efficiencyDecimal > 0",
        "description": "Efficiency must be positive for volume calculation"
      }
    ],
    "invariants": [
      {
        "condition": "gasVolume >= 0",
        "description": "Gas volume cannot be negative"
      },
      {
        "condition": "oilVolume >= 0",
        "description": "Oil volume cannot be negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "e_51: systemType == 'Gas'",
      "output": "netDemand / (0.0373 * 277.7778 * efficiencyDecimal)",
      "note": "0.0373 GJ/m3 * 277.7778 kWh/GJ = 10.3611 kWh/m3 natural gas energy content"
    },
    {
      "condition": "e_51: systemType != 'Gas'",
      "output": "0",
      "note": "Gas volume only applies to gas-fired systems"
    },
    {
      "condition": "k_54: systemType == 'Oil'",
      "output": "netDemand / (10.18 * efficiencyDecimal)",
      "note": "10.18 kWh/L is the energy content of heating oil"
    },
    {
      "condition": "k_54: systemType != 'Oil'",
      "output": "0",
      "note": "Oil volume only applies to oil-fired systems"
    }
  ],
  "edgeCases": [
    {
      "condition": "efficiencyDecimal == 0",
      "handling": "Return 0 (divisor check)",
      "rationale": "Prevent division by zero"
    },
    {
      "condition": "divisor evaluates to 0",
      "handling": "Return 0",
      "rationale": "Safety check for combined divisor product"
    }
  ],
  "formula": {
    "symbolic": "e_51 = IF(Gas, j_52 / (0.0373 * 277.7778 * e_52), 0); k_54 = IF(Oil, j_52 / (10.18 * e_52), 0)",
    "implementation": "WaterHeatingNodes.js:209-243"
  },
  "tests": [
    {
      "name": "Gas volume - typical",
      "inputs": {
        "waterHeating.systemType": "Gas",
        "waterHeating.netDemandAfterRecovery": 5000,
        "waterHeating.efficiencyDecimal": 0.95
      },
      "expected": 508.07,
      "note": "e_51 = 5000 / (0.0373 * 277.7778 * 0.95) = 5000 / 9.843 = 508.07"
    },
    {
      "name": "Gas volume - non-gas system",
      "inputs": {
        "waterHeating.systemType": "Electric",
        "waterHeating.netDemandAfterRecovery": 5000,
        "waterHeating.efficiencyDecimal": 1.0
      },
      "expected": 0
    },
    {
      "name": "Oil volume - typical",
      "inputs": {
        "waterHeating.systemType": "Oil",
        "waterHeating.netDemandAfterRecovery": 5000,
        "waterHeating.efficiencyDecimal": 0.85
      },
      "expected": 578.03,
      "note": "k_54 = 5000 / (10.18 * 0.85) = 5000 / 8.653 = 578.03"
    },
    {
      "name": "Oil volume - non-oil system",
      "inputs": {
        "waterHeating.systemType": "Gas",
        "waterHeating.netDemandAfterRecovery": 5000,
        "waterHeating.efficiencyDecimal": 0.95
      },
      "expected": 0
    }
  ]
}
