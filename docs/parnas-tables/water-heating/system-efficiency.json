{
  "_meta": {
    "description": "Water heating system efficiency calculations. Net electrical demand applies to Heatpump/Electric systems only (demand divided by efficiency, minus DWHR recovery). Efficiency decimal is a unit conversion. Net thermal demand divides raw demand by efficiency. Net demand after recovery subtracts DWHR energy.",
    "instances": [
      {
        "id": "waterHeating.netElectricalDemand",
        "legacyId": "k_51",
        "label": "Net Electrical Demand (kWh/yr)"
      },
      {
        "id": "waterHeating.efficiencyDecimal",
        "legacyId": "e_52",
        "label": "Water Heating Efficiency (decimal)"
      },
      {
        "id": "waterHeating.netThermalDemand",
        "legacyId": "j_51",
        "label": "Net Thermal Demand (kWh/yr)"
      },
      {
        "id": "waterHeating.netDemandAfterRecovery",
        "legacyId": "j_52",
        "label": "Net Demand After Recovery (kWh/yr)"
      }
    ]
  },
  "section": "S07",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "waterHeating.energyDemand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Hot water energy demand (j_50)"
      },
      {
        "name": "waterHeating.efficiency",
        "type": "number",
        "unit": "%",
        "description": "Water heating efficiency percentage (d_52) - default 100. Heat pumps can be >100%"
      },
      {
        "name": "waterHeating.systemType",
        "type": "string",
        "description": "System type: 'Heatpump', 'Electric', 'Gas', 'Oil'"
      },
      {
        "name": "waterHeating.dwhrEfficiency",
        "type": "number",
        "unit": "%",
        "description": "Drain water heat recovery efficiency (d_53) - default 0, range 0-70%"
      },
      {
        "name": "waterHeating.efficiencyDecimal",
        "type": "number",
        "description": "Efficiency as decimal (e_52) - used by j_51"
      },
      {
        "name": "waterHeating.netThermalDemand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Net thermal demand (j_51) - used by j_52"
      },
      {
        "name": "waterHeating.energyRecovered",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Energy recovered via DWHR (e_53) - used by j_52"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr or decimal"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "efficiency > 0",
        "description": "Efficiency must be positive for division"
      }
    ],
    "invariants": [
      {
        "condition": "efficiencyDecimal > 0",
        "description": "Efficiency decimal must be positive"
      },
      {
        "condition": "netDemandAfterRecovery <= netThermalDemand",
        "description": "Recovery can only reduce demand"
      }
    ]
  },
  "behavior": [
    {
      "condition": "k_51: systemType in ['Heatpump', 'Electric']",
      "output": "demand / (efficiency / 100) - (demand / (efficiency / 100)) * (dwhrEff / 100)",
      "note": "Net electrical demand: thermal demand adjusted by efficiency, minus DWHR recovery"
    },
    {
      "condition": "k_51: systemType not in ['Heatpump', 'Electric']",
      "output": "0",
      "note": "Gas/Oil systems have no electrical demand"
    },
    {
      "condition": "e_52: always",
      "output": "efficiency / 100",
      "note": "Convert percentage to decimal. 300% efficiency (heat pump) becomes 3.0"
    },
    {
      "condition": "j_51: efficiencyDecimal > 0",
      "output": "energyDemand / efficiencyDecimal",
      "note": "Raw demand divided by efficiency. For heat pumps (eff > 1), this reduces the thermal demand"
    },
    {
      "condition": "j_51: efficiencyDecimal == 0",
      "output": "energyDemand",
      "note": "Fallback for zero efficiency"
    },
    {
      "condition": "j_52: always",
      "output": "netThermalDemand - energyRecovered",
      "note": "Net demand minus DWHR recovery"
    }
  ],
  "edgeCases": [
    {
      "condition": "efficiency == 0",
      "handling": "Use raw demand (no division)",
      "rationale": "Prevent division by zero"
    },
    {
      "condition": "DWHR efficiency == 0 (no recovery system)",
      "handling": "k_51 reduces to demand/efficiency; j_52 = j_51",
      "rationale": "No drain water heat recovery installed"
    },
    {
      "condition": "Heat pump efficiency > 100%",
      "handling": "efficiencyDecimal > 1.0 is valid",
      "rationale": "Heat pumps have COP > 1 (e.g., 300% = COP 3.0)"
    }
  ],
  "formula": {
    "symbolic": "k_51 = (demand/eff - demand/eff * dwhrEff) IF electric; e_52 = eff/100; j_51 = demand/e_52; j_52 = j_51 - e_53",
    "implementation": "WaterHeatingNodes.js:101-187"
  },
  "tests": [
    {
      "name": "Net electrical demand - heat pump with DWHR",
      "inputs": {
        "waterHeating.systemType": "Heatpump",
        "waterHeating.energyDemand": 5000,
        "waterHeating.efficiency": 300,
        "waterHeating.dwhrEfficiency": 50
      },
      "expected": 833.33,
      "note": "netThermal = 5000/3.0 = 1666.67; recovered = 1666.67 * 0.5 = 833.33; net = 833.33"
    },
    {
      "name": "Net electrical demand - Gas system returns 0",
      "inputs": {
        "waterHeating.systemType": "Gas",
        "waterHeating.energyDemand": 5000,
        "waterHeating.efficiency": 95
      },
      "expected": 0
    },
    {
      "name": "Efficiency decimal - heat pump",
      "inputs": {
        "waterHeating.efficiency": 300
      },
      "expected": 3.0
    },
    {
      "name": "Efficiency decimal - gas furnace",
      "inputs": {
        "waterHeating.efficiency": 95
      },
      "expected": 0.95
    },
    {
      "name": "Net thermal demand",
      "inputs": {
        "waterHeating.energyDemand": 5000,
        "waterHeating.efficiencyDecimal": 0.95
      },
      "expected": 5263.16,
      "note": "j_51 = 5000 / 0.95 = 5263.16"
    },
    {
      "name": "Net demand after recovery",
      "inputs": {
        "waterHeating.netThermalDemand": 5263.16,
        "waterHeating.energyRecovered": 1000
      },
      "expected": 4263.16,
      "note": "j_52 = 5263.16 - 1000 = 4263.16"
    }
  ]
}
