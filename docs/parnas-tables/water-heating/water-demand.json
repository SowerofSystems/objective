{
  "_meta": {
    "description": "Water demand calculations. Litres per person per day (lpppd) is determined by method: 'By Engineer' reverse-calculates from kWh input, 'User Defined' uses direct input, standard methods use fixed lookup values. Energy demand, annual water use, and annual DHW use derive from lpppd.",
    "instances": [
      {
        "id": "waterHeating.lpppd",
        "legacyId": "h_49",
        "label": "Litres per Person per Day"
      },
      {
        "id": "waterHeating.energyDemand",
        "legacyId": "j_50",
        "label": "Hot Water Energy Demand (kWh/yr)"
      },
      {
        "id": "waterHeating.annualWaterUse",
        "legacyId": "i_49",
        "label": "Annual Water Use (L/yr)"
      },
      {
        "id": "waterHeating.annualDhwUse",
        "legacyId": "i_50",
        "label": "Annual DHW Use (L/yr)"
      }
    ]
  },
  "section": "S07",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "waterHeating.method",
        "type": "string",
        "description": "Water use method: 'User Defined', 'By Engineer', 'PHPP Method', 'NBC Method', 'OBC Method', 'Luxury'"
      },
      {
        "name": "waterHeating.userDefinedLpppd",
        "type": "number",
        "unit": "L/person/day",
        "description": "User-defined litres per person per day (e_49) - default 40"
      },
      {
        "name": "waterHeating.byEngineerKwh",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Direct engineer energy input (e_50) - default 10000"
      },
      {
        "name": "occupancy.occupants",
        "type": "number",
        "description": "Number of occupants - default 4"
      }
    ],
    "output": {
      "type": "number",
      "unit": "L/person/day (h_49), kWh/yr (j_50), L/yr (i_49, i_50)"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "method in ['User Defined', 'By Engineer', 'PHPP Method', 'NBC Method', 'OBC Method', 'Luxury']",
        "description": "Method must be one of the supported water use methods"
      }
    ],
    "invariants": [
      {
        "condition": "lpppd >= 0",
        "description": "Litres per person per day cannot be negative"
      },
      {
        "condition": "energyDemand >= 0",
        "description": "Energy demand cannot be negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "h_49: method == 'By Engineer'",
      "output": "byEngineerKwh / (365 * 0.0524 * occupants * 0.4)",
      "note": "Reverse-calculate lpppd from known energy demand. waterHeatFactor = 0.0524"
    },
    {
      "condition": "h_49: method == 'User Defined'",
      "output": "userDefinedLpppd",
      "note": "Direct user input value"
    },
    {
      "condition": "h_49: method == 'PHPP Method'",
      "output": "62.5",
      "note": "Passive House standard"
    },
    {
      "condition": "h_49: method == 'NBC Method'",
      "output": "220",
      "note": "National Building Code standard"
    },
    {
      "condition": "h_49: method == 'OBC Method'",
      "output": "275",
      "note": "Ontario Building Code standard"
    },
    {
      "condition": "h_49: method == 'Luxury'",
      "output": "400",
      "note": "High-end residential"
    },
    {
      "condition": "j_50: method == 'By Engineer'",
      "output": "byEngineerKwh",
      "note": "Direct engineer input used as energy demand"
    },
    {
      "condition": "j_50: other methods",
      "output": "lpppd * 0.4 * occupants * 0.0523 * 365",
      "note": "0.4 is DHW fraction of total water use. 0.0523 is energy factor (kWh per litre temperature rise)"
    },
    {
      "condition": "i_49: always",
      "output": "lpppd * occupants * 365",
      "note": "Total annual water use in litres"
    },
    {
      "condition": "i_50: always",
      "output": "lpppd * 0.4 * occupants * 365",
      "note": "Annual DHW use = 40% of total water use"
    }
  ],
  "edgeCases": [
    {
      "condition": "occupants == 0 (By Engineer reverse calc)",
      "handling": "Return 0",
      "rationale": "Prevent division by zero in reverse calculation"
    },
    {
      "condition": "unknown method",
      "handling": "Default to 40 L/person/day",
      "rationale": "Fallback via METHOD_LPPPD lookup returning null, then || 40"
    }
  ],
  "formula": {
    "symbolic": "h_49 = CASE(method, e_50/(365*0.0524*occ*0.4), e_49, LOOKUP[method]); j_50 = CASE(method, e_50, h_49*0.4*occ*0.0523*365); i_49 = h_49*occ*365; i_50 = h_49*0.4*occ*365",
    "implementation": "WaterHeatingNodes.js:53-278"
  },
  "tests": [
    {
      "name": "By Engineer - reverse calculate lpppd",
      "inputs": {
        "waterHeating.method": "By Engineer",
        "waterHeating.byEngineerKwh": 10000,
        "occupancy.occupants": 4
      },
      "expected": 327.84,
      "note": "h_49 = 10000 / (365 * 0.0524 * 4 * 0.4) = 327.84"
    },
    {
      "name": "User Defined - direct input",
      "inputs": {
        "waterHeating.method": "User Defined",
        "waterHeating.userDefinedLpppd": 40
      },
      "expected": 40
    },
    {
      "name": "PHPP Method - fixed value",
      "inputs": {
        "waterHeating.method": "PHPP Method"
      },
      "expected": 62.5
    },
    {
      "name": "Energy demand - standard method",
      "inputs": {
        "waterHeating.method": "User Defined",
        "waterHeating.lpppd": 40,
        "occupancy.occupants": 4
      },
      "expected": 1222.72,
      "note": "j_50 = 40 * 0.4 * 4 * 0.0523 * 365 = 1222.72"
    },
    {
      "name": "Energy demand - By Engineer passthrough",
      "inputs": {
        "waterHeating.method": "By Engineer",
        "waterHeating.byEngineerKwh": 10000
      },
      "expected": 10000
    },
    {
      "name": "Annual water use",
      "inputs": {
        "waterHeating.lpppd": 40,
        "occupancy.occupants": 4
      },
      "expected": 58400,
      "note": "i_49 = 40 * 4 * 365 = 58400"
    },
    {
      "name": "Annual DHW use",
      "inputs": {
        "waterHeating.lpppd": 40,
        "occupancy.occupants": 4
      },
      "expected": 23360,
      "note": "i_50 = 40 * 0.4 * 4 * 365 = 23360"
    }
  ]
}
