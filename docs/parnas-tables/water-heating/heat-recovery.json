{
  "_meta": {
    "description": "Heat recovery and loss calculations for water heating systems. DWHR energy recovered is proportional to drain water heat recovery efficiency. System losses apply only when efficiency <= 100% (non-heat-pump) with a factor depending on method. Exhaust losses apply only to Gas/Oil combustion systems.",
    "instances": [
      {
        "id": "waterHeating.energyRecovered",
        "legacyId": "e_53",
        "label": "Energy Recovered via DWHR (kWh/yr)"
      },
      {
        "id": "waterHeating.systemLosses",
        "legacyId": "d_54",
        "label": "Water Heating System Losses (kWh/yr)"
      },
      {
        "id": "waterHeating.exhaustLosses",
        "legacyId": "j_54",
        "label": "Exhaust Losses (kWh/yr)"
      }
    ]
  },
  "section": "S07",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "waterHeating.netThermalDemand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Net thermal demand (j_51) - for DWHR calculation"
      },
      {
        "name": "waterHeating.dwhrEfficiency",
        "type": "number",
        "unit": "%",
        "description": "Drain water heat recovery efficiency (d_53) - default 0, range 0-70%"
      },
      {
        "name": "waterHeating.efficiencyDecimal",
        "type": "number",
        "description": "System efficiency as decimal (e_52)"
      },
      {
        "name": "waterHeating.energyDemand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Hot water energy demand (j_50) - for system losses"
      },
      {
        "name": "waterHeating.method",
        "type": "string",
        "description": "Water use method - affects system loss factor"
      },
      {
        "name": "waterHeating.systemType",
        "type": "string",
        "description": "System type: 'Gas', 'Oil', etc. - for exhaust losses"
      },
      {
        "name": "waterHeating.netDemandAfterRecovery",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Net demand after DWHR recovery (j_52) - for exhaust losses"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr"
    }
  },
  "domain": {
    "preconditions": [],
    "invariants": [
      {
        "condition": "energyRecovered >= 0",
        "description": "Recovered energy cannot be negative"
      },
      {
        "condition": "systemLosses >= 0",
        "description": "System losses cannot be negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "e_53: always",
      "output": "netThermalDemand * (dwhrEff / 100)",
      "note": "Energy recovered by drain water heat recovery system"
    },
    {
      "condition": "d_54: efficiencyDecimal <= 1 AND method == 'PHPP Method'",
      "output": "energyDemand * 0.25",
      "note": "PHPP method uses 25% loss factor for non-heat-pump systems"
    },
    {
      "condition": "d_54: efficiencyDecimal <= 1 AND method != 'PHPP Method'",
      "output": "energyDemand * 0.1",
      "note": "All other methods use 10% loss factor for non-heat-pump systems"
    },
    {
      "condition": "d_54: efficiencyDecimal > 1",
      "output": "0",
      "note": "Heat pump systems (efficiency > 100%) have no system losses"
    },
    {
      "condition": "j_54: systemType in ['Gas', 'Oil']",
      "output": "netDemandAfterRecovery * (1 - efficiencyDecimal)",
      "note": "Exhaust losses for combustion systems. (1 - eff) is the fraction lost to exhaust"
    },
    {
      "condition": "j_54: systemType not in ['Gas', 'Oil']",
      "output": "0",
      "note": "No exhaust losses for electric/heat pump systems"
    }
  ],
  "edgeCases": [
    {
      "condition": "dwhrEfficiency == 0",
      "handling": "e_53 returns 0",
      "rationale": "No drain water heat recovery system installed"
    },
    {
      "condition": "efficiencyDecimal exactly 1.0",
      "handling": "System losses still apply (<=1 includes 1.0)",
      "rationale": "100% efficient electric resistance still has distribution losses"
    },
    {
      "condition": "Gas system with high efficiency (e.g., 0.98)",
      "handling": "Exhaust loss = demand * 0.02 (small but non-zero)",
      "rationale": "Even high-efficiency condensing furnaces have some exhaust losses"
    }
  ],
  "formula": {
    "symbolic": "e_53 = j_51 * (d_53/100); d_54 = IF(e_52<=1, j_50 * factor, 0); j_54 = IF(Gas/Oil, j_52 * (1-e_52), 0)",
    "implementation": "WaterHeatingNodes.js:160-340"
  },
  "tests": [
    {
      "name": "DWHR recovery at 50%",
      "inputs": {
        "waterHeating.netThermalDemand": 5000,
        "waterHeating.dwhrEfficiency": 50
      },
      "expected": 2500,
      "note": "e_53 = 5000 * 0.5 = 2500"
    },
    {
      "name": "DWHR recovery - no system",
      "inputs": {
        "waterHeating.netThermalDemand": 5000,
        "waterHeating.dwhrEfficiency": 0
      },
      "expected": 0
    },
    {
      "name": "System losses - PHPP method, gas",
      "inputs": {
        "waterHeating.efficiencyDecimal": 0.95,
        "waterHeating.energyDemand": 5000,
        "waterHeating.method": "PHPP Method"
      },
      "expected": 1250,
      "note": "d_54 = 5000 * 0.25 = 1250"
    },
    {
      "name": "System losses - non-PHPP, gas",
      "inputs": {
        "waterHeating.efficiencyDecimal": 0.95,
        "waterHeating.energyDemand": 5000,
        "waterHeating.method": "User Defined"
      },
      "expected": 500,
      "note": "d_54 = 5000 * 0.1 = 500"
    },
    {
      "name": "System losses - heat pump (none)",
      "inputs": {
        "waterHeating.efficiencyDecimal": 3.0,
        "waterHeating.energyDemand": 5000,
        "waterHeating.method": "User Defined"
      },
      "expected": 0
    },
    {
      "name": "Exhaust losses - gas system",
      "inputs": {
        "waterHeating.systemType": "Gas",
        "waterHeating.netDemandAfterRecovery": 5000,
        "waterHeating.efficiencyDecimal": 0.95
      },
      "expected": 250,
      "note": "j_54 = 5000 * (1 - 0.95) = 250"
    },
    {
      "name": "Exhaust losses - electric (none)",
      "inputs": {
        "waterHeating.systemType": "Electric",
        "waterHeating.netDemandAfterRecovery": 5000,
        "waterHeating.efficiencyDecimal": 1.0
      },
      "expected": 0
    }
  ]
}
