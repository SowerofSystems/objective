{
  "_meta": {
    "description": "Warm water fraction — the ratio of annual DHW demand to total hot water load. This computed node determines what percentage of total hot water usage goes to domestic hot water versus space heating hydronic loops. Used in S07 section compliance calculations.",
    "instances": [
      {
        "id": "waterHeating.warmWaterFraction",
        "legacyId": "h_50",
        "label": "Warm Water Fraction"
      }
    ]
  },
  "section": "S07",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "waterHeating.annualDhwDemand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Annual domestic hot water demand (h_48)"
      },
      {
        "name": "waterHeating.totalHotWaterLoad",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total hot water load including space heating hydronic contribution (h_49)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "ratio"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "annualDhwDemand >= 0",
        "description": "DHW demand cannot be negative"
      },
      {
        "condition": "totalHotWaterLoad >= annualDhwDemand",
        "description": "Total load includes DHW plus any hydronic space heating"
      }
    ],
    "invariants": [
      {
        "condition": "warmWaterFraction in [0, 1]",
        "description": "DHW fraction cannot exceed total load"
      }
    ]
  },
  "behavior": [
    {
      "condition": "totalHotWaterLoad > 0",
      "output": "annualDhwDemand / totalHotWaterLoad",
      "note": "Fraction of total hot water going to DHW"
    },
    {
      "condition": "totalHotWaterLoad = 0",
      "output": "0",
      "note": "No hot water load, no fraction"
    }
  ],
  "edgeCases": [
    {
      "condition": "No hydronic space heating",
      "handling": "warmWaterFraction = 1.0 (all hot water is DHW)",
      "rationale": "totalHotWaterLoad = annualDhwDemand when no hydronic heating"
    },
    {
      "condition": "Both inputs are 0",
      "handling": "warmWaterFraction = 0",
      "rationale": "Division guard returns 0"
    }
  ],
  "formula": {
    "symbolic": "warmWaterFraction = totalLoad > 0 ? annualDhwDemand / totalHotWaterLoad : 0",
    "implementation": "WaterHeatingNodes.js"
  },
  "tests": [
    {
      "name": "All DHW, no hydronic",
      "inputs": {
        "waterHeating.annualDhwDemand": 5000,
        "waterHeating.totalHotWaterLoad": 5000
      },
      "expected": 1.0
    },
    {
      "name": "Half DHW, half hydronic",
      "inputs": {
        "waterHeating.annualDhwDemand": 3000,
        "waterHeating.totalHotWaterLoad": 6000
      },
      "expected": 0.5
    },
    {
      "name": "Zero total load",
      "inputs": {
        "waterHeating.annualDhwDemand": 0,
        "waterHeating.totalHotWaterLoad": 0
      },
      "expected": 0
    }
  ],
  "references": [
    { "source": "WaterHeatingNodes.js (warmWaterFraction computed node)" },
    { "source": "SectionComplianceNodes.js (consumes h_50 for S07 compliance via m_50)" }
  ]
}
