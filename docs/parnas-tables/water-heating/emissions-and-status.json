{
  "_meta": {
    "description": "Water heating emissions, SHW wasted echo, and compliance status indicators. Emissions calculated from fuel volumes and emission factors for Gas/Oil only. SHW wasted is a pass-through of net demand after recovery. Status checkmarks compare compliance ratios against thresholds.",
    "instances": [
      {
        "id": "waterHeating.netEmissions",
        "legacyId": "k_49",
        "label": "Net DHW Emissions (kgCO2e/yr)"
      },
      {
        "id": "waterHeating.shwWasted",
        "legacyId": "j_53",
        "label": "SHW Wasted (kWh/yr)"
      },
      {
        "id": "waterHeating.waterUse.status",
        "legacyId": "n_49",
        "label": "Water Use Compliance Status"
      },
      {
        "id": "waterHeating.dhw.status",
        "legacyId": "n_50",
        "label": "DHW Compliance Status"
      },
      {
        "id": "waterHeating.efficiency.status",
        "legacyId": "n_52",
        "label": "Efficiency Compliance Status"
      },
      {
        "id": "waterHeating.dwhr.status",
        "legacyId": "n_53",
        "label": "DWHR Compliance Status"
      }
    ]
  },
  "section": "S07",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "waterHeating.systemType",
        "type": "string",
        "description": "System type: 'Gas', 'Oil', 'Electric', 'Heatpump'"
      },
      {
        "name": "waterHeating.gasVolume",
        "type": "number",
        "unit": "m3/yr",
        "description": "Annual gas consumption (e_51)"
      },
      {
        "name": "waterHeating.oilVolume",
        "type": "number",
        "unit": "L/yr",
        "description": "Annual oil consumption (k_54)"
      },
      {
        "name": "emissions.factor.gas",
        "type": "number",
        "unit": "g CO2e/m3",
        "description": "Gas emissions factor"
      },
      {
        "name": "emissions.factor.oil",
        "type": "number",
        "unit": "g CO2e/L",
        "description": "Oil emissions factor"
      },
      {
        "name": "waterHeating.netDemandAfterRecovery",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Net demand after recovery (j_52) - for SHW wasted"
      },
      {
        "name": "compliance.waterUse.ratio",
        "type": "number|string",
        "description": "Water use compliance ratio (percentage) - for n_49"
      },
      {
        "name": "compliance.waterEnergy.ratio",
        "type": "number|string",
        "description": "Water energy compliance ratio (percentage) - for n_50"
      },
      {
        "name": "compliance.waterEfficiency.ratio",
        "type": "number|string",
        "description": "Water efficiency compliance ratio (percentage) - for n_52"
      },
      {
        "name": "compliance.waterDWHR.ratio",
        "type": "number|string",
        "description": "DWHR compliance ratio (percentage) - for n_53"
      }
    ],
    "output": {
      "type": "number|string",
      "description": "kgCO2e/yr (k_49), kWh/yr (j_53), or status symbol (n_49/n_50/n_52/n_53)"
    }
  },
  "domain": {
    "preconditions": [],
    "invariants": [
      {
        "condition": "netEmissions >= 0",
        "description": "Emissions cannot be negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "k_49: systemType == 'Gas'",
      "output": "(gasVolume * gasFactor) / 1000",
      "note": "Gas volume in m3 * factor in g/m3, converted from g to kg"
    },
    {
      "condition": "k_49: systemType == 'Oil'",
      "output": "(oilVolume * oilFactor) / 1000",
      "note": "Oil volume in L * factor in g/L, converted from g to kg"
    },
    {
      "condition": "k_49: systemType in ['Electric', 'Heatpump']",
      "output": "0",
      "note": "No on-site combustion emissions for electric systems"
    },
    {
      "condition": "j_53: always",
      "output": "netDemandAfterRecovery",
      "note": "Echo/pass-through of j_52 - represents solar hot water potential wasted"
    },
    {
      "condition": "n_49: ratio <= 100",
      "output": "'checkmark'",
      "note": "Water use within compliance target"
    },
    {
      "condition": "n_49: ratio > 100",
      "output": "'X mark'",
      "note": "Water use exceeds compliance target"
    },
    {
      "condition": "n_50: ratio <= 100",
      "output": "'checkmark'",
      "note": "DHW energy within compliance target"
    },
    {
      "condition": "n_50: ratio > 100",
      "output": "'X mark'",
      "note": "DHW energy exceeds compliance target"
    },
    {
      "condition": "n_52: ratio >= 100",
      "output": "'checkmark'",
      "note": "Efficiency meets or exceeds reference (higher is better)"
    },
    {
      "condition": "n_52: ratio < 100",
      "output": "'X mark'",
      "note": "Efficiency below reference"
    },
    {
      "condition": "n_53: ratio >= 100",
      "output": "'checkmark'",
      "note": "DWHR efficiency meets or exceeds reference (higher is better)"
    },
    {
      "condition": "n_53: ratio < 100",
      "output": "'X mark'",
      "note": "DWHR efficiency below reference"
    },
    {
      "condition": "n_49/n_50/n_52/n_53: ratio == 'N/A'",
      "output": "'N/A'",
      "note": "No reference value available for comparison"
    }
  ],
  "edgeCases": [
    {
      "condition": "ratio contains '%' or ',' characters",
      "handling": "Stripped before parsing",
      "rationale": "Compliance ratios may arrive formatted with percentage signs or commas"
    },
    {
      "condition": "ratio is 'N/A'",
      "handling": "Return 'N/A' directly",
      "rationale": "No reference model value available for this metric"
    },
    {
      "condition": "n_49/n_50 threshold direction",
      "handling": "Pass when <= 100 (lower is better for consumption metrics)",
      "rationale": "Water use and energy consumption should be at or below reference"
    },
    {
      "condition": "n_52/n_53 threshold direction",
      "handling": "Pass when >= 100 (higher is better for efficiency metrics)",
      "rationale": "Efficiency should meet or exceed reference"
    }
  ],
  "formula": {
    "symbolic": "k_49 = CASE(type, gasVol*gasFactor/1000, oilVol*oilFactor/1000, 0); j_53 = j_52; n_49 = ratio<=100?pass:fail; n_50 = ratio<=100?pass:fail; n_52 = ratio>=100?pass:fail; n_53 = ratio>=100?pass:fail",
    "implementation": "WaterHeatingNodes.js:285-408"
  },
  "tests": [
    {
      "name": "Gas emissions",
      "inputs": {
        "waterHeating.systemType": "Gas",
        "waterHeating.gasVolume": 500,
        "emissions.factor.gas": 1921
      },
      "expected": 960.5,
      "note": "k_49 = (500 * 1921) / 1000 = 960.5"
    },
    {
      "name": "Oil emissions",
      "inputs": {
        "waterHeating.systemType": "Oil",
        "waterHeating.oilVolume": 400,
        "emissions.factor.oil": 2753
      },
      "expected": 1101.2,
      "note": "k_49 = (400 * 2753) / 1000 = 1101.2"
    },
    {
      "name": "Electric emissions (zero)",
      "inputs": {
        "waterHeating.systemType": "Electric"
      },
      "expected": 0
    },
    {
      "name": "SHW wasted - echo of j_52",
      "inputs": {
        "waterHeating.netDemandAfterRecovery": 4500
      },
      "expected": 4500
    },
    {
      "name": "Water use status - compliant",
      "inputs": {
        "compliance.waterUse.ratio": 85
      },
      "expected": "checkmark"
    },
    {
      "name": "Water use status - non-compliant",
      "inputs": {
        "compliance.waterUse.ratio": 120
      },
      "expected": "X mark"
    },
    {
      "name": "DHW status - at threshold",
      "inputs": {
        "compliance.waterEnergy.ratio": 100
      },
      "expected": "checkmark"
    },
    {
      "name": "Efficiency status - compliant",
      "inputs": {
        "compliance.waterEfficiency.ratio": 150
      },
      "expected": "checkmark"
    },
    {
      "name": "Efficiency status - non-compliant",
      "inputs": {
        "compliance.waterEfficiency.ratio": 80
      },
      "expected": "X mark"
    },
    {
      "name": "DWHR status - N/A",
      "inputs": {
        "compliance.waterDWHR.ratio": "N/A"
      },
      "expected": "N/A"
    },
    {
      "name": "DWHR status - compliant",
      "inputs": {
        "compliance.waterDWHR.ratio": 100
      },
      "expected": "checkmark"
    }
  ]
}
