{
  "id": "energy.plugLoads.subtotal",
  "legacyId": "h_70",
  "label": "Plug/Light/Equipment Subtotal",
  "section": "S09",
  "classification": "C",
  "_meta": {
    "description": "Sum of plug load, lighting, and equipment annual energy. Excludes occupant heat and DHW losses. This subtotal feeds into both the heating season and cooling season internal gains calculations."
  },
  "signature": {
    "inputs": [
      {
        "name": "internal.plugLoads.annual",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Plug load annual energy (h_65)"
      },
      {
        "name": "internal.lighting.annual",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Lighting annual energy (h_66)"
      },
      {
        "name": "internal.equipment.annual",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Equipment annual energy (h_67)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Sum of non-negative values"
      }
    ]
  },
  "behavior": [
    {
      "condition": "always",
      "output": "h_65 + h_66 + h_67",
      "note": "Simple sum of three categories"
    }
  ],
  "formula": {
    "symbolic": "h_70 = h_65 + h_66 + h_67",
    "implementation": "InternalGainsNodes.js:316-329",
    "legacy": "Section09.js"
  },
  "tests": [
    {
      "name": "Typical residential",
      "inputs": {
        "internal.plugLoads.annual": 6132,
        "internal.lighting.annual": 1314,
        "internal.equipment.annual": 4380
      },
      "expected": 11826
    }
  ],
  "references": [
    {
      "source": "InternalGainsNodes.js:316-329"
    }
  ]
}
