{
  "id": "internal.equipmentDensity",
  "legacyId": "d_67",
  "label": "Equipment Density",
  "section": "S09",
  "classification": "C",
  "_meta": {
    "description": "Equipment power density from 3D lookup table: building type x efficiency spec x elevator presence. Unlike plug load density (d_65), this varies with equipment efficiency and elevator presence because it represents actual installed building equipment."
  },
  "signature": {
    "inputs": [
      {
        "name": "building.majorOccupancy",
        "type": "string",
        "description": "Building occupancy type (d_12) - e.g., 'C-Residential', 'A - Assembly'"
      },
      {
        "name": "internal.efficiencySpec",
        "type": "string",
        "description": "Equipment efficiency spec (g_67) - 'Regular' or 'Efficient'"
      },
      {
        "name": "internal.elevators",
        "type": "string",
        "description": "Elevator presence (d_68) - 'Elevators' or 'No Elevators'"
      }
    ],
    "output": {
      "type": "number",
      "unit": "W/m2",
      "precision": 1
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output > 0",
        "description": "Equipment density is always positive"
      }
    ]
  },
  "behavior": [
    {
      "condition": "buildingType in EQUIPMENT_LOADS_TABLE",
      "output": "EQUIPMENT_LOADS_TABLE[formattedType][efficiency][elevators]",
      "note": "3D lookup: 11 building types x 2 efficiency levels x 2 elevator states = 44 possible values (3-25 W/m2)"
    },
    {
      "condition": "buildingType not found after formatting",
      "output": "5.0",
      "note": "DEFAULT_EQUIPMENT_LOAD fallback"
    }
  ],
  "edgeCases": [
    {
      "condition": "raw building type has spaces (e.g., 'A - Assembly')",
      "handling": "formatBuildingTypeForLookup normalizes to 'A-Assembly'",
      "rationale": "Handles both hyphenated and spaced variants from different data sources"
    },
    {
      "condition": "B-category ambiguity",
      "handling": "Matches on B1/B2/B3, or 'Detention'/'Care' keywords, defaults to B3-DetentionCare",
      "rationale": "B categories have overlapping naming patterns"
    },
    {
      "condition": "completely unknown type",
      "handling": "Falls back to 'A-Assembly' then to DEFAULT_EQUIPMENT_LOAD (5.0)",
      "rationale": "formatBuildingTypeForLookup returns 'A-Assembly' as last resort"
    }
  ],
  "formula": {
    "symbolic": "d_67 = EQUIPMENT_LOADS_TABLE[formatBuildingType(d_12)][g_67][d_68]",
    "implementation": "InternalGainsNodes.js:205-231",
    "legacy": "Section09.js equipmentLoadsTable"
  },
  "tests": [
    {
      "name": "Residential, Regular, No Elevators",
      "inputs": {
        "building.majorOccupancy": "C-Residential",
        "internal.efficiencySpec": "Regular",
        "internal.elevators": "No Elevators"
      },
      "expected": 5.0
    },
    {
      "name": "Residential, Efficient, Elevators",
      "inputs": {
        "building.majorOccupancy": "C-Residential",
        "internal.efficiencySpec": "Efficient",
        "internal.elevators": "Elevators"
      },
      "expected": 4.0
    },
    {
      "name": "Care, Regular, Elevators (highest)",
      "inputs": {
        "building.majorOccupancy": "B2-Care",
        "internal.efficiencySpec": "Regular",
        "internal.elevators": "Elevators"
      },
      "expected": 25.0
    },
    {
      "name": "Spaced format input",
      "inputs": {
        "building.majorOccupancy": "A - Assembly",
        "internal.efficiencySpec": "Regular",
        "internal.elevators": "No Elevators"
      },
      "expected": 7.0
    }
  ],
  "references": [
    {
      "source": "InternalGainsNodes.js:35-83 (EQUIPMENT_LOADS_TABLE)"
    },
    {
      "source": "InternalGainsNodes.js:205-231"
    }
  ]
}
