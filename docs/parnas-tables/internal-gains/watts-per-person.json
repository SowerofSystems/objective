{
  "id": "internal.occupants.wattsPerPerson",
  "legacyId": "g_64",
  "label": "Occupant Watts per Person (S+L)",
  "section": "S09",
  "classification": "C",
  "_meta": {
    "description": "Metabolic heat output per person (sensible + latent) based on activity level. Lookup from SCHEDULES-3037.csv G32:G43 activity level mapping."
  },
  "signature": {
    "inputs": [
      {
        "name": "internal.activityLevel",
        "type": "string",
        "description": "Occupant activity level (d_64) - 'Relaxed', 'Normal', 'Active', or 'Hyperactive'"
      }
    ],
    "output": {
      "type": "number",
      "unit": "W/person",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output in [96.71, 117.23, 219.81, 424.95]",
        "description": "Only four possible output values"
      }
    ]
  },
  "behavior": [
    {
      "condition": "level == 'Relaxed'",
      "output": "96.71"
    },
    {
      "condition": "level == 'Normal'",
      "output": "117.23",
      "note": "Default"
    },
    {
      "condition": "level == 'Active'",
      "output": "219.81"
    },
    {
      "condition": "level == 'Hyperactive'",
      "output": "424.95"
    }
  ],
  "edgeCases": [
    {
      "condition": "level not recognized",
      "handling": "Return 117.23 (Normal)",
      "rationale": "Fallback to typical occupant metabolic rate"
    }
  ],
  "formula": {
    "symbolic": "g_64 = ACTIVITY_WATTS[d_64]",
    "implementation": "InternalGainsNodes.js:234-245"
  },
  "tests": [
    {
      "name": "Normal activity",
      "inputs": {
        "internal.activityLevel": "Normal"
      },
      "expected": 117.23
    },
    {
      "name": "Relaxed activity",
      "inputs": {
        "internal.activityLevel": "Relaxed"
      },
      "expected": 96.71
    },
    {
      "name": "Unknown defaults to Normal",
      "inputs": {
        "internal.activityLevel": "Unknown"
      },
      "expected": 117.23
    }
  ],
  "references": [
    {
      "source": "InternalGainsNodes.js:26-31 (ACTIVITY_WATTS)"
    },
    {
      "source": "InternalGainsNodes.js:234-245"
    }
  ]
}
