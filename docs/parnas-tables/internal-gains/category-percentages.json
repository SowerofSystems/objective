      }
    ]
  },
  "section": "S09",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "internal.{category}.{heating/cooling}Gain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Category seasonal gain"
      },
      {
        "name": "internal.heatingGains or internal.coolingLoad.occupants",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total seasonal gains (i_71 or k_71)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "ratio (0-1)",
      "precision": 4
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "0 <= output <= 1",
        "description": "Percentage between 0 and 1"
      }
    ]
  },
  "behavior": [
    {
      "condition": "total > 0",
      "output": "categoryGain / total"
    },
    {
      "condition": "total == 0",
      "output": "0",
      "note": "Avoid division by zero"
    }
  ],
  "formula": {
    "symbolic": "j_{N} = i_{N} / i_71; l_{N} = k_{N} / k_71",
    "implementation": "InternalGainsNodes.js:500-530"
  },
  "tests": [
    {
      "name": "Occupants 20% of heating",
      "inputs": {
        "internal.occupants.heatingGain": 1400,
        "internal.heatingGains": 7000
      },
      "expected": 0.2
    },
    {
      "name": "Zero total",
      "inputs": {
        "internal.plugLoads.heatingGain": 0,
        "internal.heatingGains": 0
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "InternalGainsNodes.js:500-530"
    }
  ]
}
