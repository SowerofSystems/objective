{
  "_meta": {
    "description": "Annual energy consumption by internal gains category. Each category uses the same formula: (density_W * area_or_count * annualHours) / 1000. Occupants use watts/person * count; all others use W/m2 * floor area.",
    "instances": [
      {
        "id": "internal.occupants.annual",
        "legacyId": "h_64",
        "label": "Occupant Internal Gains (kWh/yr)"
      },
      {
        "id": "internal.plugLoads.annual",
        "legacyId": "h_65",
        "label": "Plug Load Internal Gains (kWh/yr)"
      },
      {
        "id": "internal.lighting.annual",
        "legacyId": "h_66",
        "label": "Lighting Internal Gains (kWh/yr)"
      },
      {
        "id": "internal.equipment.annual",
        "legacyId": "h_67",
        "label": "Equipment Internal Gains (kWh/yr)"
      }
    ]
  },
  "section": "S09",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "density (watts or W/m2)",
        "type": "number",
        "description": "h_64: g_64 (W/person), h_65: d_65 (W/m2), h_66: d_66 (W/m2), h_67: d_67 (W/m2)"
      },
      {
        "name": "area or occupant count",
        "type": "number",
        "description": "h_64: occupancy.occupants (count), h_65-h_67: building.conditionedFloorArea (m2)"
      },
      {
        "name": "occupancy.occupiedHours",
        "type": "number",
        "unit": "hrs/yr",
        "description": "Annual occupied hours - default 4380"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Annual energy is non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "h_64 (occupants)",
      "output": "(wattsPerPerson * occupants * hours) / 1000",
      "note": "Defaults: watts=117.23, occupants=4, hours=4380"
    },
    {
      "condition": "h_65 (plug loads)",
      "output": "(plugDensity * area * hours) / 1000",
      "note": "Default density=7 W/m2"
    },
    {
      "condition": "h_66 (lighting)",
      "output": "(lightingDensity * area * hours) / 1000",
      "note": "Default density=1.5 W/m2"
    },
    {
      "condition": "h_67 (equipment)",
      "output": "(equipmentDensity * area * hours) / 1000",
      "note": "Default density=3 W/m2"
    }
  ],
  "formula": {
    "symbolic": "h_{N} = (density * scale * hours) / 1000",
    "implementation": "InternalGainsNodes.js:248-309",
    "legacy": "Section09.js"
  },
  "tests": [
    {
      "name": "Occupant annual energy",
      "inputs": {
        "internal.occupants.wattsPerPerson": 117.23,
        "occupancy.occupants": 4,
        "occupancy.occupiedHours": 4380
      },
      "expected": 2053.71
    },
    {
      "name": "Plug load annual energy (200 m2)",
      "inputs": {
        "internal.plugLoadDensity": 7,
        "building.conditionedFloorArea": 200,
        "occupancy.occupiedHours": 4380
      },
      "expected": 6132
    },
    {
      "name": "Zero area yields zero",
      "inputs": {
        "internal.lightingDensity": 1.5,
        "building.conditionedFloorArea": 0,
        "occupancy.occupiedHours": 4380
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "InternalGainsNodes.js:248-309"
    }
  ]
}
