{
  "id": "internal.heatingGains",
  "legacyId": "i_71",
  "label": "Internal Gains - Heating Season",
  "section": "S09",
  "classification": "C",
  "_meta": {
    "description": "Total internal heating gains: (PLE subtotal + occupant energy + DHW losses) * heating season fraction. The heating fraction is (365 - coolingDays) / 365. This feeds into the radiant gains utilization calculation (S10 e_80)."
  },
  "signature": {
    "inputs": [
      {
        "name": "energy.plugLoads.subtotal",
        "type": "number",
        "unit": "kWh/yr",
        "description": "PLE subtotal (h_70)"
      },
      {
        "name": "internal.occupants.annual",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Occupant annual energy (h_64)"
      },
      {
        "name": "waterHeating.systemLosses",
        "type": "number",
        "unit": "kWh/yr",
        "description": "DHW system losses (d_54)"
      },
      {
        "name": "climate.coolingDays",
        "type": "number",
        "unit": "days",
        "description": "Number of cooling days (m_19)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Heating gains are non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "always",
      "output": "(h_70 + h_64 + d_54) * (365 - coolingDays) / 365",
      "note": "Proportional to heating season length"
    }
  ],
  "edgeCases": [
    {
      "condition": "coolingDays = 365",
      "handling": "Return 0",
      "rationale": "No heating season means no heating gains"
    },
    {
      "condition": "coolingDays = 0",
      "handling": "Return full annual total",
      "rationale": "Entire year is heating season"
    }
  ],
  "formula": {
    "symbolic": "i_71 = (h_70 + h_64 + d_54) * (365 - m_19) / 365",
    "implementation": "InternalGainsNodes.js:332-353",
    "legacy": "Section09.js"
  },
  "tests": [
    {
      "name": "120 cooling days",
      "inputs": {
        "energy.plugLoads.subtotal": 10000,
        "internal.occupants.annual": 2000,
        "waterHeating.systemLosses": 1000,
        "climate.coolingDays": 120
      },
      "expected": 8726.03
    },
    {
      "name": "No cooling days (all heating)",
      "inputs": {
        "energy.plugLoads.subtotal": 10000,
        "internal.occupants.annual": 2000,
        "waterHeating.systemLosses": 1000,
        "climate.coolingDays": 0
      },
      "expected": 13000
    }
  ],
  "references": [
    {
      "source": "InternalGainsNodes.js:332-353"
    }
  ]
}
