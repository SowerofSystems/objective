{
  "id": "internal.total.annual",
  "legacyId": "h_71",
  "label": "Total Internal Gains",
  "section": "S09",
  "classification": "C",
  "_meta": {
    "description": "Total annual internal gains: occupant heat + PLE subtotal + DHW losses. This is the gross annual total before seasonal splitting."
  },
  "signature": {
    "inputs": [
      {
        "name": "internal.occupants.annual",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Occupant annual energy (h_64)"
      },
      {
        "name": "energy.plugLoads.subtotal",
        "type": "number",
        "unit": "kWh/yr",
        "description": "PLE subtotal (h_70)"
      },
      {
        "name": "internal.dhwLosses.annual",
        "type": "number",
        "unit": "kWh/yr",
        "description": "DHW losses (h_69)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Sum of non-negative values"
      }
    ]
  },
  "behavior": [
    {
      "condition": "always",
      "output": "h_64 + h_70 + h_69"
    }
  ],
  "formula": {
    "symbolic": "h_71 = h_64 + h_70 + h_69",
    "implementation": "InternalGainsNodes.js:395-408"
  },
  "tests": [
    {
      "name": "Typical total",
      "inputs": {
        "internal.occupants.annual": 2054,
        "energy.plugLoads.subtotal": 11826,
        "internal.dhwLosses.annual": 1500
      },
      "expected": 15380
    }
  ],
  "references": [
    {
      "source": "InternalGainsNodes.js:395-408"
    }
  ]
}
