{
  "id": "internal.coolingLoad.occupants",
  "legacyId": "k_71",
  "label": "Internal Gains - Cooling Season",
  "section": "S09",
  "classification": "C",
  "_meta": {
    "description": "Total internal cooling load: (PLE subtotal + occupant energy + DHW losses) * cooling season fraction. The cooling fraction is coolingDays / 365. Complement of heating gains (i_71)."
  },
  "signature": {
    "inputs": [
      {
        "name": "energy.plugLoads.subtotal",
        "type": "number",
        "unit": "kWh/yr",
        "description": "PLE subtotal (h_70)"
      },
      {
        "name": "internal.occupants.annual",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Occupant annual energy (h_64)"
      },
      {
        "name": "waterHeating.systemLosses",
        "type": "number",
        "unit": "kWh/yr",
        "description": "DHW system losses (d_54)"
      },
      {
        "name": "climate.coolingDays",
        "type": "number",
        "unit": "days",
        "description": "Number of cooling days (m_19)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "behavior": [
    {
      "condition": "always",
      "output": "(h_70 + h_64 + d_54) * coolingDays / 365",
      "note": "Proportional to cooling season length"
    }
  ],
  "edgeCases": [
    {
      "condition": "coolingDays = 0",
      "handling": "Return 0",
      "rationale": "No cooling season"
    },
    {
      "condition": "coolingDays = 365",
      "handling": "Return full annual total",
      "rationale": "Entire year is cooling season"
    }
  ],
  "formula": {
    "symbolic": "k_71 = (h_70 + h_64 + d_54) * m_19 / 365",
    "implementation": "InternalGainsNodes.js:356-377",
    "legacy": "Section09.js"
  },
  "tests": [
    {
      "name": "120 cooling days",
      "inputs": {
        "energy.plugLoads.subtotal": 10000,
        "internal.occupants.annual": 2000,
        "waterHeating.systemLosses": 1000,
        "climate.coolingDays": 120
      },
      "expected": 4273.97
    },
    {
      "name": "Zero cooling days",
      "inputs": {
        "energy.plugLoads.subtotal": 10000,
        "internal.occupants.annual": 2000,
        "waterHeating.systemLosses": 1000,
        "climate.coolingDays": 0
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "InternalGainsNodes.js:356-377"
    }
  ]
}
