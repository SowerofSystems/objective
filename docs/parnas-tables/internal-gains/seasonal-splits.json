  },
  "section": "S09",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "internal.{category}.annual",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Annual energy for this category"
      },
      {
        "name": "climate.coolingDays",
        "type": "number",
        "unit": "days",
        "description": "Number of cooling days (m_19)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "heatingGain + coolingGain = annual",
        "description": "Seasonal splits sum to annual total"
      },
      {
        "condition": "output >= 0",
        "description": "Seasonal gains are non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "heating gain (i_ prefix)",
      "output": "annual * (365 - coolingDays) / 365",
      "note": "Proportional to heating season"
    },
    {
      "condition": "cooling gain (k_ prefix)",
      "output": "annual * coolingDays / 365",
      "note": "Proportional to cooling season"
    }
  ],
  "formula": {
    "symbolic": "i_{N} = h_{N} * (365 - m_19) / 365; k_{N} = h_{N} * m_19 / 365",
    "implementation": "InternalGainsNodes.js:424-454",
    "legacy": "Section09.js"
  },
  "tests": [
    {
      "name": "Occupant heating with 120 cooling days",
      "inputs": {
        "internal.occupants.annual": 2054,
        "climate.coolingDays": 120
      },
      "expected": 1379.56
    },
    {
      "name": "Plug load cooling with 120 cooling days",
      "inputs": {
        "internal.plugLoads.annual": 6132,
        "climate.coolingDays": 120
      },
      "expected": 2015.67
    }
  ],
  "references": [
    {
      "source": "InternalGainsNodes.js:424-454"
    }
  ]
}
