{
  "id": "mechanical.afueComplianceRatio",
  "legacyId": "m_115",
  "label": "AFUE Compliance Ratio",
  "section": "S13",
  "classification": "C",
  "_meta": {
    "description": "Ratio of target AFUE to reference AFUE, expressed as percentage. Values >= 100% indicate compliance. AFUE (Annual Fuel Utilization Efficiency) measures furnace/boiler efficiency."
  },
  "signature": {
    "inputs": [
      {
        "name": "heating.targetAFUE",
        "type": "number",
        "unit": "decimal",
        "description": "Target model AFUE (j_115) - e.g., 0.96 for 96% efficient"
      },
      {
        "name": "heating.referenceAFUE",
        "type": "number",
        "unit": "decimal",
        "description": "Reference model AFUE (ref_j_115)"
      },
      {
        "name": "isReferenceCalculation",
        "type": "boolean",
        "description": "True when calculating for Reference model"
      }
    ],
    "output": {
      "type": "number",
      "unit": "ratio",
      "format": "percent-0dp"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "referenceAFUE > 0 OR isReferenceCalculation",
        "description": "Reference AFUE must be positive for ratio calculation"
      }
    ],
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Ratio cannot be negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "isReferenceCalculation == true",
      "output": "1.0",
      "note": "Reference model always shows 100% (self-comparison)"
    },
    {
      "condition": "referenceAFUE > 0",
      "output": "targetAFUE / referenceAFUE",
      "note": "Higher target AFUE = better compliance ratio"
    },
    {
      "condition": "referenceAFUE == 0",
      "output": "0",
      "note": "Avoid division by zero"
    }
  ],
  "compliance": {
    "passCondition": "output >= 1.0",
    "passSymbol": "✓",
    "failSymbol": "✗",
    "relatedField": "n_115"
  },
  "formula": {
    "symbolic": "m_115 = IF(isRef, 1.0, j_115 / ref_j_115)",
    "legacy": "Section13.js lines 3323, 3307-3318"
  },
  "tests": [
    {
      "name": "Target exceeds reference (compliant)",
      "inputs": {
        "heating.targetAFUE": 0.96,
        "heating.referenceAFUE": 0.92,
        "isReferenceCalculation": false
      },
      "expected": 1.043,
      "tolerance": 0.001
    },
    {
      "name": "Target equals reference",
      "inputs": {
        "heating.targetAFUE": 0.92,
        "heating.referenceAFUE": 0.92,
        "isReferenceCalculation": false
      },
      "expected": 1.0
    },
    {
      "name": "Reference calculation",
      "inputs": {
        "heating.targetAFUE": 0.96,
        "heating.referenceAFUE": 0.92,
        "isReferenceCalculation": true
      },
      "expected": 1.0
    }
  ],
  "references": [
    {
      "source": "Section13.js:3307-3318 (calculateComplianceRatio)"
    },
    {
      "source": "Section13.js:3323 (m_115_ratio calculation)"
    }
  ]
}
