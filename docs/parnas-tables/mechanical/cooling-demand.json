{
  "id": "mechanical.cooling.effectiveCop",
  "legacyId": null,
  "label": "Cooling Demand Calculations",
  "section": "S13",
  "classification": "C",
  "_meta": {
    "description": "Cooling system demand chain: resolves the effective COP based on system configuration, calculates electrical demand from cooling energy demand, computes dedicated cooling heat sink, and derives cooling intensity per unit floor area.",
    "instances": [
      {
        "id": "mechanical.cooling.effectiveCop",
        "legacyId": null,
        "label": "Effective Cooling COP",
        "description": "No Cooling -> 0, Heatpump -> copCoolDerived, Cooling -> copDedicated"
      },
      {
        "id": "mechanical.cooling.electricalDemand",
        "legacyId": "d_117",
        "label": "Cooling Electrical Demand",
        "description": "CED_mitigated / effectiveCOP"
      },
      {
        "id": "mechanical.cooling.coolingSink",
        "legacyId": "l_116",
        "label": "Cooling Heat Sink (Dedicated)",
        "description": "demand x (COP - 1) for dedicated cooling only (not HP)"
      },
      {
        "id": "mechanical.cooling.intensity",
        "legacyId": "f_117",
        "label": "Cooling Intensity",
        "description": "electricalDemand / conditionedFloorArea"
      }
    ]
  },
  "signature": {
    "inputs": [
      {
        "name": "mechanical.cooling.systemType",
        "type": "string",
        "description": "Cooling system type (d_116) - 'No Cooling', 'Cooling'"
      },
      {
        "name": "mechanical.heating.systemType",
        "type": "string",
        "description": "Heating system type (d_113) - determines if HP provides cooling"
      },
      {
        "name": "mechanical.heating.copCoolDerived",
        "type": "number",
        "unit": "ratio",
        "description": "Derived cooling COP from heat pump (j_113)"
      },
      {
        "name": "mechanical.cooling.copDedicated",
        "type": "number",
        "unit": "ratio",
        "description": "Dedicated cooling system COP (j_116)"
      },
      {
        "name": "mechanical.cooling.effectiveCop",
        "type": "number",
        "unit": "ratio",
        "description": "Resolved effective COP - intermediate for electricalDemand"
      },
      {
        "name": "energy.ced.mitigated",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Mitigated Cooling Energy Demand from EnergyNodes"
      },
      {
        "name": "mechanical.cooling.electricalDemand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Cooling electrical demand (d_117) - intermediate for coolingSink and intensity"
      },
      {
        "name": "building.conditionedFloorArea",
        "type": "number",
        "unit": "m2",
        "description": "Conditioned floor area (h_15) from BuildingInfoNodes"
      }
    ],
    "output": {
      "type": "number",
      "unit": "ratio, kWh/yr, or kWh/m2 depending on instance"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "effectiveCop > 0 when cooling is active",
        "description": "COP must be positive for electrical demand calculation"
      }
    ],
    "invariants": [
      {
        "condition": "electricalDemand >= 0",
        "description": "Electrical demand cannot be negative"
      },
      {
        "condition": "coolingSink >= 0",
        "description": "Heat sink energy is non-negative"
      },
      {
        "condition": "intensity >= 0",
        "description": "Cooling intensity is non-negative"
      }
    ]
  },
  "behavior": [
    {
      "id": "mechanical.cooling.effectiveCop",
      "condition": "coolingType == 'No Cooling'",
      "output": "0",
      "note": "No cooling system installed"
    },
    {
      "id": "mechanical.cooling.effectiveCop",
      "condition": "heatingType == 'Heatpump'",
      "output": "copCoolDerived",
      "note": "Heat pump provides cooling; use derived COP (j_113)"
    },
    {
      "id": "mechanical.cooling.effectiveCop",
      "condition": "coolingType == 'Cooling'",
      "output": "copDedicated",
      "note": "Standalone cooling system; use dedicated COP (j_116)"
    },
    {
      "id": "mechanical.cooling.effectiveCop",
      "condition": "none of above",
      "output": "0",
      "note": "Fallback: no effective cooling"
    },
    {
      "id": "mechanical.cooling.electricalDemand",
      "condition": "coolingType == 'No Cooling' || effectiveCop == 0",
      "output": "0",
      "note": "No cooling means no electrical demand"
    },
    {
      "id": "mechanical.cooling.electricalDemand",
      "condition": "coolingType != 'No Cooling' && effectiveCop > 0",
      "output": "ced_mitigated / effectiveCop",
      "precision": "toFixed(4)",
      "note": "Electrical input = total cooling load / COP"
    },
    {
      "id": "mechanical.cooling.coolingSink",
      "condition": "heatingType == 'Heatpump' || coolingType != 'Cooling'",
      "output": "0",
      "note": "HP cooling sink goes to l_114 (sinkEnergy) instead; non-Cooling type has no sink"
    },
    {
      "id": "mechanical.cooling.coolingSink",
      "condition": "heatingType != 'Heatpump' && coolingType == 'Cooling' && cop > 1",
      "output": "electricalDemand * (effectiveCop - 1)",
      "precision": "toFixed(2)",
      "note": "Dedicated cooling heat rejection = electrical input x (COP - 1)"
    },
    {
      "id": "mechanical.cooling.coolingSink",
      "condition": "cop <= 1",
      "output": "0",
      "note": "No heat sink when COP is 1 or below"
    },
    {
      "id": "mechanical.cooling.intensity",
      "condition": "conditionedFloorArea > 0",
      "output": "electricalDemand / conditionedFloorArea",
      "precision": "toFixed(2)",
      "note": "Cooling energy use intensity (EUI) for cooling subsystem"
    },
    {
      "id": "mechanical.cooling.intensity",
      "condition": "conditionedFloorArea <= 0",
      "output": "0",
      "note": "Guard against division by zero"
    }
  ],
  "edgeCases": [
    {
      "condition": "Heatpump heating with 'Cooling' cooling type",
      "handling": "effectiveCop uses copCoolDerived (HP takes priority); coolingSink returns 0 for l_116 (goes to l_114 instead)",
      "rationale": "HP-based cooling sink is tracked separately in mechanical.cooling.sinkEnergy (l_114)"
    },
    {
      "condition": "effectiveCop == 0 with active cooling type",
      "handling": "electricalDemand returns 0",
      "rationale": "Zero COP means no meaningful cooling output"
    }
  ],
  "formula": {
    "symbolic": "effectiveCOP = CASE(d_116='No Cooling'->0, d_113='Heatpump'->j_113, d_116='Cooling'->j_116, else->0); d_117 = IF(noCooling||COP=0, 0, CED_mitigated/effectiveCOP); l_116 = IF(!HP && Cooling && COP>1, d_117*(COP-1), 0); f_117 = d_117/h_15",
    "implementation": "MechanicalNodes.js:353-448"
  },
  "tests": [
    {
      "name": "effectiveCop: No Cooling",
      "instance": "mechanical.cooling.effectiveCop",
      "inputs": {
        "mechanical.cooling.systemType": "No Cooling",
        "mechanical.heating.systemType": "Gas",
        "mechanical.heating.copCoolDerived": 1,
        "mechanical.cooling.copDedicated": 2.66
      },
      "expected": 0
    },
    {
      "name": "effectiveCop: Heatpump provides cooling",
      "instance": "mechanical.cooling.effectiveCop",
      "inputs": {
        "mechanical.cooling.systemType": "Cooling",
        "mechanical.heating.systemType": "Heatpump",
        "mechanical.heating.copCoolDerived": 2.663,
        "mechanical.cooling.copDedicated": 2.66
      },
      "expected": 2.663
    },
    {
      "name": "effectiveCop: Dedicated cooling system",
      "instance": "mechanical.cooling.effectiveCop",
      "inputs": {
        "mechanical.cooling.systemType": "Cooling",
        "mechanical.heating.systemType": "Gas",
        "mechanical.heating.copCoolDerived": 1,
        "mechanical.cooling.copDedicated": 3.5
      },
      "expected": 3.5
    },
    {
      "name": "electricalDemand: No Cooling returns 0",
      "instance": "mechanical.cooling.electricalDemand",
      "inputs": {
        "mechanical.cooling.systemType": "No Cooling",
        "mechanical.cooling.effectiveCop": 0,
        "energy.ced.mitigated": 20000
      },
      "expected": 0
    },
    {
      "name": "electricalDemand: active cooling with COP 3.5",
      "instance": "mechanical.cooling.electricalDemand",
      "inputs": {
        "mechanical.cooling.systemType": "Cooling",
        "mechanical.cooling.effectiveCop": 3.5,
        "energy.ced.mitigated": 20000
      },
      "expected": 5714.2857
    },
    {
      "name": "coolingSink: dedicated cooling with COP 3.5",
      "instance": "mechanical.cooling.coolingSink",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "mechanical.cooling.systemType": "Cooling",
        "mechanical.cooling.electricalDemand": 5714.29,
        "mechanical.cooling.effectiveCop": 3.5
      },
      "expected": 14285.73
    },
    {
      "name": "coolingSink: Heatpump cooling returns 0 (tracked in l_114)",
      "instance": "mechanical.cooling.coolingSink",
      "inputs": {
        "mechanical.heating.systemType": "Heatpump",
        "mechanical.cooling.systemType": "Cooling",
        "mechanical.cooling.electricalDemand": 5000,
        "mechanical.cooling.effectiveCop": 2.66
      },
      "expected": 0
    },
    {
      "name": "intensity: 5714 kWh over 5000 m2",
      "instance": "mechanical.cooling.intensity",
      "inputs": {
        "mechanical.cooling.electricalDemand": 5714.29,
        "building.conditionedFloorArea": 5000
      },
      "expected": 1.14
    },
    {
      "name": "intensity: zero floor area",
      "instance": "mechanical.cooling.intensity",
      "inputs": {
        "mechanical.cooling.electricalDemand": 5000,
        "building.conditionedFloorArea": 0
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "MechanicalNodes.js:353-374 (mechanical.cooling.effectiveCop)"
    },
    {
      "source": "MechanicalNodes.js:376-395 (mechanical.cooling.electricalDemand)"
    },
    {
      "source": "MechanicalNodes.js:397-427 (mechanical.cooling.coolingSink)"
    },
    {
      "source": "MechanicalNodes.js:429-448 (mechanical.cooling.intensity)"
    }
  ]
}