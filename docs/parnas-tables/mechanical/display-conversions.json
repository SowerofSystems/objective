{
  "id": "mechanical.ventilation.perPersonCfm",
  "legacyId": "f_119",
  "label": "Display Conversions and Derived Display Fields",
  "section": "S13",
  "classification": "C",
  "_meta": {
    "description": "Unit conversions for display (L/s to CFM, L/s to m3/h) and derived display fields for cooling sink energy, heating exhaust energy, and latent load factor passthrough. These nodes exist to populate UI cells with alternative unit representations and energy balance display values.",
    "instances": [
      {
        "id": "mechanical.ventilation.perPersonCfm",
        "legacyId": "f_119",
        "label": "Per-Person Ventilation Rate (CFM)",
        "description": "ratePerPerson x 2.11888"
      },
      {
        "id": "mechanical.ventilation.perPersonM3h",
        "legacyId": "h_119",
        "label": "Per-Person Ventilation Rate (m3/h)",
        "description": "ratePerPerson x 3.6"
      },
      {
        "id": "mechanical.ventilation.volumetricCfm",
        "legacyId": "f_120",
        "label": "Volumetric Ventilation Rate (CFM)",
        "description": "rateLs x 2.11888"
      },
      {
        "id": "mechanical.cooling.sinkEnergy",
        "legacyId": "l_114",
        "label": "Cooling Sink Energy (HP only)",
        "description": "cooling demand x (COP - 1) for Heatpump only"
      },
      {
        "id": "mechanical.heating.exhaustEnergy",
        "legacyId": "l_115",
        "label": "Heating Exhaust Energy",
        "description": "fuelImpact - demand for Gas/Oil only"
      },
      {
        "id": "mechanical.cooling.latentLoadDisplay",
        "legacyId": "h_122",
        "label": "Latent Load Factor (%)",
        "description": "Passthrough of cooling.latentLoadFactor"
      }
    ]
  },
  "signature": {
    "inputs": [
      {
        "name": "mechanical.ventilation.ratePerPerson",
        "type": "number",
        "unit": "L/s/person",
        "description": "Per-person ventilation rate (d_119)"
      },
      {
        "name": "mechanical.ventilation.rateLs",
        "type": "number",
        "unit": "L/s",
        "description": "Volumetric ventilation rate from rateLs calculation"
      },
      {
        "name": "mechanical.cooling.electricalDemand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Cooling electrical demand (d_117)"
      },
      {
        "name": "mechanical.cooling.cop",
        "type": "number",
        "unit": "ratio",
        "description": "Cooling COP from CoolingNodes"
      },
      {
        "name": "mechanical.heating.systemType",
        "type": "string",
        "description": "Heating system type (d_113)"
      },
      {
        "name": "mechanical.heating.fuelImpact",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Fuel energy impact (d_115)"
      },
      {
        "name": "mechanical.heating.demand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Heating system demand (d_114)"
      },
      {
        "name": "cooling.latentLoadFactor",
        "type": "number",
        "unit": "%",
        "description": "Latent load factor from CoolingNodes"
      }
    ],
    "output": {
      "type": "number",
      "unit": "CFM, m3/h, kWh/yr, or % depending on instance"
    }
  },
  "domain": {
    "preconditions": [],
    "invariants": [
      {
        "condition": "perPersonCfm >= 0",
        "description": "Ventilation rates are non-negative"
      },
      {
        "condition": "sinkEnergy >= 0",
        "description": "Cooling sink energy is non-negative"
      }
    ]
  },
  "behavior": [
    {
      "id": "mechanical.ventilation.perPersonCfm",
      "condition": "always",
      "output": "ratePerPerson * 2.11888",
      "precision": "toFixed(2)",
      "note": "Convert L/s to CFM (1 L/s = 2.11888 CFM)"
    },
    {
      "id": "mechanical.ventilation.perPersonM3h",
      "condition": "always",
      "output": "ratePerPerson * 3.6",
      "precision": "toFixed(2)",
      "note": "Convert L/s to m3/h (1 L/s = 3.6 m3/h)"
    },
    {
      "id": "mechanical.ventilation.volumetricCfm",
      "condition": "always",
      "output": "rateLs * 2.11888",
      "precision": "toFixed(2)",
      "note": "Convert total volumetric L/s to CFM"
    },
    {
      "id": "mechanical.cooling.sinkEnergy",
      "condition": "systemType == 'Heatpump'",
      "output": "electricalDemand * (cooling.cop - 1)",
      "note": "Heat rejected by HP cooling = electrical input x (COP - 1). Counterpart to l_116 which covers dedicated cooling."
    },
    {
      "id": "mechanical.cooling.sinkEnergy",
      "condition": "systemType != 'Heatpump'",
      "output": "0",
      "note": "Only HP systems use this node; dedicated cooling sink is in l_116"
    },
    {
      "id": "mechanical.heating.exhaustEnergy",
      "condition": "systemType == 'Gas' || systemType == 'Oil'",
      "output": "fuelImpact - demand",
      "note": "Energy lost as exhaust = gross fuel input minus useful heat delivered"
    },
    {
      "id": "mechanical.heating.exhaustEnergy",
      "condition": "systemType not in ['Gas', 'Oil']",
      "output": "0",
      "note": "No combustion exhaust for electric/HP/district systems"
    },
    {
      "id": "mechanical.cooling.latentLoadDisplay",
      "condition": "always",
      "output": "cooling.latentLoadFactor",
      "note": "Pure passthrough for UI display; no transformation applied"
    }
  ],
  "edgeCases": [
    {
      "condition": "cooling.cop == 1 for Heatpump sinkEnergy",
      "handling": "Returns electricalDemand * 0 = 0",
      "rationale": "COP of 1 means no net heat extraction from environment"
    },
    {
      "condition": "fuelImpact < demand for exhaustEnergy",
      "handling": "Returns negative value",
      "rationale": "Physically unlikely (would mean AFUE > 1) but no guard; upstream AFUE constraint prevents this"
    }
  ],
  "formula": {
    "symbolic": "f_119 = d_119*2.11888; h_119 = d_119*3.6; f_120 = rateLs*2.11888; l_114 = IF(HP, d_117*(COP-1), 0); l_115 = IF(Gas|Oil, d_115-d_114, 0); h_122 = latentLoadFactor",
    "implementation": "MechanicalNodes.js:542-660"
  },
  "tests": [
    {
      "name": "perPersonCfm: 10 L/s/person",
      "instance": "mechanical.ventilation.perPersonCfm",
      "inputs": {
        "mechanical.ventilation.ratePerPerson": 10
      },
      "expected": 21.19
    },
    {
      "name": "perPersonM3h: 10 L/s/person",
      "instance": "mechanical.ventilation.perPersonM3h",
      "inputs": {
        "mechanical.ventilation.ratePerPerson": 10
      },
      "expected": 36.0
    },
    {
      "name": "volumetricCfm: 6666.67 L/s",
      "instance": "mechanical.ventilation.volumetricCfm",
      "inputs": {
        "mechanical.ventilation.rateLs": 6666.67
      },
      "expected": 14125.87
    },
    {
      "name": "sinkEnergy: HP cooling with COP 2.66",
      "instance": "mechanical.cooling.sinkEnergy",
      "inputs": {
        "mechanical.heating.systemType": "Heatpump",
        "mechanical.cooling.electricalDemand": 5000,
        "mechanical.cooling.cop": 2.66
      },
      "expected": 8300
    },
    {
      "name": "sinkEnergy: Gas system returns 0",
      "instance": "mechanical.cooling.sinkEnergy",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "mechanical.cooling.electricalDemand": 5000,
        "mechanical.cooling.cop": 2.66
      },
      "expected": 0
    },
    {
      "name": "exhaustEnergy: Gas with 96% AFUE",
      "instance": "mechanical.heating.exhaustEnergy",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "mechanical.heating.fuelImpact": 52083.33,
        "mechanical.heating.demand": 50000
      },
      "expected": 2083.33
    },
    {
      "name": "exhaustEnergy: Heatpump returns 0",
      "instance": "mechanical.heating.exhaustEnergy",
      "inputs": {
        "mechanical.heating.systemType": "Heatpump",
        "mechanical.heating.fuelImpact": 0,
        "mechanical.heating.demand": 13661
      },
      "expected": 0
    },
    {
      "name": "latentLoadDisplay: passthrough 1.15",
      "instance": "mechanical.cooling.latentLoadDisplay",
      "inputs": {
        "cooling.latentLoadFactor": 1.15
      },
      "expected": 1.15
    },
    {
      "name": "latentLoadDisplay: default 1.0",
      "instance": "mechanical.cooling.latentLoadDisplay",
      "inputs": {
        "cooling.latentLoadFactor": null
      },
      "expected": 1.0
    }
  ],
  "references": [
    {
      "source": "MechanicalNodes.js:542-553 (mechanical.ventilation.perPersonCfm)"
    },
    {
      "source": "MechanicalNodes.js:556-567 (mechanical.ventilation.perPersonM3h)"
    },
    {
      "source": "MechanicalNodes.js:570-581 (mechanical.ventilation.volumetricCfm)"
    },
    {
      "source": "MechanicalNodes.js:615-629 (mechanical.cooling.sinkEnergy)"
    },
    {
      "source": "MechanicalNodes.js:632-646 (mechanical.heating.exhaustEnergy)"
    },
    {
      "source": "MechanicalNodes.js:649-660 (mechanical.cooling.latentLoadDisplay)"
    }
  ]
}