{
  "id": "mechanical.heating.demand",
  "legacyId": "d_114",
  "label": "Heating Demand and Fuel Consumption",
  "section": "S13",
  "classification": "C",
  "_meta": {
    "description": "Heating system demand, heat sink energy, fuel impact, and fuel volume consumption calculations. Converts total energy demand (TED) into system-specific electrical demand, free energy (heat sink), combustion fuel impact, and volumetric consumption for gas and oil systems.",
    "instances": [
      {
        "id": "mechanical.heating.demand",
        "legacyId": "d_114",
        "label": "Heating System Electrical Demand",
        "description": "TED / COPheat for Heatpump, else TED directly"
      },
      {
        "id": "mechanical.heating.heatingSink",
        "legacyId": "l_113",
        "label": "Heat Pump Heat Sink (Free Energy)",
        "description": "demand x (COP - 1) for Heatpump only"
      },
      {
        "id": "mechanical.heating.fuelImpact",
        "legacyId": "d_115",
        "label": "Fuel Energy Impact",
        "description": "TED / AFUE for Gas/Oil systems"
      },
      {
        "id": "mechanical.heating.gasConsumption",
        "legacyId": "h_115",
        "label": "Gas Consumption",
        "description": "fuelImpact / 10.36 for Gas systems"
      },
      {
        "id": "mechanical.heating.oilConsumption",
        "legacyId": "f_115",
        "label": "Oil Consumption",
        "description": "fuelImpact / 10.2 for Oil systems"
      }
    ]
  },
  "signature": {
    "inputs": [
      {
        "name": "mechanical.heating.systemType",
        "type": "string",
        "description": "Heating system type (d_113) - 'Oil', 'Gas', 'Heatpump', 'Electric', 'District'"
      },
      {
        "name": "mechanical.heating.copHeat",
        "type": "number",
        "unit": "ratio",
        "description": "Heating COP (h_113)"
      },
      {
        "name": "energy.ted.heating",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Total Energy Demand for heating (d_127) from EnergyNodes"
      },
      {
        "name": "mechanical.heating.afue",
        "type": "number",
        "unit": "decimal",
        "description": "AFUE efficiency (j_115) - e.g., 0.96 for 96%"
      },
      {
        "name": "mechanical.heating.demand",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Heating electrical demand (d_114) - intermediate for heatingSink"
      },
      {
        "name": "mechanical.heating.fuelImpact",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Fuel energy impact (d_115) - intermediate for gas/oil consumption"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr, m3/yr, or L/yr depending on instance"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "copHeat > 0",
        "description": "COP must be positive for division"
      },
      {
        "condition": "afue > 0 when systemType in ['Gas', 'Oil']",
        "description": "AFUE must be positive for fuel impact calculation"
      }
    ],
    "invariants": [
      {
        "condition": "demand >= 0",
        "description": "Electrical demand cannot be negative"
      },
      {
        "condition": "heatingSink >= 0",
        "description": "Free energy from heat pump is non-negative"
      },
      {
        "condition": "fuelImpact >= 0",
        "description": "Fuel impact is non-negative"
      }
    ]
  },
  "behavior": [
    {
      "id": "mechanical.heating.demand",
      "condition": "systemType == 'Heatpump' && copHeat > 0",
      "output": "ted / copHeat",
      "precision": "toFixed(4)",
      "note": "HP electrical demand is reduced by COP multiplier"
    },
    {
      "id": "mechanical.heating.demand",
      "condition": "systemType != 'Heatpump'",
      "output": "ted",
      "precision": "toFixed(4)",
      "note": "Non-HP systems: electrical demand equals TED (fuel tracked separately)"
    },
    {
      "id": "mechanical.heating.heatingSink",
      "condition": "systemType == 'Heatpump'",
      "output": "demand * (copHeat - 1)",
      "precision": "toFixed(4)",
      "note": "Free energy extracted from environment = electrical input x (COP - 1)"
    },
    {
      "id": "mechanical.heating.heatingSink",
      "condition": "systemType != 'Heatpump'",
      "output": "0",
      "note": "Only heat pumps extract environmental energy"
    },
    {
      "id": "mechanical.heating.fuelImpact",
      "condition": "(systemType == 'Gas' || systemType == 'Oil') && afue > 0",
      "output": "ted / afue",
      "precision": "toFixed(2)",
      "note": "Gross fuel energy = net demand / efficiency (AFUE < 1 means more fuel burned)"
    },
    {
      "id": "mechanical.heating.fuelImpact",
      "condition": "systemType not in ['Gas', 'Oil']",
      "output": "0",
      "note": "No combustion fuel for electric/HP/district systems"
    },
    {
      "id": "mechanical.heating.gasConsumption",
      "condition": "systemType == 'Gas'",
      "output": "fuelImpact / 10.36",
      "precision": "toFixed(2)",
      "note": "Gas energy content: 10.36 kWh/m3"
    },
    {
      "id": "mechanical.heating.gasConsumption",
      "condition": "systemType != 'Gas'",
      "output": "0"
    },
    {
      "id": "mechanical.heating.oilConsumption",
      "condition": "systemType == 'Oil'",
      "output": "fuelImpact / 10.2",
      "precision": "toFixed(2)",
      "note": "Oil energy content: 10.2 kWh/L"
    },
    {
      "id": "mechanical.heating.oilConsumption",
      "condition": "systemType != 'Oil'",
      "output": "0"
    }
  ],
  "edgeCases": [
    {
      "condition": "copHeat == 0 for Heatpump",
      "handling": "Guard fails, falls to non-HP branch returning ted directly",
      "rationale": "Zero COP is physically impossible"
    },
    {
      "condition": "afue == 0 for Gas/Oil",
      "handling": "Guard fails, returns 0 fuelImpact",
      "rationale": "Zero efficiency is physically impossible; avoids division by zero"
    }
  ],
  "formula": {
    "symbolic": "d_114 = IF(HP, TED/COP, TED); l_113 = IF(HP, d_114*(COP-1), 0); d_115 = IF(Gas|Oil, TED/AFUE, 0); h_115 = IF(Gas, d_115/10.36, 0); f_115 = IF(Oil, d_115/10.2, 0)",
    "implementation": "MechanicalNodes.js:200-310"
  },
  "tests": [
    {
      "name": "demand: Heatpump with COP 3.66",
      "instance": "mechanical.heating.demand",
      "inputs": {
        "mechanical.heating.systemType": "Heatpump",
        "mechanical.heating.copHeat": 3.66,
        "energy.ted.heating": 50000
      },
      "expected": 13661.2022
    },
    {
      "name": "demand: Gas system (pass-through)",
      "instance": "mechanical.heating.demand",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "mechanical.heating.copHeat": 1,
        "energy.ted.heating": 50000
      },
      "expected": 50000
    },
    {
      "name": "heatingSink: Heatpump free energy",
      "instance": "mechanical.heating.heatingSink",
      "inputs": {
        "mechanical.heating.systemType": "Heatpump",
        "mechanical.heating.demand": 13661,
        "mechanical.heating.copHeat": 3.66
      },
      "expected": 36339.46
    },
    {
      "name": "heatingSink: Gas returns 0",
      "instance": "mechanical.heating.heatingSink",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "mechanical.heating.demand": 50000,
        "mechanical.heating.copHeat": 1
      },
      "expected": 0
    },
    {
      "name": "fuelImpact: Gas with 96% AFUE",
      "instance": "mechanical.heating.fuelImpact",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "mechanical.heating.afue": 0.96,
        "energy.ted.heating": 50000
      },
      "expected": 52083.33
    },
    {
      "name": "fuelImpact: Heatpump returns 0",
      "instance": "mechanical.heating.fuelImpact",
      "inputs": {
        "mechanical.heating.systemType": "Heatpump",
        "mechanical.heating.afue": 0.96,
        "energy.ted.heating": 50000
      },
      "expected": 0
    },
    {
      "name": "gasConsumption: Gas system",
      "instance": "mechanical.heating.gasConsumption",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "mechanical.heating.fuelImpact": 52083.33
      },
      "expected": 5027.35
    },
    {
      "name": "oilConsumption: Oil system",
      "instance": "mechanical.heating.oilConsumption",
      "inputs": {
        "mechanical.heating.systemType": "Oil",
        "mechanical.heating.fuelImpact": 55555.56
      },
      "expected": 5446.62
    },
    {
      "name": "oilConsumption: Gas returns 0",
      "instance": "mechanical.heating.oilConsumption",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "mechanical.heating.fuelImpact": 52083.33
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "MechanicalNodes.js:200-224 (mechanical.heating.demand)"
    },
    {
      "source": "MechanicalNodes.js:226-248 (mechanical.heating.heatingSink)"
    },
    {
      "source": "MechanicalNodes.js:250-272 (mechanical.heating.fuelImpact)"
    },
    {
      "source": "MechanicalNodes.js:274-291 (mechanical.heating.gasConsumption)"
    },
    {
      "source": "MechanicalNodes.js:293-310 (mechanical.heating.oilConsumption)"
    }
  ]
}