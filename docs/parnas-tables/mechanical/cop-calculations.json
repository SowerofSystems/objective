{
  "id": "mechanical.heating.copHeat",
  "legacyId": "h_113",
  "label": "COP Calculations",
  "section": "S13",
  "classification": "C",
  "_meta": {
    "description": "Coefficient of Performance calculations for heating and cooling systems. Derives cooling COP from heat pump HSPF, and converts COP values to CEER (Combined Energy Efficiency Ratio) for both heat-pump-derived and dedicated cooling systems.",
    "instances": [
      {
        "id": "mechanical.heating.copHeat",
        "legacyId": "h_113",
        "label": "Heating COP",
        "description": "HSPF / 3.412 for Heatpump systems, else 1"
      },
      {
        "id": "mechanical.heating.copCoolDerived",
        "legacyId": "j_113",
        "label": "Cooling COP (Derived from Heat Pump)",
        "description": "max(1, copHeat - 1)"
      },
      {
        "id": "mechanical.heating.ceer",
        "legacyId": null,
        "label": "CEER (HP-derived)",
        "description": "3.412 x copCoolDerived"
      },
      {
        "id": "mechanical.heating.ceer",
        "legacyId": "j_114",
        "label": "CEER (from cooling.cop)",
        "description": "3.412 x cooling.cop"
      },
      {
        "id": "mechanical.cooling.ceer",
        "legacyId": "j_117",
        "label": "Cooling System CEER",
        "description": "3.412 x COP (dedicated or derived depending on system type)"
      }
    ]
  },
  "signature": {
    "inputs": [
      {
        "name": "mechanical.heating.systemType",
        "type": "string",
        "description": "Heating system type (d_113) - 'Oil', 'Gas', 'Heatpump', 'Electric', 'District'"
      },
      {
        "name": "mechanical.heating.hspf",
        "type": "number",
        "unit": "BTU/Wh",
        "description": "Heat Pump Seasonal Performance Factor (f_113)"
      },
      {
        "name": "mechanical.heating.copHeat",
        "type": "number",
        "unit": "ratio",
        "description": "Heating COP (h_113) - intermediate for copCoolDerived"
      },
      {
        "name": "mechanical.heating.copCoolDerived",
        "type": "number",
        "unit": "ratio",
        "description": "Derived cooling COP (j_113) - intermediate for HP-derived CEER"
      },
      {
        "name": "mechanical.cooling.cop",
        "type": "number",
        "unit": "ratio",
        "description": "Cooling COP from CoolingNodes - used by j_114 CEER"
      },
      {
        "name": "mechanical.cooling.copDedicated",
        "type": "number",
        "unit": "ratio",
        "description": "Dedicated cooling COP (j_116) - used by j_117 CEER"
      },
      {
        "name": "mechanical.cooling.systemType",
        "type": "string",
        "description": "Cooling system type (d_116) - selects COP source for j_117"
      }
    ],
    "output": {
      "type": "number",
      "unit": "ratio or BTU/Wh",
      "description": "COP (ratio) or CEER (BTU/Wh) depending on instance"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "hspf > 0 when systemType == 'Heatpump'",
        "description": "HSPF must be positive for heat pump COP calculation"
      }
    ],
    "invariants": [
      {
        "condition": "copHeat >= 1",
        "description": "COP of 1 is minimum (equivalent to resistive heating)"
      },
      {
        "condition": "copCoolDerived >= 1",
        "description": "Derived cooling COP floored at 1 via max(1, copHeat - 1)"
      }
    ]
  },
  "behavior": [
    {
      "id": "mechanical.heating.copHeat",
      "condition": "systemType == 'Heatpump' && hspf > 0",
      "output": "hspf / 3.412",
      "precision": "toFixed(4)",
      "note": "Convert HSPF (BTU/Wh) to COP (dimensionless) via standard factor 3.412 BTU/Wh"
    },
    {
      "id": "mechanical.heating.copHeat",
      "condition": "systemType != 'Heatpump'",
      "output": "1",
      "note": "Non-HP systems have effective COP of 1 (no thermodynamic multiplier)"
    },
    {
      "id": "mechanical.heating.copCoolDerived",
      "condition": "always",
      "output": "max(1, copHeat - 1)",
      "precision": "toFixed(4)",
      "note": "Cooling COP is approximately heating COP minus 1, floored at 1"
    },
    {
      "id": "mechanical.heating.ceer (no legacyId)",
      "condition": "always",
      "output": "3.412 * copCoolDerived",
      "precision": "toFixed(2)",
      "note": "Convert derived cooling COP back to CEER rating"
    },
    {
      "id": "mechanical.heating.ceer (j_114)",
      "condition": "always",
      "output": "3.412 * cooling.cop",
      "precision": "toFixed(2)",
      "note": "CEER from CoolingNodes COP (combined cooling system)"
    },
    {
      "id": "mechanical.cooling.ceer (j_117)",
      "condition": "coolingSystemType == 'Cooling'",
      "output": "3.412 * copDedicated",
      "precision": "toFixed(1)",
      "note": "Use dedicated COP for standalone cooling systems"
    },
    {
      "id": "mechanical.cooling.ceer (j_117)",
      "condition": "coolingSystemType != 'Cooling'",
      "output": "3.412 * cooling.cop",
      "precision": "toFixed(1)",
      "note": "Fall back to combined cooling COP for HP-based cooling"
    }
  ],
  "edgeCases": [
    {
      "condition": "hspf == 0 for Heatpump",
      "handling": "Returns 1 (guard: hspf > 0 check fails, falls through)",
      "rationale": "Zero HSPF is physically impossible; treat as non-HP"
    }
  ],
  "formula": {
    "symbolic": "h_113 = IF(d_113='Heatpump' AND f_113>0, f_113/3.412, 1); j_113 = max(1, h_113-1); CEER = 3.412 * COP; j_117 = IF(d_116='Cooling', 3.412*j_116, 3.412*cooling.cop)",
    "implementation": "MechanicalNodes.js:153-195, 583-612"
  },
  "tests": [
    {
      "name": "copHeat: Heatpump with HSPF 12.5",
      "instance": "mechanical.heating.copHeat",
      "inputs": {
        "mechanical.heating.systemType": "Heatpump",
        "mechanical.heating.hspf": 12.5
      },
      "expected": 3.6630
    },
    {
      "name": "copHeat: Gas system returns 1",
      "instance": "mechanical.heating.copHeat",
      "inputs": {
        "mechanical.heating.systemType": "Gas",
        "mechanical.heating.hspf": 0
      },
      "expected": 1
    },
    {
      "name": "copCoolDerived: from COP 3.663",
      "instance": "mechanical.heating.copCoolDerived",
      "inputs": {
        "mechanical.heating.copHeat": 3.663
      },
      "expected": 2.663
    },
    {
      "name": "copCoolDerived: floor at 1 when copHeat is 1",
      "instance": "mechanical.heating.copCoolDerived",
      "inputs": {
        "mechanical.heating.copHeat": 1
      },
      "expected": 1
    },
    {
      "name": "CEER (HP-derived): from copCoolDerived 2.663",
      "instance": "mechanical.heating.ceer",
      "inputs": {
        "mechanical.heating.copCoolDerived": 2.663
      },
      "expected": 9.08
    },
    {
      "name": "j_114 CEER: from cooling.cop 2.66",
      "instance": "mechanical.heating.ceer (j_114)",
      "inputs": {
        "mechanical.cooling.cop": 2.66
      },
      "expected": 9.08
    },
    {
      "name": "j_117 CEER: dedicated cooling COP 2.66",
      "instance": "mechanical.cooling.ceer",
      "inputs": {
        "mechanical.cooling.systemType": "Cooling",
        "mechanical.cooling.copDedicated": 2.66
      },
      "expected": 9.1
    },
    {
      "name": "j_117 CEER: HP-based cooling falls to cooling.cop",
      "instance": "mechanical.cooling.ceer",
      "inputs": {
        "mechanical.cooling.systemType": "No Cooling",
        "mechanical.cooling.cop": 3.0
      },
      "expected": 10.2
    }
  ],
  "references": [
    {
      "source": "MechanicalNodes.js:153-195 (copHeat, copCoolDerived, CEER HP-derived)"
    },
    {
      "source": "MechanicalNodes.js:583-595 (j_114 CEER from cooling.cop)"
    },
    {
      "source": "MechanicalNodes.js:598-612 (j_117 cooling CEER)"
    }
  ]
}