{
  "id": "mechanical.ventilation.rateLs",
  "legacyId": null,
  "label": "Ventilation Mechanical Calculations",
  "section": "S13",
  "classification": "C",
  "_meta": {
    "description": "Ventilation flow rate, unit conversion, heat recovery factor, and heating energy loss calculations. Converts conditioned volume and ACH to ventilation rates, determines heat recovery effectiveness, and calculates annual energy lost through ventilation air exchange.",
    "instances": [
      {
        "id": "mechanical.ventilation.rateLs",
        "legacyId": null,
        "label": "Ventilation Rate (L/s)",
        "description": "volume x ACH / 3.6; Natural/None -> 0"
      },
      {
        "id": "mechanical.ventilation.rateM3h",
        "legacyId": null,
        "label": "Ventilation Rate (m3/h)",
        "description": "rateLs x 3.6"
      },
      {
        "id": "mechanical.ventilation.recoveryFactor",
        "legacyId": null,
        "label": "Heat Recovery Factor",
        "description": "efficiency / 100 for HRV/ERV, else 0"
      },
      {
        "id": "mechanical.ventilation.heatingEnergyLoss",
        "legacyId": null,
        "label": "Ventilation Heating Energy Loss",
        "description": "rateLs x (1 - recovery) x HDD x 24 x 1.2 / 1000"
      }
    ]
  },
  "signature": {
    "inputs": [
      {
        "name": "mechanical.ventilation.method",
        "type": "string",
        "description": "Ventilation method (g_118) - 'HRV', 'ERV', 'Exhaust', 'Natural', 'None'"
      },
      {
        "name": "mechanical.ventilation.ach",
        "type": "number",
        "unit": "ACH",
        "description": "Air changes per hour (l_118)"
      },
      {
        "name": "volume.conditioned",
        "type": "number",
        "unit": "m3",
        "description": "Conditioned volume (d_105) from VolumeMetricsNodes"
      },
      {
        "name": "mechanical.ventilation.efficiency",
        "type": "number",
        "unit": "%",
        "description": "ERV/HRV sensible recovery efficiency (d_118)"
      },
      {
        "name": "mechanical.ventilation.rateLs",
        "type": "number",
        "unit": "L/s",
        "description": "Ventilation rate - intermediate for rateM3h and heatingEnergyLoss"
      },
      {
        "name": "mechanical.ventilation.recoveryFactor",
        "type": "number",
        "unit": "decimal",
        "description": "Recovery factor - intermediate for heatingEnergyLoss"
      },
      {
        "name": "climate.heating.degreedays",
        "type": "number | string",
        "unit": "degree-days",
        "description": "Heating degree days from ClimateNodes; may be 'Unavailable'"
      }
    ],
    "output": {
      "type": "number | string",
      "unit": "L/s, m3/h, decimal, or kWh/yr depending on instance",
      "description": "heatingEnergyLoss may return 'Unavailable' if HDD is unavailable"
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "volume > 0",
        "description": "Conditioned volume must be positive for rate calculation"
      }
    ],
    "invariants": [
      {
        "condition": "rateLs >= 0",
        "description": "Ventilation rate cannot be negative"
      },
      {
        "condition": "0 <= recoveryFactor <= 1",
        "description": "Recovery factor is a proportion between 0 and 1"
      }
    ]
  },
  "behavior": [
    {
      "id": "mechanical.ventilation.rateLs",
      "condition": "method == 'Natural' || method == 'None'",
      "output": "0",
      "note": "No mechanical ventilation flow"
    },
    {
      "id": "mechanical.ventilation.rateLs",
      "condition": "method in ['HRV', 'ERV', 'Exhaust']",
      "output": "(volume * ach) / 3.6",
      "precision": "toFixed(2)",
      "note": "Convert m3/h to L/s: volume(m3) x ACH(1/h) = m3/h; divide by 3.6 to get L/s"
    },
    {
      "id": "mechanical.ventilation.rateM3h",
      "condition": "always",
      "output": "rateLs * 3.6",
      "precision": "toFixed(2)",
      "note": "Inverse of L/s to m3/h conversion"
    },
    {
      "id": "mechanical.ventilation.recoveryFactor",
      "condition": "method == 'HRV' || method == 'ERV'",
      "output": "efficiency / 100",
      "precision": "toFixed(2)",
      "note": "Convert percentage to decimal fraction"
    },
    {
      "id": "mechanical.ventilation.recoveryFactor",
      "condition": "method not in ['HRV', 'ERV']",
      "output": "0",
      "note": "Exhaust-only and other methods have no heat recovery"
    },
    {
      "id": "mechanical.ventilation.heatingEnergyLoss",
      "condition": "HDD is available (numeric)",
      "output": "rateLs * (1 - recoveryFactor) * HDD * 24 * 1.2 / 1000",
      "precision": "toFixed(2)",
      "note": "Energy = airflow(L/s) x net loss fraction x degree-days x 24h/day x 1.2(kJ/m3K) / 1000(kJ->kWh). 1.2 is volumetric heat capacity of air."
    },
    {
      "id": "mechanical.ventilation.heatingEnergyLoss",
      "condition": "HDD is 'Unavailable' or 'N/A'",
      "output": "\"Unavailable\"",
      "note": "Cannot compute without climate data"
    }
  ],
  "edgeCases": [
    {
      "condition": "climate.heating.degreedays == 'Unavailable'",
      "handling": "Return string 'Unavailable' instead of numeric",
      "rationale": "Climate data may not be loaded yet; downstream nodes must handle string output"
    },
    {
      "condition": "method == 'Exhaust' with non-zero efficiency",
      "handling": "recoveryFactor returns 0 regardless of efficiency input",
      "rationale": "Exhaust-only ventilation cannot recover heat"
    }
  ],
  "formula": {
    "symbolic": "rateLs = IF(Natural|None, 0, volume*ACH/3.6); rateM3h = rateLs*3.6; recovery = IF(HRV|ERV, eff/100, 0); energyLoss = IF(HDD available, rateLs*(1-recovery)*HDD*24*1.2/1000, 'Unavailable')",
    "implementation": "MechanicalNodes.js:454-535"
  },
  "tests": [
    {
      "name": "rateLs: HRV with 8000 m3 at 3 ACH",
      "instance": "mechanical.ventilation.rateLs",
      "inputs": {
        "mechanical.ventilation.method": "HRV",
        "mechanical.ventilation.ach": 3.0,
        "volume.conditioned": 8000
      },
      "expected": 6666.67
    },
    {
      "name": "rateLs: Natural ventilation returns 0",
      "instance": "mechanical.ventilation.rateLs",
      "inputs": {
        "mechanical.ventilation.method": "Natural",
        "mechanical.ventilation.ach": 3.0,
        "volume.conditioned": 8000
      },
      "expected": 0
    },
    {
      "name": "rateM3h: from 6666.67 L/s",
      "instance": "mechanical.ventilation.rateM3h",
      "inputs": {
        "mechanical.ventilation.rateLs": 6666.67
      },
      "expected": 24000.01
    },
    {
      "name": "recoveryFactor: HRV at 55%",
      "instance": "mechanical.ventilation.recoveryFactor",
      "inputs": {
        "mechanical.ventilation.method": "HRV",
        "mechanical.ventilation.efficiency": 55
      },
      "expected": 0.55
    },
    {
      "name": "recoveryFactor: Exhaust returns 0",
      "instance": "mechanical.ventilation.recoveryFactor",
      "inputs": {
        "mechanical.ventilation.method": "Exhaust",
        "mechanical.ventilation.efficiency": 55
      },
      "expected": 0
    },
    {
      "name": "heatingEnergyLoss: HRV with 55% recovery, 4000 HDD",
      "instance": "mechanical.ventilation.heatingEnergyLoss",
      "inputs": {
        "mechanical.ventilation.rateLs": 6666.67,
        "mechanical.ventilation.recoveryFactor": 0.55,
        "climate.heating.degreedays": 4000
      },
      "expected": 345600.10
    },
    {
      "name": "heatingEnergyLoss: HDD unavailable",
      "instance": "mechanical.ventilation.heatingEnergyLoss",
      "inputs": {
        "mechanical.ventilation.rateLs": 6666.67,
        "mechanical.ventilation.recoveryFactor": 0.55,
        "climate.heating.degreedays": "Unavailable"
      },
      "expected": "Unavailable"
    }
  ],
  "references": [
    {
      "source": "MechanicalNodes.js:454-476 (mechanical.ventilation.rateLs)"
    },
    {
      "source": "MechanicalNodes.js:478-490 (mechanical.ventilation.rateM3h)"
    },
    {
      "source": "MechanicalNodes.js:492-510 (mechanical.ventilation.recoveryFactor)"
    },
    {
      "source": "MechanicalNodes.js:512-535 (mechanical.ventilation.heatingEnergyLoss)"
    }
  ]
}