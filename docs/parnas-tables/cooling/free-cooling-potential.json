{
  "id": "cooling.freeCoolingPotential",
  "label": "Free Cooling Potential",
  "section": "S13",
  "classification": "C",
  "_meta": {
    "description": "Free cooling calculations: raw annual potential from ventilation, daily free cooling capacity (with summer boost), and the ratio of free cooling to total unmitigated cooling demand.",
    "instances": [
      "cooling.freeCoolingRaw",
      "cooling.dailyFreeCoolingPotential",
      "cooling.freeCoolingPercent"
    ]
  },
  "constants": {
    "airDensity": {
      "value": 1.204,
      "unit": "kg/m³",
      "description": "Mass of air at standard conditions"
    },
    "specificHeatCapacity": {
      "value": 1005,
      "unit": "J/(kg·K)",
      "description": "Specific heat capacity of air"
    }
  },
  "nodes": [
    {
      "id": "cooling.freeCoolingRaw",
      "legacyId": "cooling_h_124",
      "label": "Free Cooling Raw Potential",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Raw annual free cooling potential from ventilation before setback adjustment. Based on mass air flow rate, sensible temperature differential between indoor setpoint and outdoor night temperature, and cooling season length."
      },
      "signature": {
        "inputs": [
          {
            "name": "ventilation.volumeRate",
            "type": "number",
            "unit": "m³/hr",
            "description": "Ventilation volume flow rate (h_120)"
          },
          {
            "name": "climate.cooling.nightTemp",
            "type": "number",
            "unit": "°C",
            "description": "Night-time outdoor temperature (l_20)"
          },
          {
            "name": "climate.cooling.setpoint",
            "type": "number",
            "unit": "°C",
            "description": "Indoor cooling setpoint temperature (h_24)"
          },
          {
            "name": "climate.coolingDays",
            "type": "number",
            "unit": "days",
            "description": "Cooling season length (m_19)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kWh/yr",
          "precision": 2
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "ventilation.volumeRate >= 0",
            "description": "Ventilation rate cannot be negative"
          },
          {
            "condition": "climate.coolingDays >= 0",
            "description": "Cooling season cannot be negative days"
          }
        ],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "Free cooling potential cannot be negative"
          }
        ]
      },
      "behavior": [
        {
          "condition": "setpoint <= nightTemp (tempDiff <= 0)",
          "output": "0",
          "note": "No free cooling when outdoor is warmer than or equal to setpoint"
        },
        {
          "condition": "setpoint > nightTemp",
          "output": "(h_120/3600) * 1.204 * 1005 * (h_24 - l_20) * 0.024 * m_19",
          "note": "Sensible heat removal scaled to annual energy"
        }
      ],
      "edgeCases": [
        {
          "condition": "tempDiff <= 0 (setpoint <= nightTemp)",
          "output": "0",
          "description": "No free cooling potential when outdoor air cannot absorb heat"
        }
      ],
      "formula": {
        "symbolic": "freeCoolingRaw = (h_120 / 3600) * 1.204 * 1005 * (h_24 - l_20) * 0.024 * m_19",
        "steps": [
          "1. Convert flow rate: m³/s = h_120 / 3600",
          "2. Mass flow rate: kg/s = m³/s * 1.204",
          "3. Sensible heat removal power: W = kg/s * 1005 * (T_setpoint - T_night)",
          "4. Daily energy: kWh/day = W * 0.024 (i.e., W * 86400 / 3600000)",
          "5. Annual energy: kWh/yr = kWh/day * m_19"
        ],
        "implementation": "CoolingNodes.js:223-270"
      },
      "tests": [
        {
          "name": "Typical free cooling potential",
          "inputs": {
            "ventilation.volumeRate": 288,
            "climate.cooling.nightTemp": 20.43,
            "climate.cooling.setpoint": 24,
            "climate.coolingDays": 120
          },
          "expected": 995.28,
          "tolerance": 1.0,
          "note": "(288/3600) * 1.204 * 1005 * (24 - 20.43) * 0.024 * 120 = 995.28"
        },
        {
          "name": "No cooling potential (night warmer than setpoint)",
          "inputs": {
            "ventilation.volumeRate": 288,
            "climate.cooling.nightTemp": 26,
            "climate.cooling.setpoint": 24,
            "climate.coolingDays": 120
          },
          "expected": 0,
          "note": "tempDiff = 24 - 26 = -2, clamped to 0"
        },
        {
          "name": "Zero ventilation rate",
          "inputs": {
            "ventilation.volumeRate": 0,
            "climate.cooling.nightTemp": 18,
            "climate.cooling.setpoint": 24,
            "climate.coolingDays": 120
          },
          "expected": 0,
          "note": "No ventilation means no free cooling"
        }
      ]
    },
    {
      "id": "cooling.dailyFreeCoolingPotential",
      "legacyId": "cooling_dailyFreeCooling",
      "label": "Daily Free Cooling Potential",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Daily free cooling capacity from ventilation, accounting for summer boost factor. Uses volumetric rate in L/s (unlike freeCoolingRaw which uses m³/hr). Used by Stage 2 days-of-active-cooling calculation.",
        "stage": "Stage 1 - Independent (feeds Stage 2 via days-active-cooling)"
      },
      "signature": {
        "inputs": [
          {
            "name": "ventilation.volumetricRate",
            "type": "number",
            "unit": "L/s",
            "description": "Base ventilation volumetric rate (d_120)"
          },
          {
            "name": "mechanical.ventilation.summerBoost",
            "type": "string|number",
            "description": "Summer boost factor for ventilation (l_119). 'None' or numeric multiplier"
          },
          {
            "name": "climate.cooling.nightTemp",
            "type": "number",
            "unit": "°C",
            "description": "Night-time outdoor temperature (l_20)"
          },
          {
            "name": "climate.cooling.setpoint",
            "type": "number",
            "unit": "°C",
            "description": "Indoor cooling setpoint temperature (h_24)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kWh/day",
          "precision": 4
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "ventilation.volumetricRate >= 0",
            "description": "Ventilation rate cannot be negative"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "summerBoost == 'None' or empty",
          "output": "(d_120 / 1000) * 1.204 * 1005 * (setpoint - nightTemp) * 86400 / 3600000",
          "note": "No boost applied, base ventilation rate used"
        },
        {
          "condition": "summerBoost is numeric",
          "output": "(d_120 * boostFactor / 1000) * 1.204 * 1005 * (setpoint - nightTemp) * 86400 / 3600000",
          "note": "Ventilation rate scaled by summer boost factor"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "dailyFC = (ventRate_Ls * boostFactor / 1000) * 1.204 * 1005 * (T_setpoint - T_night) * 86400 / 3600000",
        "steps": [
          "1. Apply summer boost: effectiveRate = d_120 * boostFactor (L/s)",
          "2. Convert L/s to m³/s: m³/s = effectiveRate / 1000",
          "3. Mass flow rate: kg/s = m³/s * 1.204",
          "4. Heat removal power: W = kg/s * 1005 * (T_setpoint - T_night)",
          "5. Daily energy: J = W * 86400",
          "6. Convert to kWh: kWh/day = J / 3600000"
        ],
        "implementation": "CoolingNodes.js:312-358"
      },
      "tests": [
        {
          "name": "Base ventilation, no summer boost",
          "inputs": {
            "ventilation.volumetricRate": 80,
            "mechanical.ventilation.summerBoost": "None",
            "climate.cooling.nightTemp": 20.43,
            "climate.cooling.setpoint": 24
          },
          "expected": 8.2886,
          "tolerance": 0.1,
          "note": "(80 / 1000) * 1.204 * 1005 * (24 - 20.43) * 86400 / 3600000"
        },
        {
          "name": "With summer boost factor of 1.5",
          "inputs": {
            "ventilation.volumetricRate": 80,
            "mechanical.ventilation.summerBoost": 1.5,
            "climate.cooling.nightTemp": 20.43,
            "climate.cooling.setpoint": 24
          },
          "expected": 12.4329,
          "tolerance": 0.1,
          "note": "(80 * 1.5 / 1000) * 1.204 * 1005 * 3.57 * 86400 / 3600000"
        }
      ]
    },
    {
      "id": "cooling.freeCoolingPercent",
      "legacyId": "d_124",
      "label": "Free Cooling Percentage",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Ratio of free cooling limit to total unmitigated cooling energy demand. Indicates what fraction of cooling load can be met by ventilation alone.",
        "stage": "Stage 2 - Dependent (requires energy.ced.unmitigated from energy calculations)"
      },
      "signature": {
        "inputs": [
          {
            "name": "cooling.freeCoolingLimit",
            "type": "number",
            "unit": "kWh/yr",
            "description": "Free cooling limit after setback adjustment (h_124)"
          },
          {
            "name": "energy.ced.unmitigated",
            "type": "number",
            "unit": "kWh/yr",
            "description": "Annual unmitigated cooling energy demand (d_129)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "ratio (0-1)",
          "precision": 4
        }
      },
      "domain": {
        "preconditions": [],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "Free cooling percentage cannot be negative (both inputs are non-negative)"
          }
        ]
      },
      "behavior": [
        {
          "condition": "energy.ced.unmitigated <= 0",
          "output": "0",
          "note": "No cooling demand means free cooling percentage is zero"
        },
        {
          "condition": "energy.ced.unmitigated > 0",
          "output": "freeCoolingLimit / energy.ced.unmitigated",
          "note": "Ratio can exceed 1.0 if free cooling exceeds demand"
        }
      ],
      "edgeCases": [
        {
          "condition": "energy.ced.unmitigated <= 0",
          "output": "0",
          "description": "Avoid division by zero when there is no cooling demand"
        }
      ],
      "formula": {
        "symbolic": "d_124 = h_124 / d_129",
        "where": {
          "h_124": "Free cooling limit (kWh/yr)",
          "d_129": "Unmitigated cooling energy demand (kWh/yr)"
        },
        "implementation": "CoolingNodes.js:429-452"
      },
      "tests": [
        {
          "name": "Partial free cooling coverage",
          "inputs": {
            "cooling.freeCoolingLimit": 500,
            "energy.ced.unmitigated": 2000
          },
          "expected": 0.25,
          "note": "500 / 2000 = 0.25 (25% of cooling met by ventilation)"
        },
        {
          "name": "Free cooling exceeds demand",
          "inputs": {
            "cooling.freeCoolingLimit": 1500,
            "energy.ced.unmitigated": 1000
          },
          "expected": 1.5,
          "note": "1500 / 1000 = 1.5 (150% coverage, oversized ventilation)"
        },
        {
          "name": "No cooling demand",
          "inputs": {
            "cooling.freeCoolingLimit": 500,
            "energy.ced.unmitigated": 0
          },
          "expected": 0,
          "note": "Division by zero guard returns 0"
        }
      ]
    }
  ],
  "references": [
    {
      "source": "CoolingNodes.js:223-270 (freeCoolingRaw)"
    },
    {
      "source": "CoolingNodes.js:312-358 (dailyFreeCoolingPotential)"
    },
    {
      "source": "CoolingNodes.js:429-452 (freeCoolingPercent)"
    },
    {
      "source": "COOLING-TARGET.csv cells A28-A33 (free cooling chain)"
    }
  ]
}
