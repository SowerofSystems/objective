{
  "id": "cooling.psychrometrics",
  "label": "Psychrometric Calculations",
  "section": "S13",
  "classification": "C",
  "_meta": {
    "description": "Psychrometric calculations for cooling: wet bulb temperature, indoor/outdoor humidity ratios, and latent load factor. These intermediate nodes feed into the free cooling and active cooling calculations.",
    "instances": [
      "cooling.wetBulbTemperature",
      "cooling.humidityRatio.outdoor",
      "cooling.humidityRatio.indoor",
      "cooling.humidityRatio.difference",
      "cooling.latentLoadFactor"
    ]
  },
  "constants": {
    "latentHeatVaporization": {
      "value": 2501000,
      "unit": "J/kg",
      "description": "Latent heat of vaporization of water"
    },
    "specificHeatCapacity": {
      "value": 1005,
      "unit": "J/(kg·K)",
      "description": "Specific heat capacity of air"
    },
    "outdoorSeasonalRH": {
      "value": 0.7,
      "description": "Outdoor seasonal relative humidity factor (A57)"
    },
    "atmosphericPressure": {
      "value": 101325,
      "unit": "Pa",
      "description": "Standard atmospheric pressure"
    }
  },
  "nodes": [
    {
      "id": "cooling.wetBulbTemperature",
      "legacyId": "cooling_wetBulbTemperature",
      "label": "Wet Bulb Temperature",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Wet bulb temperature estimated from dry bulb temperature and relative humidity using a linear approximation (Excel E64-E66 method)."
      },
      "signature": {
        "inputs": [
          {
            "name": "climate.cooling.nightTemp",
            "type": "number",
            "unit": "°C",
            "description": "Night-time outdoor dry bulb temperature (l_20)"
          },
          {
            "name": "climate.cooling.seasonMeanRH",
            "type": "number",
            "unit": "%",
            "description": "Cooling season mean relative humidity (l_21)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "°C",
          "precision": 4
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "climate.cooling.seasonMeanRH >= 0 AND climate.cooling.seasonMeanRH <= 100",
            "description": "Relative humidity must be a valid percentage"
          }
        ],
        "invariants": [
          {
            "condition": "output <= climate.cooling.nightTemp",
            "description": "Wet bulb temperature cannot exceed dry bulb temperature"
          }
        ]
      },
      "behavior": [
        {
          "condition": "rhPercent == 100",
          "output": "tdb",
          "note": "At 100% RH, wet bulb equals dry bulb"
        },
        {
          "condition": "0 < rhPercent < 100",
          "output": "tdb - (tdb - (tdb - (100 - rhPercent) / 5)) * (0.1 + 0.9 * (rhPercent / 100))",
          "note": "Linear approximation of wet bulb temperature"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "twb = tdb - (tdb - (tdb - (100 - RH%) / 5)) * (0.1 + 0.9 * (RH% / 100))",
        "implementation": "CoolingNodes.js:112-128"
      },
      "tests": [
        {
          "name": "Typical summer night conditions",
          "inputs": {
            "climate.cooling.nightTemp": 20.43,
            "climate.cooling.seasonMeanRH": 55.85
          },
          "expected": 15.4855,
          "tolerance": 0.01,
          "note": "20.43 - (20.43 - (20.43 - (100 - 55.85) / 5)) * (0.1 + 0.9 * (55.85 / 100))"
        },
        {
          "name": "Saturated air (100% RH)",
          "inputs": {
            "climate.cooling.nightTemp": 20,
            "climate.cooling.seasonMeanRH": 100
          },
          "expected": 20.0,
          "note": "At saturation, wet bulb equals dry bulb"
        }
      ]
    },
    {
      "id": "cooling.humidityRatio.outdoor",
      "legacyId": "cooling_humidityRatioAvg",
      "label": "Outdoor Humidity Ratio",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Outdoor humidity ratio calculated from wet bulb temperature using the Tetens saturation vapor pressure formula, scaled by outdoor seasonal RH factor (0.7)."
      },
      "signature": {
        "inputs": [
          {
            "name": "cooling.wetBulbTemperature",
            "type": "number",
            "unit": "°C",
            "description": "Estimated wet bulb temperature"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kg/kg",
          "precision": 6
        }
      },
      "domain": {
        "preconditions": [],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "Humidity ratio cannot be negative"
          }
        ]
      },
      "behavior": [
        {
          "condition": "always",
          "output": "0.62198 * partialP / (101325 - partialP)",
          "note": "partialP = saturationVaporPressure(twb) * 0.7"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "pSat = 610.94 * e^(17.625 * twb / (twb + 243.04)); partialP = pSat * 0.7; HR = 0.62198 * partialP / (101325 - partialP)",
        "implementation": "CoolingNodes.js:133-148"
      },
      "tests": [
        {
          "name": "Typical wet bulb temperature",
          "inputs": {
            "cooling.wetBulbTemperature": 15.49
          },
          "expected": 0.007639,
          "tolerance": 0.001,
          "note": "pSat = 610.94 * exp(17.625*15.49/258.53) = ~1757 Pa; partialP = 1230 Pa; HR = 0.62198 * 1230 / (101325 - 1230)"
        }
      ]
    },
    {
      "id": "cooling.humidityRatio.indoor",
      "legacyId": "cooling_humidityRatioIndoor",
      "label": "Indoor Humidity Ratio",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Indoor humidity ratio calculated from cooling setpoint temperature and indoor relative humidity using the Tetens saturation vapor pressure formula."
      },
      "signature": {
        "inputs": [
          {
            "name": "climate.cooling.setpoint",
            "type": "number",
            "unit": "°C",
            "description": "Indoor cooling setpoint temperature (h_24)"
          },
          {
            "name": "building.indoorRH",
            "type": "number",
            "unit": "%",
            "description": "Indoor relative humidity (i_59)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kg/kg",
          "precision": 6
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "building.indoorRH >= 0 AND building.indoorRH <= 100",
            "description": "Indoor RH must be a valid percentage"
          }
        ],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "Humidity ratio cannot be negative"
          }
        ]
      },
      "behavior": [
        {
          "condition": "always",
          "output": "0.62198 * partialP / (101325 - partialP)",
          "note": "partialP = saturationVaporPressure(setpoint) * (indoorRH / 100)"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "pSat = 610.94 * e^(17.625 * setpoint / (setpoint + 243.04)); partialP = pSat * (indoorRH / 100); HR = 0.62198 * partialP / (101325 - partialP)",
        "implementation": "CoolingNodes.js:150-169"
      },
      "tests": [
        {
          "name": "Typical indoor conditions (24°C, 45% RH)",
          "inputs": {
            "climate.cooling.setpoint": 24,
            "building.indoorRH": 45
          },
          "expected": 0.008434,
          "tolerance": 0.001,
          "note": "pSat = 610.94 * exp(17.625*24/267.04) = ~2983 Pa; partialP = 2983 * 0.45 = 1342 Pa; HR = 0.62198 * 1342 / (101325 - 1342)"
        }
      ]
    },
    {
      "id": "cooling.humidityRatio.difference",
      "legacyId": "cooling_humidityRatio",
      "label": "Humidity Ratio Difference",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Difference between outdoor and indoor humidity ratios. Positive values indicate outdoor air is more humid; negative values indicate indoor air is more humid."
      },
      "signature": {
        "inputs": [
          {
            "name": "cooling.humidityRatio.outdoor",
            "type": "number",
            "unit": "kg/kg",
            "description": "Outdoor humidity ratio"
          },
          {
            "name": "cooling.humidityRatio.indoor",
            "type": "number",
            "unit": "kg/kg",
            "description": "Indoor humidity ratio"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kg/kg",
          "precision": 6
        }
      },
      "domain": {
        "preconditions": [],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "always",
          "output": "outdoor - indoor",
          "note": "Simple subtraction of humidity ratios"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "HR_diff = HR_outdoor - HR_indoor",
        "implementation": "CoolingNodes.js:171-187"
      },
      "tests": [
        {
          "name": "Outdoor drier than indoor",
          "inputs": {
            "cooling.humidityRatio.outdoor": 0.007639,
            "cooling.humidityRatio.indoor": 0.008434
          },
          "expected": -0.000795,
          "tolerance": 0.0001,
          "note": "Negative difference means outdoor air is drier (dehumidification potential)"
        },
        {
          "name": "Outdoor more humid than indoor",
          "inputs": {
            "cooling.humidityRatio.outdoor": 0.012,
            "cooling.humidityRatio.indoor": 0.008
          },
          "expected": 0.004,
          "note": "Positive difference means outdoor air adds moisture"
        }
      ]
    },
    {
      "id": "cooling.latentLoadFactor",
      "legacyId": "cooling_latentLoadFactor",
      "label": "Latent Load Factor",
      "section": "S13",
      "classification": "C",
      "_meta": {
        "description": "Factor representing the ratio of total cooling load (sensible + latent) to sensible cooling load alone. Accounts for the energy required to condense moisture from outdoor air. A value of 1.0 means no latent load."
      },
      "signature": {
        "inputs": [
          {
            "name": "climate.cooling.nightTemp",
            "type": "number",
            "unit": "°C",
            "description": "Night-time outdoor temperature (l_20)"
          },
          {
            "name": "climate.cooling.setpoint",
            "type": "number",
            "unit": "°C",
            "description": "Indoor cooling setpoint temperature (h_24)"
          },
          {
            "name": "cooling.humidityRatio.difference",
            "type": "number",
            "unit": "kg/kg",
            "description": "Difference between outdoor and indoor humidity ratios"
          }
        ],
        "output": {
          "type": "number",
          "unit": "dimensionless",
          "precision": 4
        }
      },
      "domain": {
        "preconditions": [],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "nightTemp == setpoint (denominator == 0)",
          "output": "1.0",
          "note": "Avoid division by zero; assume no latent adjustment"
        },
        {
          "condition": "nightTemp != setpoint",
          "output": "1 + (2501000 * HR_diff) / (1005 * (nightTemp - setpoint))",
          "note": "Latent heat contribution relative to sensible temperature differential"
        }
      ],
      "edgeCases": [
        {
          "condition": "denominator == 0 (nightTemp == setpoint)",
          "output": "1.0",
          "description": "When indoor and outdoor temps are equal, return unity factor to avoid division by zero"
        }
      ],
      "formula": {
        "symbolic": "A6 = 1 + (L_v * HR_diff) / (C_p * (T_night - T_setpoint))",
        "where": {
          "L_v": "Latent heat of vaporization = 2,501,000 J/kg",
          "HR_diff": "Humidity ratio difference (outdoor - indoor) in kg/kg",
          "C_p": "Specific heat capacity of air = 1005 J/(kg·K)",
          "T_night": "Night-time outdoor temperature in °C",
          "T_setpoint": "Indoor cooling setpoint in °C"
        },
        "implementation": "CoolingNodes.js:193-217"
      },
      "tests": [
        {
          "name": "Typical conditions (outdoor drier than indoor)",
          "inputs": {
            "climate.cooling.nightTemp": 20.43,
            "climate.cooling.setpoint": 24,
            "cooling.humidityRatio.difference": -0.000795
          },
          "expected": 1.5537,
          "tolerance": 0.05,
          "note": "1 + (2501000 * -0.000795) / (1005 * (20.43 - 24)) = 1 + (-1988.3 / -3587.85) = 1.554"
        },
        {
          "name": "Zero temperature differential",
          "inputs": {
            "climate.cooling.nightTemp": 24,
            "climate.cooling.setpoint": 24,
            "cooling.humidityRatio.difference": -0.001
          },
          "expected": 1.0,
          "note": "Division by zero guard returns 1.0"
        }
      ]
    }
  ],
  "references": [
    {
      "source": "CoolingNodes.js:112-217 (psychrometric calculation nodes)"
    },
    {
      "source": "COOLING-TARGET.csv cells A56-A66 (psychrometric chain)"
    }
  ]
}
