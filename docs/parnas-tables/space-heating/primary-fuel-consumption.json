{
  "id": "spaceHeating.primaryFuelConsumption",
  "label": "Primary Heating Fuel Consumption",
  "section": "S13",
  "classification": "C",
  "_meta": {
    "description": "Fuel consumption for space heating, adjusted for system efficiency and fuel type conversion factor. Heatpumps use COP, all others use AFUE.",
    "fuelFactors": {
      "Electricity": { "unit": "kWh", "factor": 1 },
      "Gas": { "unit": "m³", "factor": 10.3321 },
      "Propane": { "unit": "L", "factor": 7.0833 },
      "Oil": { "unit": "L", "factor": 10.7444 },
      "Heatpump": { "unit": "kWh", "factor": 1 },
      "Wood": { "unit": "kg", "factor": 4.5 }
    }
  },
  "signature": {
    "inputs": [
      { "name": "spaceHeating.annualDemand", "type": "number", "unit": "kWh/yr" },
      { "name": "mechanical.heating.copHeat", "type": "number", "description": "COP for heatpumps" },
      { "name": "mechanical.heating.afue", "type": "number", "description": "AFUE for combustion systems" },
      { "name": "mechanical.heating.systemType", "type": "string", "description": "Fuel type" }
    ],
    "output": { "type": "number", "unit": "varies by fuel type" }
  },
  "domain": { "preconditions": [], "invariants": [] },
  "behavior": [
    { "condition": "systemType = 'Heatpump'", "output": "(demand / COP) / factor", "note": "COP efficiency, factor=1 for electric" },
    { "condition": "otherwise", "output": "(demand / AFUE) / factor", "note": "AFUE efficiency, convert to fuel units" }
  ],
  "edgeCases": [
    { "condition": "efficiency = 0", "handling": "Uses demand directly", "rationale": "Division guard" }
  ],
  "formula": {
    "symbolic": "consumption = (demand / efficiency) / FUEL_FACTOR[systemType]",
    "implementation": "SpaceHeatingNodes.js:39-61"
  },
  "tests": [
    { "name": "Gas system", "inputs": { "spaceHeating.annualDemand": 50000, "mechanical.heating.afue": 0.95, "mechanical.heating.systemType": "Gas" }, "expected": 5091.67 }
  ]
}
