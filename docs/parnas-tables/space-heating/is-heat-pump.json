{
  "id": "spaceHeating.isHeatPump",
  "label": "Is Heat Pump System",
  "section": "S13",
  "classification": "C",
  "_meta": {
    "description": "Boolean flag indicating if the primary heating system is a heat pump. Used for COP logic branching."
  },
  "signature": {
    "inputs": [
      { "name": "mechanical.heating.systemType", "type": "string", "description": "System type (d_113)" }
    ],
    "output": { "type": "boolean" }
  },
  "domain": { "preconditions": [], "invariants": [] },
  "behavior": [
    { "condition": "systemType = 'Heatpump'", "output": "true" },
    { "condition": "otherwise", "output": "false" }
  ],
  "edgeCases": [],
  "formula": {
    "symbolic": "isHP = (d_113 === 'Heatpump')",
    "implementation": "SpaceHeatingNodes.js:64-74"
  },
  "tests": [
    { "name": "Heatpump", "inputs": { "mechanical.heating.systemType": "Heatpump" }, "expected": true },
    { "name": "Gas", "inputs": { "mechanical.heating.systemType": "Gas" }, "expected": false }
  ]
}
