{
  "nodes": [
    {
      "id": "keyValues.target.tier",
      "legacyId": "i_10",
      "label": "Target TEUI Tier",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Performance tier based on TEUI reduction percentage from reference. Tier thresholds differ between code-based standards (NBC/OBC/NECB) and other standards. Code standards use 5 tiers; others use 4 tiers plus 'No Tier'."
      },
      "signature": {
        "inputs": [
          {
            "name": "keyValues.target.teui",
            "type": "number",
            "unit": "kWh/m²/yr",
            "description": "Target TEUI (h_10)"
          },
          {
            "name": "keyValues.reference.teui",
            "type": "number",
            "unit": "kWh/m²/yr",
            "description": "Reference TEUI (e_10)"
          },
          {
            "name": "building.referenceStandard",
            "type": "string",
            "description": "Reference standard name - determines tier thresholds"
          }
        ],
        "output": {
          "type": "string",
          "values": ["tier1", "tier2", "tier3", "tier4", "tier5", "No Tier"]
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "e_10 > 0",
            "description": "Reference TEUI must be positive for reduction calculation"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "e_10 <= 0",
          "output": "'No Tier'",
          "note": "Cannot determine tier without valid reference"
        },
        {
          "condition": "isCodeStandard (NBC/OBC/NECB) AND reduction > 70%",
          "output": "'tier5'",
          "note": "Net Zero Ready level for code-based standards"
        },
        {
          "condition": "isCodeStandard AND reduction > 60%",
          "output": "'tier4'"
        },
        {
          "condition": "isCodeStandard AND reduction > 50%",
          "output": "'tier3'"
        },
        {
          "condition": "isCodeStandard AND reduction > 40%",
          "output": "'tier2'"
        },
        {
          "condition": "isCodeStandard AND reduction <= 40%",
          "output": "'tier1'",
          "note": "Minimum code compliance for code-based standards"
        },
        {
          "condition": "NOT isCodeStandard AND reduction > 60%",
          "output": "'tier4'"
        },
        {
          "condition": "NOT isCodeStandard AND reduction > 45%",
          "output": "'tier3'"
        },
        {
          "condition": "NOT isCodeStandard AND reduction > 20%",
          "output": "'tier2'"
        },
        {
          "condition": "NOT isCodeStandard AND reduction > 10%",
          "output": "'tier1'"
        },
        {
          "condition": "NOT isCodeStandard AND reduction <= 10%",
          "output": "'No Tier'"
        }
      ],
      "edgeCases": [
        {
          "condition": "standard string is empty",
          "handling": "Treated as non-code standard",
          "rationale": "Non-code thresholds apply by default"
        }
      ],
      "formula": {
        "symbolic": "reduction = 1 - h_10/e_10; i_10 = tierLookup(reduction, isCodeStandard)",
        "implementation": "KeyValuesNodes.js:263-298"
      },
      "tests": [
        {
          "name": "NBC standard at 75% reduction = tier5",
          "inputs": {
            "keyValues.target.teui": 37.5,
            "keyValues.reference.teui": 150,
            "building.referenceStandard": "NBC 2020"
          },
          "expected": "tier5"
        },
        {
          "name": "NBC standard at 45% reduction = tier2",
          "inputs": {
            "keyValues.target.teui": 82.5,
            "keyValues.reference.teui": 150,
            "building.referenceStandard": "NBC 2020"
          },
          "expected": "tier2"
        },
        {
          "name": "Non-code standard at 50% reduction = tier3",
          "inputs": {
            "keyValues.target.teui": 75,
            "keyValues.reference.teui": 150,
            "building.referenceStandard": "PHIUS"
          },
          "expected": "tier3"
        },
        {
          "name": "Non-code standard at 5% reduction = No Tier",
          "inputs": {
            "keyValues.target.teui": 142.5,
            "keyValues.reference.teui": 150,
            "building.referenceStandard": "PHIUS"
          },
          "expected": "No Tier"
        },
        {
          "name": "Zero reference TEUI",
          "inputs": {
            "keyValues.target.teui": 75,
            "keyValues.reference.teui": 0,
            "building.referenceStandard": "NBC 2020"
          },
          "expected": "No Tier"
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:263-298"
        }
      ]
    },
    {
      "id": "keyValues.reference.tier",
      "legacyId": "f_10",
      "label": "Reference TEUI Tier",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Reference model tier indicator. Always returns 'tier1' as the reference model represents baseline code compliance."
      },
      "signature": {
        "inputs": [],
        "output": {
          "type": "string",
          "values": ["tier1"]
        }
      },
      "domain": {
        "preconditions": [],
        "invariants": [
          {
            "condition": "output == 'tier1'",
            "description": "Reference tier is always tier1"
          }
        ]
      },
      "behavior": [
        {
          "condition": "always",
          "output": "'tier1'",
          "note": "Reference model is always baseline tier1"
        }
      ],
      "edgeCases": [],
      "formula": {
        "symbolic": "f_10 = 'tier1'",
        "implementation": "KeyValuesNodes.js:301-309"
      },
      "tests": [
        {
          "name": "Always returns tier1",
          "inputs": {},
          "expected": "tier1"
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:301-309"
        }
      ]
    },
    {
      "id": "keyValues.annualCarbon.reductionPercent",
      "legacyId": "j_8",
      "label": "Annual Carbon Reduction %",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Percentage reduction in annual carbon intensity from reference to target (or actual in Utility Bills mode). Displayed as a string with '%' suffix."
      },
      "signature": {
        "inputs": [
          {
            "name": "keyValues.reference.annualCarbon",
            "type": "number",
            "description": "Reference annual carbon (e_8)"
          },
          {
            "name": "keyValues.target.annualCarbon",
            "type": "number",
            "description": "Target annual carbon (h_8)"
          },
          {
            "name": "keyValues.actual.annualCarbon",
            "type": "number | string",
            "description": "Actual annual carbon (k_8) - may be 'N/A'"
          },
          {
            "name": "building.analysisMode",
            "type": "string",
            "description": "Analysis mode (d_14)"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%'"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "e_8 != 0",
            "description": "Reference carbon must be non-zero for reduction calculation"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "e_8 == 0",
          "output": "'0%'",
          "note": "No reduction possible when reference is zero"
        },
        {
          "condition": "analysisMode == 'Utility Bills' AND k_8 is numeric",
          "output": "round((1 - k_8/e_8) * 100) + '%'",
          "note": "Use actual value in Utility Bills mode"
        },
        {
          "condition": "analysisMode != 'Utility Bills' OR k_8 is not numeric",
          "output": "round((1 - h_8/e_8) * 100) + '%'",
          "note": "Use target value otherwise"
        }
      ],
      "edgeCases": [
        {
          "condition": "Utility Bills mode but k_8 is 'N/A'",
          "handling": "Falls back to target value (h_8)",
          "rationale": "k_8 is not numeric, so standard target path is used"
        }
      ],
      "formula": {
        "symbolic": "j_8 = round((1 - valueToUse/e_8) * 100) + '%'",
        "implementation": "KeyValuesNodes.js:316-335"
      },
      "tests": [
        {
          "name": "50% reduction in Targeted Use mode",
          "inputs": {
            "keyValues.reference.annualCarbon": 30.0,
            "keyValues.target.annualCarbon": 15.0,
            "keyValues.actual.annualCarbon": "N/A",
            "building.analysisMode": "Targeted Use"
          },
          "expected": "50%"
        },
        {
          "name": "Utility Bills mode uses actual value",
          "inputs": {
            "keyValues.reference.annualCarbon": 30.0,
            "keyValues.target.annualCarbon": 15.0,
            "keyValues.actual.annualCarbon": 20.0,
            "building.analysisMode": "Utility Bills"
          },
          "expected": "33%"
        },
        {
          "name": "Zero reference returns 0%",
          "inputs": {
            "keyValues.reference.annualCarbon": 0,
            "keyValues.target.annualCarbon": 15.0,
            "keyValues.actual.annualCarbon": "N/A",
            "building.analysisMode": "Targeted Use"
          },
          "expected": "0%"
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:316-335"
        }
      ]
    },
