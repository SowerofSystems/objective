    {
      "id": "keyValues.lifetimeCarbon.percent",
      "legacyId": "m_6",
      "label": "Lifetime Carbon %",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Lifetime carbon percentage computed differently based on carbon standard. BR18 uses annualized carbon / 12 kgCO2e/m²/yr limit. IPCC and TGS4 Tier standards use modelled vs adopted cap. TGS4 'Typical Values' uses modelled vs typology. Returns N/A for unsupported standards or when typology status is N/A."
      },
      "signature": {
        "inputs": [
          {
            "name": "building.userModelledEmbodiedCarbon",
            "type": "number",
            "unit": "kgCO2e/m²",
            "description": "User-modelled embodied carbon (i_41)"
          },
          {
            "name": "building.serviceLife",
            "type": "number",
            "unit": "years",
            "description": "Building service life (h_13)"
          },
          {
            "name": "building.carbonStandard",
            "type": "string",
            "description": "Carbon standard (d_15): 'BR18 (Denmark)', 'IPCC AR6 EPC', 'IPCC AR6 EA', 'TGS4 Tier 2', 'TGS4 Tier 3', 'TGS4'"
          },
          {
            "name": "building.typologyEmbodiedCarbon",
            "type": "number",
            "unit": "kgCO2e/m²",
            "description": "Typology embodied carbon baseline (i_39)"
          },
          {
            "name": "building.embodiedCarbonTarget",
            "type": "number",
            "unit": "kgCO2e/m²",
            "description": "Adopted embodied carbon cap (d_16)"
          },
          {
            "name": "keyValues.actual.annualCarbon",
            "type": "number | string",
            "description": "Actual annual carbon (k_8) - may be 'N/A'"
          },
          {
            "name": "keyValues.target.annualCarbon",
            "type": "number",
            "description": "Target annual carbon (h_8)"
          },
          {
            "name": "building.analysisMode",
            "type": "string",
            "description": "Analysis mode (d_14)"
          },
          {
            "name": "emissions.typologyStatus",
            "type": "string",
            "description": "Typology status (i_40) - 'N/A' when not applicable"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%' or 'N/A'"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "emissions.typologyStatus != 'N/A'",
            "description": "Typology status must be available"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "i_40 == 'N/A'",
          "output": "'N/A'",
          "note": "No typology data available"
        },
        {
          "condition": "d_15 == 'BR18 (Denmark)' AND h_13 > 0",
          "output": "round((i_41/h_13 + k_8_calc) / 12 * 100) + '%'",
          "note": "BR18 uses 12 kgCO2e/m²/yr as the benchmark denominator"
        },
        {
          "condition": "d_15 in ['IPCC AR6 EPC', 'IPCC AR6 EA'] AND d_16 > 0",
          "output": "round(i_41 / d_16 * 100) + '%'",
          "note": "IPCC: modelled embodied carbon vs adopted cap"
        },
        {
          "condition": "d_15 in ['TGS4 Tier 2', 'TGS4 Tier 3'] AND d_16 > 0",
          "output": "round(i_41 / d_16 * 100) + '%'",
          "note": "TGS4 Tier: modelled embodied carbon vs adopted cap"
        },
        {
          "condition": "d_15 == 'TGS4' AND i_39 > 0",
          "output": "round(i_41 / i_39 * 100) + '%'",
          "note": "TGS4 Typical Values: modelled vs typology baseline"
        },
        {
          "condition": "all other cases",
          "output": "'N/A'",
          "note": "Unsupported carbon standard"
        }
      ],
      "edgeCases": [
        {
          "condition": "d_16 or i_39 is 0 for IPCC/TGS4",
          "handling": "Return 'N/A'",
          "rationale": "Division by zero protection"
        },
        {
          "condition": "Utility Bills mode with numeric k_8",
          "handling": "Use k_8 instead of h_8 for BR18 calculation",
          "rationale": "BR18 formula includes annual operational carbon"
        }
      ],
      "formula": {
        "symbolic": "m_6 = CASE(d_15, BR18: round((i_41/h_13+k_8_calc)/12*100)+'%', IPCC/TGS4Tier: round(i_41/d_16*100)+'%', TGS4: round(i_41/i_39*100)+'%', else: 'N/A')",
        "implementation": "KeyValuesNodes.js:390-457"
      },
      "tests": [
        {
          "name": "BR18 standard calculation",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 300,
            "building.serviceLife": 50,
            "building.carbonStandard": "BR18 (Denmark)",
            "keyValues.target.annualCarbon": 5.0,
            "keyValues.actual.annualCarbon": "N/A",
            "building.analysisMode": "Targeted Use",
            "emissions.typologyStatus": "OK"
          },
          "expected": "92%",
          "note": "(300/50 + 5.0) / 12 = 11/12 = 0.917 => 92%"
        },
        {
          "name": "IPCC AR6 EPC standard",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 250,
            "building.carbonStandard": "IPCC AR6 EPC",
            "building.embodiedCarbonTarget": 500,
            "emissions.typologyStatus": "OK"
          },
          "expected": "50%",
          "note": "250/500 = 0.5 => 50%"
        },
        {
          "name": "TGS4 Tier 2 standard",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 300,
            "building.carbonStandard": "TGS4 Tier 2",
            "building.embodiedCarbonTarget": 400,
            "emissions.typologyStatus": "OK"
          },
          "expected": "75%",
          "note": "300/400 = 0.75 => 75%"
        },
        {
          "name": "TGS4 typical values",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 300,
            "building.carbonStandard": "TGS4",
            "building.typologyEmbodiedCarbon": 600,
            "emissions.typologyStatus": "OK"
          },
          "expected": "50%",
          "note": "300/600 = 0.5 => 50%"
        },
        {
          "name": "Typology status N/A returns N/A",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 300,
            "building.carbonStandard": "BR18 (Denmark)",
            "emissions.typologyStatus": "N/A"
          },
          "expected": "N/A"
        },
        {
          "name": "Unsupported standard returns N/A",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 300,
            "building.carbonStandard": "Unknown",
            "emissions.typologyStatus": "OK"
          },
          "expected": "N/A"
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:390-457"
        }
      ]
    }
  ]
}
