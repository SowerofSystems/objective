    {
      "id": "keyValues.annualCarbon.remainingPercent",
      "legacyId": "m_8",
      "label": "Annual Carbon Remaining %",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Complement of annual carbon reduction percentage. If 50% reduced, 50% remaining. Used for progress bar display."
      },
      "signature": {
        "inputs": [
          {
            "name": "keyValues.annualCarbon.reductionPercent",
            "type": "string",
            "description": "Annual carbon reduction percentage (j_8), e.g. '50%'"
          }
        ],
        "output": {
          "type": "string",
          "format": "'{integer}%'"
        }
      },
      "domain": {
        "preconditions": [],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "always",
          "output": "(100 - reductionPercent) + '%'",
          "note": "Complement of the reduction percentage"
        }
      ],
      "edgeCases": [
        {
          "condition": "j_8 is empty or undefined",
          "handling": "Default to '0%' for j_8, returning '100%'",
          "rationale": "No reduction means 100% remains"
        }
      ],
      "formula": {
        "symbolic": "m_8 = (100 - parseNum(j_8)) + '%'",
        "implementation": "KeyValuesNodes.js:360-372"
      },
      "tests": [
        {
          "name": "50% reduction leaves 50% remaining",
          "inputs": {
            "keyValues.annualCarbon.reductionPercent": "50%"
          },
          "expected": "50%"
        },
        {
          "name": "0% reduction leaves 100% remaining",
          "inputs": {
            "keyValues.annualCarbon.reductionPercent": "0%"
          },
          "expected": "100%"
        },
        {
          "name": "100% reduction leaves 0% remaining",
          "inputs": {
            "keyValues.annualCarbon.reductionPercent": "100%"
          },
          "expected": "0%"
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:360-372"
        }
      ]
    },
