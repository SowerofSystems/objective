{
  "nodes": [
    {
      "id": "keyValues.actual.teui",
      "legacyId": "k_10",
      "label": "Actual TEUI (kWh/m²/yr)",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Actual building TEUI from utility bills divided by conditioned floor area. Only computed when analysis mode is 'Utility Bills'; returns N/A otherwise."
      },
      "signature": {
        "inputs": [
          {
            "name": "energy.actual.total",
            "type": "number",
            "unit": "kWh/yr",
            "description": "Actual total energy from utility bills (f_32)"
          },
          {
            "name": "building.conditionedFloorArea",
            "type": "number",
            "unit": "m²",
            "description": "Conditioned floor area (h_15)"
          },
          {
            "name": "building.analysisMode",
            "type": "string",
            "description": "Analysis mode: 'Utility Bills' or 'Targeted Use' (d_14)"
          }
        ],
        "output": {
          "type": "number | string",
          "unit": "kWh/m²/yr",
          "precision": 1,
          "description": "Numeric value when in Utility Bills mode, 'N/A' otherwise"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "analysisMode == 'Utility Bills'",
            "description": "Actual values only available in Utility Bills mode"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "analysisMode != 'Utility Bills'",
          "output": "'N/A'",
          "note": "Actual column not applicable in Targeted Use mode"
        },
        {
          "condition": "analysisMode == 'Utility Bills' AND area > 0",
          "output": "round(actualEnergy / area, 1)",
          "note": "Standard TEUI from utility bill data"
        },
        {
          "condition": "analysisMode == 'Utility Bills' AND area <= 0",
          "output": "0",
          "note": "Guard against division by zero"
        }
      ],
      "edgeCases": [
        {
          "condition": "analysisMode is undefined or empty",
          "handling": "Default to 'Targeted Use', return 'N/A'",
          "rationale": "Safe default when mode not set"
        }
      ],
      "formula": {
        "symbolic": "k_10 = IF(d_14 != 'Utility Bills', 'N/A', round(f_32 / h_15, 1))",
        "implementation": "KeyValuesNodes.js:199-213"
      },
      "tests": [
        {
          "name": "Utility Bills mode with data",
          "inputs": {
            "energy.actual.total": 25000,
            "building.conditionedFloorArea": 200,
            "building.analysisMode": "Utility Bills"
          },
          "expected": 125.0
        },
        {
          "name": "Targeted Use mode returns N/A",
          "inputs": {
            "energy.actual.total": 25000,
            "building.conditionedFloorArea": 200,
            "building.analysisMode": "Targeted Use"
          },
          "expected": "N/A"
        },
        {
          "name": "No mode specified defaults to N/A",
          "inputs": {
            "energy.actual.total": 25000,
            "building.conditionedFloorArea": 200
          },
          "expected": "N/A"
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:199-213"
        }
      ]
    },
    {
      "id": "keyValues.actual.annualCarbon",
      "legacyId": "k_8",
      "label": "Actual Annual Carbon (kgCO2e/m²/yr)",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Actual annual carbon intensity from utility bills divided by conditioned floor area. Only computed when analysis mode is 'Utility Bills'; returns N/A otherwise."
      },
      "signature": {
        "inputs": [
          {
            "name": "emissions.actual.subtotal",
            "type": "number",
            "unit": "kgCO2e/yr",
            "description": "Actual emissions subtotal from utility bills (g_32)"
          },
          {
            "name": "building.conditionedFloorArea",
            "type": "number",
            "unit": "m²",
            "description": "Conditioned floor area (h_15)"
          },
          {
            "name": "building.analysisMode",
            "type": "string",
            "description": "Analysis mode: 'Utility Bills' or 'Targeted Use' (d_14)"
          }
        ],
        "output": {
          "type": "number | string",
          "unit": "kgCO2e/m²/yr",
          "precision": 1,
          "description": "Numeric value when in Utility Bills mode, 'N/A' otherwise"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "analysisMode == 'Utility Bills'",
            "description": "Actual values only available in Utility Bills mode"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "analysisMode != 'Utility Bills'",
          "output": "'N/A'",
          "note": "Actual column not applicable in Targeted Use mode"
        },
        {
          "condition": "analysisMode == 'Utility Bills' AND area > 0",
          "output": "round(actualEmissions / area, 1)",
          "note": "Standard carbon intensity from utility bill data"
        },
        {
          "condition": "analysisMode == 'Utility Bills' AND area <= 0",
          "output": "0",
          "note": "Guard against division by zero"
        }
      ],
      "edgeCases": [
        {
          "condition": "analysisMode is undefined or empty",
          "handling": "Default to 'Targeted Use', return 'N/A'",
          "rationale": "Safe default when mode not set"
        }
      ],
      "formula": {
        "symbolic": "k_8 = IF(d_14 != 'Utility Bills', 'N/A', round(g_32 / h_15, 1))",
        "implementation": "KeyValuesNodes.js:217-232"
      },
      "tests": [
        {
          "name": "Utility Bills mode with data",
          "inputs": {
            "emissions.actual.subtotal": 4000,
            "building.conditionedFloorArea": 200,
            "building.analysisMode": "Utility Bills"
          },
          "expected": 20.0
        },
        {
          "name": "Targeted Use mode returns N/A",
          "inputs": {
            "emissions.actual.subtotal": 4000,
            "building.conditionedFloorArea": 200,
            "building.analysisMode": "Targeted Use"
          },
          "expected": "N/A"
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:217-232"
        }
      ]
    },
    {
      "id": "keyValues.actual.lifetimeCarbon",
      "legacyId": "k_6",
      "label": "Actual Lifetime Carbon (kgCO2e/m²)",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Actual building lifetime carbon intensity combining annualized embodied carbon with actual annual operational carbon from utility bills. Only computed in Utility Bills mode."
      },
      "signature": {
        "inputs": [
          {
            "name": "building.userModelledEmbodiedCarbon",
            "type": "number",
            "unit": "kgCO2e/m²",
            "description": "User-modelled embodied carbon (i_41)"
          },
          {
            "name": "building.serviceLife",
            "type": "number",
            "unit": "years",
            "description": "Building service life (h_13), default 50"
          },
          {
            "name": "keyValues.actual.annualCarbon",
            "type": "number | string",
            "unit": "kgCO2e/m²/yr",
            "description": "Actual annual carbon intensity (k_8) - may be 'N/A'"
          },
          {
            "name": "building.analysisMode",
            "type": "string",
            "description": "Analysis mode: 'Utility Bills' or 'Targeted Use' (d_14)"
          }
        ],
        "output": {
          "type": "number | string",
          "unit": "kgCO2e/m²",
          "precision": 1,
          "description": "Numeric value when in Utility Bills mode, 'N/A' otherwise"
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "analysisMode == 'Utility Bills'",
            "description": "Actual values only available in Utility Bills mode"
          },
          {
            "condition": "k_8 is numeric",
            "description": "Actual annual carbon must be a valid number"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "analysisMode != 'Utility Bills'",
          "output": "'N/A'",
          "note": "Actual column not applicable in Targeted Use mode"
        },
        {
          "condition": "k_8 is string (N/A)",
          "output": "'N/A'",
          "note": "Cannot compute lifetime if annual is unavailable"
        },
        {
          "condition": "analysisMode == 'Utility Bills' AND serviceLife > 0 AND k_8 is numeric",
          "output": "round(embodied / serviceLife + k_8, 1)",
          "note": "Annualized embodied carbon plus actual annual operational carbon"
        },
        {
          "condition": "serviceLife <= 0",
          "output": "0",
          "note": "Guard against division by zero"
        }
      ],
      "edgeCases": [
        {
          "condition": "k_8 is 'N/A' string",
          "handling": "Return 'N/A'",
          "rationale": "Cannot compute lifetime carbon from unavailable annual data"
        }
      ],
      "formula": {
        "symbolic": "k_6 = IF(d_14 != 'Utility Bills', 'N/A', IF(k_8 is string, 'N/A', round(i_41 / h_13 + k_8, 1)))",
        "implementation": "KeyValuesNodes.js:235-256"
      },
      "tests": [
        {
          "name": "Utility Bills mode with valid data",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 300,
            "building.serviceLife": 50,
            "keyValues.actual.annualCarbon": 20.0,
            "building.analysisMode": "Utility Bills"
          },
          "expected": 26.0,
          "note": "300/50 + 20.0 = 6 + 20 = 26.0"
        },
        {
          "name": "Targeted Use mode returns N/A",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 300,
            "building.serviceLife": 50,
            "keyValues.actual.annualCarbon": "N/A",
            "building.analysisMode": "Targeted Use"
          },
          "expected": "N/A"
        },
        {
          "name": "k_8 is N/A string",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 300,
            "building.serviceLife": 50,
            "keyValues.actual.annualCarbon": "N/A",
            "building.analysisMode": "Utility Bills"
          },
          "expected": "N/A"
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:235-256"
        }
      ]
    }
  ]
}
