{
  "nodes": [
    {
      "id": "keyValues.target.teui",
      "legacyId": "h_10",
      "label": "Target TEUI (kWh/m²/yr)",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Target building TEUI calculated from total target energy divided by conditioned floor area. Represents the designer's proposed energy intensity."
      },
      "signature": {
        "inputs": [
          {
            "name": "energy.target.total",
            "type": "number",
            "unit": "kWh/yr",
            "description": "Target model total energy (j_32)"
          },
          {
            "name": "building.conditionedFloorArea",
            "type": "number",
            "unit": "m²",
            "description": "Conditioned floor area (h_15)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kWh/m²/yr",
          "precision": 1
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "targetArea > 0",
            "description": "Floor area must be positive for division"
          }
        ],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "TEUI cannot be negative"
          }
        ]
      },
      "behavior": [
        {
          "condition": "targetArea > 0",
          "output": "round(targetEnergy / targetArea, 1)",
          "note": "Standard TEUI calculation rounded to 1 decimal place"
        },
        {
          "condition": "targetArea <= 0",
          "output": "0",
          "note": "Guard against division by zero"
        }
      ],
      "edgeCases": [
        {
          "condition": "targetArea is 0 or negative",
          "handling": "Return 0",
          "rationale": "Cannot compute intensity without valid floor area"
        }
      ],
      "formula": {
        "symbolic": "h_10 = round(j_32 / h_15, 1)",
        "implementation": "KeyValuesNodes.js:147-159"
      },
      "tests": [
        {
          "name": "High-performance target",
          "inputs": {
            "energy.target.total": 15000,
            "building.conditionedFloorArea": 200
          },
          "expected": 75.0
        },
        {
          "name": "Zero floor area guard",
          "inputs": {
            "energy.target.total": 15000,
            "building.conditionedFloorArea": 0
          },
          "expected": 0
        },
        {
          "name": "Passive House level",
          "inputs": {
            "energy.target.total": 6000,
            "building.conditionedFloorArea": 200
          },
          "expected": 30.0
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:147-159"
        }
      ]
    },
    {
      "id": "keyValues.target.annualCarbon",
      "legacyId": "h_8",
      "label": "Target Annual Carbon (kgCO2e/m²/yr)",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Target building annual carbon intensity calculated from total target emissions divided by conditioned floor area. Represents the designer's proposed operational carbon intensity."
      },
      "signature": {
        "inputs": [
          {
            "name": "emissions.target.subtotal",
            "type": "number",
            "unit": "kgCO2e/yr",
            "description": "Target model emissions subtotal (k_32)"
          },
          {
            "name": "building.conditionedFloorArea",
            "type": "number",
            "unit": "m²",
            "description": "Conditioned floor area (h_15)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kgCO2e/m²/yr",
          "precision": 1
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "targetArea > 0",
            "description": "Floor area must be positive for division"
          }
        ],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "Carbon intensity should not be negative for typical buildings"
          }
        ]
      },
      "behavior": [
        {
          "condition": "targetArea > 0",
          "output": "round(targetEmissions / targetArea, 1)",
          "note": "Standard carbon intensity calculation rounded to 1 decimal place"
        },
        {
          "condition": "targetArea <= 0",
          "output": "0",
          "note": "Guard against division by zero"
        }
      ],
      "edgeCases": [
        {
          "condition": "targetArea is 0 or negative",
          "handling": "Return 0",
          "rationale": "Cannot compute intensity without valid floor area"
        }
      ],
      "formula": {
        "symbolic": "h_8 = round(k_32 / h_15, 1)",
        "implementation": "KeyValuesNodes.js:162-174"
      },
      "tests": [
        {
          "name": "Typical target",
          "inputs": {
            "emissions.target.subtotal": 3000,
            "building.conditionedFloorArea": 200
          },
          "expected": 15.0
        },
        {
          "name": "Zero floor area guard",
          "inputs": {
            "emissions.target.subtotal": 3000,
            "building.conditionedFloorArea": 0
          },
          "expected": 0
        },
        {
          "name": "Low-carbon target",
          "inputs": {
            "emissions.target.subtotal": 500,
            "building.conditionedFloorArea": 200
          },
          "expected": 2.5
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:162-174"
        }
      ]
    },
    {
      "id": "keyValues.target.lifetimeCarbon",
      "legacyId": "h_6",
      "label": "Target Lifetime Carbon (kgCO2e/m²)",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Target building lifetime carbon intensity combining annualized embodied carbon with annual operational carbon. Represents the total carbon per m² the designer proposes over the building service life."
      },
      "signature": {
        "inputs": [
          {
            "name": "building.userModelledEmbodiedCarbon",
            "type": "number",
            "unit": "kgCO2e/m²",
            "description": "User-modelled embodied carbon (i_41)"
          },
          {
            "name": "building.serviceLife",
            "type": "number",
            "unit": "years",
            "description": "Building service life (h_13), default 50"
          },
          {
            "name": "keyValues.target.annualCarbon",
            "type": "number",
            "unit": "kgCO2e/m²/yr",
            "description": "Target annual carbon intensity (h_8)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kgCO2e/m²",
          "precision": 1
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "serviceLife > 0",
            "description": "Service life must be positive for annualization"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "serviceLife > 0",
          "output": "round(embodied / serviceLife + h_8, 1)",
          "note": "Annualized embodied carbon plus annual operational carbon"
        },
        {
          "condition": "serviceLife <= 0",
          "output": "0",
          "note": "Guard against division by zero"
        }
      ],
      "edgeCases": [
        {
          "condition": "serviceLife is 0",
          "handling": "Return 0",
          "rationale": "Cannot annualize without valid service life"
        }
      ],
      "formula": {
        "symbolic": "h_6 = round(i_41 / h_13 + h_8, 1)",
        "implementation": "KeyValuesNodes.js:177-192"
      },
      "tests": [
        {
          "name": "Typical target with embodied and operational",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 300,
            "building.serviceLife": 50,
            "keyValues.target.annualCarbon": 15.0
          },
          "expected": 21.0,
          "note": "300/50 + 15.0 = 6 + 15 = 21.0"
        },
        {
          "name": "No embodied carbon",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 0,
            "building.serviceLife": 50,
            "keyValues.target.annualCarbon": 15.0
          },
          "expected": 15.0
        },
        {
          "name": "Zero service life guard",
          "inputs": {
            "building.userModelledEmbodiedCarbon": 300,
            "building.serviceLife": 0,
            "keyValues.target.annualCarbon": 15.0
          },
          "expected": 0
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:177-192"
        }
      ]
    }
  ]
}
