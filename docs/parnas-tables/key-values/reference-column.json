{
  "nodes": [
    {
      "id": "keyValues.reference.teui",
      "legacyId": "e_10",
      "label": "Reference TEUI (kWh/m²/yr)",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Reference building TEUI calculated from total reference energy divided by reference floor area. Represents the baseline code-compliant energy intensity."
      },
      "signature": {
        "inputs": [
          {
            "name": "reference.energy.total",
            "type": "number",
            "unit": "kWh/yr",
            "description": "Reference model total energy (ref_j_32)"
          },
          {
            "name": "reference.building.conditionedFloorArea",
            "type": "number",
            "unit": "m²",
            "description": "Reference model conditioned floor area (ref_h_15)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kWh/m²/yr",
          "precision": 1
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "refArea > 0",
            "description": "Reference floor area must be positive for division"
          }
        ],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "TEUI cannot be negative"
          }
        ]
      },
      "behavior": [
        {
          "condition": "refArea > 0",
          "output": "round(refEnergy / refArea, 1)",
          "note": "Standard TEUI calculation rounded to 1 decimal place"
        },
        {
          "condition": "refArea <= 0",
          "output": "0",
          "note": "Guard against division by zero"
        }
      ],
      "edgeCases": [
        {
          "condition": "refArea is 0 or negative",
          "handling": "Return 0",
          "rationale": "Cannot compute intensity without valid floor area"
        }
      ],
      "formula": {
        "symbolic": "e_10 = round(ref_j_32 / ref_h_15, 1)",
        "implementation": "KeyValuesNodes.js:95-107"
      },
      "tests": [
        {
          "name": "Typical residential reference",
          "inputs": {
            "reference.energy.total": 30000,
            "reference.building.conditionedFloorArea": 200
          },
          "expected": 150.0
        },
        {
          "name": "Zero floor area guard",
          "inputs": {
            "reference.energy.total": 30000,
            "reference.building.conditionedFloorArea": 0
          },
          "expected": 0
        },
        {
          "name": "Fractional result rounds to 1 decimal",
          "inputs": {
            "reference.energy.total": 10000,
            "reference.building.conditionedFloorArea": 300
          },
          "expected": 33.3
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:95-107"
        }
      ]
    },
    {
      "id": "keyValues.reference.annualCarbon",
      "legacyId": "e_8",
      "label": "Reference Annual Carbon (kgCO2e/m²/yr)",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Reference building annual carbon intensity calculated from total reference emissions divided by reference floor area. Represents the baseline operational carbon intensity."
      },
      "signature": {
        "inputs": [
          {
            "name": "reference.emissions.subtotal",
            "type": "number",
            "unit": "kgCO2e/yr",
            "description": "Reference model emissions subtotal (ref_k_32)"
          },
          {
            "name": "reference.building.conditionedFloorArea",
            "type": "number",
            "unit": "m²",
            "description": "Reference model conditioned floor area (ref_h_15)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kgCO2e/m²/yr",
          "precision": 1
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "refArea > 0",
            "description": "Reference floor area must be positive for division"
          }
        ],
        "invariants": [
          {
            "condition": "output >= 0",
            "description": "Carbon intensity cannot be negative for reference model"
          }
        ]
      },
      "behavior": [
        {
          "condition": "refArea > 0",
          "output": "round(refEmissions / refArea, 1)",
          "note": "Standard carbon intensity calculation rounded to 1 decimal place"
        },
        {
          "condition": "refArea <= 0",
          "output": "0",
          "note": "Guard against division by zero"
        }
      ],
      "edgeCases": [
        {
          "condition": "refArea is 0 or negative",
          "handling": "Return 0",
          "rationale": "Cannot compute intensity without valid floor area"
        }
      ],
      "formula": {
        "symbolic": "e_8 = round(ref_k_32 / ref_h_15, 1)",
        "implementation": "KeyValuesNodes.js:110-122"
      },
      "tests": [
        {
          "name": "Typical residential reference",
          "inputs": {
            "reference.emissions.subtotal": 6000,
            "reference.building.conditionedFloorArea": 200
          },
          "expected": 30.0
        },
        {
          "name": "Zero floor area guard",
          "inputs": {
            "reference.emissions.subtotal": 6000,
            "reference.building.conditionedFloorArea": 0
          },
          "expected": 0
        },
        {
          "name": "Fractional result rounds to 1 decimal",
          "inputs": {
            "reference.emissions.subtotal": 1000,
            "reference.building.conditionedFloorArea": 300
          },
          "expected": 3.3
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:110-122"
        }
      ]
    },
    {
      "id": "keyValues.reference.lifetimeCarbon",
      "legacyId": "e_6",
      "label": "Reference Lifetime Carbon (kgCO2e/m²)",
      "section": "S01",
      "classification": "C",
      "_meta": {
        "description": "Reference building lifetime carbon intensity combining annualized embodied carbon with annual operational carbon. Represents the total carbon impact per m² over the building service life."
      },
      "signature": {
        "inputs": [
          {
            "name": "reference.emissions.embodied",
            "type": "number",
            "unit": "kgCO2e/m²",
            "description": "Reference typology embodied carbon (ref_i_39)"
          },
          {
            "name": "reference.building.serviceLife",
            "type": "number",
            "unit": "years",
            "description": "Reference service life (ref_h_13), default 50"
          },
          {
            "name": "keyValues.reference.annualCarbon",
            "type": "number",
            "unit": "kgCO2e/m²/yr",
            "description": "Reference annual carbon intensity (e_8)"
          }
        ],
        "output": {
          "type": "number",
          "unit": "kgCO2e/m²",
          "precision": 1
        }
      },
      "domain": {
        "preconditions": [
          {
            "condition": "refServiceLife > 0",
            "description": "Service life must be positive for annualization"
          }
        ],
        "invariants": []
      },
      "behavior": [
        {
          "condition": "refServiceLife > 0",
          "output": "round(refEmbodied / refServiceLife + e_8, 1)",
          "note": "Annualized embodied carbon plus annual operational carbon"
        },
        {
          "condition": "refServiceLife <= 0",
          "output": "0",
          "note": "Guard against division by zero"
        }
      ],
      "edgeCases": [
        {
          "condition": "refServiceLife is 0",
          "handling": "Return 0",
          "rationale": "Cannot annualize without valid service life"
        }
      ],
      "formula": {
        "symbolic": "e_6 = round(ref_i_39 / ref_h_13 + e_8, 1)",
        "implementation": "KeyValuesNodes.js:125-140"
      },
      "tests": [
        {
          "name": "Typical reference with embodied and operational",
          "inputs": {
            "reference.emissions.embodied": 500,
            "reference.building.serviceLife": 50,
            "keyValues.reference.annualCarbon": 30.0
          },
          "expected": 40.0,
          "note": "500/50 + 30.0 = 10 + 30 = 40.0"
        },
        {
          "name": "No embodied carbon",
          "inputs": {
            "reference.emissions.embodied": 0,
            "reference.building.serviceLife": 50,
            "keyValues.reference.annualCarbon": 30.0
          },
          "expected": 30.0
        },
        {
          "name": "Zero service life guard",
          "inputs": {
            "reference.emissions.embodied": 500,
            "reference.building.serviceLife": 0,
            "keyValues.reference.annualCarbon": 30.0
          },
          "expected": 0
        }
      ],
      "references": [
        {
          "source": "KeyValuesNodes.js:125-140"
        }
      ]
    }
  ]
}
