{
  "_meta": {
    "description": "Interior surface temperature estimates for all 11 envelope components. Uses the simplified steady-state formula T_si = T_interior - (U * deltaT * R_si) where R_si is the interior surface resistance varying by heat flow direction. Air-facing components use winterAverage for exterior temp; ground-facing use constant 10 degrees C.",
    "instances": [
      {
        "id": "transmissionLoss.roof.surfaceTemp",
        "legacyId": "o_85",
        "label": "Roof/Ceiling Surface Temperature"
      },
      {
        "id": "transmissionLoss.walls.surfaceTemp",
        "legacyId": "o_86",
        "label": "Walls Above Grade Surface Temperature"
      },
      {
        "id": "transmissionLoss.exposedFloor.surfaceTemp",
        "legacyId": "o_87",
        "label": "Exposed Floor Surface Temperature"
      },
      {
        "id": "transmissionLoss.doors.surfaceTemp",
        "legacyId": "o_88",
        "label": "Doors Surface Temperature"
      },
      {
        "id": "transmissionLoss.windowNorth.surfaceTemp",
        "legacyId": "o_89",
        "label": "Window North Surface Temperature"
      },
      {
        "id": "transmissionLoss.windowEast.surfaceTemp",
        "legacyId": "o_90",
        "label": "Window East Surface Temperature"
      },
      {
        "id": "transmissionLoss.windowSouth.surfaceTemp",
        "legacyId": "o_91",
        "label": "Window South Surface Temperature"
      },
      {
        "id": "transmissionLoss.windowWest.surfaceTemp",
        "legacyId": "o_92",
        "label": "Window West Surface Temperature"
      },
      {
        "id": "transmissionLoss.skylights.surfaceTemp",
        "legacyId": "o_93",
        "label": "Skylights Surface Temperature"
      },
      {
        "id": "transmissionLoss.wallsBelowGrade.surfaceTemp",
        "legacyId": "o_94",
        "label": "Walls Below Grade Surface Temperature"
      },
      {
        "id": "transmissionLoss.slabOnGrade.surfaceTemp",
        "legacyId": "o_95",
        "label": "Slab on Grade Surface Temperature"
      }
    ]
  },
  "section": "S11",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.{id}.area",
        "type": "number",
        "unit": "m2",
        "description": "Component area - surface temp returns '' if area is 0"
      },
      {
        "name": "transmissionLoss.{id}.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "Component U-value"
      },
      {
        "name": "climate.heating.setpoint",
        "type": "number",
        "unit": "C",
        "description": "Interior heating setpoint temperature (default 21)"
      },
      {
        "name": "climate.temperature.winterAverage",
        "type": "number",
        "unit": "C",
        "description": "Winter average outdoor temperature (default -5) - air-facing only"
      }
    ],
    "output": {
      "type": "number | string",
      "unit": "C",
      "precision": 2
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "area > 0",
        "description": "Surface temperature is only meaningful when the component has area"
      }
    ],
    "invariants": [
      {
        "condition": "T_si <= T_interior",
        "description": "Surface temperature is at or below interior setpoint during heating"
      }
    ]
  },
  "behavior": [
    {
      "condition": "air-facing component with area > 0",
      "output": "T_interior - (U * (T_interior - winterAverage) * R_si)",
      "note": "R_si varies: roof=0.10, walls/doors/windows=0.13, exposedFloor=0.17, skylights=0.10"
    },
    {
      "condition": "ground-facing component with area > 0",
      "output": "T_interior - (U * (T_interior - 10) * R_si)",
      "note": "Ground temperature is constant 10 C. R_si: wallsBelowGrade=0.13, slabOnGrade=0.17"
    },
    {
      "condition": "area is 0",
      "output": "\"\"",
      "note": "Empty string when component has no area"
    }
  ],
  "edgeCases": [
    {
      "condition": "area is 0",
      "handling": "Return empty string ''",
      "rationale": "No physical surface to compute temperature for"
    },
    {
      "condition": "U-value is very high",
      "handling": "Surface temp may be well below interior",
      "rationale": "Poor insulation creates large temperature gradient"
    }
  ],
  "formula": {
    "symbolic": "T_si = T_int - (U * deltaT * R_si) where deltaT = T_int - T_ext",
    "implementation": "TransmissionLossNodes.js:718-783",
    "legacy": "Section11.js"
  },
  "constants": {
    "R_SI_MAP": {
      "roof": 0.10,
      "walls": 0.13,
      "exposedFloor": 0.17,
      "doors": 0.13,
      "windowNorth": 0.13,
      "windowEast": 0.13,
      "windowSouth": 0.13,
      "windowWest": 0.13,
      "skylights": 0.10,
      "wallsBelowGrade": 0.13,
      "slabOnGrade": 0.17
    },
    "groundTemperature": 10,
    "note": "R_si direction: upward=0.10 (roof, skylights), horizontal=0.13 (walls, doors, windows, wallsBelowGrade), downward=0.17 (exposedFloor, slabOnGrade)"
  },
  "tests": [
    {
      "name": "Roof surface temp (U=0.15, Tint=21, Text=-5)",
      "inputs": {
        "transmissionLoss.roof.area": 80,
        "transmissionLoss.roof.uValue": 0.15,
        "climate.heating.setpoint": 21,
        "climate.temperature.winterAverage": -5
      },
      "expected": 20.61,
      "note": "21 - (0.15 * 26 * 0.10) = 21 - 0.39 = 20.61"
    },
    {
      "name": "Wall surface temp (U=0.2, Tint=21, Text=-10)",
      "inputs": {
        "transmissionLoss.walls.area": 120,
        "transmissionLoss.walls.uValue": 0.2,
        "climate.heating.setpoint": 21,
        "climate.temperature.winterAverage": -10
      },
      "expected": 20.19,
      "note": "21 - (0.2 * 31 * 0.13) = 21 - 0.806 = 20.194"
    },
    {
      "name": "Below-grade wall surface temp (ground=10 C)",
      "inputs": {
        "transmissionLoss.wallsBelowGrade.area": 40,
        "transmissionLoss.wallsBelowGrade.uValue": 0.3,
        "climate.heating.setpoint": 21
      },
      "expected": 20.57,
      "note": "21 - (0.3 * 11 * 0.13) = 21 - 0.429 = 20.571"
    },
    {
      "name": "Zero area returns empty string",
      "inputs": {
        "transmissionLoss.skylights.area": 0,
        "transmissionLoss.skylights.uValue": 2.0,
        "climate.heating.setpoint": 21,
        "climate.temperature.winterAverage": -5
      },
      "expected": ""
    }
  ],
  "references": [
    {
      "source": "TransmissionLossNodes.js:718-730 (R_SI_MAP constants)"
    },
    {
      "source": "TransmissionLossNodes.js:732-757 (air-facing surface temps)"
    },
    {
      "source": "TransmissionLossNodes.js:759-783 (ground-facing surface temps)"
    }
  ]
}
