  "section": "S11",
  "signature": {
    "inputs": "These ARE the inputs (registered via graph.registerInput in TransmissionLossNodes.js). Fenestration areas (d_88-d_93) are NOT inputs -- they are computed nodes bridged from S10 RadiantGains.",
    "output": "Values stored in MultiModelState, consumed by heat loss/gain, R-Imperial, condensation risk, surface temperature, and F280 peak load calculations"
  },
  "domain": {
    "preconditions": [
      {
        "condition": "RSI values > 0",
        "description": "Thermal resistance must be positive for U-value conversion (1/RSI)"
      },
      {
        "condition": "U-values >= 0",
        "description": "Thermal transmittance cannot be negative"
      },
      {
        "condition": "Areas >= 0",
        "description": "Envelope component areas cannot be negative"
      },
      {
        "condition": "Thermal bridge penalty in [0, 100]",
        "description": "Penalty is a percentage of component subtotal"
      }
    ],
    "invariants": [
      {
        "condition": "All inputs are C-classified",
        "description": "All transmission loss inputs can differ between Target and Reference models"
      },
      {
        "condition": "Opaque components use RSI input -> computed U-value; fenestration uses U-value input -> computed RSI",
        "description": "Two different input patterns for insulation specification"
      }
    ]
  },
  "behavior": [
    {
      "condition": "RSI input (f_85-f_87, f_94-f_95) changes",
      "output": "Triggers recomputation of U-value (g_*), R-Imperial (e_*), heat loss (i_*), heat gain (k_*), surface temperature (o_*), condensation risk (cr_*)",
      "note": "U-value = 1/RSI; RSI > 0 required to avoid division by zero"
    },
    {
      "condition": "U-value input (g_88-g_93) changes",
      "output": "Triggers recomputation of RSI (f_*), R-Imperial (e_*), heat loss (i_*), heat gain (k_*), surface temperature (o_*), condensation risk (cr_*)",
      "note": "RSI = 1/U-value"
    },
    {
      "condition": "Area input (d_85-d_87, d_94-d_95) changes",
      "output": "Triggers recomputation of heat loss (i_*), heat gain (k_*), area percentages (h_*), and subtotals",
      "note": "C-classified, model-specific"
    },
    {
      "condition": "Thermal bridge penalty (d_97) changes",
      "output": "Triggers recomputation of penalty heat loss (i_97), penalty heat gain (k_97), and totals",
      "note": "Applied as percentage of component subtotal: i_97 = subtotal * (penalty/100)"
    }
  ],
  "edgeCases": [
    {
      "condition": "RSI = 0 for an opaque component",
      "handling": "U-value = 0, heat loss = 0",
      "rationale": "Guard: rsi > 0 ? 1/rsi : 0"
    },
    {
      "condition": "Thermal bridge penalty default (20) vs compute fallback (5)",
      "handling": "Input default is 20%, but several compute functions use parseNum(..., 5) fallback",
      "rationale": "Known inconsistency between registered default and compute-time fallback"
    },
    {
      "condition": "Fenestration areas are 0 (no S10 data)",
      "handling": "Computed area nodes (d_88-d_93) return 0, no heat loss/gain for those components",
      "rationale": "Areas bridged from RadiantGains -- must be entered in S10 first"
    }
  ],
