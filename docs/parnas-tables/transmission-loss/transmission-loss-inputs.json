  "section": "S11",
  "signature": {
    "inputs": "These ARE the inputs (registered via graph.registerInput in TransmissionLossNodes.js)",
    "output": "Values stored in MultiModelState, consumed by UA, R-Imperial, condensation risk, and F280 peak load calculations"
  },
  "domain": {
    "preconditions": [
      {
        "condition": "U-values >= 0",
        "description": "Thermal transmittance cannot be negative"
      },
      {
        "condition": "Areas >= 0",
        "description": "Envelope component areas cannot be negative"
      }
    ],
    "invariants": [
      {
        "condition": "U-values are C-classified, areas are G-classified",
        "description": "U-values can differ between Target and Reference models; areas are shared geometry"
      }
    ]
  },
  "behavior": [
    {
      "condition": "Any U-value (d_85–d_92, d_95) changes",
      "output": "Triggers recomputation of corresponding UA (h_*), R-Imperial (e_*), and condensation risk (cr_*) nodes",
      "note": "C-classified, model-specific. Also affects downstream totals (h_93, h_94, h_96) and effective U-values (d_93, d_94, d_96)"
    },
    {
      "condition": "Any area (g_85–g_92, g_95) changes",
      "output": "Triggers recomputation of corresponding UA (h_*) and total area nodes (g_93, g_94, g_96)",
      "note": "G-classified, affects all models. Also affects F280 peak envelope heat loss"
    }
  ],
  "edgeCases": [
    {
      "condition": "U-value is 0 for a component",
      "handling": "UA = 0, R-Imperial = 0, condensation risk = 0",
      "rationale": "Component not present or perfectly insulated (theoretical)"
    },
    {
      "condition": "Area is 0 for a component",
      "handling": "UA = 0, component contributes nothing to totals",
      "rationale": "Component not present in building envelope"
    }
  ],
  "tests": [
