{
  "_meta": {
    "description": "Heat loss and heat gain through ground-facing envelope components: wallsBelowGrade and slabOnGrade. Uses ground-specific degree days and a capacitance factor for heat gain calculations.",
    "instances": [
      {
        "id": "transmissionLoss.wallsBelowGrade.heatLoss",
        "legacyId": "i_94",
        "label": "Walls Below Grade Heat Loss"
      },
      {
        "id": "transmissionLoss.slabOnGrade.heatLoss",
        "legacyId": "i_95",
        "label": "Slab on Grade Heat Loss"
      },
      {
        "id": "transmissionLoss.wallsBelowGrade.heatGain",
        "legacyId": "k_94",
        "label": "Walls Below Grade Heat Gain"
      },
      {
        "id": "transmissionLoss.slabOnGrade.heatGain",
        "legacyId": "k_95",
        "label": "Slab on Grade Heat Gain"
      }
    ]
  },
  "section": "S11",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.{id}.area",
        "type": "number",
        "unit": "m2",
        "description": "Component area (d_{row})"
      },
      {
        "name": "transmissionLoss.{id}.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "Component U-value (g_{row})"
      },
      {
        "name": "climate.groundFacing.hdd",
        "type": "number",
        "unit": "degree-days",
        "description": "Ground-facing heating degree days"
      },
      {
        "name": "climate.groundFacing.cdd",
        "type": "number",
        "unit": "degree-days",
        "description": "Ground-facing cooling degree days"
      },
      {
        "name": "building.capacitance.percentage",
        "type": "number",
        "unit": "%",
        "description": "Building capacitance percentage (i_21) - used to derive capacitance factor for heat gain"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "groundHDD is not 'Unavailable' or 'N/A' (for heat loss)",
        "description": "Ground-facing HDD must be available for heat loss calculation"
      }
    ],
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Heat transfer values are non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "heat loss",
      "output": "(area * uValue * groundHDD * 24) / 1000",
      "note": "Same formula as air-facing but using ground-specific HDD"
    },
    {
      "condition": "heat gain",
      "output": "(area * uValue * capacitanceFactor * groundCDD * 24) / 1000",
      "note": "capacitanceFactor = i_21/100 with fallback to 0.5 if 0 or NaN"
    }
  ],
  "edgeCases": [
    {
      "condition": "groundHDD is 'Unavailable' or 'N/A'",
      "handling": "Heat loss returns 'Unavailable'",
      "rationale": "Cannot compute without ground degree days"
    },
    {
      "condition": "capacitance percentage is 0 or NaN",
      "handling": "capacitanceFactor defaults to 0.5",
      "rationale": "Legacy fallback: if i_21/100 yields 0 or NaN, use 0.5"
    },
    {
      "condition": "area is 0",
      "handling": "Return 0",
      "rationale": "No area means no heat transfer"
    }
  ],
  "formula": {
    "symbolic": "i_{row} = (d_{row} * g_{row} * groundHDD * 24) / 1000; k_{row} = (d_{row} * g_{row} * capacitanceFactor * groundCDD * 24) / 1000",
    "implementation": "TransmissionLossNodes.js:239-287",
    "legacy": "Section11.js"
  },
  "tests": [
    {
      "name": "Below-grade wall heat loss",
      "inputs": {
        "transmissionLoss.wallsBelowGrade.area": 40,
        "transmissionLoss.wallsBelowGrade.uValue": 0.3,
        "climate.groundFacing.hdd": 3000
      },
      "expected": 864.0
    },
    {
      "name": "Slab heat gain with capacitance",
      "inputs": {
        "transmissionLoss.slabOnGrade.area": 80,
        "transmissionLoss.slabOnGrade.uValue": 0.25,
        "climate.groundFacing.cdd": 150,
        "building.capacitance.percentage": 60
      },
      "expected": 43.2
    },
    {
      "name": "Capacitance fallback to 0.5 when 0",
      "inputs": {
        "transmissionLoss.slabOnGrade.area": 80,
        "transmissionLoss.slabOnGrade.uValue": 0.25,
        "climate.groundFacing.cdd": 150,
        "building.capacitance.percentage": 0
      },
      "expected": 36.0
    },
    {
      "name": "Unavailable ground HDD",
      "inputs": {
        "transmissionLoss.wallsBelowGrade.area": 40,
        "transmissionLoss.wallsBelowGrade.uValue": 0.3,
        "climate.groundFacing.hdd": "Unavailable"
      },
      "expected": "Unavailable"
    }
  ],
  "references": [
    {
      "source": "TransmissionLossNodes.js:239-287"
    }
  ]
}
