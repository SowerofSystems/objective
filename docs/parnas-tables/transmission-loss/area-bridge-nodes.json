{
  "_meta": {
    "description": "Bridge nodes that pass glazing areas from Section 10 (radiant gains) to Section 11 (transmission losses). Rows 88-93 in S11 mirror rows 73-78 from S10, so door, window, and skylight areas are computed rather than input.",
    "instances": [
      {
        "id": "transmissionLoss.doors.area",
        "legacyId": "d_88",
        "label": "Doors Area (bridged from S10 row 73)"
      },
      {
        "id": "transmissionLoss.windowNorth.area",
        "legacyId": "d_89",
        "label": "Window North Area (bridged from S10 row 74)"
      },
      {
        "id": "transmissionLoss.windowEast.area",
        "legacyId": "d_90",
        "label": "Window East Area (bridged from S10 row 75)"
      },
      {
        "id": "transmissionLoss.windowSouth.area",
        "legacyId": "d_91",
        "label": "Window South Area (bridged from S10 row 76)"
      },
      {
        "id": "transmissionLoss.windowWest.area",
        "legacyId": "d_92",
        "label": "Window West Area (bridged from S10 row 77)"
      },
      {
        "id": "transmissionLoss.skylights.area",
        "legacyId": "d_93",
        "label": "Skylights Area (bridged from S10 row 78)"
      }
    ]
  },
  "section": "S11",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "radiantGains.row{S10Row}.area",
        "type": "number",
        "unit": "m2",
        "description": "Glazing area from S10 (d_{73..78}) - source of truth for door/window/skylight areas"
      }
    ],
    "output": {
      "type": "number",
      "unit": "m2",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Area values are non-negative"
      },
      {
        "condition": "output === radiantGains.row{S10Row}.area",
        "description": "Bridge node is a direct pass-through with no transformation"
      }
    ]
  },
  "behavior": [
    {
      "condition": "always",
      "output": "parseNum(radiantGains.row{S10Row}.area)",
      "note": "Direct pass-through: d_88=d_73, d_89=d_74, d_90=d_75, d_91=d_76, d_92=d_77, d_93=d_78"
    }
  ],
  "edgeCases": [
    {
      "condition": "source area is null/undefined",
      "handling": "Return 0",
      "rationale": "parseNum defaults to 0"
    }
  ],
  "formula": {
    "symbolic": "d_{row} = d_{S10Row} where {88:73, 89:74, 90:75, 91:76, 92:77, 93:78}",
    "implementation": "TransmissionLossNodes.js:68-78",
    "legacy": "Section11.js"
  },
  "tests": [
    {
      "name": "Door area bridged from S10",
      "inputs": {
        "radiantGains.row73.area": 5.0
      },
      "expected": 5.0
    },
    {
      "name": "Window South bridged from S10",
      "inputs": {
        "radiantGains.row76.area": 12.5
      },
      "expected": 12.5
    },
    {
      "name": "Null source defaults to 0",
      "inputs": {
        "radiantGains.row74.area": null
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "TransmissionLossNodes.js:49-57 (AREA_BRIDGE mapping)"
    },
    {
      "source": "TransmissionLossNodes.js:68-78 (bridge node registration)"
    }
  ]
}
