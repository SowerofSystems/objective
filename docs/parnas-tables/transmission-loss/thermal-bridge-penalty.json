{
  "_meta": {
    "description": "Thermal bridge penalty calculations and grand totals. The penalty is a percentage surcharge on envelope component heat transfer, applied after component subtotals are computed. Grand totals include penalty + component subtotals.",
    "instances": [
      {
        "id": "transmissionLoss.thermalBridgePenalty.decimal",
        "legacyId": "e_97",
        "label": "Thermal Bridge Penalty (decimal)"
      },
      {
        "id": "transmissionLoss.thermalBridgePenalty.heatLoss",
        "legacyId": "i_97",
        "label": "Thermal Bridge Penalty Heat Loss"
      },
      {
        "id": "transmissionLoss.thermalBridgePenalty.heatGain",
        "legacyId": "k_97",
        "label": "Thermal Bridge Penalty Heat Gain"
      },
      {
        "id": "transmissionLoss.thermalBridgePenalty.heatLossPercent",
        "legacyId": "j_97",
        "label": "Thermal Bridge Heat Loss %"
      },
      {
        "id": "transmissionLoss.total.heatLoss",
        "label": "Total Heat Loss with Penalty"
      },
      {
        "id": "transmissionLoss.total.heatGain",
        "label": "Total Heat Gain with Penalty"
      }
    ]
  },
  "section": "S11",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.thermalBridgePenalty",
        "type": "number",
        "unit": "%",
        "description": "Thermal bridge penalty percentage (d_97) - user input, default 20"
      },
      {
        "name": "transmissionLoss.components.subtotalHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_98 - sum of all component heat losses"
      },
      {
        "name": "transmissionLoss.components.subtotalHeatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "k_98 - sum of all component heat gains"
      }
    ],
    "output": {
      "type": "number",
      "unit": "varies (decimal, kWh/yr, ratio)",
      "precision": 4
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "components.subtotalHeatLoss must be computed first",
        "description": "Penalty is applied to already-computed component subtotals"
      }
    ],
    "invariants": [
      {
        "condition": "0 <= decimal <= 1",
        "description": "Penalty decimal is clamped between 0 and 1"
      },
      {
        "condition": "total.heatLoss = i_97 + i_98",
        "description": "Grand total is penalty plus component subtotal"
      }
    ]
  },
  "behavior": [
    {
      "condition": "thermalBridgePenalty.decimal (e_97)",
      "output": "clamp(d_97 / 100, 0, 1)",
      "note": "Converts percentage to decimal, clamped to [0, 1]"
    },
    {
      "condition": "thermalBridgePenalty.heatLoss (i_97)",
      "output": "i_98 * (d_97 / 100)",
      "note": "Penalty heat loss = component subtotal * penalty fraction"
    },
    {
      "condition": "thermalBridgePenalty.heatGain (k_97)",
      "output": "k_98 * (d_97 / 100)",
      "note": "Penalty heat gain = component subtotal * penalty fraction"
    },
    {
      "condition": "thermalBridgePenalty.heatLossPercent (j_97)",
      "output": "i_97 / i_98",
      "note": "Penalty as fraction of component subtotal"
    },
    {
      "condition": "total.heatLoss",
      "output": "i_97 + i_98",
      "note": "Grand total = penalty + components"
    },
    {
      "condition": "total.heatGain",
      "output": "k_97 + k_98",
      "note": "Grand total = penalty + components"
    }
  ],
  "edgeCases": [
    {
      "condition": "penalty percentage is 0",
      "handling": "i_97 = 0, total equals component subtotal",
      "rationale": "No penalty applied"
    },
    {
      "condition": "component subtotal is 0",
      "handling": "heatLossPercent returns 0",
      "rationale": "Avoid division by zero"
    },
    {
      "condition": "penalty default",
      "handling": "parseNum fallback to 5 for penalty percentage",
      "rationale": "TransmissionLossNodes.js uses default 5 in parseNum calls"
    }
  ],
  "formula": {
    "symbolic": "e_97 = clamp(d_97/100, 0, 1); i_97 = i_98 * d_97/100; j_97 = i_97/i_98; total = i_97 + i_98",
    "implementation": "TransmissionLossNodes.js:461-564",
    "legacy": "Section11.js"
  },
  "tests": [
    {
      "name": "20% penalty on 6200 kWh subtotal",
      "inputs": {
        "transmissionLoss.components.subtotalHeatLoss": 6200,
        "transmissionLoss.thermalBridgePenalty": 20
      },
      "expected": {
        "i_97": 1240,
        "total": 7440
      }
    },
    {
      "name": "Penalty decimal clamped to 1",
      "inputs": {
        "transmissionLoss.thermalBridgePenalty": 150
      },
      "expected": {
        "e_97": 1.0
      }
    },
    {
      "name": "Penalty percentage of subtotal",
      "inputs": {
        "transmissionLoss.thermalBridgePenalty.heatLoss": 1240,
        "transmissionLoss.components.subtotalHeatLoss": 6200
      },
      "expected": {
        "j_97": 0.2
      }
    }
  ],
  "references": [
    {
      "source": "TransmissionLossNodes.js:461-477 (i_97 penalty heat loss)"
    },
    {
      "source": "TransmissionLossNodes.js:479-494 (k_97 penalty heat gain)"
    },
    {
      "source": "TransmissionLossNodes.js:631-643 (e_97 decimal)"
    },
    {
      "source": "TransmissionLossNodes.js:536-564 (total heat loss/gain)"
    },
    {
      "source": "TransmissionLossNodes.js:659-674 (j_97 heat loss percent)"
    }
  ]
}
