  "section": "S11",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.{id}.rsi",
        "type": "number",
        "unit": "m2K/W",
        "description": "RSI value (for RSI-input components: roof, walls, exposedFloor, wallsBelowGrade, slabOnGrade)"
      },
      {
        "name": "transmissionLoss.{id}.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "U-value (for U-value-input components: doors, windows, skylights)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "W/m2K or m2K/W",
      "precision": 4
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "input > 0",
        "description": "RSI or U-value must be positive for meaningful reciprocal"
      }
    ],
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Thermal properties are non-negative"
      },
      {
        "condition": "RSI * U = 1 (when both > 0)",
        "description": "RSI and U-value are exact reciprocals"
      }
    ]
  },
  "behavior": [
    {
      "condition": "RSI-input component (roof, walls, exposedFloor, wallsBelowGrade, slabOnGrade)",
      "output": "U = 1 / RSI",
      "note": "RSI default is 5.0; computes U-value as reciprocal"
    },
    {
      "condition": "U-value-input component (doors, windows, skylights)",
      "output": "RSI = 1 / U",
      "note": "U-value default is 2.0; computes RSI as reciprocal"
    }
  ],
  "edgeCases": [
    {
      "condition": "RSI is 0 or negative",
      "handling": "Return 0",
      "rationale": "Guard against division by zero; rsi > 0 check in compute"
    },
    {
      "condition": "U-value is 0 or negative",
      "handling": "Return 0",
      "rationale": "Guard against division by zero; uValue > 0 check in compute"
    }
  ],
  "formula": {
    "symbolic": "RSI-input: g_{row} = 1 / f_{row}; U-input: f_{row} = 1 / g_{row}",
    "implementation": "TransmissionLossNodes.js:154-184",
    "legacy": "Section11.js"
  },
  "tests": [
    {
      "name": "RSI 5.0 yields U 0.2",
      "inputs": {
        "transmissionLoss.roof.rsi": 5.0
      },
      "expected": 0.2
    },
    {
      "name": "U-value 2.0 yields RSI 0.5",
      "inputs": {
        "transmissionLoss.doors.uValue": 2.0
      },
      "expected": 0.5
    },
    {
      "name": "RSI 0 returns 0",
      "inputs": {
        "transmissionLoss.walls.rsi": 0
      },
      "expected": 0
    },
    {
      "name": "U-value 0 returns 0",
      "inputs": {
        "transmissionLoss.windowSouth.uValue": 0
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "TransmissionLossNodes.js:154-184"
    }
  ]
}
