  "section": "S11",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.{id}.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Component heat loss (i_{row})"
      },
      {
        "name": "transmissionLoss.{id}.heatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Component heat gain (k_{row})"
      },
      {
        "name": "transmissionLoss.{id}.area",
        "type": "number",
        "unit": "m2",
        "description": "Component area (d_{row})"
      },
      {
        "name": "transmissionLoss.components.subtotalHeatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "i_98 - component subtotal heat loss (denominator for heat loss %)"
      },
      {
        "name": "transmissionLoss.components.subtotalHeatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "k_98 - component subtotal heat gain (denominator for heat gain %)"
      },
      {
        "name": "transmissionLoss.airFacing.totalArea",
        "type": "number",
        "unit": "m2",
        "description": "Air-facing total area (denominator for air-facing area %)"
      },
      {
        "name": "transmissionLoss.groundFacing.totalArea",
        "type": "number",
        "unit": "m2",
        "description": "Ground-facing total area (denominator for ground-facing area %)"
      }
    ],
    "output": {
      "type": "number",
      "unit": "ratio (0-1)",
      "precision": 4
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "SUM(heatLossPercent for all components) approximates 1.0",
        "description": "Component percentages sum to 100% of subtotal"
      },
      {
        "condition": "SUM(areaPercent within each group) = 1.0 when total > 0",
        "description": "Area percentages sum to 100% within each group"
      }
    ]
  },
  "behavior": [
    {
      "condition": "heatLossPercent (j_{row})",
      "output": "componentHeatLoss / subtotalHeatLoss",
      "note": "Denominator is i_98 (components only, without penalty)"
    },
    {
      "condition": "heatGainPercent (l_{row})",
      "output": "-componentHeatGain / subtotalHeatGain",
      "note": "NEGATIVE sign convention: -k_{row} / k_98; threshold |k_98| > 0.001"
    },
    {
      "condition": "areaPercent (h_{85..93}) air-facing",
      "output": "componentArea / airFacing.totalArea",
      "note": "Air-facing components use air-facing total as denominator"
    },
    {
      "condition": "areaPercent (h_{94..95}) ground-facing",
      "output": "componentArea / groundFacing.totalArea",
      "note": "Ground-facing components use ground-facing total as denominator"
    },
    {
      "condition": "thermalBridgePenalty.heatGainPercent (l_97)",
      "output": "-penaltyHeatGain / subtotalHeatGain",
      "note": "Same negative convention as component percentages"
    },
    {
      "condition": "total.heatLossPercent (j_98)",
      "output": "1.0",
      "note": "Constant: represents 100%"
    },
    {
      "condition": "total.heatGainPercent (l_98)",
      "output": "-1.0",
      "note": "Constant: represents -100% (negative convention)"
    },
    {
      "condition": "total.rImprovement (e_98)",
      "output": "0",
      "note": "Constant: not calculated in legacy code"
    }
  ],
  "edgeCases": [
    {
      "condition": "subtotal is 0",
      "handling": "Return 0 for percentage",
      "rationale": "Avoid division by zero when no heat transfer exists"
    },
    {
      "condition": "heat gain subtotal near zero (|k_98| <= 0.001)",
      "handling": "Return 0",
      "rationale": "Guard against near-zero division"
    },
    {
      "condition": "group area total is 0",
      "handling": "Return 0 for area percentage",
      "rationale": "parseNum defaults total to 1 to avoid division by zero, but returns 0 if truly 0"
    }
  ],
  "formula": {
    "symbolic": "j_{row} = i_{row}/i_98; l_{row} = -k_{row}/k_98; h_{row} = d_{row}/groupTotal",
    "implementation": "TransmissionLossNodes.js:499-601",
    "legacy": "Section11.js"
  },
  "tests": [
    {
      "name": "Roof heat loss is 30% of subtotal",
      "inputs": {
        "transmissionLoss.roof.heatLoss": 1860,
        "transmissionLoss.components.subtotalHeatLoss": 6200
      },
      "expected": 0.3
    },
    {
      "name": "Heat gain percentage with negative convention",
      "inputs": {
        "transmissionLoss.windowSouth.heatGain": 100,
        "transmissionLoss.components.subtotalHeatGain": 500
      },
      "expected": -0.2
    },
    {
      "name": "Air-facing area percentage",
      "inputs": {
        "transmissionLoss.walls.area": 120,
        "transmissionLoss.airFacing.totalArea": 240
      },
      "expected": 0.5
    },
    {
      "name": "Ground-facing area percentage",
      "inputs": {
        "transmissionLoss.slabOnGrade.area": 80,
        "transmissionLoss.groundFacing.totalArea": 120
      },
      "expected": 0.6667,
      "note": "Approximate (80/120)"
    },
    {
      "name": "Zero subtotal returns 0",
      "inputs": {
        "transmissionLoss.roof.heatLoss": 0,
        "transmissionLoss.components.subtotalHeatLoss": 0
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "TransmissionLossNodes.js:499-530 (heat loss/gain percentages)"
    },
    {
      "source": "TransmissionLossNodes.js:571-601 (area percentages)"
    },
    {
      "source": "TransmissionLossNodes.js:659-711 (penalty and total percentages)"
    }
  ]
