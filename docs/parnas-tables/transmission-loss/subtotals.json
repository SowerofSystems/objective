{
  "_meta": {
    "description": "Subtotal nodes for transmission loss calculations. Includes air-facing totals, ground-facing totals, component subtotals (row 98), and total envelope area. These are intermediate aggregations used by penalty, percentage, and downstream section calculations.",
    "instances": [
      {
        "id": "transmissionLoss.airFacing.totalArea",
        "label": "Air-Facing Total Area"
      },
      {
        "id": "transmissionLoss.airFacing.totalHeatLoss",
        "label": "Air-Facing Total Heat Loss"
      },
      {
        "id": "transmissionLoss.airFacing.totalHeatGain",
        "label": "Air-Facing Total Heat Gain"
      },
      {
        "id": "transmissionLoss.airFacing.weightedUValue",
        "label": "Air-Facing Weighted U-Value"
      },
      {
        "id": "transmissionLoss.groundFacing.totalArea",
        "label": "Ground-Facing Total Area"
      },
      {
        "id": "transmissionLoss.groundFacing.totalHeatLoss",
        "label": "Ground-Facing Total Heat Loss"
      },
      {
        "id": "transmissionLoss.groundFacing.totalHeatGain",
        "label": "Ground-Facing Total Heat Gain"
      },
      {
        "id": "transmissionLoss.components.subtotalHeatLoss",
        "legacyId": "i_98",
        "label": "Envelope Components Subtotal Heat Loss"
      },
      {
        "id": "transmissionLoss.components.subtotalHeatGain",
        "legacyId": "k_98",
        "label": "Envelope Components Subtotal Heat Gain"
      },
      {
        "id": "transmissionLoss.total.envelopeArea",
        "legacyId": "d_98",
        "label": "Total Envelope Area"
      },
      {
        "id": "transmissionLoss.total.area",
        "label": "Total Area (air + ground)"
      },
      {
        "id": "transmissionLoss.total.areaPercent",
        "legacyId": "h_98",
        "label": "Total Area Percentage (constant 100%)"
      }
    ]
  },
  "section": "S11",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.{component}.area",
        "type": "number",
        "unit": "m2",
        "description": "Individual component areas"
      },
      {
        "name": "transmissionLoss.{component}.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "Individual component U-values (for weighted U-value)"
      },
      {
        "name": "transmissionLoss.{component}.heatLoss",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Individual component heat losses"
      },
      {
        "name": "transmissionLoss.{component}.heatGain",
        "type": "number",
        "unit": "kWh/yr",
        "description": "Individual component heat gains"
      },
      {
        "name": "transmissionLoss.thermalBridgePenalty",
        "type": "number",
        "unit": "%",
        "description": "Thermal bridge penalty percentage (d_97) - used in weighted U-value"
      }
    ],
    "output": {
      "type": "number",
      "unit": "varies (m2, kWh/yr, W/m2K, or string)",
      "precision": 2
    }
  },
  "domain": {
    "invariants": [
      {
        "condition": "totalArea >= 0",
        "description": "Sum of non-negative areas is non-negative"
      },
      {
        "condition": "i_98 = airFacing.totalHeatLoss + groundFacing.totalHeatLoss",
        "description": "Component subtotal excludes thermal bridge penalty"
      },
      {
        "condition": "d_98 = SUM(d_85:d_95)",
        "description": "Total envelope area is sum of all 11 component areas"
      }
    ]
  },
  "behavior": [
    {
      "condition": "airFacing.totalArea",
      "output": "SUM(d_85, d_86, d_87, d_88, d_89, d_90, d_91, d_92, d_93)",
      "note": "Sum of all 9 air-facing component areas"
    },
    {
      "condition": "airFacing.totalHeatLoss",
      "output": "SUM(i_85:i_93)",
      "note": "Sum of all 9 air-facing heat losses"
    },
    {
      "condition": "airFacing.totalHeatGain",
      "output": "SUM(k_85:k_93)",
      "note": "Sum of all 9 air-facing heat gains"
    },
    {
      "condition": "airFacing.weightedUValue",
      "output": "SUMPRODUCT(g_85:g_93, d_85:d_93) / SUM(d_85:d_93) * (1 + d_97/100)",
      "note": "Area-weighted U-value including thermal bridge penalty factor"
    },
    {
      "condition": "groundFacing.totalArea",
      "output": "d_94 + d_95",
      "note": "Sum of 2 ground-facing component areas"
    },
    {
      "condition": "groundFacing.totalHeatLoss",
      "output": "i_94 + i_95",
      "note": "Sum of 2 ground-facing heat losses"
    },
    {
      "condition": "groundFacing.totalHeatGain",
      "output": "k_94 + k_95",
      "note": "Sum of 2 ground-facing heat gains"
    },
    {
      "condition": "components.subtotalHeatLoss (i_98)",
      "output": "airFacing.totalHeatLoss + groundFacing.totalHeatLoss",
      "note": "Total component heat loss WITHOUT thermal bridge penalty"
    },
    {
      "condition": "components.subtotalHeatGain (k_98)",
      "output": "airFacing.totalHeatGain + groundFacing.totalHeatGain",
      "note": "Total component heat gain WITHOUT thermal bridge penalty"
    },
    {
      "condition": "total.envelopeArea (d_98)",
      "output": "SUM(d_85:d_95)",
      "note": "All 11 component areas (excludes d_96 interior floor)"
    },
    {
      "condition": "total.area",
      "output": "airFacing.totalArea + groundFacing.totalArea",
      "note": "Same as d_98 but computed from group subtotals"
    },
    {
      "condition": "total.areaPercent (h_98)",
      "output": "\"100%\"",
      "note": "Constant string value"
    }
  ],
  "edgeCases": [
    {
      "condition": "all component areas are 0",
      "handling": "weightedUValue returns 0 (guard: totalArea === 0)",
      "rationale": "Avoid division by zero in weighted average"
    },
    {
      "condition": "penalty input default",
      "handling": "weightedUValue uses penalty default of 5%",
      "rationale": "parseNum fallback for transmissionLoss.thermalBridgePenalty"
    }
  ],
  "formula": {
    "symbolic": "i_98 = SUM(i_85:i_95); d_98 = SUM(d_85:d_95); weightedU = SUMPRODUCT(g,d)/SUM(d) * (1+d_97/100)",
    "implementation": "TransmissionLossNodes.js:292-654",
    "legacy": "Section11.js"
  },
  "tests": [
    {
      "name": "Air-facing area subtotal",
      "inputs": {
        "transmissionLoss.roof.area": 80,
        "transmissionLoss.walls.area": 120,
        "transmissionLoss.exposedFloor.area": 0,
        "transmissionLoss.doors.area": 5,
        "transmissionLoss.windowNorth.area": 8,
        "transmissionLoss.windowEast.area": 6,
        "transmissionLoss.windowSouth.area": 12,
        "transmissionLoss.windowWest.area": 6,
        "transmissionLoss.skylights.area": 3
      },
      "expected": 240
    },
    {
      "name": "Component subtotal heat loss",
      "inputs": {
        "transmissionLoss.airFacing.totalHeatLoss": 5000,
        "transmissionLoss.groundFacing.totalHeatLoss": 1200
      },
      "expected": 6200
    },
    {
      "name": "Weighted U-value with 20% penalty",
      "inputs": {
        "transmissionLoss.roof.area": 100,
        "transmissionLoss.roof.uValue": 0.15,
        "transmissionLoss.walls.area": 100,
        "transmissionLoss.walls.uValue": 0.25,
        "transmissionLoss.airFacing.totalArea": 200,
        "transmissionLoss.thermalBridgePenalty": 20
      },
      "expected": 0.24,
      "note": "(0.15*100+0.25*100)/200 * 1.2 = 0.2 * 1.2 = 0.24 (simplified with only 2 components)"
    }
  ],
  "references": [
    {
      "source": "TransmissionLossNodes.js:292-358 (air-facing subtotals)"
    },
    {
      "source": "TransmissionLossNodes.js:363-400 (ground-facing subtotals)"
    },
    {
      "source": "TransmissionLossNodes.js:409-440 (component subtotals i_98/k_98)"
    },
    {
      "source": "TransmissionLossNodes.js:606-618 (d_98 total envelope area)"
    }
  ]
}
