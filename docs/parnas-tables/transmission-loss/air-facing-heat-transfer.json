  "section": "S11",
  "classification": "C",
  "signature": {
    "inputs": [
      {
        "name": "transmissionLoss.{id}.area",
        "type": "number",
        "unit": "m2",
        "description": "Component area (d_{row})"
      },
      {
        "name": "transmissionLoss.{id}.uValue",
        "type": "number",
        "unit": "W/m2K",
        "description": "Component U-value (g_{row})"
      },
      {
        "name": "climate.heating.degreedays",
        "type": "number",
        "unit": "degree-days",
        "description": "Heating degree days (HDD) - for heat loss"
      },
      {
        "name": "climate.cooling.degreedays",
        "type": "number",
        "unit": "degree-days",
        "description": "Cooling degree days (CDD) - for heat gain"
      }
    ],
    "output": {
      "type": "number",
      "unit": "kWh/yr",
      "precision": 2
    }
  },
  "domain": {
    "preconditions": [
      {
        "condition": "HDD/CDD is not 'Unavailable' or 'N/A'",
        "description": "Degree days must be available for calculation (heat loss returns 'Unavailable', heat gain returns 0)"
      }
    ],
    "invariants": [
      {
        "condition": "output >= 0",
        "description": "Heat transfer values are non-negative"
      }
    ]
  },
  "behavior": [
    {
      "condition": "heat loss (HDD available)",
      "output": "(area * uValue * HDD * 24) / 1000",
      "note": "24 converts degree-days to degree-hours; /1000 converts W to kW"
    },
    {
      "condition": "heat gain (CDD available)",
      "output": "(area * uValue * CDD * 24) / 1000",
      "note": "Same formula but using cooling degree days"
    }
  ],
  "edgeCases": [
    {
      "condition": "HDD is 'Unavailable' or 'N/A'",
      "handling": "Heat loss returns 'Unavailable'",
      "rationale": "Cannot compute heat loss without heating degree days"
    },
    {
      "condition": "CDD is 'Unavailable' or 'N/A'",
      "handling": "Heat gain returns 0",
      "rationale": "Legacy behavior: returns 0 for heat gains when CDD unavailable"
    },
    {
      "condition": "area is 0",
      "handling": "Return 0",
      "rationale": "No area means no heat transfer"
    }
  ],
  "formula": {
    "symbolic": "i_{row} = (d_{row} * g_{row} * HDD * 24) / 1000; k_{row} = (d_{row} * g_{row} * CDD * 24) / 1000",
    "implementation": "TransmissionLossNodes.js:189-234",
    "legacy": "Section11.js"
  },
  "tests": [
    {
      "name": "Standard wall heat loss",
      "inputs": {
        "transmissionLoss.walls.area": 100,
        "transmissionLoss.walls.uValue": 0.2,
        "climate.heating.degreedays": 4000
      },
      "expected": 1920.0
    },
    {
      "name": "Window heat gain with CDD",
      "inputs": {
        "transmissionLoss.windowSouth.area": 10,
        "transmissionLoss.windowSouth.uValue": 1.5,
        "climate.cooling.degreedays": 200
      },
      "expected": 72.0
    },
    {
      "name": "Unavailable HDD returns Unavailable",
      "inputs": {
        "transmissionLoss.roof.area": 50,
        "transmissionLoss.roof.uValue": 0.15,
        "climate.heating.degreedays": "Unavailable"
      },
      "expected": "Unavailable"
    },
    {
      "name": "Unavailable CDD returns 0 for heat gain",
      "inputs": {
        "transmissionLoss.roof.area": 50,
        "transmissionLoss.roof.uValue": 0.15,
        "climate.cooling.degreedays": "Unavailable"
      },
      "expected": 0
    }
  ],
  "references": [
    {
      "source": "TransmissionLossNodes.js:189-234"
    }
  ]
}
